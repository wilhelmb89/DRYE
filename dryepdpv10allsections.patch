Subject: [PATCH 2/5] PDP v10: 'Missing interface' grid as in-column module

- New visual product-description module inside .hero-info right column
- Hairline 2-up tile grid (mockup .sec.bg / .gr) with editable settings
- Full-bleed soft band via column-padding negative margins
- base.css tokens, emerald eyebrow, Clash/DM Sans, mobile-first + 768px
- Disable duplicate standalone drye-functional-benefits section
- New assets/drye-pdp-modules.css for in-column modules
---
 assets/drye-pdp-modules.css          | 159 ++++++
 pdp-v10-section1-review-slider.patch | 722 +++++++++++++++++++++++++++
 sections/drye-pdp-hero.liquid        |  52 +-
 templates/product.json               |   1 +
 4 files changed, 933 insertions(+), 1 deletion(-)
 create mode 100644 assets/drye-pdp-modules.css
 create mode 100644 pdp-v10-section1-review-slider.patch

diff --git a/assets/drye-pdp-modules.css b/assets/drye-pdp-modules.css
new file mode 100644
index 0000000..883df57
--- /dev/null
+++ b/assets/drye-pdp-modules.css
@@ -0,0 +1,159 @@
+/* ==========================================================================
+   DRYE PDP v10 — in-column product-description modules
+   These live inside .hero-info (the right column). On desktop they scroll
+   beside the sticky gallery; on mobile .hero-info is the single column,
+   so they stack exactly like the v10 mockup.
+   Built through base.css tokens. Brand emerald/sage, DRYE fonts.
+   ========================================================================== */
+
+/* ---- Module shell ----------------------------------------------------- */
+
+.hero .pdp-mod {
+  margin-top: 22px;
+  padding-top: 24px;
+  border-top: 1px solid var(--border, #E5E7EB);
+}
+
+/* Full-bleed: cancel the hero-info horizontal padding so a module's
+   background spans the whole right column, then restore the padding inside.
+   hero-info padding-x is 20px below 768px and 48px at/above 768px. */
+.hero .pdp-mod--bleed {
+  margin-left: -20px;
+  margin-right: -20px;
+  padding-left: 20px;
+  padding-right: 20px;
+}
+
+.hero .pdp-mod--soft {
+  background: var(--bg-soft, #F8FAFC);
+}
+
+.hero .pdp-mod--dark {
+  background: var(--bg-ink, #0F2230);
+  border-top-color: transparent;
+}
+
+/* Bleed modules carry their own vertical padding (the tinted/dark band) */
+.hero .pdp-mod--bleed {
+  padding-top: 26px;
+  padding-bottom: 26px;
+  border-top: none;
+}
+
+/* ---- Module type ------------------------------------------------------ */
+
+.hero .pdp-mod__eyebrow {
+  display: block;
+  margin-bottom: 8px;
+  font-family: "DM Sans", sans-serif;
+  font-size: 9px;
+  font-weight: 700;
+  letter-spacing: 0.16em;
+  text-transform: uppercase;
+  color: var(--emerald, #0D9488);
+}
+
+.hero .pdp-mod--dark .pdp-mod__eyebrow {
+  color: var(--sage, #5F8A8B);
+}
+
+.hero .pdp-mod__h2 {
+  margin: 0 0 9px;
+  font-family: "Clash Grotesk", sans-serif;
+  font-size: clamp(20px, 5.5vw, 24px);
+  font-weight: 600;
+  letter-spacing: -0.03em;
+  line-height: 1.06;
+  color: var(--deep, #1E3A4C);
+}
+
+.hero .pdp-mod--dark .pdp-mod__h2 {
+  color: #fff;
+}
+
+.hero .pdp-mod__body {
+  margin: 0;
+  font-family: "DM Sans", sans-serif;
+  font-size: 13px;
+  line-height: 1.6;
+  color: var(--muted, #4B5563);
+}
+
+.hero .pdp-mod--dark .pdp-mod__body {
+  color: #C8D4DA;
+}
+
+.hero .pdp-mod__body strong {
+  color: var(--deep, #1E3A4C);
+  font-weight: 600;
+}
+
+.hero .pdp-mod--dark .pdp-mod__body strong {
+  color: #fff;
+}
+
+/* ---- Missing interface: hairline 2-up grid ---------------------------- */
+
+.hero .pdp-mi__grid {
+  margin-top: 16px;
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  border-left: 1px solid var(--border, #E5E7EB);
+  border-top: 1px solid var(--border, #E5E7EB);
+}
+
+.hero .pdp-mi__tile {
+  padding: 13px 13px 15px;
+  border-right: 1px solid var(--border, #E5E7EB);
+  border-bottom: 1px solid var(--border, #E5E7EB);
+  background: var(--bg, #fff);
+}
+
+.hero .pdp-mi__tile-title {
+  margin: 0 0 5px;
+  font-family: "Clash Grotesk", sans-serif;
+  font-size: 13px;
+  font-weight: 600;
+  letter-spacing: -0.01em;
+  line-height: 1.2;
+  color: var(--deep, #1E3A4C);
+}
+
+.hero .pdp-mi__tile-desc {
+  margin: 0;
+  font-family: "DM Sans", sans-serif;
+  font-size: 11.5px;
+  line-height: 1.45;
+  color: var(--muted, #4B5563);
+}
+
+/* ---- Desktop refinements (sticky right column) ------------------------ */
+
+@media (min-width: 768px) {
+  .hero .pdp-mod--bleed {
+    margin-left: -48px;
+    margin-right: -48px;
+    padding-left: 48px;
+    padding-right: 48px;
+  }
+
+  .hero .pdp-mod__h2 {
+    font-size: 24px;
+  }
+
+  .hero .pdp-mod__body {
+    font-size: 14px;
+  }
+
+  .hero .pdp-mi__tile {
+    padding: 16px 16px 18px;
+  }
+
+  .hero .pdp-mi__tile-title {
+    font-size: 14px;
+  }
+
+  .hero .pdp-mi__tile-desc {
+    font-size: 12px;
+  }
+}
