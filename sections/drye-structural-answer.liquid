        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DRYE Structural Answer",
      "blocks": [
        {
          "type": "gallery_image"
        },
        {
          "type": "gallery_image"
        },
        {
          "type": "gallery_image"
        },
        {
          "type": "fact",
