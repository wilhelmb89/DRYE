      "id": "heading_em",
      "label": "Italic heading text",
      "default": "not open air."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Green subheading",
      "default": "0.4mm thin. No chemicals. No coatings. Fits inside any work glove."
    },
    {
