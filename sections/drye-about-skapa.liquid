{{ 'section-drye-about-skapa.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section drye-about-skapa"
  id="drye-about-skapa-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="drye-about-skapa__bg"></div>
  <div class="drye-about-skapa__img-bg"></div>

  <div class="dryeNEW-container">
    <div class="dryeNEW-grid dryeNEW-grid--2 drye-about-skapa__grid">
      <div class="drye-about-skapa__left">
        {% if section.settings.award_label != blank %}
          <div class="drye-about-skapa__award dryeNEW-reveal">
            <span class="dryeNEW-micro drye-about-skapa__award-label">
              {{ section.settings.award_label }}
            </span>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="dryeNEW-h2 drye-about-skapa__heading dryeNEW-reveal dryeNEW-rd1">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="dryeNEW-body drye-about-skapa__body dryeNEW-reveal dryeNEW-rd2">
            {{ section.settings.body }}
          </div>
        {% endif %}

        {% if section.settings.link_label != blank %}
          <a
            class="dryeNEW-link drye-about-skapa__link dryeNEW-reveal dryeNEW-rd3"
            href="{{ section.settings.link_url | default: '#' }}"
          >
            {{ section.settings.link_label }}
          </a>
        {% endif %}
      </div>

      <div class="drye-about-skapa__right dryeNEW-reveal dryeNEW-rd2">
        <div class="drye-about-skapa__quote">
          {% if section.settings.quote_text != blank %}
            <p class="dryeNEW-editorial drye-about-skapa__quote-text">
              {{ section.settings.quote_text }}
            </p>
          {% endif %}

          {% if section.settings.quote_attr != blank %}
            <span class="dryeNEW-micro drye-about-skapa__quote-attr">
              {{ section.settings.quote_attr }}
            </span>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE About SKAPA",
  "tag": "section",
  "class": "section-drye-about-skapa",
  "settings": [
    {
      "type": "text",
      "id": "award_label",
      "label": "Award label",
      "default": "SKAPA Prize — 2020"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sweden's most recognised innovation award. In memory of Alfred Nobel."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>DRYE received the SKAPA Prize for its textile technology — developed to prevent moisture damage to the skin in protective equipment. The award is given in memory of Alfred Nobel, <strong>for innovations with genuine societal and commercial significance.</strong></p>"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "See the research"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "The same award category that has recognised innovations subsequently adopted by global industry. Not recognition for potential — recognition for a validated, working mechanism."
    },
    {
      "type": "text",
      "id": "quote_attr",
      "label": "Quote attribution",
      "default": "SKAPA Foundation — Innovation in Memory of Alfred Nobel"
    }
  ],
  "presets": [
    {
      "name": "DRYE About SKAPA"
    }
  ]
}
{% endschema %}