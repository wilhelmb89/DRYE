{{ 'component-drye-physics.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section the-physics" id="drye-physics-{{ section.id }}">
  <div class="dryeNEW-container inner">
    <span class="dryeNEW-micro reveal dryeNEW-reveal">
      {{ section.settings.eyebrow }}
    </span>

    <h2 class="dryeNEW-h2--problem reveal rd1 dryeNEW-reveal dryeNEW-rd1">
      {{ section.settings.heading_line_1 }}<br><em class="dryeNEW-editorial">{{ section.settings.heading_line_2 }}</em>
    </h2>

    <p class="lead reveal rd2 dryeNEW-reveal dryeNEW-rd2">
      {{ section.settings.lead | strip_html }}
    </p>

    <div class="layer-diagram reveal rd2 dryeNEW-reveal dryeNEW-rd2">
      <div class="diagram-label-row">
        <span>{{ section.settings.label_skin }}</span>
        <span>{{ section.settings.label_liner }}</span>
        <span>{{ section.settings.label_glove }}</span>
      </div>

      <div class="diagram-layers">
        <div class="diagram-layer layer-inner">
          <div class="layer-info">
            <div class="layer-name">{{ section.settings.inner_layer_name }}</div>
            <div class="layer-property">{{ section.settings.inner_layer_property }}</div>
          </div>
          <div class="layer-visual"></div>
          <div class="layer-desc">{{ section.settings.inner_layer_desc }}</div>
        </div>

        <div class="diagram-layer layer-transport">
          <div class="layer-info">
            <div class="layer-name">{{ section.settings.transport_layer_name }}</div>
            <div class="layer-property">{{ section.settings.transport_layer_property }}</div>
          </div>
          <div class="layer-visual">
            <div class="transport-arrow"><span></span></div>
            <div class="transport-arrow"><span></span></div>
            <div class="transport-arrow"><span></span></div>
          </div>
          <div class="layer-desc">{{ section.settings.transport_layer_desc }}</div>
        </div>

        <div class="diagram-layer layer-outer">
          <div class="layer-info">
            <div class="layer-name">{{ section.settings.outer_layer_name }}</div>
            <div class="layer-property">{{ section.settings.outer_layer_property }}</div>
          </div>
          <div class="layer-visual"></div>
          <div class="layer-desc">{{ section.settings.outer_layer_desc }}</div>
        </div>
      </div>
    </div>

    <div class="mech-cols reveal rd3 dryeNEW-reveal dryeNEW-rd3">
      <div class="mech-col left">
        <div class="mech-tag">{{ section.settings.left_tag }}</div>
        <h3>{{ section.settings.left_title }}</h3>
        <p class="desc">{{ section.settings.left_desc | strip_html }}</p>

        <ul class="mech-steps">
          {% assign left_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'left_step' %}
              {% assign left_index = left_index | plus: 1 %}
              <li class="mech-step" {{ block.shopify_attributes }}>
                <span class="step-n">{{ left_index | prepend: '0' | slice: -2, 2 }}</span>
                <div class="step-content">
                  <strong>{{ block.settings.title }}</strong>{{ block.settings.text }}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="mech-col right">
        <div class="mech-tag">{{ section.settings.right_tag }}</div>
        <h3>{{ section.settings.right_title }}</h3>
        <p class="desc">{{ section.settings.right_desc | strip_html }}</p>

        <ul class="mech-steps">
          {% assign right_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'right_step' %}
              {% assign right_index = right_index | plus: 1 %}
              <li class="mech-step" {{ block.shopify_attributes }}>
                <span class="step-n">{{ right_index | prepend: '0' | slice: -2, 2 }}</span>
                <div class="step-content">
                  <strong>{{ block.settings.title }}</strong>{{ block.settings.text }}
                </div>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

