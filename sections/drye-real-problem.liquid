{{ 'drye-real-problem.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} .sec {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media(min-width:768px){
    #shopify-section-{{ section.id }} .sec {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
</style>

<section class="sec">
  <div class="sec-in">
    <div class="micro rev d1">{{ section.settings.eyebrow }}</div>
    <h2 class="sec-h rev d2">{{ section.settings.heading }}</h2>
    <p class="sec-sub rev d3">{{ section.settings.subheading }}</p>

    <div class="fail-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'fail_card' %}
            <div class="fail-card rev d{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="fail-lbl">{{ block.settings.label }}</div>
              <div class="fail-name">{{ block.settings.title }}</div>
              <div class="fail-why">{{ block.settings.body }}</div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  <div class="fail-swipe-hint" aria-hidden="true">
  <span>Swipe</span>
  <svg class="fail-swipe-icon" width="18" height="18" viewBox="0 0 24 24" fill="none">
    <path d="M8 5l8 7-8 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" stroke-linejoin="miter"/>
  </svg>
</div>
    <div class="physics-box rev d5">
      <div class="physics-q">{{ section.settings.quote }}</div>
      <div class="physics-src">{{ section.settings.quote_source }}</div>
    </div>
  </div>


</section>


<script>
  (function () {
    const section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    const reveals = section.querySelectorAll('.rev');

    if (reveals.length) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.07 });

      reveals.forEach((el) => observer.observe(el));
    }

    if (window.innerWidth >= 768) return;

    const scroller = section.querySelector('.fail-grid');
    const hint = section.querySelector('.fail-swipe-hint');

    if (!scroller || !hint) return;

    const hideHint = function () {
      hint.classList.add('is-hidden');
      scroller.removeEventListener('scroll', onScroll);
      scroller.removeEventListener('touchstart', hideHint);
      scroller.removeEventListener('pointerdown', hideHint);
    };

    const onScroll = function () {
      if (scroller.scrollLeft > 12) {
        hideHint();
      }
    };

    scroller.addEventListener('scroll', onScroll, { passive: true });
    scroller.addEventListener('touchstart', hideHint, { passive: true });
    scroller.addEventListener('pointerdown', hideHint, { passive: true });
  })();
</script>

<div id="reviews"></div>

