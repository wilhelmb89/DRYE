{% comment %}
  DRYE — Announcement Bar
  Fixed under DRYE header
  Product page only
{% endcomment %}

{% if section.settings.enabled and request.page_type == 'product' %}
  <section
    id="shopify-section-{{ section.id }}"
    class="dryeNEW-annbar-section"
    data-section-id="{{ section.id }}"
    role="region"
    aria-label="Announcement"
    style="
      --ann-height: {{ section.settings.height }}px;
      --ann-speed: {{ section.settings.speed }}s;
      --ann-bg: {{ section.settings.bg_color }};
      --ann-text: {{ section.settings.text_color }};
      --ann-icon-height: {{ section.settings.icon_height }}px;
    "
  >
    <div class="dryeNEW-annbar-spacer" aria-hidden="true"></div>

    <div class="dryeNEW-annbar">
      <div class="dryeNEW-shell">
        <div class="dryeNEW-annbar__viewport">
<div class="dryeNEW-annbar__track" aria-hidden="true">
  {% for group in (1..2) %}
    <div class="dryeNEW-annbar__group">
      {% for i in (1..3) %}
        {% case i %}
          {% when 1 %}{% assign ann_text = section.settings.text %}
          {% when 2 %}{% assign ann_text = section.settings.text_2 %}
          {% when 3 %}{% assign ann_text = section.settings.text_3 %}
        {% endcase %}
        <span class="dryeNEW-annbar__item">
          {% case i %}
            {% when 1 %}<svg class="dryeNEW-annbar__svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="1" y="6" width="14" height="9" rx="1"></rect><path d="M15 9l3 1v4h-3V9zM5 15v2M11 15v2"></path></svg>
            {% when 2 %}<svg class="dryeNEW-annbar__svg" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M10 2l7 3v5c0 4.5-3.5 7.5-7 8.5C6.5 17.5 3 14.5 3 10V5l7-3z"></path><path d="M7 10l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            {% when 3 %}<svg class="dryeNEW-annbar__svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><circle cx="8" cy="8" r="7"></circle><path d="M8 5v3l2 2" stroke-linecap="round"></path></svg>
          {% endcase %}
          <span class="dryeNEW-annbar__text">{{ ann_text }}</span>
        </span>
        <span class="dryeNEW-annbar__dot" aria-hidden="true">·</span>
      {% endfor %}
    </div>
  {% endfor %}
</div>

          <div class="dryeNEW-visually-hidden">
            {% if section.settings.link_url != blank %}
              <a href="{{ section.settings.link_url }}">{{ section.settings.text }} · {{ section.settings.text_2 }} · {{ section.settings.text_3 }}</a>
            {% else %}
              {{ section.settings.text }} · {{ section.settings.text_2 }} · {{ section.settings.text_3 }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {%- style -%}
      #shopify-section-{{ section.id }} {
        position: relative;
        z-index: 998;
      }

      #shopify-section-{{ section.id }} .dryeNEW-annbar-spacer {
        height: var(--ann-height);
      }

      #shopify-section-{{ section.id }} .dryeNEW-annbar {
        position: fixed;
        top: var(--nav-height);
        left: 0;
        width: 100%;
        z-index: 998;
        min-height: var(--ann-height);
        display: flex;
        align-items: center;
        overflow: hidden;
        background: var(--ann-bg);
        color: var(--ann-text);
        border-bottom: var(--border-base);
      }

      #shopify-section-{{ section.id }} .dryeNEW-annbar__viewport {
        position: relative;
        width: 100%;
        overflow: hidden;
      }

      /* Desktop spacing — generous breathing room */
#shopify-section-{{ section.id }} .dryeNEW-annbar__track {
  display: flex;
  width: max-content;
  align-items: center;
  animation: dryeAnnbarMarquee-{{ section.id }} var(--ann-speed) linear infinite;
  will-change: transform;
}

#shopify-section-{{ section.id }} .dryeNEW-annbar__group {
  display: flex;
  align-items: center;
  gap: 0;
  flex: 0 0 auto;
  padding-right: 0;
}

#shopify-section-{{ section.id }} .dryeNEW-annbar__item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 9px 28px;
  white-space: nowrap;
  flex: 0 0 auto;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: rgba(255, 255, 255, 0.75);
}

#shopify-section-{{ section.id }} .dryeNEW-annbar__svg {
  width: 13px;
  height: 13px;
  flex: 0 0 auto;
  display: block;
  opacity: 0.6;
}

#shopify-section-{{ section.id }} .dryeNEW-annbar__dot {
  flex: 0 0 auto;
  color: rgba(255, 255, 255, 0.2);
  font-size: 9px;
}

      #shopify-section-{{ section.id }} .dryeNEW-annbar__text,
      #shopify-section-{{ section.id }} .dryeNEW-annbar__link {
        color: inherit;
      }

      #shopify-section-{{ section.id }} .dryeNEW-annbar__link {
        text-decoration: none;
        border-bottom: 1px solid currentColor;
        padding-bottom: 2px;
      }

      #shopify-section-{{ section.id }} .dryeNEW-annbar__link:hover {
        opacity: 0.85;
      }

      /* ICON BASE — respects PNG transparency, no color manipulation */
      #shopify-section-{{ section.id }} .dryeNEW-annbar__icon {
        height: var(--ann-icon-height);
        width: auto;
        display: block;
        flex: 0 0 auto;
        object-fit: contain;
      }

      {% if section.settings.force_white_icons %}
        /* Forces icons to render as white silhouette — use for dark-colored source files */
        #shopify-section-{{ section.id }} .dryeNEW-annbar__icon {
          filter: brightness(0) invert(1);
        }
      {% endif %}

      @keyframes dryeAnnbarMarquee-{{ section.id }} {
        from {
          transform: translate3d(0, 0, 0);
        }
        to {
          transform: translate3d(-50%, 0, 0);
        }
      }

      /* Mobile spacing — proportionally tighter but still breathing */
@media (max-width: 767px) {
  #shopify-section-{{ section.id }} .dryeNEW-annbar__group {
    gap: 0;
    padding-right: 0;
  }

  #shopify-section-{{ section.id }} .dryeNEW-annbar__item {
    gap: 8px;
  }
}

@media (prefers-reduced-motion: reduce) {
  #shopify-section-{{ section.id }} .dryeNEW-annbar__track {
    animation-duration: calc(var(--ann-speed) * 2);
  }
}
    {%- endstyle -%}
  </section>
{% endif %}

{% schema %}
{
  "name": "DRYE Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on 3+ pairs"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Ticker item 2",
      "default": "30-day money-back guarantee"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Ticker item 3",
      "default": "Dispatched within 24 hours"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Optional link"
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "paragraph",
      "content": "Upload white/light PNG with transparent background for the default rendering. If your source file is dark and you need it to appear white, enable the option below."
    },
    {
      "type": "image_picker",
      "id": "left_icon",
      "label": "Left icon"
    },
    {
      "type": "image_picker",
      "id": "right_icon",
      "label": "Right icon"
    },
    {
      "type": "range",
      "id": "icon_height",
      "label": "Icon height",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "force_white_icons",
      "label": "Force icons to white",
      "info": "Enable only if your PNG source is dark-colored and you want it to render as white silhouette",
      "default": false
    },
    {
      "type": "header",
      "content": "Bar styling"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Bar height",
      "min": 32,
      "max": 56,
      "step": 2,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll duration",
      "min": 10,
      "max": 40,
      "step": 2,
      "default": 22,
      "unit": "s"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0F2230"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "DRYE Announcement Bar"
    }
  ]
}
{% endschema %}
