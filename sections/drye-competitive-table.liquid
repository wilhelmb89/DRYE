{{ 'component-drye-competitive-table.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section drye-comp" id="drye-comp-{{ section.id }}" data-section-id="{{ section.id }}" data-drye-section data-section-index="11" data-section-name="competitive_table">  
  <div class="dryeNEW-container">
    <div class="drye-comp__intro drye-comp__reveal">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro drye-comp__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank or section.settings.heading_emphasis != blank %}
        <h2 class="dryeNEW-h2 drye-comp__heading">
          {% if section.settings.heading != blank %}
            <span class="drye-comp__heading-main">
              {{ section.settings.heading }}
            </span>
          {% endif %}

          {% if section.settings.heading_emphasis != blank %}
            <span class="dryeNEW-em drye-comp__heading-emphasis">
              {{ section.settings.heading_emphasis }}
            </span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="dryeNEW-body drye-comp__body">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    <div class="drye-comp__mobile-hint" aria-hidden="true">
      {{ section.settings.mobile_hint }}
    </div>

    <div class="drye-comp__table-wrap drye-comp__reveal drye-comp__rd1">
      <table class="drye-comp__table">
        <thead>
          <tr>
            <th>{{ section.settings.col_1 }}</th>
            <th>{{ section.settings.col_2 }}</th>
            <th>{{ section.settings.col_3 }}</th>
            <th>{{ section.settings.col_4 }}</th>
          </tr>
        </thead>

        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'row' %}
              <tr class="{% if block.settings.is_drye %}drye-comp__row--drye{% endif %}" {{ block.shopify_attributes }}>
                <td>{{ block.settings.solution }}</td>

                <td>
                  <span class="drye-comp__status drye-comp__status--{{ block.settings.skin_status }}">
                    {{ block.settings.skin_text }}
                  </span>
                </td>

                <td>
                  <span class="drye-comp__status drye-comp__status--{{ block.settings.col_3_status }}">
                    {{ block.settings.col_3_text }}
                  </span>
                </td>

                <td>
                  <span class="drye-comp__cost">{{ block.settings.cost }}</span>
                  {% if block.settings.cost_math != blank %}
                    <span class="drye-comp__cost-math">{{ block.settings.cost_math }}</span>
                  {% endif %}
                </td>
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>

      {% if section.settings.note_text != blank or section.settings.note_strong != blank %}
        <div class="drye-comp__note">
          {% if section.settings.note_text != blank %}
            <span class="dryeNEW-em drye-comp__note-em">{{ section.settings.note_text }}</span>
          {% endif %}
          {% if section.settings.note_strong != blank %}
            <strong>{{ section.settings.note_strong }}</strong>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('drye-comp-{{ section.id }}');
    if (!root) return;

    var items = root.querySelectorAll('.drye-comp__reveal');
    if (!items.length) return;

    if (!('IntersectionObserver' in window)) {
      items.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08 });

    items.forEach(function(el) {
      observer.observe(el);
    });
  })();
</script>

