{{ 'section-professions.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-professions.js' | asset_url }}" defer="defer"></script>

<section
  class="dryeNEW-section drye-prof"
  data-professions-section
  data-section-id="{{ section.id }}"
>
  <div class="dryeNEW-container">
    {% if section.settings.micro != blank %}
      <span class="dryeNEW-micro drye-prof__micro dryeNEW-reveal">
        {{ section.settings.micro }}
      </span>
    {% endif %}

    <h2 class="dryeNEW-h2 drye-prof__title dryeNEW-reveal dryeNEW-rd1">
      {{ section.settings.heading_line_1 }}<br>
      <em>{{ section.settings.heading_line_2 }}</em>
    </h2>

    {% if section.settings.lead != blank %}
      <div class="dryeNEW-body drye-prof__lead dryeNEW-reveal dryeNEW-rd2">
        <p>{{ section.settings.lead }}</p>
      </div>
    {% endif %}

    <div
      class="drye-prof__tabs dryeNEW-reveal dryeNEW-rd2"
      role="tablist"
      aria-label="Profession tabs"
    >
      {% for block in section.blocks %}
        {% assign panel_id = 'tab-' | append: section.id | append: '-' | append: block.settings.tab_id %}
        <button
          type="button"
          class="drye-prof__tab{% if forloop.first %} is-active{% endif %}"
          data-prof-tab
          data-target="{{ panel_id }}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="{{ panel_id }}"
          id="button-{{ panel_id }}"
          {{ block.shopify_attributes }}
        >
          <span class="dryeNEW-micro drye-prof__tab-text">
            {{ block.settings.tab_label }}
          </span>
        </button>
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      {% assign panel_id = 'tab-' | append: section.id | append: '-' | append: block.settings.tab_id %}
      <div
        class="drye-prof__panel{% if forloop.first %} is-active{% endif %}"
        id="{{ panel_id }}"
        role="tabpanel"
        aria-labelledby="button-{{ panel_id }}"
        {% unless forloop.first %}hidden{% endunless %}
      >
        <div class="drye-prof__grid">
          <div class="drye-prof__left">
            {% if block.settings.context_label != blank %}
              <div class="dryeNEW-micro drye-prof__context">
                {{ block.settings.context_label }}
              </div>
            {% endif %}

            {% if block.settings.heading != blank %}
              <h3 class="dryeNEW-h3 drye-prof__panel-title">
                {{ block.settings.heading }}
              </h3>
            {% endif %}

            {% if block.settings.body != blank %}
              <div class="dryeNEW-body drye-prof__body">
                <p>{{ block.settings.body }}</p>
              </div>
            {% endif %}

            <ul class="drye-prof__facts">
              {% if block.settings.fact_1_strong != blank or block.settings.fact_1_text != blank %}
                <li class="dryeNEW-body--caption">
                  <strong>{{ block.settings.fact_1_strong }}</strong>{{ block.settings.fact_1_text }}
                </li>
              {% endif %}
              {% if block.settings.fact_2_strong != blank or block.settings.fact_2_text != blank %}
                <li class="dryeNEW-body--caption">
                  <strong>{{ block.settings.fact_2_strong }}</strong>{{ block.settings.fact_2_text }}
                </li>
              {% endif %}
              {% if block.settings.fact_3_strong != blank or block.settings.fact_3_text != blank %}
                <li class="dryeNEW-body--caption">
                  <strong>{{ block.settings.fact_3_strong }}</strong>{{ block.settings.fact_3_text }}
                </li>
              {% endif %}
            </ul>
          </div>

          <div class="drye-prof__right">
            <div class="drye-prof__scenario">
              {% if block.settings.scenario_label != blank %}
                <div class="dryeNEW-micro drye-prof__scenario-label">
                  {{ block.settings.scenario_label }}
                </div>
              {% endif %}

              <div class="drye-prof__steps">
                {% if block.settings.step_1_label != blank or block.settings.step_1_text != blank %}
                  <div class="drye-prof__step">
                    <span class="dryeNEW-micro drye-prof__step-label">{{ block.settings.step_1_label }}</span>
                    <div class="dryeNEW-body--caption drye-prof__step-text">
                      <p>{{ block.settings.step_1_text }}</p>
                    </div>
                  </div>
                {% endif %}

                {% if block.settings.step_2_label != blank or block.settings.step_2_text != blank %}
                  <div class="drye-prof__step">
                    <span class="dryeNEW-micro drye-prof__step-label">{{ block.settings.step_2_label }}</span>
                    <div class="dryeNEW-body--caption drye-prof__step-text">
                      <p>{{ block.settings.step_2_text }}</p>
                    </div>
                  </div>
                {% endif %}

                {% if block.settings.step_3_label != blank or block.settings.step_3_text != blank %}
                  <div class="drye-prof__step">
                    <span class="dryeNEW-micro drye-prof__step-label">{{ block.settings.step_3_label }}</span>
                    <div class="dryeNEW-body--caption drye-prof__step-text">
                      <p>{{ block.settings.step_3_text }}</p>
                    </div>
                  </div>
                {% endif %}

                {% if block.settings.step_drye_label != blank or block.settings.step_drye_text != blank %}
                  <div class="drye-prof__step drye-prof__step--drye">
                    <span class="dryeNEW-micro drye-prof__step-label">{{ block.settings.step_drye_label }}</span>
                    <div class="dryeNEW-body--caption drye-prof__step-text">
                      <p>{{ block.settings.step_drye_text }}</p>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

