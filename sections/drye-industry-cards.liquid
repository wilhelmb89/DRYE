{% comment %}
  DRYE — Industry cards. Full-bleed grid of image cards with a hover
  overlay and centered label. Token-based (base.css). Cards are blocks.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .drye-ind {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    padding: var(--space-6) var(--page-pad);
    background: {{ section.settings.bg_color | default: '#ffffff' }};
  }
  #shopify-section-{{ section.id }} .drye-ind__card {
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 4 / 3;
    background: var(--bg-ink);
  }
  #shopify-section-{{ section.id }} .drye-ind__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }
  #shopify-section-{{ section.id }} .drye-ind__overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 22, 33, 0.70);
    transition: background 0.4s ease;
  }
  #shopify-section-{{ section.id }} .drye-ind__card:hover .drye-ind__overlay { background: rgba(10, 22, 33, 0.22); }
  #shopify-section-{{ section.id }} .drye-ind__label {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: 16px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #fff;
    text-align: center;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    padding: 0 var(--space-8);
    transition: transform 0.3s ease;
  }
  #shopify-section-{{ section.id }} .drye-ind__card:hover .drye-ind__label { transform: translateY(-4px); }

  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .drye-ind {
      grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
      gap: var(--space-8);
      padding: var(--space-8) var(--page-pad);
      max-width: calc(var(--max-width) + (var(--page-pad) * 2));
      margin: 0 auto;
    }
    #shopify-section-{{ section.id }} .drye-ind__label { font-size: 22px; }
  }
</style>

<div class="drye-ind">
  {%- for block in section.blocks -%}
    {%- capture bg -%}{% if block.settings.image != blank %}background-image:url('{{ block.settings.image | image_url: width: 900 }}');{% endif %}{%- endcapture -%}
    {%- if block.settings.link != blank -%}
      <a class="drye-ind__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
        <div class="drye-ind__bg" style="{{ bg }}"></div>
        <div class="drye-ind__overlay"></div>
        <span class="drye-ind__label">{{ block.settings.label }}</span>
      </a>
    {%- else -%}
      <div class="drye-ind__card" {{ block.shopify_attributes }}>
        <div class="drye-ind__bg" style="{{ bg }}"></div>
        <div class="drye-ind__overlay"></div>
        <span class="drye-ind__label">{{ block.settings.label }}</span>
      </div>
    {%- endif -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "DRYE Industry Cards",
  "tag": "section",
  "class": "drye-industry-section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Industry" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "DRYE Industry Cards",
      "blocks": [
        { "type": "card", "settings": { "label": "Automotive / Industry" } },
        { "type": "card", "settings": { "label": "Elite Sports" } },
        { "type": "card", "settings": { "label": "Healthcare" } },
        { "type": "card", "settings": { "label": "Military" } }
      ]
    }
  ]
}
{% endschema %}
