{{ 'drye-liner-objection-reviews.css' | asset_url | stylesheet_tag }}
{{ 'drye-liner-swipe.js' | asset_url | script_tag }}

<section class="dryeNEW-section drye-liner-objection-reviews" id="{{ section.settings.section_id | default: 'liner-objections' }}" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container">
    <div class="drye-liner-objection-reviews__inner" id="drye-liner-objection-reviews-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dryeNEW-micro drye-liner-objection-reviews__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="dryeNEW-h2 drye-liner-objection-reviews__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="drye-liner-objection-reviews__rating-badge">
        <span class="drye-liner-objection-reviews__stars" aria-hidden="true">★★★★★</span>
        {%- if section.settings.rating_score != blank -%}
          <span class="drye-liner-objection-reviews__score">{{ section.settings.rating_score }}</span>
        {%- endif -%}
        {%- if section.settings.rating_count_text != blank -%}
          <span class="drye-liner-objection-reviews__dot" aria-hidden="true">·</span>
          <a href="{{ section.settings.rating_count_url | default: '#' }}" class="drye-liner-objection-reviews__count">{{ section.settings.rating_count_text }}</a>
        {%- endif -%}
      </div>

      <div class="drye-liner-objection-reviews__slider">
        <div class="drye-liner-objection-reviews__wrap" data-drye-liner-swipe-wrap>
          <div class="drye-liner-objection-reviews__track" id="drye-liner-objection-reviews-track-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'review' -%}
                <div class="drye-liner-objection-reviews__card" data-review-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.question != blank -%}
                    <div class="drye-liner-objection-reviews__question">{{ block.settings.question }}</div>
                  {%- endif -%}

                  {%- if block.settings.quote != blank -%}
                    <p class="drye-liner-objection-reviews__quote">{{ block.settings.quote }}</p>
                  {%- endif -%}

                  <div class="drye-liner-objection-reviews__attribution">
                    <span class="drye-liner-objection-reviews__verified" aria-hidden="true">✓</span>
                    <span class="drye-liner-objection-reviews__name">{{ block.settings.name }}</span>
                  </div>

                  {%- if block.settings.role != blank -%}
                    <div class="drye-liner-objection-reviews__role">{{ block.settings.role }}</div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <div class="drye-liner-objection-reviews__nav">
          <div class="drye-liner-objection-reviews__nav-btns">
            <button
              type="button"
              class="drye-liner-objection-reviews__nav-btn"
              id="drye-liner-objection-reviews-prev-{{ section.id }}"
              aria-label="Previous review"
            >←</button>
            <button
              type="button"
              class="drye-liner-objection-reviews__nav-btn"
              id="drye-liner-objection-reviews-next-{{ section.id }}"
              aria-label="Next review"
            >→</button>
          </div>

          <a href="{{ section.settings.rating_count_url | default: '#' }}" class="drye-liner-objection-reviews__readall">Read all →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    function init() {
      if (typeof initDryeLinerSwipe !== 'function') return;
      initDryeLinerSwipe({
        trackId: 'drye-liner-objection-reviews-track-{{ section.id }}',
        prevId: 'drye-liner-objection-reviews-prev-{{ section.id }}',
        nextId: 'drye-liner-objection-reviews-next-{{ section.id }}',
        cardSelector: '.drye-liner-objection-reviews__card',
        gap: 8
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

{% schema %}
{
  "name": "DRYE Liner Objection",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "liner-objections"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Straight answers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What mechanics ask first."
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "default": "4.85/5"
    },
    {
      "type": "text",
      "id": "rating_count_text",
      "label": "Rating count text",
      "default": "47 reviews"
    },
    {
      "type": "url",
      "id": "rating_count_url",
      "label": "Rating count link URL"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Do they really keep hands dry?"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "EV Mechanic"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "BMW Bilia"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "DRYE Liner Objection",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "question": "Do they really keep hands dry?",
            "quote": "Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer.",
            "name": "EV Mechanic",
            "role": "BMW Bilia"
          }
        },
        {
          "type": "review",
          "settings": {
            "question": "Won't they feel weird under the glove?",
            "quote": "No impact on fingertip sensitivity in electric safety gloves. Increased comfort and reduced the need to air the hand.",
            "name": "Simon V.",
            "role": "Verified buyer"
          }
        },
        {
          "type": "review",
          "settings": {
            "question": "Do they actually last?",
            "quote": "My hands get so itchy I can't work without a layer between my skin and the glove. The lining gloves stay drier than cotton — I've been using them continuously.",
            "name": "Heavy Vehicle Mechanic",
            "role": "Verified buyer"
          }
        },
        {
          "type": "review",
          "settings": {
            "question": "Work across different jobs?",
            "quote": "I've been using them in automotive repair, home construction, and moving heavy materials — work that needs real grip and precision. No more eczema or rashes on my hands. Nitrile gloves don't tear anymore because they go on and off easily without sweaty skin.",
            "name": "Brian Jee",
            "role": "Verified buyer"
          }
        }
      ]
    }
  ]
}
{% endschema %}
