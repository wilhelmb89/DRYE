{{ 'drye-liner-objection-reviews.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section drye-liner-objection-reviews" id="{{ section.settings.section_id | default: 'liner-objections' }}" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container">
    <div class="drye-liner-objection-reviews__widget" id="drye-liner-objection-reviews-{{ section.id }}">
      {%- if section.settings.eyebrow != blank -%}
        <span class="dryeNEW-micro drye-liner-objection-reviews__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="dryeNEW-h2 drye-liner-objection-reviews__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="drye-liner-objection-reviews__rating-badge">
        <span class="drye-liner-objection-reviews__stars" aria-hidden="true">★★★★★</span>
        {%- if section.settings.rating_score != blank -%}
          <span class="drye-liner-objection-reviews__score">{{ section.settings.rating_score }}</span>
        {%- endif -%}
        {%- if section.settings.rating_count_text != blank -%}
          <a href="{{ section.settings.rating_count_url | default: '#' }}" class="drye-liner-objection-reviews__count">{{ section.settings.rating_count_text }}</a>
        {%- endif -%}
      </div>

      <div class="drye-liner-objection-reviews__panels">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div
              class="drye-liner-objection-reviews__panel{% if forloop.first %} is-active{% endif %}"
              data-review-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.question != blank -%}
                <div class="drye-liner-objection-reviews__question">{{ block.settings.question }}</div>
              {%- endif -%}

              {%- if block.settings.quote != blank -%}
                <p class="drye-liner-objection-reviews__quote">{{ block.settings.quote }}</p>
              {%- endif -%}

              <div class="drye-liner-objection-reviews__attribution">
                <span class="drye-liner-objection-reviews__verified" aria-hidden="true">✓</span>
                <span class="drye-liner-objection-reviews__name">{{ block.settings.name }}</span>
              </div>

              {%- if block.settings.role != blank -%}
                <div class="drye-liner-objection-reviews__role">{{ block.settings.role }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="drye-liner-objection-reviews__nav">
        <div class="drye-liner-objection-reviews__nav-btns">
          <button
            type="button"
            class="drye-liner-objection-reviews__nav-btn"
            data-drye-liner-objection-reviews-prev
            aria-label="Previous review"
          >←</button>
          <button
            type="button"
            class="drye-liner-objection-reviews__nav-btn"
            data-drye-liner-objection-reviews-next
            aria-label="Next review"
          >→</button>
        </div>

        <a href="{{ section.settings.rating_count_url | default: '#' }}" class="drye-liner-objection-reviews__readall">Read all</a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('drye-liner-objection-reviews-{{ section.id }}');
    if (!root) return;

    var panels = root.querySelectorAll('.drye-liner-objection-reviews__panel');
    if (!panels.length) return;

    var current = 0;
    panels.forEach(function (panel, i) {
      if (panel.classList.contains('is-active')) {
        current = i;
      }
    });

    function show(index) {
      panels.forEach(function (panel, i) {
        panel.classList.toggle('is-active', i === index);
      });
      current = index;
    }

    var prevBtn = root.querySelector('[data-drye-liner-objection-reviews-prev]');
    var nextBtn = root.querySelector('[data-drye-liner-objection-reviews-next]');

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        show((current - 1 + panels.length) % panels.length);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        show((current + 1) % panels.length);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "DRYE Liner Objection Reviews",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "liner-objections"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Straight answers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What mechanics ask first."
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Rating score",
      "default": "4.85/5"
    },
    {
      "type": "text",
      "id": "rating_count_text",
      "label": "Rating count text",
      "default": "47 reviews"
    },
    {
      "type": "url",
      "id": "rating_count_url",
      "label": "Rating count link URL"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Do they really keep hands dry?"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "EV Mechanic"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "BMW Bilia"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "DRYE Liner Objection Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "question": "Do they really keep hands dry?",
            "quote": "Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer.",
            "name": "EV Mechanic",
            "role": "BMW Bilia"
          }
        },
        {
          "type": "review",
          "settings": {
            "question": "Won't they feel weird under the glove?",
            "quote": "No impact on fingertip sensitivity in electric safety gloves. Increased comfort and reduced the need to air the hand.",
