{{ 'drye-mechanics-tesla-technicians.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section mech-tesla" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container">

    <div class="mech-tesla__intro">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="dryeNEW-h2 mech-tesla__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="dryeNEW-body mech-tesla__sub">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    {% if section.settings.rating_number != blank or section.settings.rating_label != blank or section.settings.rating_subline != blank %}
      <div class="mech-tesla__rating">
        {% if section.settings.rating_number != blank %}
          <div class="mech-tesla__rating-num">
            {{ section.settings.rating_number }}
            {% if section.settings.rating_small != blank %}
              <small>{{ section.settings.rating_small }}</small>
            {% endif %}
          </div>
        {% endif %}

        <div class="mech-tesla__rating-lbl">
          {% if section.settings.rating_label != blank %}
            <strong>{{ section.settings.rating_label }}</strong>
          {% endif %}
          {% if section.settings.rating_subline != blank %}
            {{ section.settings.rating_subline }}
          {% endif %}
        </div>
      </div>
    {% endif %}

    <div class="mech-tesla__grid">
      {% for block in section.blocks %}
        {% if block.type == 'quote' %}
          <div class="mech-tesla__card" {{ block.shopify_attributes }}>
            {% if block.settings.quote != blank %}
              <div class="mech-tesla__card-q">
                {{ block.settings.quote }}
              </div>
            {% endif %}

            {% if block.settings.name != blank or block.settings.meta != blank %}
              <div class="dryeNEW-body--sm mech-tesla__card-attr">
                {% if block.settings.name != blank %}
                  <strong>{{ block.settings.name }}</strong>
                {% endif %}
                {% if block.settings.meta != blank %}
                  {{ block.settings.meta }}
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.context_label != blank or section.settings.context_body != blank %}
      <div class="mech-tesla__context">
        {% if section.settings.context_label != blank %}
          <div class="dryeNEW-micro mech-tesla__context-lbl">
            {{ section.settings.context_label }}
          </div>
        {% endif %}

        {% if section.settings.context_body != blank %}
          <div class="dryeNEW-body mech-tesla__context-body">
            {{ section.settings.context_body }}
          </div>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "DRYE Mechanics Tesla",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Peer case"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What technicians said after testing DRYE under Class 0 gloves."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>These were not lifestyle users. <strong>These were EV technicians working under Class 0 gloves</strong> where sweat becomes a real operational problem.</p>"
    },
    {
      "type": "text",
      "id": "rating_number",
      "label": "Rating number",
      "default": "4.6"
    },
    {
      "type": "text",
      "id": "rating_small",
      "label": "Rating small text",
      "default": "/5"
    },
    {
      "type": "text",
      "id": "rating_label",
      "label": "Rating label",
      "default": "Overall field rating"
    },
    {
      "type": "text",
      "id": "rating_subline",
      "label": "Rating subline",
      "default": "from EV technicians testing DRYE"
    },
    {
      "type": "text",
      "id": "context_label",
      "label": "Context label",
      "default": "Why this matters"
    },
    {
      "type": "richtext",
      "id": "context_body",
      "label": "Context body",
      "default": "<p>Battery work is one of the worst-case environments for trapped sweat: thick insulating gloves, long wear time, repeated removal, and skin that already takes a beating from heat and friction. <strong>If DRYE works there, it is not a cosmetic improvement.</strong></p>"
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "Quote card",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"It felt drier inside the glove, and I didn't need to air my hands the same way.\""
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name / role line 1",
          "default": "EV technician"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta line 2",
          "default": "Class 0 glove user"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DRYE Mechanics Tesla Technicians",
      "blocks": [
        {
          "type": "quote",
          "settings": {
            "quote": "\"It felt drier inside the glove, and I didn't need to air my hands the same way.\"",
            "name": "EV technician",
            "meta": "Class 0 glove user"
          }
        },
        {
          "type": "quote",
          "settings": {
            "quote": "\"You notice it after a full day. Less soggy skin. Less irritation when taking the gloves off.\"",
            "name": "Technician test feedback",
            "meta": "Battery and service work"
          }
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}