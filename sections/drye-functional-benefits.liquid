    {
      "type": "textarea",
      "id": "note",
      "label": "Bottom note",
      "default": "Performance properties are structural — built into the fabric architecture rather than applied as a coating or finish."
    }
  ],
  "presets": [
    {
      "name": "DRYE Functional Benefits"
    }
  ]
}
{% endschema %}