{{ 'dryeNEW-hero.css' | asset_url | stylesheet_tag }}

{%- assign credibility_blocks = section.blocks | where: 'type', 'credibility_item' -%}
{%- assign stat_blocks = section.blocks | where: 'type', 'stat_item' -%}

<section
  class="dryeNEW-hero"
  data-section-id="{{ section.id }}"
  data-section-type="dryeNEW-hero"
  data-drye-section
  data-section-index="1"
  data-section-name="hero"
>
  <div class="dryeNEW-hero__media">
    {%- if section.settings.poster_image_desktop != blank -%}
      {{
        section.settings.poster_image_desktop
        | image_url: width: 2200
        | image_tag:
          class: 'dryeNEW-hero__poster dryeNEW-hero__poster--desktop',
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '768, 1200, 1600, 2200'
      }}
    {%- endif -%}

    {%- if section.settings.poster_image_mobile != blank -%}
      {{
        section.settings.poster_image_mobile
        | image_url: width: 1200
        | image_tag:
          class: 'dryeNEW-hero__poster dryeNEW-hero__poster--mobile',
          alt: '',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '480, 768, 960, 1200'
      }}
    {%- endif -%}

    <div class="dryeNEW-hero__overlay"></div>
  </div>

  <div class="dryeNEW-hero__content-wrap">
    {%- if credibility_blocks.size > 0 -%}
      <div class="dryeNEW-cred-bar">
        {%- for block in credibility_blocks -%}
          <div class="dryeNEW-cred-item" {{ block.shopify_attributes }}>
            <div class="dryeNEW-cred-dot"></div>
            <span>{{ block.settings.text }}</span>
          </div>

          {%- unless forloop.last -%}
            <div class="dryeNEW-cred-divider"></div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank or section.settings.heading_echo != blank -%}
      <h1 class="dryeNEW-hero__heading">
        {%- if section.settings.heading_line_1 != blank -%}
          <span class="dryeNEW-hero__heading-line">{{ section.settings.heading_line_1 }}</span>
        {%- endif -%}
        {%- if section.settings.heading_line_2 != blank -%}
          <span class="dryeNEW-hero__heading-line">{{ section.settings.heading_line_2 }}</span>
        {%- endif -%}
        {%- if section.settings.heading_echo != blank -%}
          <span class="dryeNEW-hero__heading-echo">{{ section.settings.heading_echo }}</span>
        {%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading_line_1 != blank or section.settings.subheading_line_2 != blank or section.settings.subheading_emphasis != blank -%}
      <p class="dryeNEW-hero__sub">
        {%- if section.settings.subheading_line_1 != blank -%}
          <span class="dryeNEW-hero__sub-line">{{ section.settings.subheading_line_1 }}</span>
        {%- endif -%}
        {%- if section.settings.subheading_line_2 != blank or section.settings.subheading_emphasis != blank -%}
          <span class="dryeNEW-hero__sub-line">
            {{ section.settings.subheading_line_2 }}
            {%- if section.settings.subheading_emphasis != blank -%}
              <strong> {{ section.settings.subheading_emphasis }}</strong>
            {%- endif -%}
          </span>
        {%- endif -%}
      </p>
    {%- endif -%}

    <div class="dryeNEW-dual-cta">
      {%- if section.settings.path_1_text_line_1 != blank or section.settings.path_1_text_line_2 != blank -%}
        <a
          href="{{ section.settings.path_1_link | default: '#problem' }}"
          data-scroll-target="{{ section.settings.path_1_link | default: '#problem' }}"
          class="dryeNEW-cta-path dryeNEW-cta-path--passive"
        >
          {%- if section.settings.path_1_label != blank -%}
            <span class="dryeNEW-cta-path__label">{{ section.settings.path_1_label }}</span>
          {%- endif -%}
          <span class="dryeNEW-cta-path__text">
            {%- if section.settings.path_1_text_line_1 != blank -%}
              <span class="dryeNEW-cta-path__text-line">{{ section.settings.path_1_text_line_1 }}</span>
            {%- endif -%}
            {%- if section.settings.path_1_text_line_2 != blank -%}
              <span class="dryeNEW-cta-path__text-line">{{ section.settings.path_1_text_line_2 }}</span>
            {%- endif -%}
          </span>
        </a>
      {%- endif -%}

      {%- if section.settings.path_2_text_line_1 != blank or section.settings.path_2_text_line_2 != blank -%}
        <a
          href="{{ section.settings.path_2_link | default: '#mechanism' }}"
          data-scroll-target="{{ section.settings.path_2_link | default: '#mechanism' }}"
          class="dryeNEW-cta-path dryeNEW-cta-path--primary"
        >
          {%- if section.settings.path_2_label != blank -%}
            <span class="dryeNEW-cta-path__label">{{ section.settings.path_2_label }}</span>
          {%- endif -%}
          <span class="dryeNEW-cta-path__text">
            {%- if section.settings.path_2_text_line_1 != blank -%}
              <span class="dryeNEW-cta-path__text-line">{{ section.settings.path_2_text_line_1 }}</span>
            {%- endif -%}
            {%- if section.settings.path_2_text_line_2 != blank -%}
              <span class="dryeNEW-cta-path__text-line">{{ section.settings.path_2_text_line_2 }}</span>
            {%- endif -%}
          </span>
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if stat_blocks.size > 0 -%}
    <div class="dryeNEW-hero__stats-shell">
      <div
        class="dryeNEW-hero__stats-inner"
        style="--drye-stat-count: {{ stat_blocks.size }};"
      >
        {%- for block in stat_blocks -%}
          <div class="dryeNEW-hstat" {{ block.shopify_attributes }}>
            <div class="dryeNEW-hstat__num">{{ block.settings.value }}</div>
            <div class="dryeNEW-hstat__label">
              {{ block.settings.label_line_1 }}
              {%- if block.settings.label_line_2 != blank -%}
                <br>{{ block.settings.label_line_2 }}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    var scrollLinks = section.querySelectorAll('[data-scroll-target]');

    function getHeaderOffset() {
      return window.innerWidth < 768 ? 104 : 72;
    }

    scrollLinks.forEach(function (link) {
      link.addEventListener('click', function (event) {
        var selector = link.getAttribute('data-scroll-target');
        if (!selector || selector.charAt(0) !== '#') return;

        var target = document.querySelector(selector);
        if (!target) return;

        event.preventDefault();

        var top = target.getBoundingClientRect().top + window.pageYOffset - getHeaderOffset();

        window.scrollTo({
          top: top,
          behavior: 'smooth'
        });

        if (window.history && window.history.replaceState) {
          window.history.replaceState(null, '', window.location.pathname + window.location.search);
        }
      });
    });
  })();
</script>

<script
  src="https://cdnjs.cloudflare.com/ajax/libs/hls.js/1.4.12/hls.min.js"
  defer
></script>

