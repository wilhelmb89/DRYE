{{ 'drye-contact-section-2.css' | asset_url | stylesheet_tag }}

<section class="contact-layout">

  <div class="contact-left">

    <div class="track-cards dryeNEW-reveal">
      {% for block in section.blocks %}
        {% if block.type == 'track_card' %}
          <div
            class="track-card{% if block.settings.is_active %} active{% endif %}"
            data-track="{{ block.settings.track_key }}"
            {{ block.shopify_attributes }}
          >
            <span class="tc-label">{{ block.settings.label }}</span>
            <div class="tc-title">{{ block.settings.title }}</div>
            <p class="tc-body">{{ block.settings.body }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="team-section dryeNEW-reveal dryeNEW-rd2">
      <span class="team-label">{{ section.settings.team_label }}</span>

      <div class="team-list">
        {% for block in section.blocks %}
          {% if block.type == 'team_member' %}
            <div class="team-member" {{ block.shopify_attributes }}>
              <div class="team-avatar">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 200
                    | image_tag:
                      alt: block.settings.name,
                      loading: 'lazy'
                  }}
                {% endif %}
              </div>

              <div class="team-info">
                <div class="team-name">{{ block.settings.name }}</div>
                <div class="team-role">{{ block.settings.role }}</div>

                <div class="team-links">
                  {% if block.settings.linkedin_url != blank %}
                    <a href="{{ block.settings.linkedin_url }}" class="team-link">
                      {{ block.settings.linkedin_label }}
                    </a>
                  {% endif %}

                  {% if block.settings.email != blank %}
                    <a href="mailto:{{ block.settings.email }}" class="team-link">
                      {{ block.settings.email }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

  </div>

  <div class="contact-right dryeNEW-reveal dryeNEW-rd2">

    {% for block in section.blocks %}
      {% if block.type == 'form_panel' %}
        <div
          class="form-panel{% if block.settings.is_active %} active{% endif %}"
          id="panel-{{ block.settings.track_key }}"
          data-track="{{ block.settings.track_key }}"
          {{ block.shopify_attributes }}
        >
          <div class="form-header">
            <span class="dryeNEW-micro">{{ block.settings.eyebrow }}</span>
            <h2 class="form-title">{{ block.settings.title }}</h2>
            <p class="form-desc">{{ block.settings.description }}</p>
          </div>

          {% form 'contact', class: 'contact-form' %}
            <input type="hidden" name="contact[contact_track]" value="{{ block.settings.track_key }}">
            <input type="hidden" name="contact[form_context]" value="{{ block.settings.title }}">

            <div class="field-row two">
              <div class="field">
                <label class="field-label" for="ContactFormName-{{ block.id }}">
                  {{ block.settings.name_label }} <span>*</span>
                </label>
                <input
                  id="ContactFormName-{{ block.id }}"
                  type="text"
                  name="contact[name]"
                  placeholder="{{ block.settings.name_placeholder }}"
                  required
                >
              </div>

              <div class="field">
                <label class="field-label" for="ContactFormEmail-{{ block.id }}">
                  {{ block.settings.email_label }} <span>*</span>
                </label>
                <input
                  id="ContactFormEmail-{{ block.id }}"
                  type="email"
                  name="contact[email]"
                  placeholder="{{ block.settings.email_placeholder }}"
                  required
                >
              </div>
            </div>

            {% if block.settings.show_optional_field %}
              <div class="field-row">
                <div class="field">
                  <label class="field-label" for="ContactFormOptional-{{ block.id }}">
                    {{ block.settings.optional_label }}
                  </label>
                  <input
                    id="ContactFormOptional-{{ block.id }}"
                    type="text"
                    name="contact[{{ block.settings.optional_field_key | handle }}]"
                    placeholder="{{ block.settings.optional_placeholder }}"
                  >
                </div>
              </div>
            {% endif %}

            <div class="field-row">
              <div class="field">
                <label class="field-label" for="ContactFormMessage-{{ block.id }}">
                  {{ block.settings.message_label }} <span>*</span>
                </label>
                <textarea
                  id="ContactFormMessage-{{ block.id }}"
                  name="contact[body]"
                  placeholder="{{ block.settings.message_placeholder }}"
                  required
                ></textarea>
              </div>
            </div>

            <div class="form-footer">
              <button class="btn-submit" type="submit">
                {{ block.settings.button_label }}
              </button>

              <span class="form-guarantee">
                {{ block.settings.guarantee }}
              </span>
            </div>

            {% if form.posted_successfully? %}
              <div class="form-success show">
                <span class="success-icon">✓</span>
                <div class="success-h">{{ block.settings.success_heading }}</div>
                <p class="success-body">{{ block.settings.success_body }}</p>
              </div>
            {% endif %}

            {% if form.errors %}
              <div class="form-errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}
          {% endform %}
        </div>
      {% endif %}
    {% endfor %}

  </div>

</section>

