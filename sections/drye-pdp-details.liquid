{%- comment -%}
  DRYE PDP Details — standalone accordion (Why It Matters / Specifications /
  Who Makes This / How It Works / Fit and care / Shipping). Add under the PDP
  in the theme editor. Self-contained: own CSS + toggle JS.
{%- endcomment -%}

{%- assign uid = section.id -%}
{%- assign maxw = section.settings.max_width | default: 720 -%}

<style>
  .drye-details {
    padding: {{ section.settings.pad_top | default: 8 }}px 20px {{ section.settings.pad_bottom | default: 40 }}px;
    background: {{ section.settings.bg_color | default: '#ffffff' }};
  }
  .drye-details__inner { max-width: {{ maxw }}px; margin: 0 auto; }

  .drye-details .acc { border-bottom: 1px solid var(--border, #E5E7EB); }
  .drye-details .acc:first-child { border-top: 1px solid var(--border, #E5E7EB); }
  .drye-details .acc__btn {
    width: 100%; display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 17px 2px; border: 0; background: none; text-align: left;
    font-family: var(--font-body, "DM Sans", sans-serif); font-size: 15px; font-weight: 600;
    letter-spacing: 0.04em; text-transform: uppercase; color: var(--deep, #1E3A4C); cursor: pointer;
  }
  .drye-details .acc__btn:focus-visible { outline: 2px solid var(--emerald, #0D9488); outline-offset: 2px; }
  .drye-details .acc__chev {
    flex: 0 0 auto; width: 10px; height: 6px; color: var(--caption, #9CA3AF); transition: transform 0.28s ease;
  }
  .drye-details .acc__btn[aria-expanded="true"] .acc__chev { transform: rotate(180deg); }
  .drye-details .acc__panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.3s ease; }
  .drye-details .acc__panel.open { grid-template-rows: 1fr; }
  .drye-details .acc__inner { overflow: hidden; }
  .drye-details .acc__body { padding: 2px 2px 20px; font-size: 14px; line-height: 1.6; color: var(--body, #374151); }
  .drye-details .acc__body h5 { font-family: var(--font-display, "Clash Grotesk", sans-serif); font-size: 14px; font-weight: 600; color: var(--deep, #1E3A4C); margin: 14px 0 4px; }
  .drye-details .acc__body h5:first-child { margin-top: 0; }
  .drye-details .acc__body p { margin: 0 0 10px; }
  .drye-details .acc__body p:last-child { margin-bottom: 0; }
  .drye-details .acc__body ul { margin: 0 0 12px; padding-left: 18px; list-style: disc; }
  .drye-details .acc__body li { margin: 0 0 6px; padding-left: 2px; }
  .drye-details .acc__body li:last-child { margin-bottom: 0; }
  .drye-details .acc__body li::marker { color: var(--caption, #9CA3AF); }
  .drye-details .acc__body a { color: var(--emerald, #0D9488); text-decoration: none; font-weight: 500; }
  .drye-details .acc__body .fn { font-size: 14px; color: var(--caption, #9CA3AF); margin: 12px 0 0; }
  .drye-details .acc__sources { font-size: 10.5px; color: var(--caption, #9CA3AF); line-height: 1.5; margin: 12px 0 0; }
  .drye-details .acc__link { margin: 12px 0 0; }
  .drye-details .acc__link-btn { background: none; border: 0; padding: 0; margin: 0; cursor: pointer; font-family: var(--font-body, "DM Sans", sans-serif); font-size: 14px; color: var(--emerald, #0D9488); font-weight: 500; text-align: left; }

  /* Specifications datasheet */
  .drye-details .ds { width: 100%; border-collapse: collapse; background: transparent; font-size: 12px; letter-spacing: -0.01em; }
  .drye-details .ds td { padding: 9px 0; border-bottom: 1px solid var(--border, #E5E7EB); vertical-align: top; font-weight: 400; line-height: 1.4; white-space: normal; }
  .drye-details .ds tr:last-child td { border-bottom: 0; }
  .drye-details .ds .k { width: 1%; color: var(--muted, #4B5563); text-align: left; white-space: nowrap; padding-right: 12px; }
  .drye-details .ds .v { color: var(--deep, #1E3A4C); text-align: right; }
  .drye-details .ds-note-h { margin: 14px 0 5px; font-size: 10px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--caption, #9CA3AF); }
  .drye-details .ds-note { margin: 0; padding: 0; list-style: none; }
  .drye-details .ds-note li { font-size: 11px; color: var(--body, #374151); line-height: 1.4; padding: 3px 0 3px 13px; position: relative; }
  .drye-details .ds-note li::before { content: "—"; position: absolute; left: 0; color: var(--caption, #9CA3AF); }

  /* Media inside How It Works */
  .drye-details .desc-media { margin: 16px 0 0; }
  .drye-details .desc-media__img, .drye-details .desc-media__video { width: 100%; display: block; border-radius: 8px; }

  /* Who Makes This — photo + partner logos */
  .drye-details .drye-maker__photo { display: block; width: 100%; height: auto; border-radius: 8px; margin: 0 0 12px; object-fit: cover; }
  .drye-details .drye-partners { margin-top: 14px; padding-top: 12px; border-top: 1px solid #E5E5E5; }
  .drye-details .drye-partners__label { display: block; margin-bottom: 10px; font-family: "DM Sans", sans-serif; font-size: 9px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--caption, #9CA3AF); }
  .drye-details .drye-partners__logos { display: flex; flex-wrap: wrap; align-items: center; gap: 14px 22px; }
  .drye-details .drye-partners__logo { display: inline-flex; align-items: center; }
  .drye-details .drye-partners__logo img { height: 30px; width: auto; max-width: 120px; object-fit: contain; opacity: 0.65; filter: grayscale(1); }
  .drye-details .drye-partners__logo--boras img { height: 90px; max-width: 240px; }
  .drye-details .drye-partners__logo--uppsala img { height: 36px; max-width: 140px; }
</style>

<section class="drye-details" id="drye-details-{{ uid }}" data-drye-details>
  <div class="drye-details__inner">

    {% if section.settings.acc_why_body != blank %}
    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p0-{{ uid }}" id="dtl-b0-{{ uid }}">{{ section.settings.acc_why_label | default: 'Why It Matters' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p0-{{ uid }}" role="region" aria-labelledby="dtl-b0-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        {{ section.settings.acc_why_body }}
        <p class="acc__sources">Park &amp; Lee 2025 · TRGS 401 · Warner et al., J Invest Dermatol 2003 · Hikima &amp; Maibach 2006</p>
      </div></div></div>
    </div>
    {% endif %}

    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p1-{{ uid }}" id="dtl-b1-{{ uid }}">{{ section.settings.acc_specs_label | default: 'Specifications' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p1-{{ uid }}" role="region" aria-labelledby="dtl-b1-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        <table class="ds">
          <tr><td class="k">Construction</td><td class="v">Single jersey, plated · circular knitted</td></tr>
          <tr><td class="k">Skin side</td><td class="v">55% polypropylene — hydrophobic</td></tr>
          <tr><td class="k">Outer side</td><td class="v">45% lyocell (Tencel) — hydrophilic</td></tr>
          <tr><td class="k">Moisture asymmetry</td><td class="v">28% higher absorption on outer side (n=10)</td></tr>
          <tr><td class="k">Air permeability</td><td class="v">1800–1850 mm/s (ISO 9237)</td></tr>
          <tr><td class="k">Thickness</td><td class="v">0.4 mm</td></tr>
          <tr><td class="k">Weight</td><td class="v">200 g/m²</td></tr>
          <tr><td class="k">Size range</td><td class="v">5–12</td></tr>
          <tr><td class="k">Length range</td><td class="v">163–226 mm</td></tr>
          <tr><td class="k">Wash</td><td class="v">Machine, up to 90 °C</td></tr>
          <tr><td class="k">Lifespan</td><td class="v">6–12 months</td></tr>
          <tr><td class="k">Worn under</td><td class="v">Nitrile, latex, rubber, HV</td></tr>
          <tr><td class="k">Certification</td><td class="v">OEKO-TEX® Standard 100 — fabric and thread</td></tr>
          <tr><td class="k">Patent</td><td class="v">Pending · SE 2615359-3</td></tr>
        </table>
        <p class="ds-note-h">Not designed for</p>
        <ul class="ds-note">
          <li>Wearing without an outer glove</li>
          <li>Cut protection</li>
          <li>Touchscreen use</li>
        </ul>
      </div></div></div>
    </div>

    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p2-{{ uid }}" id="dtl-b2-{{ uid }}">{{ section.settings.acc_maker_label | default: 'Who Makes This' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p2-{{ uid }}" role="region" aria-labelledby="dtl-b2-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        {% if section.settings.maker_image != blank %}
          <img class="drye-maker__photo" src="{{ section.settings.maker_image | image_url: width: 900 }}" alt="{{ section.settings.acc_maker_label | default: 'Who Makes This' | escape }}" loading="lazy" width="{{ section.settings.maker_image.width }}" height="{{ section.settings.maker_image.height }}">
        {% endif %}
        {{ section.settings.acc_maker_body }}
        <div class="drye-partners">
          <span class="drye-partners__label">Developed &amp; validated with</span>
          <div class="drye-partners__logos">
            <span class="drye-partners__logo drye-partners__logo--uppsala"><img src="https://cdn.shopify.com/s/files/1/0686/9581/8505/files/images_4.png?v=1784673289" alt="Uppsala University" loading="lazy"></span>
            <span class="drye-partners__logo drye-partners__logo--boras"><img src="https://cdn.shopify.com/s/files/1/0686/9581/8505/files/1652448387777.jpg?v=1784673262" alt="The Swedish School of Textiles, Borås" loading="lazy"></span>
            <span class="drye-partners__logo"><img src="https://cdn.shopify.com/s/files/1/0686/9581/8505/files/images_5.png?v=1784673293" alt="Wargön Innovation" loading="lazy"></span>
          </div>
        </div>
      </div></div></div>
    </div>

    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p3-{{ uid }}" id="dtl-b3-{{ uid }}">{{ section.settings.acc_how_label | default: 'How It Works' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p3-{{ uid }}" role="region" aria-labelledby="dtl-b3-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        {{ section.settings.acc_how_body }}
        {% if section.settings.how_video != blank %}
          <div class="desc-media">{{ section.settings.how_video | video_tag: class: 'desc-media__video', autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto' }}</div>
        {% elsif section.settings.how_image != blank %}
          <div class="desc-media"><img class="desc-media__img" src="{{ section.settings.how_image | image_url: width: 1600 }}" alt="How DRYE works" loading="lazy"></div>
        {% endif %}
        <p class="fn">Seven years of textile development. Patent pending · SE 2615359-3.</p>
      </div></div></div>
    </div>

    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p4-{{ uid }}" id="dtl-b4-{{ uid }}">{{ section.settings.acc_sizing_label | default: 'Fit and care' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p4-{{ uid }}" role="region" aria-labelledby="dtl-b4-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        {{ section.settings.acc_sizing_body }}
        <p class="acc__link"><button type="button" class="js-open-size-guide acc__link-btn">Not sure of your size? → Open the size guide</button></p>
      </div></div></div>
    </div>

    <div class="acc">
      <button class="acc__btn" type="button" aria-expanded="false" aria-controls="dtl-p5-{{ uid }}" id="dtl-b5-{{ uid }}">{{ section.settings.acc_shipping_label | default: 'Shipping And Returns' }}<svg class="acc__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg></button>
      <div class="acc__panel" id="dtl-p5-{{ uid }}" role="region" aria-labelledby="dtl-b5-{{ uid }}"><div class="acc__inner"><div class="acc__body">
        <h5>The Glove-Off Test — 30 days</h5>
        <p>Wear them one full shift under your sealed glove. If your skin isn't drier when the glove comes off, keep the liners and we refund every dollar. Sending a worn pair back from the US costs more than the pair is worth. No forms, no return shipping.</p>
        <h5>Wrong size?</h5>
        <p>If you measured against our guide and it still doesn't fit, we ship the correct size at no cost.</p>
        <h5>Which shipping option should I choose?</h5>
        <p><strong>United States</strong></p>
        <ul>
          <li>PostNord — 5–10 business days. Normally 4–6, currently slower due to US customs processing. Duties and taxes are included in the price you pay at checkout. Nothing to pay on delivery.</li>
          <li>UPS — 1–3 business days. Duties, taxes and a brokerage fee are billed to you by UPS on delivery.</li>
        </ul>
        <p><strong>Canada</strong></p>
        <ul>
          <li>PostNord — 4–6 business days. No duty under CETA. Provincial tax and a CAD 9.95 handling fee are collected on delivery.</li>
          <li>UPS — 1–3 business days. Taxes and UPS import fees are billed to you on delivery.</li>
        </ul>
        <p><a href="#drye-faq">Full shipping and returns policy → See the FAQ above</a></p>
      </div></div></div>
    </div>

  </div>
</section>

<script>
  (function () {
    var root = document.getElementById('drye-details-{{ uid }}');
    if (!root || root.dataset.bound === '1') return;
    root.dataset.bound = '1';
    var btns = Array.prototype.slice.call(root.querySelectorAll('.acc__btn'));
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var panel = root.querySelector('#' + btn.getAttribute('aria-controls'));
        var open = btn.getAttribute('aria-expanded') === 'true';
        btns.forEach(function (b) {
          b.setAttribute('aria-expanded', 'false');
          var p = root.querySelector('#' + b.getAttribute('aria-controls'));
          if (p) { p.classList.remove('open'); }
        });
        if (!open) {
          btn.setAttribute('aria-expanded', 'true');
          if (panel) { panel.classList.add('open'); }
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "DRYE PDP Details",
  "tag": "section",
  "class": "drye-pdp-details-section",
  "settings": [
    { "type": "range", "id": "max_width", "label": "Content max width", "min": 560, "max": 1000, "step": 20, "unit": "px", "default": 720 },
    { "type": "range", "id": "pad_top", "label": "Padding top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 8 },
    { "type": "range", "id": "pad_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 40 },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "header", "content": "Why It Matters" },
    { "type": "text", "id": "acc_why_label", "label": "Label", "default": "Why It Matters" },
    { "type": "richtext", "id": "acc_why_body", "label": "Body", "default": "<p>Inside a sealed glove, humidity passes 90% within minutes and skin temperature holds around 35°C for the rest of the shift.</p><p>German TRGS 401 classifies more than two hours a day in occlusive gloves as wet work — a recognised occupational hazard. EV and HV technicians run three to six hours per shift.</p><p>Skin that stays wet softens and swells. Wet skin is more permeable than dry skin.</p><p>DRYE keeps skin drier. That's the whole intervention.</p>" },
    { "type": "header", "content": "Specifications" },
    { "type": "text", "id": "acc_specs_label", "label": "Label", "default": "Specifications" },
    { "type": "header", "content": "Who Makes This" },
    { "type": "text", "id": "acc_maker_label", "label": "Label", "default": "Who Makes This" },
    { "type": "image_picker", "id": "maker_image", "label": "Photo (seamstress)", "info": "Shown above the maker text." },
    { "type": "richtext", "id": "acc_maker_body", "label": "Body", "default": "<p>Made by Granqvists Gloves AB, Karlstad, Sweden — a glove manufacturer since 1984. The same production unit has supplied roughly 80% of military gloves to the Swedish, Norwegian and Finnish armed forces. ISO 9001 and ISO 14001 certified. Fabric knitted in Sweden by Trikåby. Sewn in the EU.</p>" },
    { "type": "header", "content": "How It Works" },
    { "type": "text", "id": "acc_how_label", "label": "Label", "default": "How It Works" },
    { "type": "richtext", "id": "acc_how_body", "label": "Body", "default": "<p>Your glove still does the protecting. DRYE changes what touches your skin — a thin dry layer between your hand and the nitrile, latex, rubber or sealed work glove.</p><p>Every liner that absorbs has a saturation point. Once it fills, it becomes the wet layer against your skin. DRYE routes moisture outward instead. The skin side is built not to hold sweat, so it has no saturation point.</p><p>One fabric, knitted in one operation. Two surfaces. One direction. No coatings, no chemicals, no membranes.</p>" },
    { "type": "video", "id": "how_video", "label": "How It Works — video (optional)" },
    { "type": "image_picker", "id": "how_image", "label": "How It Works — image (fallback)" },
    { "type": "header", "content": "Fit and care" },
    { "type": "text", "id": "acc_sizing_label", "label": "Label", "default": "Fit and care" },
    { "type": "richtext", "id": "acc_sizing_body", "label": "Body", "default": "<h5>How it should feel</h5><p>Snug, like a second skin. You should feel the fabric, not the seams. If it's tight across the back of the hand, size up. Circumference decides — not finger length.</p><h5>Putting them on</h5><p>The fabric is 0.4 mm. Pull them on gently, finger by finger. Do not yank them on the way you would an outer glove — that puts all the load on the thumb and finger seams.</p><h5>Taking them off</h5><p>Go slow. Peel finger by finger rather than pulling from the cuff.</p><h5>Washing</h5><p>Machine wash up to 90 °C. Nothing washes out — there are no coatings or chemical finishes to lose, and they do not shrink. Air dry if you can. They dry fast. Tumble drying works but will make the surface pill over time.</p><h5>Daily wear</h5><p>If you wear them every shift, two or three pairs works best — one on, one drying, one in the bag. Same idea as work boots.</p>" },
    { "type": "header", "content": "Shipping And Returns" },
    { "type": "text", "id": "acc_shipping_label", "label": "Label", "default": "Shipping And Returns" }
  ],
  "presets": [
    { "name": "DRYE PDP Details" }
  ]
}
{% endschema %}
