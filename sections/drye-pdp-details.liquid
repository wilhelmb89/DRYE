{{ 'drye-pdp-details.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section drye-pdp-details" id="drye-pdp-details-{{ section.id }}" data-drye-section data-section-name="pdp-details">
  <div class="dryeNEW-container" id="pdp-det-container-{{ section.id }}">
    <div class="pdp-det__layout">

      {%- comment -%} COL 1 — Accordions {%- endcomment -%}
      <div class="pdp-det__left" id="pdp-det-acc-{{ section.id }}">

        {%- comment -%}--- WHY IT MATTERS ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="why">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-why">
            {{ section.settings.acc_why_label | default: 'Why It Matters' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="pdp-det__panel" id="pdp-det-p-why-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body">
              <ul class="pdp-det__list">
                <li>Sealed gloves reach <strong>~90% RH within 5–7 minutes.</strong></li>
                <li>Wet skin can become more permeable; drier skin feels better over a shift.</li>
                <li>DRYE keeps the skin side drier. <a href="/pages/research">Evidence →</a></li>
              </ul>
              <p class="pdp-det__source">Park &amp; Lee 2025 · TRGS 401 · Hikima &amp; Maibach 2006</p>
            </div></div>
          </div>
        </div>

        {%- comment -%}--- HOW IT WORKS ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="how">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-how">
            {{ section.settings.acc_how_label | default: 'How It Works' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="pdp-det__panel" id="pdp-det-p-how-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body">
              <ul class="pdp-det__list">
                <li><strong>Asymmetric Layering:</strong> skin side 55% PP (hydrophobic), outer 45% lyocell (hydrophilic).</li>
                <li>Transports moisture outward; no coatings or membranes.</li>
                <li><strong>0.4 mm</strong> — worn under your existing glove.</li>
              </ul>
            </div></div>
          </div>
        </div>

        {%- comment -%}--- FIT AND CARE ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="fit">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-fit">
            {{ section.settings.acc_fit_label | default: 'Fit and Care' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="pdp-det__panel" id="pdp-det-p-fit-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body">
              <ul class="pdp-det__list">
                <li><strong>Fit:</strong> snug, second-skin.</li>
                <li><strong>On/off:</strong> slow, finger-by-finger.</li>
                <li><strong>Wash:</strong> 140–195°F (60–90°C). Expected life: 6–12 months.</li>
              </ul>
            </div></div>
          </div>
        </div>

        {%- comment -%}--- SPECIFICATIONS ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="specs">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-specs">
            {{ section.settings.acc_specs_label | default: 'Specifications' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="pdp-det__panel" id="pdp-det-p-specs-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body">
              <ul class="pdp-det__list">
                <li>Single-jersey (plated) · 0.4 mm · 40 g per pair · sizes 5–12.</li>
                <li>OEKO-TEX® Standard 100 · Patent pending.</li>
                <li>Not designed for: without outer glove · cut protection · touchscreen use.</li>
              </ul>
              <table class="pdp-det__ds">
                <tbody>
                  <tr><td class="k">Skin side</td><td class="v">55% polypropylene — hydrophobic</td></tr>
                  <tr><td class="k">Outer side</td><td class="v">45% lyocell (Tencel) — hydrophilic</td></tr>
                  <tr><td class="k">Weight</td><td class="v">40 g per pair</td></tr>
                  <tr><td class="k">Wash</td><td class="v">140–195°F / 60–90°C</td></tr>
                  <tr><td class="k">Air permeability</td><td class="v">1800–1850 mm/s (ISO 9237)</td></tr>
                  <tr><td class="k">Moisture asymmetry</td><td class="v">28% higher outer side</td></tr>
                  <tr><td class="k">Certification</td><td class="v">OEKO-TEX® Standard 100</td></tr>
                  <tr><td class="k">Patent</td><td class="v">Pending · SE 2615359-3</td></tr>
                </tbody>
              </table>
            </div></div>
          </div>
        </div>

        {%- comment -%}--- SHIPPING AND RETURNS ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="ship">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-ship">
            {{ section.settings.acc_ship_label | default: 'Shipping and Returns' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          <div class="pdp-det__panel" id="pdp-det-p-ship-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body">
              <ul class="pdp-det__list">
                <li><strong>USA PostNord:</strong> import prepaid (0 USD at door). <strong>UPS:</strong> import fees to recipient.</li>
                <li><strong>Canada:</strong> tax + carrier fees may apply.</li>
                <li>30-day money-back guarantee. <a href="/pages/policy">Full policy →</a></li>
              </ul>
            </div></div>
          </div>
        </div>

        {%- comment -%}--- WHO MAKES THIS ---{%- endcomment -%}
        <div class="pdp-det__acc" data-acc="who">
          <button class="pdp-det__btn" type="button" data-radio-id="r-det-who">
            {{ section.settings.acc_who_label | default: 'Who Makes This' }}
            <svg class="pdp-det__chev" viewBox="0 0 10 6" fill="none">
              <path d="M0 0l5 6 5-6z" fill="currentColor"/>
            </svg>
          </button>
          {%- if section.settings.maker_image != blank -%}
            <div class="pdp-det__maker-img">
              {{ section.settings.maker_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Granqvists Gloves factory' }}
            </div>
          {%- endif -%}
          <div class="pdp-det__panel" id="pdp-det-p-who-{{ section.id }}">
            <div class="pdp-det__inner"><div class="pdp-det__body" style="padding-top:12px;">
              <ul class="pdp-det__list">
                <li><strong>Granqvists Gloves AB, Karlstad, Sweden</strong> — glove manufacturer since 1984. The same factory supplies ~80% of military gloves to the Swedish, Norwegian and Finnish armed forces.</li>
                <li>Fabric knitted by Trikåby, Sweden. Sewn in the EU. ISO 9001 / ISO 14001 / OEKO-TEX® Standard 100.</li>
              </ul>
              <div class="pdp-det__partners">
                <span class="pdp-det__partners-label">Developed &amp; validated with</span>
                <div class="pdp-det__partners-logos">
                  {%- if section.settings.partner_logo_1 != blank -%}
                    <span class="uppsala">
                      {{ section.settings.partner_logo_1 | image_url: width: 200 | image_tag: loading: 'lazy', alt: section.settings.partner_logo_1_alt | default: 'Research partner' }}
                    </span>
                  {%- endif -%}
                  {%- if section.settings.partner_logo_2 != blank -%}
                    <span class="boras">
                      {{ section.settings.partner_logo_2 | image_url: width: 300 | image_tag: loading: 'lazy', alt: section.settings.partner_logo_2_alt | default: 'Research partner' }}
                    </span>
                  {%- endif -%}
                  {%- if section.settings.partner_logo_3 != blank -%}
                    <span>
                      {{ section.settings.partner_logo_3 | image_url: width: 200 | image_tag: loading: 'lazy', alt: section.settings.partner_logo_3_alt | default: 'Research partner' }}
                    </span>
                  {%- endif -%}
                </div>
              </div>
            </div></div>
          </div>
        </div>

      </div>

      {%- comment -%} COL 2 — Contextual right panel (desktop only) {%- endcomment -%}
      <div class="pdp-det__right">
        <div class="pdp-det__right-inner">

          {%- comment -%}--- VIS: WHY IT MATTERS ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--pad" id="vis-det-why">
            <div class="pdp-det__vis-micro">Relative humidity — sealed glove</div>
            <div class="pdp-det__stat">90<span class="pdp-det__stat-suf">%</span></div>
            <div class="pdp-det__stat-sub">Within 5–7 minutes of donning</div>
            <div class="pdp-det__row">
              <div class="pdp-det__row-lbl">Open glove</div>
              <div style="display:flex;align-items:center;gap:10px;width:100%;">
                <div class="pdp-det__row-track"><div class="pdp-det__row-fill" style="width:32%; background:var(--border);"></div></div>
                <div class="pdp-det__row-val">~32%</div>
              </div>
            </div>
            <div class="pdp-det__row">
              <div class="pdp-det__row-lbl">Sealed glove — no liner</div>
              <div style="display:flex;align-items:center;gap:10px;width:100%;">
                <div class="pdp-det__row-track"><div class="pdp-det__row-fill" style="width:90%;"></div></div>
                <div class="pdp-det__row-val">&gt;90%</div>
              </div>
            </div>
            <div class="pdp-det__row">
              <div class="pdp-det__row-lbl">Sealed glove — with DRYE</div>
              <div style="display:flex;align-items:center;gap:10px;width:100%;">
                <div class="pdp-det__row-track"><div class="pdp-det__row-fill pdp-det__row-fill--em" style="width:52%;"></div></div>
                <div class="pdp-det__row-val">Lower</div>
              </div>
            </div>
            <p class="pdp-det__source-sm">Park &amp; Lee 2025</p>
          </div>

          {%- comment -%}--- VIS: HOW IT WORKS (mechanism diagram) ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--pad pdp-det__vis--dark" id="vis-det-how">
            <div class="pdp-det__vis-micro" style="color:rgba(95,138,139,0.9); text-align:center; margin-bottom:20px;">Cotton · DRYE</div>
            <div class="pdp-det__mech-grid">
              <div class="pdp-det__mech-card">
                <div class="pdp-det__mech-media">
                  <svg viewBox="0 0 100 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="6" y="8" width="88" height="8" fill="#1E3A4C"/>
                    <line x1="8" y1="16" x2="8" y2="70" stroke="#E5E7EB" stroke-width="1"/>
                    <line x1="92" y1="16" x2="92" y2="70" stroke="#E5E7EB" stroke-width="1"/>
                    <rect x="8" y="62" width="84" height="8" fill="#A8B5BC"/>
                    <path d="M25 60 L25 22 M22 27 L25 22 L28 27" stroke="#0D9488" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M50 60 L50 22 M47 27 L50 22 L53 27" stroke="#0D9488" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M75 60 L75 22 M72 27 L75 22 L78 27" stroke="#0D9488" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M45 4 L55 14 M55 4 L45 14" stroke="#EF4444" stroke-width="1.6" stroke-linecap="round"/>
                    <line x1="8" y1="70" x2="92" y2="70" stroke="#1E3A4C" stroke-width="1.5"/>
                  </svg>
                </div>
                <div class="pdp-det__mech-body">
                  <div class="pdp-det__mech-name">Cotton</div>
                  <p class="pdp-det__mech-desc">Sweat stays trapped against your skin.</p>
                </div>
              </div>
              <div class="pdp-det__mech-card pdp-det__mech-card--drye">
                <div class="pdp-det__mech-media">
                  <svg viewBox="0 0 100 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="6" y="0" width="88" height="4" fill="#1E3A4C"/>
                    <rect x="6" y="4" width="88" height="4" fill="#DDE9E9"/>
                    <rect x="6" y="8" width="88" height="4" fill="#E8EFEF"/>
                    <line x1="8" y1="12" x2="92" y2="12" stroke="#9CA3AF" stroke-width="1" stroke-dasharray="3 3"/>
                    <line x1="8" y1="12" x2="8" y2="70" stroke="#E5E7EB" stroke-width="1"/>
                    <line x1="92" y1="12" x2="92" y2="70" stroke="#E5E7EB" stroke-width="1"/>
                    <rect x="8" y="62" width="84" height="8" fill="#E5E7EB"/>
                    <ellipse cx="37" cy="60" rx="1.5" ry="2.2" fill="rgba(80,160,240,0.8)" opacity="0">
                      <animate attributeName="cy" values="60;30;12;6" keyTimes="0;0.5;0.85;1" dur="4.5s" begin="0s" repeatCount="indefinite"/>
                      <animate attributeName="opacity" values="0;0.75;0.75;0.4;0" keyTimes="0;0.08;0.6;0.9;1" dur="4.5s" begin="0s" repeatCount="indefinite"/>
                    </ellipse>
                    <ellipse cx="62" cy="60" rx="1.5" ry="2.2" fill="rgba(80,160,240,0.8)" opacity="0">
                      <animate attributeName="cy" values="60;30;12;6" keyTimes="0;0.5;0.85;1" dur="4.5s" begin="1.5s" repeatCount="indefinite"/>
                      <animate attributeName="opacity" values="0;0.75;0.75;0.4;0" keyTimes="0;0.08;0.6;0.9;1" dur="4.5s" begin="1.5s" repeatCount="indefinite"/>
                    </ellipse>
                    <path d="M25 60 L25 5 M22 10 L25 5 L28 10" stroke="#1E3A4C" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M50 60 L50 5 M47 10 L50 5 L53 10" stroke="#1E3A4C" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M75 60 L75 5 M72 10 L75 5 L78 10" stroke="#1E3A4C" stroke-width="1.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="8" y1="70" x2="92" y2="70" stroke="#1E3A4C" stroke-width="1.5"/>
                  </svg>
                </div>
                <div class="pdp-det__mech-body">
                  <div class="pdp-det__mech-name">DRYE Liner</div>
                  <p class="pdp-det__mech-desc">Water is pulled through and spread outward. Skin stays dry.</p>
                </div>
              </div>
            </div>
            <p class="pdp-det__mech-foot">Asymmetric Layering — one fabric, one direction</p>
          </div>

          {%- comment -%}--- VIS: FIT AND CARE (size guide) ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--pad" id="vis-det-fit">
            <div class="pdp-det__vis-micro">Size guide</div>
            <div class="pdp-det__sizetoggle" id="pdp-det-size-toggle-{{ section.id }}">
              <button class="is-active" type="button" data-unit="mm">MM</button>
              <button type="button" data-unit="in">INCHES</button>
            </div>
            <div class="pdp-det__sizegrid">
              <span class="pdp-det__sizegrid-th">Size</span>
              <span class="pdp-det__sizegrid-th">EU</span>
              <span class="pdp-det__sizegrid-th">Hand circ.</span>
              <div class="pdp-det__sizegrid-row"><span>5</span><span>XXS</span><span class="pdp-det__sz" data-mm="150–162 mm" data-in='5.9–6.4"'>150–162 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>6</span><span>XS</span><span class="pdp-det__sz" data-mm="163–172 mm" data-in='6.4–6.8"'>163–172 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>7</span><span>S</span><span class="pdp-det__sz" data-mm="172–181 mm" data-in='6.8–7.1"'>172–181 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>8</span><span>M</span><span class="pdp-det__sz" data-mm="182–193 mm" data-in='7.2–7.6"'>182–193 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>9</span><span>L</span><span class="pdp-det__sz" data-mm="194–205 mm" data-in='7.6–8.1"'>194–205 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>10</span><span>XL</span><span class="pdp-det__sz" data-mm="206–216 mm" data-in='8.1–8.5"'>206–216 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>11</span><span>XXL</span><span class="pdp-det__sz" data-mm="217–226 mm" data-in='8.5–8.9"'>217–226 mm</span></div>
              <div class="pdp-det__sizegrid-row"><span>12</span><span>XXXL</span><span class="pdp-det__sz" data-mm="227–236 mm" data-in='8.9–9.3"'>227–236 mm</span></div>
            </div>
            <p style="font-size:9px; color:var(--caption); margin-top:10px; letter-spacing:0.06em;">Measure at widest point — knuckles, not finger length.</p>
          </div>

          {%- comment -%}--- VIS: SPECIFICATIONS ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--pad" id="vis-det-specs">
            <div class="pdp-det__vis-micro">Fabric construction</div>
            <div class="pdp-det__layer">
              <div>
                <div class="pdp-det__layer-name">Outer layer</div>
                <div class="pdp-det__layer-sub">Lyocell (Tencel) — hydrophilic</div>
              </div>
              <div class="pdp-det__layer-pct pdp-det__layer-pct--em">45%</div>
            </div>
            <div class="pdp-det__layer">
              <div>
                <div class="pdp-det__layer-name">Skin layer</div>
                <div class="pdp-det__layer-sub">Polypropylene — hydrophobic</div>
              </div>
              <div class="pdp-det__layer-pct">55%</div>
            </div>
            <div class="pdp-det__tiles">
              <div class="pdp-det__tile">
                <div class="pdp-det__tile-num">0.4<span class="pdp-det__tile-unit">mm</span></div>
                <div class="pdp-det__tile-lbl">Thickness</div>
              </div>
              <div class="pdp-det__tile">
                <div class="pdp-det__tile-num">40<span class="pdp-det__tile-unit">g</span></div>
                <div class="pdp-det__tile-lbl">Per pair</div>
              </div>
              <div class="pdp-det__tile">
                <div class="pdp-det__tile-num pdp-det__tile-num--em">28<span class="pdp-det__tile-unit">%</span></div>
                <div class="pdp-det__tile-lbl">Asymmetry</div>
              </div>
            </div>
          </div>

          {%- comment -%}--- VIS: SHIPPING AND RETURNS ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--pad pdp-det__vis--dark" id="vis-det-ship">
            <div class="pdp-det__guar-micro">The Glove-Off Test</div>
            <div class="pdp-det__guar-num">30 <span>day guarantee</span></div>
            <div class="pdp-det__guar-body">Wear one full shift. If your skin isn't drier when the glove comes off — full refund. No forms, no return shipping.</div>
            <div style="margin-top:20px; border-top:1px solid rgba(255,255,255,0.1); padding-top:16px;">
              <div class="pdp-det__ship-row">
                <span class="pdp-det__ship-dest">USA — PostNord</span>
                <span class="pdp-det__ship-note">Duties prepaid · 5–10 days</span>
              </div>
              <div class="pdp-det__ship-row">
                <span class="pdp-det__ship-dest">USA — UPS</span>
                <span class="pdp-det__ship-note">Duties on delivery · 1–3 days</span>
              </div>
              <div class="pdp-det__ship-row">
                <span class="pdp-det__ship-dest">Canada</span>
                <span class="pdp-det__ship-note">Tax + fees may apply · 4–6 days</span>
              </div>
            </div>
          </div>

          {%- comment -%}--- VIS: WHO MAKES THIS ---{%- endcomment -%}
          <div class="pdp-det__vis pdp-det__vis--who" id="vis-det-who">
            {%- if section.settings.maker_image != blank -%}
              {{ section.settings.maker_image | image_url: width: 900 | image_tag:
                loading: 'lazy',
                alt: 'Granqvists Gloves factory',
                style: 'width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;'
              }}
            {%- endif -%}
          </div>

        </div>

        <div class="pdp-det__cap">
          <span data-for="why">Humidity levels inside sealed protective gloves — internal study data</span>
          <span data-for="how">One fabric. Two surfaces. One direction.</span>
          <span data-for="fit">Circumference decides — not finger length.</span>
          <span data-for="specs">Single jersey, plated knit — 0.4 mm total thickness</span>
          <span data-for="ship">Full refund if skin isn't drier after one shift.</span>
          <span data-for="who">Granqvists Gloves AB — Karlstad, Sweden. Since 1984.</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
(function() {
  var container = document.getElementById('pdp-det-container-{{ section.id }}');
  var accRoot   = document.getElementById('pdp-det-acc-{{ section.id }}');
  if (!container || !accRoot) return;

  // 1. Inject hidden radio inputs before .pdp-det__layout
  var layout = container.querySelector('.pdp-det__layout');
  if (!document.getElementById('r-det-why')) {
    ['why','how','fit','specs','ship','who'].forEach(function(key, i) {
      var inp = document.createElement('input');
      inp.className = 'pdp-det-r';
      inp.type      = 'radio';
      inp.name      = 'pdp-det-acc-{{ section.id }}';
      inp.id        = 'r-det-' + key;
      container.insertBefore(inp, layout);
    });
  }

  // 2. Default: open "Why It Matters"
  function fireRadio(id) {
    var r = document.getElementById(id);
    if (r) { r.checked = true; r.dispatchEvent(new Event('change', { bubbles: true })); }
  }
  fireRadio('r-det-why');

  // 3. Accordion click → check radio
  var btns = accRoot.querySelectorAll('[data-radio-id]');
  btns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      fireRadio(btn.getAttribute('data-radio-id'));
    });
  });

  // 4. MM / Inches toggle
  var toggle = document.getElementById('pdp-det-size-toggle-{{ section.id }}');
  if (toggle) {
    toggle.querySelectorAll('button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var unit = btn.getAttribute('data-unit');
        toggle.querySelectorAll('button').forEach(function(b) { b.classList.remove('is-active'); });
        btn.classList.add('is-active');
        document.querySelectorAll('.pdp-det__sz').forEach(function(el) {
          el.textContent = unit === 'mm' ? el.getAttribute('data-mm') : el.getAttribute('data-in');
        });
      });
    });
  }
})();
</script>

