{{ 'drye-liner-worker-proof.css' | asset_url | stylesheet_tag }}
{{ 'drye-liner-worker-proof.js' | asset_url | script_tag }}

<div class="drye-liner-worker-proof" id="{{ section.settings.section_id | default: 'liner-worker-proof' }}" data-section-id="{{ section.id }}">
  <div class="drye-liner-worker-proof__card" id="drye-liner-worker-proof-{{ section.id }}">
    <div class="drye-liner-worker-proof__line">
      <svg class="drye-liner-worker-proof__check" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.15"></circle>
        <path d="M7 12.5l3 3 7-7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      {%- if section.settings.headline != blank -%}
        <span class="drye-liner-worker-proof__returns">{{ section.settings.headline }}</span>
      {%- endif -%}
    </div>

    {%- if section.settings.subline != blank -%}
      <div class="drye-liner-worker-proof__keep">{{ section.settings.subline }}</div>
    {%- endif -%}

    {%- if section.settings.ticker_label != blank -%}
      <div class="drye-liner-worker-proof__tlabel">{{ section.settings.ticker_label }}</div>
    {%- endif -%}

    <div class="drye-liner-worker-proof__ticker-wrap" data-drye-liner-worker-proof-wrap>
      <ul class="drye-liner-worker-proof__ticker" data-drye-liner-worker-proof-ticker>
        {%- for pass in (1..2) -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'quote' -%}
              <li class="drye-liner-worker-proof__item-wrap">
                <button
                  type="button"
                  class="drye-liner-worker-proof__item"
                  data-drye-liner-worker-proof-item
                  data-full="{{ block.settings.full_text | escape }}"
                  data-handle="{{ block.settings.handle | escape }}"
                  data-label="{{ block.settings.label | escape }}"
                  {% if pass == 1 %}{{ block.shopify_attributes }}{% endif %}
                >
                  {%- if block.settings.handle != blank -%}
                    <span class="drye-liner-worker-proof__ihandle">{{ block.settings.handle }}</span>
                  {%- endif -%}
                  <span class="drye-liner-worker-proof__iquote">{{ block.settings.short_text }}</span>
                  <span class="drye-liner-worker-proof__iplus" aria-hidden="true">+</span>
                </button>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- if section.settings.hint_text != blank -%}
      <div class="drye-liner-worker-proof__hint">
        <span class="drye-liner-worker-proof__hint-plus" aria-hidden="true">+</span>
        <span>{{ section.settings.hint_text }}</span>
      </div>
    {%- endif -%}

    <div class="drye-liner-worker-proof__expand" data-drye-liner-worker-proof-expand hidden>
      <button type="button" class="drye-liner-worker-proof__expand-close" data-drye-liner-worker-proof-close aria-label="Close">×</button>
      <p class="drye-liner-worker-proof__expand-quote" data-drye-liner-worker-proof-quote></p>
      <div class="drye-liner-worker-proof__expand-meta">
        <span class="drye-liner-worker-proof__expand-source" data-drye-liner-worker-proof-source></span>
      </div>
    </div>

    {%- if section.settings.orders_line != blank -%}
      <div class="drye-liner-worker-proof__orders"><strong>{{ section.settings.orders_line }}</strong></div>
    {%- endif -%}

    {%- if section.settings.states_line != blank -%}
      <div class="drye-liner-worker-proof__states">{{ section.settings.states_line }}</div>
    {%- endif -%}
  </div>
</div>

