
  {{ 'drye-blog-cta-strip.css' | asset_url | stylesheet_tag }}

<section class="cta-strip" data-drye-section data-section-name="blog_cta_strip">
  <span class="micro" style="justify-content:center;display:flex;">
    {{ section.settings.eyebrow }}
  </span>

  <h2 class="cta-h">
    {{ section.settings.heading }}
    <em>{{ section.settings.heading_emphasis }}</em>
  </h2>

  <p class="cta-sub">{{ section.settings.subtext }}</p>

  <a href="{{ section.settings.primary_url }}" class="btn-primary">
    {{ section.settings.primary_label }}
  </a>

  <a href="{{ section.settings.secondary_url }}" class="btn-secondary">
    {{ section.settings.secondary_label }}
  </a>
</section>

{% schema %}
{
  "name": "DRYE Blog CTA Strip",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "You've read the evidence."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Now try it."
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis",
      "default": " 30 days. Full refund if it doesn't work."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "If the physics don't change your shift — we'll return every dollar. No forms. No questions."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Order DRYE Liners →"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "See the Research"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "DRYE Blog CTA Strip"
    }
  ]
}
{% endschema %}