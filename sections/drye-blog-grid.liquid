
  {{ 'drye-blog-grid.css' | asset_url | stylesheet_tag }}

{% assign max_posts = section.settings.max_posts %}
{% assign total_count = blog.articles_count %}

{% if section.settings.exclude_first_post and total_count > 0 %}
  {% assign total_count = total_count | minus: 1 %}
{% endif %}

<section class="grid-sec">
  <div class="grid-in">
    <div class="grid-header">
      <h2 class="grid-h">{{ section.settings.heading }}</h2>
      <span class="grid-count" id="post-count">
        {{ total_count }}{% if total_count == 1 %} article{% else %} articles{% endif %}
      </span>
    </div>

    {% assign pin_tag = section.settings.pin_tag | default: 'pinned' %}
    {% liquid
      assign exclude_id = ''
      if section.settings.exclude_first_post and blog.articles.size > 0
        assign exclude_id = blog.articles.first.id
      endif
      assign shown = 0
      assign card_index = 0
    %}

    <div class="post-grid" id="post-grid">
      {%- comment -%} Pinned posts first (any article tagged with the pin tag) {%- endcomment -%}
      {% for article in blog.articles %}
        {% if shown >= max_posts %}{% break %}{% endif %}
        {% unless article.tags contains pin_tag %}{% continue %}{% endunless %}
        {% if exclude_id != '' and article.id == exclude_id %}{% continue %}{% endif %}
        {% assign card_index = card_index | plus: 1 %}
        {% render 'drye-blog-card', article: article, card_index: card_index %}
        {% assign shown = shown | plus: 1 %}
      {% endfor %}

      {%- comment -%} Then the remaining posts in normal (newest-first) order {%- endcomment -%}
      {% for article in blog.articles %}
        {% if shown >= max_posts %}{% break %}{% endif %}
        {% if article.tags contains pin_tag %}{% continue %}{% endif %}
        {% if exclude_id != '' and article.id == exclude_id %}{% continue %}{% endif %}
        {% assign card_index = card_index | plus: 1 %}
        {% render 'drye-blog-card', article: article, card_index: card_index %}
        {% assign shown = shown | plus: 1 %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE Blog Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All Reports"
    },
    {
      "type": "range",
      "id": "max_posts",
      "label": "Max posts",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "exclude_first_post",
      "label": "Exclude first post from grid",
      "default": true,
      "info": "Use this if the newest post is already shown in the featured section above."
    },
    {
      "type": "text",
      "id": "pin_tag",
      "label": "Pin tag",
      "default": "pinned",
      "info": "Articles with this tag are shown first in the grid. Add the tag to a blog post in the admin to pin it to the top."
    }
  ],
  "presets": [
    {
      "name": "DRYE Blog Grid"
    }
  ]
}
{% endschema %}