{{ 'drye-liner-product-clarity.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section drye-liner-product-clarity"
  id="{{ section.settings.section_id | default: 'liner-product' }}"
  data-section-id="{{ section.id }}"
>
  <div class="dryeNEW-container">
    <div class="drye-liner-product-clarity__inner">
      <div class="drye-liner-product-clarity__intro">
        {% if section.settings.heading != blank or section.settings.heading_emphasis != blank %}
          <h2 class="dryeNEW-h2 drye-liner-product-clarity__heading">
            {%- if section.settings.heading != blank -%}
              {{ section.settings.heading }}<br>
            {%- endif -%}
            {%- if section.settings.heading_emphasis != blank -%}
              <span class="dryeNEW-editorial">{{ section.settings.heading_emphasis }}</span>
            {%- endif -%}
          </h2>
        {% endif %}

        {% if section.settings.body != blank %}
          <div class="dryeNEW-body drye-liner-product-clarity__body">{{ section.settings.body }}</div>
        {% endif %}
      </div>

      <div class="drye-liner-product-clarity__image">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              class: 'drye-liner-product-clarity__img',
              loading: 'lazy',
              sizes: '(min-width: 768px) 340px, 100vw',
              alt: section.settings.image.alt | default: section.settings.heading | strip_html
          }}
        {% else %}
          <div class="drye-liner-product-clarity__placeholder">
            <span>Product photo — mechanic's hand wearing DRYE liner under work glove, 2:3 crop</span>
          </div>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <ul class="drye-liner-product-clarity__specs">
          {%- for block in section.blocks -%}
            {%- if block.type == 'spec' -%}
              <li class="drye-liner-product-clarity__spec" {{ block.shopify_attributes }}>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7l3 3 5-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>
                  {% if block.settings.title != blank %}
                    <strong>{{ block.settings.title }}</strong>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    {{ block.settings.description }}
                  {% endif %}
                </span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE Liner Product Clarity",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "liner-product"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DRYE goes under"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis",
      "default": "your existing glove."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Thin enough you forget it's there. Strong enough to last a shift.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image (2:3)"
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Thin by design."
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Doesn't add bulk or reduce dexterity."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DRYE Liner Product Clarity",
      "blocks": [
        {
          "type": "spec",
          "settings": {
            "title": "Thin by design.",
            "description": "Doesn't add bulk or reduce dexterity."
          }
        },
        {
          "type": "spec",
          "settings": {
            "title": "Works under any glove.",
            "description": "Nitrile, latex, rubber, HV."
          }
        },
        {
          "type": "spec",
          "settings": {
            "title": "Stays in place.",
            "description": "Between skin and glove. All shift."
          }
        }
      ]
    }
  ]
}
{% endschema %}
