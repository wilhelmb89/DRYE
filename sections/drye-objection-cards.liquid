{{ 'section-drye-objection-cards.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section objection-cards" data-section-id="{{ section.id }}" data-drye-section data-section-index="7" data-section-name="objections">  <div class="dryeNEW-container">
    <div class="objection-cards__intro">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro objection-cards__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="dryeNEW-h2 objection-cards__heading">
          {{ section.settings.heading }}
          {% if section.settings.heading_emphasis != blank %}
            <em class="dryeNEW-em">{{ section.settings.heading_emphasis }}</em>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="dryeNEW-body objection-cards__sub">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    <div class="objection-cards__strip-wrap">
      <button
  class="objection-cards__arrow objection-cards__arrow--prev"
  type="button"
  data-objection-prev
  aria-label="Previous"
>
  ←
</button>

<button
  class="objection-cards__arrow objection-cards__arrow--next"
  type="button"
  data-objection-next
  aria-label="Next"
>
  →
</button>
      <div
        class="objection-cards__swipe-hint"
        data-objection-swipe-hint
        aria-hidden="true"
      >
        Swipe
      </div>

      <div
        class="objection-cards__grid"
        data-objection-strip
        {% if section.blocks.size < 2 %}data-single-card="true"{% endif %}
      >
        {% for block in section.blocks %}
          {% assign has_name = false %}
          {% assign has_meta = false %}

          {% if block.settings.name != blank %}
            {% assign has_name = true %}
          {% endif %}

          {% if block.settings.meta != blank %}
            {% assign has_meta = true %}
          {% endif %}

          <article class="objection-cards__card" {{ block.shopify_attributes }}>
            {% if block.settings.profession != blank %}
              <span class="objection-cards__prof">
                {{ block.settings.profession }}
              </span>
            {% endif %}

            {% if block.settings.question != blank %}
              <h3 class="dryeNEW-h3 objection-cards__q">
                {{ block.settings.question }}
              </h3>
            {% endif %}

            {% if block.settings.quote != blank %}
              <blockquote class="dryeNEW-body objection-cards__quote">
                <p>{{ block.settings.quote }}</p>
              </blockquote>
            {% endif %}

            {% if has_name or has_meta %}
              <div class="dryeNEW-body--caption objection-cards__attr">
                {% if has_name %}
                  <span class="objection-cards__name">{{ block.settings.name }}</span>
                {% endif %}

                {% if has_name and has_meta %}
                  <span class="objection-cards__sep"> · </span>
                {% endif %}

                {% if has_meta %}
                  <span class="objection-cards__meta">{{ block.settings.meta }}</span>
                {% endif %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>

      <div class="objection-cards__fade" data-objection-fade aria-hidden="true"></div>
    </div>

    {% if section.blocks.size > 1 %}
      <div class="objection-cards__dots" data-objection-dots aria-hidden="true"></div>
    {% endif %}
  </div>
</section>

<script>
  (() => {
    const sectionId = {{ section.id | json }};
    const section = document.querySelector('[data-section-id="' + sectionId + '"]');
    if (!section) return;

    const strip = section.querySelector('[data-objection-strip]');
    const hint = section.querySelector('[data-objection-swipe-hint]');
    const fade = section.querySelector('[data-objection-fade]');
    const dotsWrap = section.querySelector('[data-objection-dots]');
    const prevBtn = section.querySelector('[data-objection-prev]');
const nextBtn = section.querySelector('[data-objection-next]');
    if (!strip) return;

    const desktopMq = window.matchMedia('(min-width: 768px)');
    const cards = Array.from(strip.querySelectorAll('.objection-cards__card'));
    let hasInteracted = false;

    if (cards.length <= 1) {
      if (hint) hint.classList.add('is-hidden');
      if (fade) fade.classList.add('is-hidden');
      return;
    }

    const dots = [];
    if (dotsWrap) {
      cards.forEach((_, index) => {
        const dot = document.createElement('span');
        dot.className = 'objection-cards__dot';

        if (index === 0) {
          dot.classList.add('is-active');
        }

        dotsWrap.appendChild(dot);
        dots.push(dot);
      });
    }

    const getScrollAmount = () => {
      const firstCard = strip.querySelector('.objection-cards__card');
      if (!firstCard) return strip.clientWidth * 0.8;

      const styles = window.getComputedStyle(strip);
      const gap = parseFloat(styles.columnGap || styles.gap) || 0;

      return firstCard.getBoundingClientRect().width + gap;
    };

    const getActiveIndex = () => {
      const step = getScrollAmount();
      if (step <= 0) return 0;

      return Math.min(cards.length - 1, Math.round(strip.scrollLeft / step));
    };
const scrollByAmount = (dir) => {
  strip.scrollBy({
    left: getScrollAmount() * dir,
    behavior: 'smooth'
  });
};

if (prevBtn) {
  prevBtn.addEventListener('click', () => scrollByAmount(-1));
}

if (nextBtn) {
  nextBtn.addEventListener('click', () => scrollByAmount(1));
}

if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  setTimeout(() => {
    strip.scrollBy({ left: 18, behavior: 'smooth' });

    setTimeout(() => {
      strip.scrollBy({ left: -18, behavior: 'smooth' });
    }, 400);
  }, 700);
}
    const updateDots = () => {
      if (!dots.length) return;

      const active = getActiveIndex();

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === active);
      });
    };

    const updateFade = () => {
      if (!fade) return;

      const maxScroll = strip.scrollWidth - strip.clientWidth;
      const atEnd = strip.scrollLeft >= maxScroll - 8;

      fade.classList.toggle('is-hidden', atEnd);
    };

    const updateHint = () => {
      if (!hint) return;

      if (desktopMq.matches) {
        hint.classList.add('is-hidden');
        return;
      }

      const maxScroll = strip.scrollWidth - strip.clientWidth;

      if (maxScroll <= 8 || strip.scrollLeft > 16 || hasInteracted) {
        hint.classList.add('is-hidden');
      } else {
        hint.classList.remove('is-hidden');
      }
    };

    const fadeDots = () => {
      if (dotsWrap) {
        dotsWrap.classList.add('is-faded');
      }
    };

    const hideHintOnInteraction = () => {
      if (desktopMq.matches || hasInteracted) return;

      hasInteracted = true;

      if (hint) {
        hint.classList.add('is-hidden');
      }

      fadeDots();
    };

    strip.addEventListener(
      'scroll',
      () => {
        updateHint();
        updateFade();
        updateDots();
      },
      { passive: true }
    );

    strip.addEventListener('touchstart', hideHintOnInteraction, { passive: true });
    strip.addEventListener('pointerdown', hideHintOnInteraction, { passive: true });

    window.addEventListener('resize', () => {
      updateHint();
      updateFade();
      updateDots();
    });

    updateHint();
    updateFade();
    updateDots();
  })();
</script>

{% schema %}
{
