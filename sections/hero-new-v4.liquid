{% comment %}
  Hero New V4 — matches the desktop + mobile preview layout exactly.
  Buttons reuse the theme's two-row button (dryeNEW-cta-path, loaded via
  dryeNEW-hero.css) but are equal-width side by side on desktop and a
  single full-width button on mobile. Values use base.css tokens.
{% endcomment %}

{{ 'dryeNEW-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign ss = section.settings
  assign scrim = ss.scrim_opacity | default: 82 | divided_by: 100.0
  assign cf_sub = ss.cf_subdomain | default: 'customer-fqpngdzqcoky7qmz'

  assign d_src = ''
  if ss.desktop_media_type == 'video' and ss.desktop_video_id != blank
    assign d_src = ss.desktop_video_id
    unless d_src contains 'http'
      assign d_src = 'https://' | append: cf_sub | append: '.cloudflarestream.com/' | append: d_src | append: '/manifest/video.m3u8'
    endunless
  endif

  assign m_src = ''
  if ss.mobile_media_type == 'video' and ss.mobile_video_id != blank
    assign m_src = ss.mobile_video_id
    unless m_src contains 'http'
      assign m_src = 'https://' | append: cf_sub | append: '.cloudflarestream.com/' | append: m_src | append: '/manifest/video.m3u8'
    endunless
  endif

  assign needs_hls = false
  if d_src != '' or m_src != ''
    assign needs_hls = true
  endif

  assign m_label = ss.cta_mobile_label | default: ss.cta_primary_label
  assign m_text = ss.cta_mobile_text | default: ss.cta_primary_text
  assign m_url = ss.cta_mobile_url | default: ss.cta_primary_url

  assign cred_has = false
  if ss.cred_row_1 != blank or ss.cred_row_2 != blank
    assign cred_has = true
  endif
-%}

{%- capture cred_bar -%}
  <div class="hero-cred">
    {%- if ss.cred_row_1 != blank -%}
      <div class="hero-cred__row">
        {%- assign cred_items_1 = ss.cred_row_1 | split: '|' -%}
        {%- for it in cred_items_1 -%}<span class="hero-cred__item"><i class="hero-cred__dot"></i>{{ it | strip }}</span>{%- endfor -%}
      </div>
    {%- endif -%}
    {%- if ss.cred_row_2 != blank -%}
      <div class="hero-cred__row">
        {%- assign cred_items_2 = ss.cred_row_2 | split: '|' -%}
        {%- for it in cred_items_2 -%}<span class="hero-cred__item"><i class="hero-cred__dot"></i>{{ it | strip }}</span>{%- endfor -%}
      </div>
    {%- endif -%}
  </div>
{%- endcapture -%}

<style>
  /* ============ DESKTOP HERO ============ */
  #shopify-section-{{ section.id }} .drye-hero {
    position: relative;
    overflow: hidden;
    color: #fff;
    min-height: 620px;
    display: flex;
  }
  #shopify-section-{{ section.id }} .drye-hero__media { position: absolute; inset: 0; z-index: 0; }
  #shopify-section-{{ section.id }} .drye-hero__poster {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center;
  }
  #shopify-section-{{ section.id }} .drye-hero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg,
      rgba(10, 22, 33, {{ scrim }}) 0%,
      rgba(10, 22, 33, calc({{ scrim }} * 0.72)) 42%,
      rgba(10, 22, 33, 0) 82%);
  }
  #shopify-section-{{ section.id }} .drye-hero__inner {
    position: relative; z-index: 2; width: 100%;
    max-width: calc(var(--max-width) + (var(--page-pad) * 2));
    margin: 0 auto;
    padding: 72px var(--page-pad);
    display: flex; flex-direction: column;
    align-items: flex-start; justify-content: center;
  }
  #shopify-section-{{ section.id }} .drye-hero__col {
    display: flex; flex-direction: column; gap: var(--space-18);
    max-width: 700px; width: 100%;
  }
  #shopify-section-{{ section.id }} .drye-hero h1 {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: 48px; line-height: 1.04; letter-spacing: -0.02em;
    margin: 0; text-align: left; color: #fff;
  }
  /* Italic in the heading -> Playfair editorial (like the rest of the site) */
  #shopify-section-{{ section.id }} h1 em,
  #shopify-section-{{ section.id }} h1 i {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  #shopify-section-{{ section.id }} .drye-sub {
    font-family: var(--font-body);
    font-size: 15px; font-weight: var(--fw-medium);
    line-height: 1.55; letter-spacing: -0.01em;
    color: var(--white-075); margin: 0; max-width: 34ch;
  }
  #shopify-section-{{ section.id }} .drye-sub strong { color: #fff; font-weight: var(--fw-semibold); }
  #shopify-section-{{ section.id }} .drye-reviews { display: flex; align-items: center; gap: var(--space-10); }
  #shopify-section-{{ section.id }} .drye-reviews__stars { color: #f5b301; font-size: 15px; letter-spacing: 1px; line-height: 1; }
  #shopify-section-{{ section.id }} .drye-reviews__text { font-family: var(--font-body); font-size: var(--fs-caption); color: var(--white-070); }

  /* action cluster shrinks to its widest child (buttons stretch to match) */
  #shopify-section-{{ section.id }} .drye-action {
    display: inline-flex; flex-direction: column; align-items: stretch;
    gap: var(--space-16); align-self: flex-start;
  }
  #shopify-section-{{ section.id }} .drye-action__btns { display: flex; gap: var(--space-12); width: 100%; }
  /* equal width, two-row theme buttons */
  #shopify-section-{{ section.id }} .drye-action__btns .dryeNEW-cta-path {
    flex: 1 1 0; max-width: none; min-height: 0;
  }
  /* Green-dot credibility bar (from the old DRYE NEW Hero) */
  #shopify-section-{{ section.id }} .hero-cred { display: flex; flex-direction: column; gap: var(--space-8); }
  #shopify-section-{{ section.id }} .hero-cred__row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-8) var(--space-18); }
  #shopify-section-{{ section.id }} .hero-cred__item {
    display: inline-flex; align-items: center; gap: var(--space-7);
    font-family: var(--font-body); font-size: var(--fs-micro-3); font-weight: var(--fw-medium);
    letter-spacing: 0.08em; text-transform: uppercase; color: var(--white-050); white-space: nowrap;
  }
  #shopify-section-{{ section.id }} .hero-cred__dot { width: 5px; height: 5px; border-radius: 50%; background: #14b8a6; flex: none; }

  /* ============ MOBILE HERO ============ */
  #shopify-section-{{ section.id }} .m-hero { display: none; }

  @media (max-width: 767px) {
    #shopify-section-{{ section.id }} .drye-hero { display: none; }

    #shopify-section-{{ section.id }} .m-hero {
      position: relative; min-height: 620px; display: flex; flex-direction: column;
      padding: calc(var(--nav-height) + 24px) var(--page-pad) 28px; color: #fff; overflow: hidden;
    }
    #shopify-section-{{ section.id }} .m-hero__poster {
      position: absolute; inset: 0; width: 100%; height: 100%;
      object-fit: cover; object-position: center 20%; z-index: 0;
    }
    #shopify-section-{{ section.id }} .m-hero__overlay {
      content: ""; position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(180deg,
        rgba(10, 22, 33, 0.64) 0%, rgba(10, 22, 33, 0.34) 36%,
        rgba(10, 22, 33, 0.46) 62%, rgba(10, 22, 33, 0.9) 100%);
    }
    #shopify-section-{{ section.id }} .m-hero > *:not(.m-hero__poster):not(.m-hero__overlay) { position: relative; z-index: 2; }

    #shopify-section-{{ section.id }} .m-hero h1 {
      font-family: var(--font-display); font-weight: var(--fw-semibold);
      font-size: 35px; line-height: 1; letter-spacing: -0.03em;
      margin: 20% 0 0; color: #fff; text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
    }
    #shopify-section-{{ section.id }} .m-sub {
      margin-top: auto; font-family: var(--font-body);
      font-size: 15px; font-weight: var(--fw-medium); line-height: 1.55;
      letter-spacing: -0.01em; color: var(--white-075); margin-bottom: 16px; max-width: 34ch;
    }
    #shopify-section-{{ section.id }} .m-sub strong { color: #fff; font-weight: var(--fw-semibold); }

    #shopify-section-{{ section.id }} .m-cta-group { margin-bottom: 18px; }
    #shopify-section-{{ section.id }} .m-cta-group .dryeNEW-cta-path {
      width: 100%; max-width: none; min-height: 0;
    }

    #shopify-section-{{ section.id }} .m-hero .hero-cred { margin-bottom: 22px; gap: var(--space-6); }
    #shopify-section-{{ section.id }} .m-hero .hero-cred__row { gap: var(--space-6) var(--space-12); }
    #shopify-section-{{ section.id }} .m-hero .hero-cred__item { font-size: var(--fs-micro-2); letter-spacing: 0.06em; }
  }
</style>

<section class="hero-new-v4-wrap" data-section-id="{{ section.id }}">

  {%- comment -%} ================= DESKTOP ================= {%- endcomment -%}
  <div class="drye-hero">
    <div class="drye-hero__media">
      {%- if d_src != '' -%}
        <video class="drye-hero__poster" muted loop playsinline autoplay preload="none"
          {%- if ss.desktop_image != blank %} poster="{{ ss.desktop_image | image_url: width: 2200 }}"{% endif %}
          data-hero-hls="{{ d_src | escape }}"></video>
      {%- elsif ss.desktop_image != blank -%}
        {{ ss.desktop_image | image_url: width: 2200 | image_tag: class: 'drye-hero__poster', alt: '', loading: 'eager', fetchpriority: 'high', widths: '768,1200,1600,2200' }}
      {%- endif -%}
      <div class="drye-hero__overlay"></div>
    </div>

    <div class="drye-hero__inner">
      <div class="drye-hero__col">
        {%- if ss.heading_line_1 != blank or ss.heading_line_2 != blank -%}
          <h1>
            {{- ss.heading_line_1 -}}
            {%- if ss.heading_line_2 != blank -%}<br>{{ ss.heading_line_2 }}{%- endif -%}
          </h1>
        {%- endif -%}

        {%- if ss.subheading != blank or ss.subheading_emphasis != blank -%}
          <p class="drye-sub">{{ ss.subheading }}{% if ss.subheading_emphasis != blank %} <strong>{{ ss.subheading_emphasis }}</strong>{% endif %}</p>
        {%- endif -%}

        {%- if ss.star_label != blank -%}
          <div class="drye-reviews">
            <span class="drye-reviews__stars" aria-hidden="true">{%- assign n = ss.star_count | round -%}{%- for i in (1..n) -%}★{%- endfor -%}</span>
            <span class="drye-reviews__text">{{ ss.star_label }}</span>
          </div>
        {%- endif -%}

        <div class="drye-action">
          <div class="drye-action__btns">
            {%- if ss.cta_primary_text != blank -%}
              <a href="{{ ss.cta_primary_url | default: '#' }}" class="dryeNEW-cta-path dryeNEW-cta-path--primary">
                {%- if ss.cta_primary_label != blank -%}<span class="dryeNEW-cta-path__label">{{ ss.cta_primary_label }}</span>{%- endif -%}
                <span class="dryeNEW-cta-path__text"><span class="dryeNEW-cta-path__text-line">{{ ss.cta_primary_text }}</span></span>
              </a>
            {%- endif -%}
            {%- if ss.cta_secondary_text != blank -%}
              <a href="{{ ss.cta_secondary_url | default: '#' }}" class="dryeNEW-cta-path dryeNEW-cta-path--passive">
                {%- if ss.cta_secondary_label != blank -%}<span class="dryeNEW-cta-path__label">{{ ss.cta_secondary_label }}</span>{%- endif -%}
                <span class="dryeNEW-cta-path__text"><span class="dryeNEW-cta-path__text-line">{{ ss.cta_secondary_text }}</span></span>
              </a>
            {%- endif -%}
          </div>

          {%- if cred_has -%}
            {{ cred_bar }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ================= MOBILE ================= {%- endcomment -%}
  <div class="m-hero">
    {%- if m_src != '' -%}
      <video class="m-hero__poster" muted loop playsinline autoplay preload="none"
        {%- if ss.mobile_image != blank %} poster="{{ ss.mobile_image | image_url: width: 1200 }}"{% endif %}
        data-hero-hls="{{ m_src | escape }}"></video>
    {%- elsif ss.mobile_image != blank -%}
      {{ ss.mobile_image | image_url: width: 1200 | image_tag: class: 'm-hero__poster', alt: '', loading: 'eager', fetchpriority: 'high', widths: '480,768,960,1200' }}
    {%- endif -%}
    <div class="m-hero__overlay"></div>

    {%- if ss.heading_line_1 != blank or ss.heading_line_2 != blank -%}
      <h1>{{ ss.heading_line_1 }} {{ ss.heading_line_2 }}</h1>
    {%- endif -%}

    {%- if ss.subheading != blank or ss.subheading_emphasis != blank -%}
      <p class="m-sub">{{ ss.subheading }}{% if ss.subheading_emphasis != blank %} <strong>{{ ss.subheading_emphasis }}</strong>{% endif %}</p>
    {%- endif -%}

    {%- if m_text != blank -%}
      <div class="m-cta-group">
        <a href="{{ m_url | default: '#' }}" class="dryeNEW-cta-path dryeNEW-cta-path--passive">
          {%- if m_label != blank -%}<span class="dryeNEW-cta-path__label">{{ m_label }}</span>{%- endif -%}
          <span class="dryeNEW-cta-path__text"><span class="dryeNEW-cta-path__text-line">{{ m_text }}</span></span>
        </a>
      </div>
    {%- endif -%}

    {%- if cred_has -%}
      {{ cred_bar }}
    {%- endif -%}
  </div>
</section>

{%- if needs_hls -%}
  <script>
    (function () {
      var root = document.querySelector('[data-section-id="{{ section.id }}"]');
      if (!root) return;
      function initHls(video, url) {
        if (video.dataset.hlsReady) return;
        video.dataset.hlsReady = '1';
        var hls = new Hls({ autoStartLoad: true });
        hls.loadSource(url);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, function () {
          var p = video.play(); if (p && p.catch) p.catch(function () {});
        });
      }
      var loading = false;
      function loadLib() {
        if (loading) return; loading = true;
        var s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/hls.js@1';
        s.onload = function () {
          root.querySelectorAll('[data-hero-hls]').forEach(function (v) {
            initHls(v, v.getAttribute('data-hero-hls'));
          });
        };
        document.head.appendChild(s);
      }
      root.querySelectorAll('[data-hero-hls]').forEach(function (video) {
        var url = video.getAttribute('data-hero-hls');
        if (!url) return;
        if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = url;
          var p = video.play(); if (p && p.catch) p.catch(function () {});
        } else if (window.Hls) {
          initHls(video, url);
        } else {
          loadLib();
        }
      });
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Hero New V4",
  "tag": "section",
  "class": "hero-new-v4-section",
  "settings": [
    { "type": "header", "content": "Heading" },
    { "type": "inline_richtext", "id": "heading_line_1", "label": "Heading line 1", "info": "Use the italic button for Playfair editorial style.", "default": "Add one dry layer" },
    { "type": "inline_richtext", "id": "heading_line_2", "label": "Heading line 2", "info": "Use the italic button for Playfair editorial style.", "default": "under your gloves" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "0.4 mm thin. Worn inside your existing glove — nitrile, latex, textile, rubber or HV." },
    { "type": "text", "id": "subheading_emphasis", "label": "Subheading — bold sentence", "info": "Shown bold/white after the subheading.", "default": "What changes is what your skin sits against." },

    { "type": "header", "content": "Reviews" },
    { "type": "range", "id": "star_count", "label": "Star count", "min": 0, "max": 5, "step": 1, "default": 5 },
    { "type": "text", "id": "star_label", "label": "Star label", "default": "Rated 4.8/5 by 1,200+ glove-wearers" },

    { "type": "header", "content": "Primary CTA (solid white — desktop left)" },
    { "type": "text", "id": "cta_primary_label", "label": "Small label", "default": "Order now" },
    { "type": "text", "id": "cta_primary_text", "label": "Button text", "default": "Order one DRYE layer →" },
    { "type": "url", "id": "cta_primary_url", "label": "Link" },

    { "type": "header", "content": "Secondary CTA (ghost — desktop right)" },
    { "type": "text", "id": "cta_secondary_label", "label": "Small label", "default": "The evidence" },
    { "type": "text", "id": "cta_secondary_text", "label": "Button text", "default": "See the proof →" },
    { "type": "url", "id": "cta_secondary_url", "label": "Link" },

    { "type": "header", "content": "Mobile CTA (single button)" },
    { "type": "text", "id": "cta_mobile_label", "label": "Small label", "info": "Falls back to primary.", "default": "Order now" },
    { "type": "text", "id": "cta_mobile_text", "label": "Button text", "info": "Falls back to primary.", "default": "Order DRYE liners here →" },
    { "type": "url", "id": "cta_mobile_url", "label": "Link", "info": "Falls back to primary." },

    { "type": "header", "content": "Credibility bar (green dots)" },
    { "type": "paragraph", "content": "Two rows of dotted items. Separate items with a | (pipe)." },
    { "type": "text", "id": "cred_row_1", "label": "Row 1", "default": "EV workshops | National Guard, Ukraine | 27 US states" },
    { "type": "text", "id": "cred_row_2", "label": "Row 2", "default": "SKAPA Innovation Award, in memory of Alfred Nobel" },

    { "type": "header", "content": "Cloudflare video" },
    { "type": "text", "id": "cf_subdomain", "label": "Cloudflare customer subdomain", "info": "e.g. customer-fqpngdzqcoky7qmz — used to build the .m3u8 URL from a video UID.", "default": "customer-fqpngdzqcoky7qmz" },

    { "type": "header", "content": "Background — Desktop" },
    { "type": "select", "id": "desktop_media_type", "label": "Desktop media type", "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Cloudflare Stream video" } ], "default": "image" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop image", "info": "Also used as the video poster when media type is Video." },
    { "type": "text", "id": "desktop_video_id", "label": "Desktop video — UID or .m3u8 URL", "info": "Paste the Cloudflare Stream video UID, or a full HLS .m3u8 URL." },

    { "type": "header", "content": "Background — Mobile" },
    { "type": "select", "id": "mobile_media_type", "label": "Mobile media type", "options": [ { "value": "image", "label": "Image" }, { "value": "video", "label": "Cloudflare Stream video" } ], "default": "image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile image", "info": "Also used as the video poster when media type is Video." },
    { "type": "text", "id": "mobile_video_id", "label": "Mobile video — UID or .m3u8 URL", "info": "Paste the Cloudflare Stream video UID, or a full HLS .m3u8 URL." },

    { "type": "header", "content": "Appearance" },
    { "type": "range", "id": "scrim_opacity", "label": "Scrim opacity", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 82 }
  ],
  "presets": [ { "name": "Hero New V4" } ]
}
{% endschema %}
