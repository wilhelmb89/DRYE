{{ 'drye-contact-section-1.css' | asset_url | stylesheet_tag }}
{{ 'drye-contact-section-1.css' | asset_url | stylesheet_tag }}
<script src="{{ 'drye-contact-section-tabs.js' | asset_url }}" defer="defer"></script>

<section class="contact-hero">
  <div class="contact-hero-in">
    <span class="micro rev" style="color:rgba(255,255,255,.25);">
      {{ section.settings.eyebrow }}
    </span>

    <h1 class="contact-hero-h rev rd1">
      {{ section.settings.heading }}
      <em>{{ section.settings.heading_emphasis }}</em>
    </h1>

    <p class="contact-hero-sub rev rd2">
      {{ section.settings.subheading }}
    </p>
  </div>
</section>

<div class="track-bar">
  <div class="track-in">
    {% for block in section.blocks %}
      <button
        class="track-btn{% if block.settings.is_active %} active{% elsif section.blocks.size > 0 and forloop.first and active_found != true %} active{% endif %}"
        data-track="{{ block.settings.track_key }}"
        type="button"
      >
        {{ block.settings.label }}
      </button>

      {% if block.settings.is_active %}
        {% assign active_found = true %}
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "DRYE Contact Section 1",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Talk to us directly."
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis",
      "default": "No support bots. No ticket queue."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Three reasons to reach out. Pick yours below."
    }
  ],
  "blocks": [
    {
      "type": "track",
      "name": "Track tab",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Customer / Order"
        },
        {
          "type": "text",
          "id": "track_key",
          "label": "Track key",
          "default": "customer"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Active by default",
          "default": true
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "DRYE Contact Section 1",
      "blocks": [
        {
          "type": "track",
          "settings": {
            "label": "Customer / Order",
            "track_key": "customer",
            "is_active": true
          }
        },
        {
          "type": "track",
          "settings": {
            "label": "B2B / Procurement",
            "track_key": "b2b",
            "is_active": false
          }
        },
        {
          "type": "track",
          "settings": {
            "label": "Share Results",
            "track_key": "results",
            "is_active": false
          }
        }
      ]
    }
  ]
}
{% endschema %}