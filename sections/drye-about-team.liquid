{{ 'section-drye-about-team.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section drye-about-team"
  id="drye-about-team-{{ section.id }}"
  data-section-id="{{ section.id }}" data-drye-section data-section-name="about_team"
>
  <div class="dryeNEW-container">
    <div class="drye-about-team__header dryeNEW-reveal">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro drye-about-team__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="dryeNEW-h2 drye-about-team__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
    </div>

    <div class="drye-about-team__grid dryeNEW-reveal dryeNEW-rd1">
      {% for block in section.blocks %}
        <article class="drye-about-team__card" {{ block.shopify_attributes }}>
          <div class="drye-about-team__image">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'drye-about-team__image-img',
                  alt: block.settings.name,
                  loading: 'lazy',
                  widths: '400,600,800,1000,1200',
                  sizes: '(min-width: 600px) 50vw, 100vw'
              }}
            {% else %}
              <div class="drye-about-team__image-placeholder">
                {% if block.settings.placeholder_label != blank %}
                  {{ block.settings.placeholder_label }}
                {% else %}
                  [ TEAM PHOTO ]
                {% endif %}
              </div>
            {% endif %}
          </div>

          <div class="drye-about-team__body">
            {% if block.settings.name != blank %}
              <div class="dryeNEW-h3 drye-about-team__name">
                {{ block.settings.name }}
              </div>
            {% endif %}

            {% if block.settings.role != blank %}
              <div class="dryeNEW-micro drye-about-team__role">
                {{ block.settings.role }}
              </div>
            {% endif %}

            {% if block.settings.bio != blank %}
              <div class="dryeNEW-body--caption drye-about-team__bio">
                <p>{{ block.settings.bio }}</p>
              </div>
            {% endif %}

            {% if block.settings.linkedin_label != blank or block.settings.email != blank %}
              <div class="drye-about-team__links">
                {% if block.settings.linkedin_label != blank %}
                  <a
                    href="{{ block.settings.linkedin_url | default: '#' }}"
                    class="dryeNEW-link drye-about-team__link"
                  >
                    {{ block.settings.linkedin_label }}
                  </a>
                {% endif %}

                {% if block.settings.email != blank %}
                  <a
                    href="mailto:{{ block.settings.email }}"
                    class="dryeNEW-link drye-about-team__link"
                  >
                    {{ block.settings.email }}
                  </a>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE About Team",
  "tag": "section",
  "class": "section-drye-about-team",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The people behind it"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One founder lived with the skin damage. The other spent years causing it."
    }
  ],
  "blocks": [
    {
      "type": "person",
      "name": "Person",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "placeholder_label",
          "label": "Placeholder label",
          "default": "[ WILHELM PHOTO ]"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Wilhelm Bäckström"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "default": "Founder & CEO"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Bio",
          "default": "Has lived with atopic eczema. The personal frustration with reactive solutions — creams, steroids, short-term relief — became the founding premise: change the environment, not the treatment protocol."
        },
        {
          "type": "text",
          "id": "linkedin_label",
          "label": "LinkedIn label",
          "default": "LinkedIn"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn URL"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email",
          "default": "wilhelm@drye.se"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DRYE About Team",
      "blocks": [
        {
          "type": "person",
          "settings": {
            "placeholder_label": "[ WILHELM PHOTO ]",
            "name": "Wilhelm Bäckström",
            "role": "Founder & CEO",
            "bio": "Has lived with atopic eczema. The personal frustration with reactive solutions — creams, steroids, short-term relief — became the founding premise: change the environment, not the treatment protocol.",
            "linkedin_label": "LinkedIn",
            "email": "wilhelm@drye.se"
          }
        },
        {
          "type": "person",
          "settings": {
            "placeholder_label": "[ ANDREW PHOTO ]",
            "name": "Andrew Brathwaite",
            "role": "Co-Founder — EV Engineer",
            "bio": "EV engineer by trade — Tesla, CAKE, Fisker. Spent years working in environments where sealed gloves and sweat are an occupational constant. Understood the problem from a different angle than Wilhelm, and brought the engineering rigour to take the validated mechanism from institution to product.",
            "linkedin_label": "LinkedIn",
            "email": "andrew@drye.se"
          }
        }
      ]
    }
  ]
}
{% endschema %}