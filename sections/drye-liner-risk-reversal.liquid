{{ 'drye-liner-risk-reversal.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section drye-liner-risk-reversal" id="{{ section.settings.section_id | default: 'liner-risk' }}" data-section-id="{{ section.id }}" data-drye-section data-section-name="risk_reversal" data-section-type="drye-liner-risk-reversal">
  <div class="dryeNEW-container drye-liner-risk-reversal__inner">
    <div class="drye-liner-risk-reversal__wrap">
      {%- if section.settings.days_number != blank -%}
        <div class="drye-liner-risk-reversal__badge">
          <span class="drye-liner-risk-reversal__num">{{ section.settings.days_number }}</span>
          {%- if section.settings.days_word != blank -%}
            <span class="drye-liner-risk-reversal__word">{{ section.settings.days_word }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="drye-liner-risk-reversal__copy">
        {%- if section.settings.heading != blank -%}
          <h3>{{ section.settings.heading }}</h3>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <p>{{ section.settings.body }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="drye-liner-risk-reversal__cta-wrap">
        <a class="dryeNEW-button drye-liner-risk-reversal__cta" href="{{ section.settings.cta_url | default: '#' }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

    {%- if section.settings.guarantee_text != blank -%}
      <p class="drye-liner-risk-reversal__guarantee">{{ section.settings.guarantee_text }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DRYE Liner Risk Reversal",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "liner-risk"
    },
    {
      "type": "text",
      "id": "days_number",
      "label": "Days number",
      "default": "30"
    },
    {
      "type": "text",
      "id": "days_word",
      "label": "Days word",
      "default": "Days"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Try it risk-free."
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body",
      "default": "If DRYE Liner doesn't change your shift, full refund. No hassle."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Get DRYE Liner"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee microcopy",
      "default": "30-Day Money Back Guarantee"
    }
  ],
  "presets": [
    {
      "name": "DRYE Liner Risk Reversal"
    }
  ]
}
{% endschema %}
