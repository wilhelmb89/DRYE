{{ 'section-drye-about-cta.css' | asset_url | stylesheet_tag }}

<section class="drye-about-cta" id="drye-about-cta-{{ section.id }}" data-drye-section data-section-name="mid_cta">
    {% if section.settings.eyebrow != blank %}
      <span class="drye-about-cta__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading_line_1 != blank or section.settings.heading_line_2 != blank %}
      <h2 class="drye-about-cta__heading">
        {{ section.settings.heading_line_1 }}
        {% if section.settings.heading_line_2 != blank %}
          <em>{{ section.settings.heading_line_2 }}</em>
        {% endif %}
      </h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="drye-about-cta__sub">{{ section.settings.subtext }}</p>
    {% endif %}

    <div class="drye-about-cta__actions">
      {% if section.settings.primary_label != blank %}
        <a
          href="{{ section.settings.primary_url | default: '#' }}"
          class="drye-about-cta__btn drye-about-cta__btn--primary"
        >
          {{ section.settings.primary_label }}
        </a>
      {% endif %}

      {% if section.settings.secondary_label != blank %}
        <a
          href="{{ section.settings.secondary_url | default: '#' }}"
          class="drye-about-cta__btn drye-about-cta__btn--secondary"
        >
          {{ section.settings.secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE About CTA",
  "tag": "section",
  "class": "section-drye-about-cta",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "You've seen where it comes from."
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Heading line 1",
      "default": "Now see if it works"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Heading italic line",
      "default": " for your shift."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "30 days. Full refund if the physics don't change anything. No forms. No questions."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Order DRYE Liners →"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "See the Research"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    }
  ],
  "presets": [
    {
      "name": "DRYE About CTA"
    }
  ]
}
{% endschema %}