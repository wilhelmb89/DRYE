<script>
  (() => {
    const sectionEl = document.querySelector('[data-section-id="{{ section.id }}"][data-product-section]');
    if (!sectionEl || sectionEl.dataset.dryePdpBound === 'true') return;
    sectionEl.dataset.dryePdpBound = 'true';

    const productJsonEl = sectionEl.querySelector('[data-product-json]');
    if (!productJsonEl) return;

    const productData = JSON.parse(productJsonEl.textContent);
    const form = sectionEl.querySelector('[data-product-form]');
    const variantIdInput = form ? form.querySelector('[data-variant-id]') : null;
    const priceEl = sectionEl.querySelector('[data-price]');
    const stickyPriceEl = document.querySelector('[data-sticky-price]');
    const mainAtc = sectionEl.querySelector('[data-main-atc]');
    const stickySubmit = sectionEl.querySelector('[data-sticky-submit]');
    const qtyInput = sectionEl.querySelector('.qty-val');
    const qtyMinus = sectionEl.querySelector('[data-qty-minus]');
    const qtyPlus = sectionEl.querySelector('[data-qty-plus]');

    // ── Live price (unit × quantity) + cost-per-month timeline ──
    const cpmWrap = sectionEl.querySelector('[data-cpm]');
    const cpmRows = cpmWrap ? Array.from(cpmWrap.querySelectorAll('[data-cpm-price]')) : [];
    const moneySampleEl = sectionEl.querySelector('[data-money-sample]');

    function parseMoneyParts(str) {
      if (!str) return null;
      const first = str.search(/\d/);
      if (first === -1) return null;
      let last = first;
      for (let i = str.length - 1; i >= 0; i--) { if (/\d/.test(str.charAt(i))) { last = i; break; } }
      const prefix = str.slice(0, first);
      const suffix = str.slice(last + 1);
      const numStr = str.slice(first, last + 1);
      const hasDot = numStr.indexOf('.') !== -1;
      const hasComma = numStr.indexOf(',') !== -1;
      let decSep = '', grpSep = '';
      if (hasDot && hasComma) {
        decSep = numStr.lastIndexOf('.') > numStr.lastIndexOf(',') ? '.' : ',';
        grpSep = decSep === '.' ? ',' : '.';
      } else if (hasDot || hasComma) {
        const sep = hasDot ? '.' : ',';
        const afterLen = numStr.length - numStr.lastIndexOf(sep) - 1;
        const count = numStr.split(sep).length - 1;
        if (count === 1 && afterLen >= 1 && afterLen <= 2) { decSep = sep; grpSep = sep === '.' ? ',' : '.'; }
        else { grpSep = sep; decSep = sep === '.' ? ',' : '.'; }
      }
      let dec = 0;
      if (decSep) {
        const afterLen = numStr.length - numStr.lastIndexOf(decSep) - 1;
        if (afterLen >= 1 && afterLen <= 2) { dec = afterLen; } else { grpSep = grpSep || decSep; decSep = ''; }
      }
      var wsMatch = numStr.match(/\d(\s)\d/);
      if (wsMatch) grpSep = wsMatch[1];
      let clean = numStr.replace(/[\s ]/g, '');
      if (grpSep) clean = clean.split(grpSep).join('');
      if (decSep) clean = clean.replace(decSep, '.');
      const value = parseFloat(clean);
      if (isNaN(value)) return null;
      return { prefix: prefix, suffix: suffix, value: value, dec: dec, decSep: decSep || '.', grpSep: grpSep || ',' };
    }

    function formatMoneyTpl(value, tpl, decOverride) {
      const d = (decOverride == null) ? tpl.dec : decOverride;
      const factor = Math.pow(10, d);
      const fixed = (Math.round(value * factor) / factor).toFixed(d);
      const parts = fixed.split('.');
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, tpl.grpSep);
      const num = (d > 0 && parts[1] != null) ? parts[0] + tpl.decSep + parts[1] : parts[0];
      return tpl.prefix + num + tpl.suffix;
    }

    // Market-correct format template from Shopify's own money output; base unit amount from the rendered price.
    const cpmMoneyTpl = parseMoneyParts(moneySampleEl ? moneySampleEl.textContent : (priceEl ? priceEl.textContent : ''));
    const cpmBaseUnit = priceEl ? parseMoneyParts(priceEl.textContent) : null;
    const cpmBaseAmount = cpmBaseUnit ? cpmBaseUnit.value : null;
    const cpmInitCents = (productData.selected_or_first_available_variant && productData.selected_or_first_available_variant.price)
      || (productData.variants && productData.variants[0] && productData.variants[0].price) || 0;

    function renderPriceCPM() {
      if (!priceEl || !cpmMoneyTpl || cpmBaseAmount == null) return;
      const qty = Math.max(1, Math.min(10, parseInt(qtyInput && qtyInput.value, 10) || 1));
      const variant = (typeof getVariantFromOptions === 'function' && getVariantFromOptions())
        || productData.selected_or_first_available_variant;
      let unit = cpmBaseAmount;
      if (variant && variant.price && cpmInitCents) unit = cpmBaseAmount * (Number(variant.price) / Number(cpmInitCents));
      const total = unit * qty;
      const totalStr = formatMoneyTpl(total, cpmMoneyTpl);
      priceEl.textContent = totalStr;
      if (stickyPriceEl) stickyPriceEl.textContent = totalStr;
      if (cpmWrap && cpmRows.length) {
        cpmRows.forEach(function (el) {
          const months = parseInt(el.getAttribute('data-cpm-price'), 10) || 1;
          el.textContent = formatMoneyTpl(total / months, cpmMoneyTpl, 0);
        });
        cpmWrap.hidden = false;
      }
    }

    const sizeTrigger = sectionEl.querySelector('[data-size-trigger]');
    const sizeList = sectionEl.querySelector('[data-size-list]');
    const sizeLabel = sectionEl.querySelector('[data-size-label]');
    const sizeOptions = Array.from(sectionEl.querySelectorAll('[data-size-option]'));
    const panelEl = sectionEl.querySelector('[data-size-panel]');
    const tabButtons = Array.from(sectionEl.querySelectorAll('[data-drye-tabs] .tab-btn'));
const faqButtons = Array.from(sectionEl.querySelectorAll('[data-drye-tabs] .faq-q'));
const reviewScrollRows = Array.from(sectionEl.querySelectorAll('[data-review-scroll]'));

function scrollToReviews(event) {
  const targetSelector = {{ review_anchor | json }};
  const target =
    document.querySelector(targetSelector) ||
    document.querySelector('.jdgm-review-widget') ||
    document.querySelector('.jdgm-rev-widg');

  if (!target) {
    window.location.hash = targetSelector.replace('#', '');
    return;
  }

  event.preventDefault();

  target.scrollIntoView({
    behavior: 'smooth',
    block: 'start'
  });

  history.replaceState(null, '', targetSelector);
}

reviewScrollRows.forEach((row) => {
  row.addEventListener('click', scrollToReviews);

  row.addEventListener('keydown', (event) => {
    if (event.key === 'Enter' || event.key === ' ') {
      scrollToReviews(event);
    }
  });
});

const shopifyRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

    let currentOptions = (productData.selected_or_first_available_variant && productData.selected_or_first_available_variant.options)
      ? [...productData.selected_or_first_available_variant.options]
      : (productData.variants[0] ? [...productData.variants[0].options] : []);

    // Trigger shows "Choose your size" until the shopper actually picks one.
    // currentOptions still holds a real variant under the hood, so price / ATC /
    // cart-drawer / market coupling all stay intact — only the visible label waits.
    let userHasPickedSize = false;

    function isVariantPreorder(variant) {
      if (!variant) return false;
      return variant.inventory_policy === 'continue' && Number(variant.inventory_quantity) <= 0;
    }

    function syncButtonStates(selectedVariant) {
      const canBuy = !!(selectedVariant && (selectedVariant.available || isVariantPreorder(selectedVariant)));

      if (mainAtc) {
        mainAtc.disabled = !canBuy;
        mainAtc.textContent = canBuy ? {{ atc_button_label | json }} : 'Sold out';
      }

      if (stickySubmit) {
        stickySubmit.disabled = !canBuy;
        stickySubmit.textContent = canBuy ? {{ sticky_button_label | json }} : 'Sold out';
      }
    }


    function syncSizeUI() {
      if (!sizeOptions.length || !sizeLabel || !sizeTrigger) return;

      sizeOptions.forEach((option) => {
        const position = Number(option.dataset.optionPosition) - 1;
        const isSelected = currentOptions[position] === option.dataset.optionValue;
        const showSelected = isSelected && userHasPickedSize;

        option.classList.toggle('selected', showSelected);
        option.setAttribute('aria-selected', showSelected ? 'true' : 'false');

        if (showSelected) {
          sizeLabel.textContent = option.dataset.optionValue;
          sizeTrigger.classList.add('has-val');
        }
      });
    }

    function closeSizeDropdown() {
      if (!sizeTrigger || !sizeList) return;

      sizeTrigger.classList.remove('open');
      sizeList.classList.remove('open');
      sizeTrigger.setAttribute('aria-expanded', 'false');
    }
    sectionEl.querySelectorAll('.js-open-size-guide').forEach((button) => {
  button.addEventListener('click', () => {
    closeSizeDropdown();
  });
});

    function getVariantFromOptions() {
      return productData.variants.find((variant) => {
        return variant.options.every((option, index) => option === currentOptions[index]);
      }) || null;
    }

    function pushViewItem(selectedVariant) {
      if (!selectedVariant) return;

      const eventKey = `view_item:${productData.id}:${selectedVariant.id}`;
      window.DRYETrackedEvents = window.DRYETrackedEvents || {};

      if (window.DRYETrackedEvents[eventKey]) return;
      window.DRYETrackedEvents[eventKey] = true;

      fetch(shopifyRoot + 'variants/' + selectedVariant.id + '.js', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' }
      })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (variant) {
          if (!variant) return;

          const presentmentValue = Number(variant.price) / 100;

          return fetch(shopifyRoot + 'cart.js', {
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
          })
            .then(function (res) { return res.ok ? res.json() : null; })
            .then(function (cart) {
              const currency = (cart && cart.currency) || 'SEK';

              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'view_item',
                event_source: 'drye_pdp_hero',
                ecommerce: {
                  currency: currency,
                  value: presentmentValue,
                  items: [{
                    item_id: String(selectedVariant.sku || selectedVariant.id),
                    item_name: productData.title,
                    item_brand: 'DRYE',
                    item_variant: selectedVariant.title,
                    price: presentmentValue,
                    quantity: 1
                  }]
                }
              });
            });
        })
        .catch(function (err) {
          console.warn('[DRYE PDP] view_item tracking skipped', err);
        });
    }

    function pushAddToCart(selectedVariant, quantity) {
      if (!selectedVariant) return;

      const qty = Number(quantity || 1);

      fetch(shopifyRoot + 'variants/' + selectedVariant.id + '.js', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' }
      })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (variant) {
          if (!variant) return;

          const unitPrice = Number(variant.price) / 100;

          return fetch(shopifyRoot + 'cart.js', {
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
          })
            .then(function (res) { return res.ok ? res.json() : null; })
            .then(function (cart) {
              const currency = (cart && cart.currency) || 'SEK';

              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'add_to_cart',
                event_source: 'drye_pdp_hero',
                ecommerce: {
                  currency: currency,
                  value: unitPrice * qty,
                  items: [{
                    item_id: String(selectedVariant.sku || selectedVariant.id),
                    item_name: productData.title,
                    item_brand: 'DRYE',
                    item_variant: selectedVariant.title,
                    price: unitPrice,
                    quantity: qty
                  }]
                }
              });
            });
        })
        .catch(function (err) {
          console.warn('[DRYE PDP] add_to_cart tracking skipped', err);
        });
    }

function updateVariant(pushEvent = false) {
      const selectedVariant = getVariantFromOptions();

      syncSizeUI();
      syncButtonStates(selectedVariant);

      if (selectedVariant) {
        // Uppdatera variant-ID i form:en så rätt variant läggs i cart
        if (variantIdInput) variantIdInput.value = selectedVariant.id;

if (pushEvent && !(window.Shopify && window.Shopify.designMode)) {
  pushViewItem(selectedVariant);
}
      }

      renderPriceCPM();
    }

    // ── Sold-out & Preorder size panel ──
    const PREORDER_MAIN_LABEL = {{ section.settings.preorder_main_atc_label | default: 'Preorder below ↓' | json }};

    const PANEL_CFG = {
      lowStockThreshold : {{ section.settings.low_stock_threshold | default: 10 }},
      shippingDate      : {{ section.settings.shipping_date | default: 'TBD' | json }},
      shippingMonth     : {{ section.settings.shipping_month | default: 'TBD' | json }},
      cutoffDate        : {{ section.settings.cutoff_date | default: 'TBD' | json }},
      regularPrice      : parseFloat(({{ product.price | money_without_currency | json }}).replace(/[^0-9.]/g, '')) || 0,
      currency          : {{ cart.currency.iso_code | json }},
      discountCode      : {{ section.settings.preorder_discount_code | default: 'PREORDER15' | json }},
      discountPercent   : {{ section.settings.preorder_discount_percent | default: 15 }},
      cutoffText        : {{ section.settings.preorder_cutoff_text | default: 'Your 15% preorder discount is applied automatically at checkout.' | json }}
    };

    const pushDL = (eventName, data) => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(Object.assign({ event: eventName, event_source: 'drye_pdp_hero' }, data));
    };

    let currentPanelVariant = null;

    const openPanel = (opt) => {
      if (!panelEl) return;
      const size = opt.dataset.optionValue;
      const variantId = opt.dataset.variantId || '';
      const policy = opt.dataset.policy || 'deny';
      const qty = parseInt(opt.dataset.qty || '0', 10);
      const isPreorder = policy === 'continue' && qty <= 0;
      currentPanelVariant = { size, variantId };

      const preorderBlock = panelEl.querySelector('[data-panel-preorder]');
      const divider = panelEl.querySelector('[data-panel-divider]');
      const notifyBlock = panelEl.querySelector('[data-panel-notify]');

      if (preorderBlock) {
        preorderBlock.hidden = !isPreorder;
        if (isPreorder) {
          const headingEl = preorderBlock.querySelector('[data-panel-preorder-heading]');
          const shipsEl = preorderBlock.querySelector('[data-panel-ships-badge]');
          const origEl = preorderBlock.querySelector('[data-panel-price-orig]');
          const saleEl = preorderBlock.querySelector('[data-panel-price-sale]');
          const discEl = preorderBlock.querySelector('[data-panel-discount]');
          const priceRow = preorderBlock.querySelector('.sz-panel-price-row');
          const cutoffEl = preorderBlock.querySelector('[data-panel-cutoff]');
          const btnEl = preorderBlock.querySelector('[data-panel-preorder-btn]');

          const pct = PANEL_CFG.discountPercent;
          if (headingEl) headingEl.textContent = 'Reserve your ' + size + ' now';
          if (shipsEl) shipsEl.textContent = 'Ships ' + PANEL_CFG.shippingDate;
          // Show only the discount chip (no struck/sale price). The real discount
          // is applied by the code at cart time; this just advertises it.
          if (origEl) origEl.textContent = '';
          if (saleEl) saleEl.textContent = '';
          if (discEl) discEl.textContent = pct + '% OFF';
          if (priceRow) priceRow.hidden = !(pct > 0);
          if (cutoffEl) cutoffEl.textContent = String(PANEL_CFG.cutoffText)
            .replace(/\{date\}/g, PANEL_CFG.shippingDate)
            .replace(/\{cutoff\}/g, PANEL_CFG.cutoffDate)
            .replace(/\{percent\}/g, pct)
            .replace(/\{month\}/g, PANEL_CFG.shippingMonth);
          if (btnEl) {
            btnEl.textContent = pct > 0
              ? 'PREORDER — ' + pct + '% OFF'
              : 'PREORDER — SHIPS ' + String(PANEL_CFG.shippingDate).toUpperCase();
            btnEl.disabled = false;
            btnEl.style.background = '';
          }
        }
      }

      if (divider) divider.hidden = !isPreorder;

      if (notifyBlock) {
        const notifyHeadingEl = notifyBlock.querySelector('[data-panel-notify-heading]');
        if (notifyHeadingEl) notifyHeadingEl.textContent =
          'Not ready to wait? Get an email the second ' + size + ' is back.';
        const formEl = notifyBlock.querySelector('[data-notify-form]');
        const emailEl = notifyBlock.querySelector('[data-notify-email]');
        const errEl = notifyBlock.querySelector('[data-notify-err]');
        const successEl = notifyBlock.querySelector('[data-notify-success]');
        if (formEl) formEl.hidden = false;
        if (emailEl) emailEl.value = '';
        if (errEl) errEl.hidden = true;
        if (successEl) successEl.hidden = true;
      }

      panelEl.hidden = false;
    };

    const closePanel = () => {
      if (panelEl) panelEl.hidden = true;
      currentPanelVariant = null;
    };

    if (sizeTrigger && sizeList) {
      sizeTrigger.addEventListener('click', (event) => {
        event.stopPropagation();
        const isOpen = sizeTrigger.classList.toggle('open');
        sizeList.classList.toggle('open', isOpen);
        sizeTrigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      sizeOptions.forEach((option) => {
        option.addEventListener('click', (event) => {
          event.stopPropagation();

          const position = Number(option.dataset.optionPosition) - 1;
          const value = option.dataset.optionValue;
          const variantId = option.dataset.variantId || '';
          const policy = option.dataset.policy || 'deny';
          const qty = parseInt(option.dataset.qty || '0', 10);
          const isPreorder = policy === 'continue' && qty <= 0;
          const isSoldOut = option.dataset.available === 'false' && policy === 'deny';

          currentOptions[position] = value;
          userHasPickedSize = true;
          closeSizeDropdown();
          updateVariant(true);

          if (isSoldOut) {
            pushDL('size_soldout_click', { size: value, variant_id: variantId });
            openPanel(option);
          } else if (isPreorder) {
            pushDL('size_soldout_click', { size: value, variant_id: variantId });
            openPanel(option);
            // Preorder is bought ONLY via the panel button (single path + discount),
            // so force the main ATC + sticky submit disabled.
            if (mainAtc) {
              mainAtc.disabled = true;
              mainAtc.textContent = PREORDER_MAIN_LABEL;
            }
            if (stickySubmit) {
              stickySubmit.disabled = true;
              stickySubmit.textContent = PREORDER_MAIN_LABEL;
            }
          } else {
            closePanel();
          }
        });
      });

      document.addEventListener('click', (event) => {
        if (!event.target.closest('[data-size-dropdown]') && !event.target.closest('[data-size-panel]')) {
          closeSizeDropdown();
        }
      });
    }

    // Panel interactions
    if (panelEl) {
      const preorderBtn = panelEl.querySelector('[data-panel-preorder-btn]');

      const keepPreorderMainDisabled = () => {
        if (mainAtc) { mainAtc.disabled = true; mainAtc.textContent = PREORDER_MAIN_LABEL; }
        if (stickySubmit) { stickySubmit.disabled = true; stickySubmit.textContent = PREORDER_MAIN_LABEL; }
      };

      const applyDiscountCode = () =>
        fetch('/discount/' + encodeURIComponent(PANEL_CFG.discountCode), { credentials: 'same-origin' })
          .then(() => {})
          .catch(() => {});

      const getCartDiscount = () =>
        fetch(shopifyRoot + 'cart.js', { credentials: 'same-origin', headers: { Accept: 'application/json' } })
          .then((r) => (r.ok ? r.json() : null))
          .then((c) => (c ? (Number(c.original_total_price) - Number(c.total_price)) : 0))
          .catch(() => 0);

      if (preorderBtn) {
        preorderBtn.addEventListener('click', async () => {
          if (!currentPanelVariant || preorderBtn.disabled) return;
          const { size, variantId } = currentPanelVariant;
          const origText = preorderBtn.textContent;

          pushDL('preorder_add_to_cart', { size, variant_id: variantId, currency: PANEL_CFG.currency });

          preorderBtn.disabled = true;
          preorderBtn.textContent = 'Adding…';

          try {
            // 1) Apply the preorder discount code first (sets the cart-level discount).
            await applyDiscountCode();

            // 2) Add the preorder variant directly so the Preorder line-item property
            //    actually persists (the drawer's own add path forwards only id + quantity).
            await fetch(shopifyRoot + 'cart/add.js', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
              body: JSON.stringify({
                id: variantId,
                quantity: 1,
                properties: { Preorder: 'Ships ' + PANEL_CFG.shippingDate }
              })
            });

            // 3) Confirm the discount actually landed; if not, re-apply once and re-check.
            let discount = await getCartDiscount();
            if (discount <= 0) {
              await applyDiscountCode();
              discount = await getCartDiscount();
            }

            // 4) Open + refresh the drawer so it shows the discounted cart.
            if (window.DRYE_CartDrawer && typeof window.DRYE_CartDrawer.refresh === 'function') {
              window.DRYE_CartDrawer.refresh(true);
            } else if (window.DRYE_CartDrawer && typeof window.DRYE_CartDrawer.open === 'function') {
              window.DRYE_CartDrawer.open();
            }

            keepPreorderMainDisabled();

            preorderBtn.textContent = 'Added ✓';
            preorderBtn.style.background = '#0a6960';
            setTimeout(() => {
              preorderBtn.textContent = origText;
              preorderBtn.style.background = '';
              preorderBtn.disabled = false;
            }, 3000);
          } catch (err) {
            preorderBtn.textContent = origText;
            preorderBtn.disabled = false;
          }
        });
      }

      // The email input lives inside the product form; stop Enter from submitting it.
      const notifyEmailInput = panelEl.querySelector('[data-notify-email]');
      if (notifyEmailInput) {
        notifyEmailInput.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            event.preventDefault();
            const submitBtn = panelEl.querySelector('[data-notify-submit]');
            if (submitBtn) submitBtn.click();
          }
        });
      }

      // Notify me — email capture
      panelEl.addEventListener('click', (event) => {
        if (!event.target.closest('[data-notify-submit]')) return;
        if (!currentPanelVariant) return;
        const emailEl = panelEl.querySelector('[data-notify-email]');
        const errEl = panelEl.querySelector('[data-notify-err]');
        const formEl = panelEl.querySelector('[data-notify-form]');
        const successEl = panelEl.querySelector('[data-notify-success]');
        const email = emailEl ? emailEl.value.trim() : '';
        const valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        if (!valid) { if (errEl) errEl.hidden = false; return; }
        if (errEl) errEl.hidden = true;
        const { size, variantId } = currentPanelVariant;

        const kl = window.klaviyo || window._learnq;
        if (kl) {
          kl.push(['identify', { '$email': email }]);
          kl.push(['track', 'Back in Stock Requested', {
            product: {{ product.title | json }}, variant_id: variantId, size
          }]);
        } else {
          const fd = new FormData();
          fd.append('form_type', 'customer');
          fd.append('utf8', '✓');
          fd.append('contact[email]', email);
          fd.append('contact[tags]', 'backinstock-' + size);
          fetch('/contact#contact_form', { method: 'POST', body: fd }).catch(() => {});
        }
        pushDL('notify_me_submit', { size, variant_id: variantId });
        if (formEl) formEl.hidden = true;
        if (successEl) successEl.hidden = false;
      });
    }

    function setQty(nextValue) {
      if (!qtyInput) return;
      const safeValue = Math.max(1, Math.min(10, Number(nextValue) || 1));
      qtyInput.value = safeValue;
      renderPriceCPM();
    }

    if (qtyMinus) {
      qtyMinus.addEventListener('click', () => {
        setQty((parseInt(qtyInput.value, 10) || 1) - 1);
      });
    }

    if (qtyPlus) {
      qtyPlus.addEventListener('click', () => {
        setQty((parseInt(qtyInput.value, 10) || 1) + 1);
      });
    }

    if (stickySubmit && form) {
      stickySubmit.addEventListener('click', () => {
        form.requestSubmit();
      });
    }


tabButtons.forEach((btn) => {
  btn.addEventListener('click', () => {
    const tabId = btn.dataset.tab;
    const tabs = btn.closest('[data-drye-tabs]');
    if (!tabs) return;

    tabs.querySelectorAll('.tab-btn').forEach((button) => {
      const isActive = button === btn;
      button.classList.toggle('active', isActive);
      button.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });

    tabs.querySelectorAll('.tab-panel').forEach((panel) => {
      panel.classList.toggle('active', panel.dataset.panel === tabId);
    });
  });
});

faqButtons.forEach((button) => {
  button.addEventListener('click', () => {
    const item = button.closest('.faq-item');
    if (!item) return;
    item.classList.toggle('open');

    // DRYE tracking — faq_open
const allItems = Array.from(item.parentNode.querySelectorAll('.faq-item'));
const faqIndex = allItems.indexOf(item) + 1;
window.dataLayer = window.dataLayer || [];
setTimeout(function() {
  window.dataLayer.push({ event: 'faq_open', faq_index: faqIndex });
}, 0);
  });
});
const wteTimelines = Array.from(sectionEl.querySelectorAll('[data-hero-wte-timeline]'));

wteTimelines.forEach((timeline) => {
  const stops = Array.from(timeline.querySelectorAll('.hero-wte-stop'));

  stops.forEach((stop) => {
    const trigger = stop.querySelector('.hero-wte-trigger');
    if (!trigger) return;

    trigger.addEventListener('click', () => {
      const isOpen = stop.classList.contains('is-open');

      stops.forEach((item) => {
        item.classList.remove('is-open');

        const itemTrigger = item.querySelector('.hero-wte-trigger');
        if (itemTrigger) {
          itemTrigger.setAttribute('aria-expanded', 'false');
        }
      });

      if (!isOpen) {
        stop.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
});
    const isThemeEditor = window.Shopify && window.Shopify.designMode;

    updateVariant();

    const initialVariant = getVariantFromOptions();

    if (!isThemeEditor && initialVariant) {
      pushViewItem(initialVariant);
    }
  })();
</script>


