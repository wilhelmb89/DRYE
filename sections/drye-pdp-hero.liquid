    {
      "name": "DRYE PDP Hero",
      "blocks": [
        {
          "type": "description"
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do they work with nitrile/latex/vinyl gloves?",
            "answer": "Yes — this is the primary use case. 0.4mm thin, designed to layer inside sealed gloves without affecting fit. Works with nitrile, latex, vinyl, rubber, hockey gloves, ski gloves, and work gloves."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do I wear this under or instead of gloves?",
            "answer": "Under. DRYE is a liner — put it on first, then your gloves over them. It works inside any sealed glove."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Do they make my gloves tighter or uncomfortable?",
            "answer": "At 0.4mm, the liner adds less bulk than a standard glove lining. 9/9 workers in the automotive field study reported zero dexterity compromise. Grip is typically maintained or improved."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What makes these better than cotton or silk liners?",
            "answer": "It's not comparable — they work on completely different principles. Cotton, bamboo, and silk absorb moisture. Under pressure, they collapse and trap it against your skin. DRYE doesn't absorb. It routes moisture through the fiber via a structural gradient. No saturation point."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will this help heal my eczema or just protect it?",
            "answer": "Both — but the mechanism is protection, not treatment. By removing the wet environment that causes continuous re-irritation, the skin recovers on its own schedule. It removes the condition that prevents healing."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I use them overnight with cream?",
            "answer": "Yes. Many users combine overnight cream with DRYE as a liner under cotton gloves. The cream is not displaced — DRYE routes moisture only, not cream or oil."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How does it actually help my skin?",
            "answer": "Sealed gloves trap sweat against skin. pH rises, the skin barrier breaks down, bacteria multiply. DRYE keeps the skin surface dry — the barrier stays intact and the skin can recover."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will these make my hands too warm or tight?",
            "answer": "No. The moisture transport keeps the microclimate drier, which typically feels cooler — not warmer. At 0.4mm there is no meaningful compression or tightness."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long does a pair last, and how do I wash it?",
            "answer": "Machine wash cold, air dry. 4–12 months depending on frequency. Performance is structural — no coatings or chemical treatments to wash out."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Shipping, Customs & Delivery",
            "answer": "Ships within 24 hours from Sweden. USA, Canada, UK delivery: 5–9 business days. Import duties may apply depending on destination."
          }
        }
      ]
    }
  ]
