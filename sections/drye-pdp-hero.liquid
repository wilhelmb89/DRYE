{% liquid
  assign current_product = product
  assign selected_variant = current_product.selected_or_first_available_variant
assign review_rating = section.settings.review_rating_fallback
assign review_count = section.settings.review_count_fallback
  assign review_anchor = '#reviews'
  assign price_note = section.settings.price_note
  assign sticky_button_label = section.settings.sticky_button_label
  assign atc_button_label = section.settings.atc_button_label
  assign preorder_note = ''
  assign in_stock_note = 'In stock'
%}

{{ 'drye-pdp-hero.css' | asset_url | stylesheet_tag }}
{{ 'drye-review-slider.css' | asset_url | stylesheet_tag }}
{{ 'drye-pdp-modules.css' | asset_url | stylesheet_tag }}

<section
  class="hero"
  id="product-top"
  data-section-id="{{ section.id }}"
  data-product-section
>
  <div class="hero-media" data-gallery-root>
    {% assign visible_media_count = 0 %}

    {% for media in current_product.media %}
      {% assign media_src = media.preview_image | image_url | split: '?' | first %}

      {% unless media_src contains 'cart-drawer-image' %}
        {% assign visible_media_count = visible_media_count | plus: 1 %}
      {% endunless %}
    {% endfor %}

    {% if visible_media_count > 1 %}
      <div class="hero-gallery-thumbs" aria-hidden="true">
        {% assign thumb_index = 0 %}

        {% for media in current_product.media %}
          {% assign media_src = media.preview_image | image_url | split: '?' | first %}

          {% unless media_src contains 'cart-drawer-image' %}
            <button
              type="button"
              class="hero-gallery-thumb{% if thumb_index == 0 %} is-active{% endif %}"
              data-gallery-thumb
              data-gallery-thumb-index="{{ thumb_index }}"
              aria-label="View product media {{ thumb_index | plus: 1 }}"
              tabindex="-1"
            >
              {% if media.preview_image != blank %}
                {{
                  media.preview_image
                  | image_url: width: 240
                  | image_tag:
                    alt: media.alt | default: current_product.title,
                    widths: '120, 180, 240',
                    sizes: '(min-width: 1024px) 60px, 0px',
                    loading: 'lazy'
                }}

                {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                  <span class="hero-gallery-thumb__play" aria-hidden="true">▶</span>
                {% endif %}
              {% else %}
                <span class="hero-gallery-thumb__fallback">
                  {{ media.media_type }}
                </span>
              {% endif %}
            </button>

            {% assign thumb_index = thumb_index | plus: 1 %}
          {% endunless %}
        {% endfor %}
        <button
  type="button"
  class="hero-gallery-thumb hero-gallery-thumb--review"
  data-gallery-thumb
  data-gallery-thumb-index="{{ visible_media_count }}"
  aria-label="View reviews slide"
  tabindex="-1"
>
  <span class="hero-gallery-thumb__fallback">
    ★
  </span>
</button>
      </div>
    {% endif %}

    <div class="hero-gallery-main" data-gallery-viewport>
      <div class="hero-gallery-track" data-gallery-track>
        {% if visible_media_count > 0 %}
          {% for media in current_product.media %}
            {% assign media_src = media.preview_image | image_url | split: '?' | first %}

            {% unless media_src contains 'cart-drawer-image' %}
              <div class="hero-gallery-slide" data-gallery-slide>
                {% case media.media_type %}

                  {% when 'image' %}
                    {{
                      media
                      | image_url: width: 2200
                      | image_tag:
                        alt: media.alt | default: current_product.title,
                        widths: '480, 720, 960, 1200, 1600, 2000, 2200',
                        sizes: '(min-width: 1024px) 600px, (min-width: 768px) 50vw, 100vw',
                        loading: 'eager',
                        class: 'hero-media-img'
                    }}

                  {% when 'video' %}
                    {{
                      media
                      | video_tag:
                        class: 'hero-media-video',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'auto'
                    }}

                  {% when 'external_video' %}
                    {{
                      media
                      | external_video_tag:
                        class: 'hero-media-video'
                    }}

                  {% else %}
                    {{ media | media_tag: class: 'hero-media-img' }}

                {% endcase %}
              </div>
            {% endunless %}
          {% endfor %}
          <a
  href="#reviews"
  class="hero-gallery-slide hero-gallery-slide--review-cta"
  data-gallery-slide
  aria-label="Read customer reviews"
>
  <div class="hero-review-cta-card">
    <span class="dryeNEW-micro hero-review-cta-card__eyebrow">
      Reviews
    </span>

    <h2 class="dryeNEW-h2 hero-review-cta-card__heading">
      See what workers say after the first week
    </h2>

    <p class="dryeNEW-body hero-review-cta-card__body">
      Read verified reviews from people using DRYE inside sealed gloves.
    </p>

    <span class="hero-review-cta-card__link">
      Read reviews ↓
    </span>
  </div>
</a>
        {% else %}
          <div class="hero-gallery-slide" data-gallery-slide>
            {{ 'product-1' | placeholder_svg_tag: 'hero-media-img hero-media-placeholder' }}
          </div>
        {% endif %}
      </div>

      {% if visible_media_count > 1 %}
        <div class="hero-gallery-nav">
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--prev"
            data-gallery-prev
            aria-label="Previous image"
            disabled
          >
            ‹
          </button>
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--next"
            data-gallery-next
            aria-label="Next image"
          >
            ›
          </button>
        </div>
      {% endif %}

      <div class="hero-overlay">
        <div class="ho-name">{{ section.settings.overlay_name }}</div>
        <div class="ho-quote">{{ section.settings.overlay_quote }}</div>
      </div>
    </div>
  </div>
  <div class="hero-info">
    <div class="stars-row">
      <span class="stars" aria-hidden="true">★★★★★</span>
      <span class="stars-lbl">
        {{ review_rating }}/5 · <a href="{{ review_anchor }}">{{ review_count }} reviews</a>
      </span>
    </div>

    {% if section.settings.eyebrow != blank and section.settings.show_eyebrow %}
      <div class="h-eye">{{ section.settings.eyebrow }}</div>
    {% endif %}

    <h1 class="h-title">
      {{ section.settings.heading_line_1 }}<br>
      {{ section.settings.heading_line_2 }}
    </h1>

    <div class="h-sub">
      {{ section.settings.subtext }}
    </div>

    <div class="price-row" data-price-row>
      <span class="price" data-price>{{ selected_variant.price | money_with_currency }}</span>
      {% if price_note != blank %}
        <span class="price-note">{{ price_note }}</span>
      {% endif %}
    </div>

    {% assign size_option_position = blank %}
    {% for option in current_product.options_with_values %}
      {% assign option_name_downcase = option.name | downcase %}
      {% if option_name_downcase contains 'size' or option_name_downcase contains 'storlek' %}
        {% assign size_option_position = option.position %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% form 'product', current_product, class: 'product-form', novalidate: 'novalidate', action: routes.cart_add_url, data-product-form: '' %}
      {% if size_option_position != blank %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id>
      {% endif %}

      <div class="buy-block">
        <div class="form-lbl">
          <span>{{ section.settings.option_label }}</span>
          <button type="button" class="size-guide-link js-open-size-guide">
            {{ section.settings.size_guide_label }}
          </button>
        </div>

        {% if size_option_position != blank %}
          {% assign size_option_index = size_option_position | minus: 1 %}
          {% assign size_option = current_product.options_with_values[size_option_index] %}

          <div class="sz-dd" data-size-dropdown>
            <button
              type="button"
              class="sz-dd-trigger{% if selected_variant.options[size_option_index] != blank %} has-val{% endif %}"
              data-size-trigger
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span data-size-label>
                {% if selected_variant.options[size_option_index] != blank %}
                  {{ selected_variant.options[size_option_index] }}
                {% else %}
                  {{ section.settings.size_placeholder }}
                {% endif %}
              </span>
              <svg class="sz-dd-arrow" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0 0l5 6 5-6z" fill="#9CA3AF"/>
              </svg>
            </button>

<div class="sz-dd-list" data-size-list role="listbox" aria-label="{{ size_option.name }}">

<button
  type="button"
  class="sz-dd-help dryeNEW-body--caption js-open-size-guide"
>
  <span>Unsure of your size? Click here</span>
  <span class="sz-dd-help__arrow" aria-hidden="true">→</span>
</button>

{% for value in size_option.values %}
  {% liquid
    assign matched_variant = blank
    for variant in current_product.variants
      if variant.options[size_option_index] == value
        assign matched_variant = variant
        break
      endif
    endfor

    assign is_selected = false
    if selected_variant.options[size_option_index] == value
      assign is_selected = true
    endif

    assign is_preorder = false
    if matched_variant != blank
      if matched_variant.inventory_policy == 'continue' and matched_variant.inventory_quantity <= 0
        assign is_preorder = true
      endif
    endif

    assign is_available = true
    if matched_variant != blank and matched_variant.available == false and is_preorder == false
      assign is_available = false
    endif

    assign is_in_stock = false
    if matched_variant != blank and matched_variant.available and is_preorder == false
      assign is_in_stock = true
    endif
  %}
  <button
    type="button"
    class="sz-dd-opt{% unless is_available %} sold-out{% endunless %}{% if is_selected %} selected{% endif %}{% if is_preorder %} preorder{% endif %}"
    data-size-option
    data-option-position="{{ size_option_position }}"
    data-option-value="{{ value | escape }}"
    data-available="{% if is_available %}true{% else %}false{% endif %}"
    data-preorder="{% if is_preorder %}true{% else %}false{% endif %}"
    role="option"
    aria-selected="{% if is_selected %}true{% else %}false{% endif %}"
    {% unless is_available %}disabled{% endunless %}
  >
    {{ value }}{% if is_preorder %} — {{ preorder_note }}{% elsif is_in_stock %} — {{ in_stock_note }}{% elsif is_available == false %} — Sold out{% endif %}
  </button>
{% endfor %}
            </div>
          </div>
        {% else %}
          <select class="variant-select-fallback" name="id">
            {% for variant in current_product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant.id == selected_variant.id %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }} - {{ variant.price | money_with_currency }}
              </option>
            {% endfor %}
          </select>
        {% endif %}
      </div>

<div class="qty-block">
  <div class="form-lbl">
    <span>{{ section.settings.quantity_label }}</span>
  </div>

  <div class="qty-wrap">
    <button
      type="button"
      class="qty-btn"
      data-qty-minus
      aria-label="Decrease quantity"
    >
      −
    </button>

    <input
      class="qty-val"
      id="qty-{{ section.id }}"
      name="quantity"
      type="text"
      value="1"
      inputmode="numeric"
      readonly
    >

    <button
      type="button"
      class="qty-btn"
      data-qty-plus
      aria-label="Increase quantity"
    >
      +
    </button>
  </div>
</div>

      <ul class="bullets">
        {% if section.settings.bullet_1 != blank %}<li>{{ section.settings.bullet_1 }}</li>{% endif %}
        {% if section.settings.bullet_2 != blank %}<li>{{ section.settings.bullet_2 }}</li>{% endif %}
        {% if section.settings.bullet_3 != blank %}<li>{{ section.settings.bullet_3 }}</li>{% endif %}
        {% if section.settings.bullet_4 != blank %}<li>{{ section.settings.bullet_4 }}</li>{% endif %}
        {% if section.settings.bullet_5 != blank %}<li>{{ section.settings.bullet_5 }}</li>{% endif %}
        {% if section.settings.bullet_6 != blank %}<li>{{ section.settings.bullet_6 }}</li>{% endif %}
      </ul>

      {% assign selected_variant_preorder = false %}
      {% if selected_variant.inventory_policy == 'continue' and selected_variant.inventory_quantity <= 0 %}
        {% assign selected_variant_preorder = true %}
      {% endif %}

      <button
        type="submit"
        class="atc-btn-full"
        data-main-atc
        {% unless selected_variant.available or selected_variant_preorder %}disabled{% endunless %}
      >
        {% if selected_variant.available or selected_variant_preorder %}
          {{ atc_button_label }}
        {% else %}
          Sold out
        {% endif %}
      </button>
    {% endform %}


    <div class="trust-row">
      <div class="trust-item">
        <img
          src="{{ 'icon-shield-check.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_1 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-refund-arrows (2).svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_2 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-truck.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_3 }}</span>
      </div>
    </div>

    {% if section.settings.show_inline_review_slider %}
      {% for block in section.blocks %}
        {% if block.type == 'review_slider' %}
          <div class="pdp-review-slider-block" {{ block.shopify_attributes }}>
            {% render 'drye-review-slider-inline', block: block %}
          </div>
        {% endif %}
      {% endfor %}
    {% endif %}


    {% assign desc_media = section.blocks | where: 'type', 'desc_media' %}
    {% assign rendered_desc = '' %}
    {% assign desc_title = section.settings.description_toggle_closed %}
    {% assign found_description_block = false %}

    {% for block in section.blocks %}
      {% if block.type == 'description' %}
        {% assign found_description_block = true %}
        {% assign desc_title = block.settings.title | default: section.settings.description_toggle_closed %}

        {% if block.settings.use_product_description and product.description != blank %}
          {% assign rendered_desc = product.description %}
        {% else %}
          {% assign rendered_desc = block.settings.custom_description %}
        {% endif %}

        {% for m in desc_media %}
          {% assign key = m.settings.key | strip %}
          {% if key != blank and rendered_desc contains key %}
            {% capture media_markup %}
<div class="desc-media">
  {% if m.settings.video != blank %}
    {{ m.settings.video | video_tag: class: 'desc-media__video', autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto' }}
  {% elsif m.settings.image != blank %}
    {{ m.settings.image | image_url: width: 1600 | image_tag: class: 'desc-media__img', loading: 'lazy', decoding: 'async' }}
  {% endif %}
</div>
            {% endcapture %}
            {% assign rendered_desc = rendered_desc | replace: key, media_markup %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}

    {% if found_description_block %}
      <div class="pdp-desc">
        <div class="pdp-desc-title">
          {{ desc_title }}
        </div>

        <div class="pdp-extra open">
          <div class="pdp-richtext">
            {{ rendered_desc }}
          </div>
        </div>
      </div>
    {% endif %}

{% comment %} v10 — Missing interface: visual product-description grid (in-column) {% endcomment %}
{% if section.settings.mi_heading != blank %}
  <div class="pdp-mod pdp-mod--bleed pdp-mod--soft pdp-mi">
    {% if section.settings.mi_eyebrow != blank %}
      <span class="pdp-mod__eyebrow">{{ section.settings.mi_eyebrow }}</span>
    {% endif %}
    <h2 class="pdp-mod__h2">{{ section.settings.mi_heading }}</h2>
    {% if section.settings.mi_body != blank %}
      <p class="pdp-mod__body">{{ section.settings.mi_body }}</p>
    {% endif %}

    <div class="pdp-mi__grid">
      {% for i in (1..6) %}
        {% liquid
          assign t_key = 'mi_tile_' | append: i | append: '_title'
          assign d_key = 'mi_tile_' | append: i | append: '_desc'
          assign tile_title = section.settings[t_key]
          assign tile_desc = section.settings[d_key]
        %}
        {% if tile_title != blank %}
          <div class="pdp-mi__tile">
            <h3 class="pdp-mi__tile-title">{{ tile_title }}</h3>
            {% if tile_desc != blank %}
              <p class="pdp-mi__tile-desc">{{ tile_desc }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% comment %} v10 — The invention: dark absorption comparison (in-column) {% endcomment %}
{% if section.settings.inv_heading != blank %}
  <div class="pdp-mod pdp-mod--bleed pdp-mod--dark pdp-inv">
    {% if section.settings.inv_eyebrow != blank %}
      <span class="pdp-mod__eyebrow">{{ section.settings.inv_eyebrow }}</span>
    {% endif %}
    <h2 class="pdp-mod__h2">{{ section.settings.inv_heading }}</h2>
    {% if section.settings.inv_body != blank %}
      <p class="pdp-mod__body">{{ section.settings.inv_body }}</p>
    {% endif %}

    <div class="pdp-inv__cmp">
      {% for i in (1..6) %}
        {% liquid
          assign n_key = 'inv_row_' | append: i | append: '_name'
          assign v_key = 'inv_row_' | append: i | append: '_value'
          assign p_key = 'inv_row_' | append: i | append: '_percent'
          assign h_key = 'inv_row_' | append: i | append: '_highlight'
          assign row_name = section.settings[n_key]
          assign row_value = section.settings[v_key]
          assign row_percent = section.settings[p_key] | default: 0
          assign row_highlight = section.settings[h_key]
        %}
        {% if row_name != blank %}
          <div class="pdp-inv__row{% if row_highlight %} is-drye{% endif %}">
            <span class="pdp-inv__name">{{ row_name }}</span>
            <span class="pdp-inv__bar" aria-hidden="true">
              <i style="width: {{ row_percent }}%;"></i>
            </span>
            <strong class="pdp-inv__val">{{ row_value }}</strong>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.inv_note != blank %}
      <p class="pdp-inv__note">{{ section.settings.inv_note }}</p>
    {% endif %}
  </div>
{% endif %}

{% assign wte_blocks = section.blocks | where: 'type', 'htab_wte_stage' %}
{% assign faq_blocks = section.blocks | where: 'type', 'faq' %}

{% comment %}
  v10 — FAQ: 3 tabs (in-column). Tab labels + per-tab counts are SECTION
  settings (these survive Shopify's editor sync; per-block fields do not).
  FAQ blocks are sliced into 3 groups by their order: tab 1 = first N1,
  tab 2 = next N2, tab 3 = the rest. Reorder FAQs / tweak counts to taste.
  Reuses the existing tab + accordion JS.
{% endcomment %}
{% if faq_blocks.size > 0 %}
  {% liquid
    assign t1 = section.settings.faq_tab_1_label | default: 'Feel'
    assign t2 = section.settings.faq_tab_2_label | default: 'Grip'
    assign t3 = section.settings.faq_tab_3_label | default: 'Lifetime'

    assign n1 = section.settings.faq_tab_1_count | default: 4
    assign n2 = section.settings.faq_tab_2_count | default: 3
    assign split2 = n1 | plus: n2
  %}

  <div class="pdp-mod pdp-mod--bleed pdp-faq" data-drye-tabs>
    {% if section.settings.faq_eyebrow != blank %}
      <span class="pdp-mod__eyebrow">{{ section.settings.faq_eyebrow }}</span>
    {% endif %}
    {% if section.settings.faq_heading != blank %}
      <h2 class="pdp-mod__h2">{{ section.settings.faq_heading }}</h2>
    {% endif %}

    <div class="pdp-faq__tabs tab-nav" role="tablist">
      <button type="button" class="tab-btn active" data-tab="faq-1" role="tab" aria-selected="true">{{ t1 }}</button>
      <button type="button" class="tab-btn" data-tab="faq-2" role="tab" aria-selected="false">{{ t2 }}</button>
      <button type="button" class="tab-btn" data-tab="faq-3" role="tab" aria-selected="false">{{ t3 }}</button>
    </div>

    {% for tabnum in (1..3) %}
      <div
        class="tab-panel{% if forloop.first %} active{% endif %}"
        data-panel="faq-{{ tabnum }}"
        role="tabpanel"
      >
        <div class="faq-list">
          {% for block in faq_blocks %}
            {% liquid
              assign pos = forloop.index0
              assign in_tab = false
              if tabnum == 1 and pos < n1
                assign in_tab = true
              elsif tabnum == 2 and pos >= n1 and pos < split2
                assign in_tab = true
              elsif tabnum == 3 and pos >= split2
                assign in_tab = true
              endif
            %}
            {% if in_tab %}
              <div class="faq-item{% if block.settings.open_by_default %} open{% endif %}" {{ block.shopify_attributes }}>
                <button type="button" class="faq-q">
                  <span class="faq-q-text">{{ block.settings.question }}</span>
                  <span class="faq-icon" aria-hidden="true"></span>
                </button>

                <div class="faq-a">
                  <div class="faq-a-inner">
                    {{ block.settings.answer | escape | newline_to_br }}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
{% endif %}

{% comment %} v10 — What to expect: dark timeline (in-column). Reuses WTE accordion JS. {% endcomment %}
{% if wte_blocks.size > 0 %}
  <div class="pdp-mod pdp-mod--bleed pdp-mod--dark pdp-wte">
    {% if section.settings.wte_eyebrow != blank %}
      <span class="pdp-mod__eyebrow">{{ section.settings.wte_eyebrow }}</span>
    {% endif %}
    {% if section.settings.wte_heading != blank %}
      <h2 class="pdp-mod__h2">{{ section.settings.wte_heading }}</h2>
    {% endif %}

    <div class="hero-wte-timeline" data-hero-wte-timeline>
      {% for block in wte_blocks %}
        {% liquid
          assign clock_angle = 210

          case forloop.index
            when 1
              assign clock_angle = 210
            when 2
              assign clock_angle = 330
            when 3
              assign clock_angle = 30
            when 4
              assign clock_angle = 90
            when 5
              assign clock_angle = 120
            when 6
              assign clock_angle = 150
          endcase
        %}

        <div
          class="hero-wte-stop{% if forloop.first %} is-open{% endif %}"
          {{ block.shopify_attributes }}
        >
          <button
            type="button"
            class="hero-wte-trigger"
            aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}"
          >
            <span class="hero-wte-clock" aria-hidden="true">
              <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="30" cy="30" r="26" stroke-width="1.5"/>
                <line x1="30" y1="7" x2="30" y2="12" stroke-width="1.5"/>
                <line x1="53" y1="30" x2="48" y2="30" stroke-width="1.5"/>
                <line x1="30" y1="53" x2="30" y2="48" stroke-width="1.5"/>
                <line x1="7" y1="30" x2="12" y2="30" stroke-width="1.5"/>
                <line x1="30" y1="30" x2="30" y2="16" stroke-width="2.5" transform="rotate({{ clock_angle }}, 30, 30)"/>
                <circle cx="30" cy="30" r="2.5" fill="currentColor" stroke="none"/>
              </svg>
            </span>

            <span class="hero-wte-heading">
              {% if block.settings.stage_label != blank %}
                <span class="dryeNEW-stat-number hero-wte-time">
