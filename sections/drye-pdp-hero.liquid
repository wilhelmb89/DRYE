{% liquid
  assign current_product = product
  assign selected_variant = current_product.selected_or_first_available_variant
assign review_rating = section.settings.review_rating_fallback
assign review_count = section.settings.review_count_fallback
  assign review_anchor = '#judgeme_product_reviews'
  assign price_note = section.settings.price_note
  assign sticky_button_label = section.settings.sticky_button_label
  assign atc_button_label = section.settings.atc_button_label
  assign preorder_note = ''
  assign in_stock_note = 'In stock'
%}

{{ 'drye-pdp-hero.css' | asset_url | stylesheet_tag }}
{{ 'drye-review-slider.css' | asset_url | stylesheet_tag }}
{{ 'drye-worker-proof.css' | asset_url | stylesheet_tag }}

<section
  class="hero"
  id="product-top"
  data-section-id="{{ section.id }}"
  data-product-section
>
  <div class="hero-media" data-gallery-root>
    {% assign visible_media_count = 0 %}

    {% for media in current_product.media %}
      {% assign media_src = media.preview_image | image_url | split: '?' | first %}

      {% unless media_src contains 'cart-drawer-image' %}
        {% assign visible_media_count = visible_media_count | plus: 1 %}
      {% endunless %}
    {% endfor %}

    {% if visible_media_count > 1 %}
      <div class="hero-gallery-thumbs" aria-hidden="true">
        {% assign thumb_index = 0 %}

        {% for media in current_product.media %}
          {% assign media_src = media.preview_image | image_url | split: '?' | first %}

          {% unless media_src contains 'cart-drawer-image' %}
            <button
              type="button"
              class="hero-gallery-thumb{% if thumb_index == 0 %} is-active{% endif %}"
              data-gallery-thumb
              data-gallery-thumb-index="{{ thumb_index }}"
              aria-label="View product media {{ thumb_index | plus: 1 }}"
              tabindex="-1"
            >
              {% if media.preview_image != blank %}
                {{
                  media.preview_image
                  | image_url: width: 240
                  | image_tag:
                    alt: media.alt | default: current_product.title,
                    widths: '120, 180, 240',
                    sizes: '(min-width: 1024px) 60px, 0px',
                    loading: 'lazy'
                }}

                {% if media.media_type == 'video' or media.media_type == 'external_video' %}
                  <span class="hero-gallery-thumb__play" aria-hidden="true">▶</span>
                {% endif %}
              {% else %}
                <span class="hero-gallery-thumb__fallback">
                  {{ media.media_type }}
                </span>
              {% endif %}
            </button>

            {% assign thumb_index = thumb_index | plus: 1 %}
          {% endunless %}
        {% endfor %}
        <button
  type="button"
  class="hero-gallery-thumb hero-gallery-thumb--review"
  data-gallery-thumb
  data-gallery-thumb-index="{{ visible_media_count }}"
  aria-label="View reviews slide"
  tabindex="-1"
>
  <span class="hero-gallery-thumb__fallback">
    ★
  </span>
</button>
      </div>
    {% endif %}

    <div class="hero-gallery-main" data-gallery-viewport>
      <div class="hero-gallery-track" data-gallery-track>
        {% if visible_media_count > 0 %}
          {% for media in current_product.media %}
            {% assign media_src = media.preview_image | image_url | split: '?' | first %}

            {% unless media_src contains 'cart-drawer-image' %}
              <div class="hero-gallery-slide" data-gallery-slide>
                {% case media.media_type %}

                  {% when 'image' %}
                    {{
                      media
                      | image_url: width: 2200
                      | image_tag:
                        alt: media.alt | default: current_product.title,
                        widths: '480, 720, 960, 1200, 1600, 2000, 2200',
                        sizes: '(min-width: 1024px) 600px, (min-width: 768px) 50vw, 100vw',
                        loading: 'eager',
                        class: 'hero-media-img'
                    }}

                  {% when 'video' %}
                    {{
                      media
                      | video_tag:
                        class: 'hero-media-video',
                        autoplay: true,
                        loop: true,
                        muted: true,
                        controls: false,
                        playsinline: true,
                        preload: 'auto'
                    }}

                  {% when 'external_video' %}
                    {{
                      media
                      | external_video_tag:
                        class: 'hero-media-video'
                    }}

                  {% else %}
                    {{ media | media_tag: class: 'hero-media-img' }}

                {% endcase %}
              </div>
            {% endunless %}
          {% endfor %}
<a
  href="{{ review_anchor }}"
  class="hero-gallery-slide hero-gallery-slide--review-cta"
  data-gallery-slide
  aria-label="Read customer reviews"
>
  <div class="hero-review-cta-card">
    <span class="dryeNEW-micro hero-review-cta-card__eyebrow">
      Reviews
    </span>

    <h2 class="dryeNEW-h2 hero-review-cta-card__heading">
      See what workers say after the first week
    </h2>

    <p class="dryeNEW-body hero-review-cta-card__body">
      Read verified reviews from people using DRYE inside sealed gloves.
    </p>

    <span class="hero-review-cta-card__link">
      Read reviews ↓
    </span>
  </div>
</a>
        {% else %}
          <div class="hero-gallery-slide" data-gallery-slide>
            {{ 'product-1' | placeholder_svg_tag: 'hero-media-img hero-media-placeholder' }}
          </div>
        {% endif %}
      </div>

      {% if visible_media_count > 1 %}
        <div class="hero-gallery-nav">
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--prev"
            data-gallery-prev
            aria-label="Previous image"
            disabled
          >
            ‹
          </button>
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--next"
            data-gallery-next
            aria-label="Next image"
          >
            ›
          </button>
        </div>
      {% endif %}

      <div class="hero-overlay">
        <div class="ho-name">{{ section.settings.overlay_name }}</div>
        <div class="ho-quote">{{ section.settings.overlay_quote }}</div>
      </div>
    </div>
  </div>
  {% if section.settings.proof_show_recent and section.settings.proof_recent_items != blank %}
    <div class="hero-proof-strip">
      {% if section.settings.proof_recent_label != blank %}
        <span class="hero-proof-strip__label">{{ section.settings.proof_recent_label }}</span>
      {% endif %}
      {% assign recent_lines = section.settings.proof_recent_items | newline_to_br | split: '<br />' %}
      {% for line in recent_lines %}
        {% assign line_text = line | strip %}
        {% if line_text != blank %}<span class="hero-proof-strip__item">{{ line_text }}</span>{% endif %}
      {% endfor %}
    </div>
  {% endif %}

  {% assign desc_media = section.blocks | where: 'type', 'desc_media' %}
  {% assign rendered_desc = '' %}
  {% assign desc_title = section.settings.description_toggle_closed %}
  {% assign found_description_block = false %}

  {% for block in section.blocks %}
    {% if block.type == 'description' %}
      {% assign found_description_block = true %}
      {% assign desc_title = block.settings.title | default: section.settings.description_toggle_closed %}

      {% if block.settings.use_product_description and product.description != blank %}
        {% assign rendered_desc = product.description %}
      {% else %}
        {% assign rendered_desc = block.settings.custom_description %}
      {% endif %}

      {% for m in desc_media %}
        {% assign key = m.settings.key | strip %}
        {% if key != blank and rendered_desc contains key %}
          {% capture media_markup %}
<div class="desc-media">
  {% if m.settings.video != blank %}
    {{ m.settings.video | video_tag: class: 'desc-media__video', autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto' }}
  {% elsif m.settings.image != blank %}
    {{ m.settings.image | image_url: width: 1600 | image_tag: class: 'desc-media__img', loading: 'lazy', decoding: 'async' }}
  {% endif %}
</div>
          {% endcapture %}
          {% assign rendered_desc = rendered_desc | replace: key, media_markup %}
        {% endif %}
      {% endfor %}
    {% endif %}
  {% endfor %}

  <div class="hero-info">
    <div class="stars-row" data-review-scroll role="link" tabindex="0" aria-label="Read customer reviews">
      <span class="stars" aria-hidden="true">★★★★★</span>
      <span class="stars-lbl">
        {{ review_rating }}/5 · <a href="{{ review_anchor }}">{{ review_count }} reviews</a>
      </span>
    </div>

    <h1 class="h-title">
      {{ section.settings.heading_line_1 }}<br>
      {{ section.settings.heading_line_2 }}
    </h1>

    <div class="h-sub">
      {{ section.settings.subtext }}
    </div>

    {% assign size_option_position = blank %}
    {% for option in current_product.options_with_values %}
      {% assign option_name_downcase = option.name | downcase %}
      {% if option_name_downcase contains 'size' or option_name_downcase contains 'storlek' %}
        {% assign size_option_position = option.position %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% form 'product', current_product, class: 'product-form', novalidate: 'novalidate', action: routes.cart_add_url, data-product-form: '' %}
      {% if size_option_position != blank %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id>
      {% endif %}

      <div class="buy-block">
        <div class="form-lbl">
          <span>{{ section.settings.option_label }}</span>
          <button type="button" class="size-guide-link js-open-size-guide">
            {{ section.settings.size_guide_label }}
          </button>
        </div>

        {% if size_option_position != blank %}
          {% assign size_option_index = size_option_position | minus: 1 %}
          {% assign size_option = current_product.options_with_values[size_option_index] %}

          <div class="sz-dd" data-size-dropdown>
            <button
              type="button"
              class="sz-dd-trigger"
              data-size-trigger
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span data-size-label>{{ section.settings.size_placeholder }}</span>
              <svg class="sz-dd-arrow" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0 0l5 6 5-6z" fill="#9CA3AF"/>
              </svg>
            </button>

<div class="sz-dd-list" data-size-list role="listbox" aria-label="{{ size_option.name }}">

{% for value in size_option.values %}
  {% liquid
    assign matched_variant = blank
    for variant in current_product.variants
      if variant.options[size_option_index] == value
        assign matched_variant = variant
        break
      endif
    endfor

    assign is_selected = false
    if selected_variant.options[size_option_index] == value
      assign is_selected = true
    endif

    assign is_preorder = false
    if matched_variant != blank
      if matched_variant.inventory_policy == 'continue' and matched_variant.inventory_quantity <= 0
        assign is_preorder = true
      endif
    endif

    assign is_available = true
    if matched_variant != blank and matched_variant.available == false and is_preorder == false
      assign is_available = false
    endif

    assign is_in_stock = false
    if matched_variant != blank and matched_variant.available and is_preorder == false
      assign is_in_stock = true
    endif

    if matched_variant.inventory_management == 'shopify'
      assign variant_policy = matched_variant.inventory_policy
    else
      assign variant_policy = 'deny'
    endif
    assign variant_qty = matched_variant.inventory_quantity

    assign fit_note = ''
    assign fit_lines = section.settings.size_fit_notes | newline_to_br | split: '<br />'
    for fit_line in fit_lines
      assign fit_parts = fit_line | strip | split: '='
      assign fit_key = fit_parts[0] | strip
      if fit_key == value and fit_parts.size > 1
        assign fit_note = fit_parts[1] | strip
        break
      endif
    endfor
  %}
  <button
    type="button"
    class="sz-dd-opt{% unless is_available %} sold-out{% endunless %}{% if is_selected %} selected{% endif %}{% if is_preorder %} preorder{% endif %}"
    data-size-option
    data-option-position="{{ size_option_position }}"
    data-option-value="{{ value | escape }}"
    data-available="{% if is_available %}true{% else %}false{% endif %}"
    data-preorder="{% if is_preorder %}true{% else %}false{% endif %}"
    data-policy="{% if matched_variant.inventory_management == 'shopify' %}{{ matched_variant.inventory_policy }}{% else %}deny{% endif %}"
    data-qty="{{ matched_variant.inventory_quantity }}"
    data-variant-id="{{ matched_variant.id }}"
    role="option"
    aria-selected="{% if is_selected %}true{% else %}false{% endif %}"
  >
    <span class="sz-dd-main"><span class="sz-dd-size">{{ value }}</span>{% if fit_note != blank %}<span class="sz-dd-fit">{{ fit_note }}</span>{% endif %}</span>{% if matched_variant != blank %}{% if variant_policy == 'continue' and variant_qty <= 0 %}<span class="sz-dd-note sz-dd-note--low">{{ section.settings.preorder_dropdown_label | default: 'Low stock' }}</span>{% elsif variant_policy == 'deny' and variant_qty <= 0 %}<span class="sz-dd-note sz-dd-note--soldout">Sold out · Notify me →</span>{% elsif variant_qty > 0 and variant_qty <= section.settings.low_stock_threshold %}<span class="sz-dd-note sz-dd-note--low">Only {{ variant_qty }} left</span>{% else %}<span class="sz-dd-note">In stock</span>{% endif %}{% endif %}
  </button>
{% endfor %}

<button
  type="button"
  class="sz-dd-help js-open-size-guide"
>
  <span class="sz-dd-help__text">{{ section.settings.size_help_label | default: 'Unsure of your size?' }}</span>
  <span class="sz-dd-help__arrow" aria-hidden="true">→</span>
</button>
            </div>
          </div>

          <div class="sz-inline-panel" data-size-panel hidden>

            {% comment %} Preorder block — hidden by default, JS shows it for preorder sizes {% endcomment %}
            <div class="sz-panel-preorder" data-panel-preorder hidden>
              <div class="sz-panel-preorder-head">
                <p class="sz-panel-heading" data-panel-preorder-heading></p>
                <span class="sz-panel-ships-badge" data-panel-ships-badge></span>
              </div>
              <div class="sz-panel-price-row">
                <s class="sz-panel-price-orig" data-panel-price-orig></s>
                <span class="sz-panel-price-sale" data-panel-price-sale></span>
                <span class="sz-panel-discount" data-panel-discount></span>
              </div>
              <p class="sz-panel-cutoff" data-panel-cutoff></p>
              <button type="button" class="sz-panel-preorder-btn" data-panel-preorder-btn></button>
              <p class="sz-panel-micro">{{ section.settings.preorder_micro }}</p>
            </div>

            {% comment %} Divider — visible only when preorder block is shown {% endcomment %}
            <div class="sz-panel-divider" data-panel-divider hidden></div>

            {% comment %} Notify me block — always shown in panel {% endcomment %}
            <div class="sz-panel-notify" data-panel-notify>
              <p class="sz-panel-notify-heading" data-panel-notify-heading></p>
              <div data-notify-form>
                <div class="sz-panel-form-row">
                  <input type="email" class="sz-panel-email" data-notify-email
                         placeholder="{{ section.settings.notify_placeholder }}"
                         autocomplete="email">
                  <button type="button" class="sz-panel-notify-btn" data-notify-submit>
                    {{ section.settings.notify_cta }}
                  </button>
                </div>
                <p class="sz-panel-email-err" data-notify-err hidden>
                  {{ section.settings.notify_email_error }}
                </p>
              </div>
              <p class="sz-panel-success" data-notify-success hidden>
                {{ section.settings.notify_success }}
              </p>
            </div>

          </div>
        {% else %}
          <select class="variant-select-fallback" name="id">
            {% for variant in current_product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant.id == selected_variant.id %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }} - {{ variant.price | money_with_currency }}
              </option>
            {% endfor %}
          </select>
        {% endif %}
      </div>

<div class="qty-block">
  <div class="form-lbl">
    <span>{{ section.settings.quantity_label }}</span>
  </div>

  <div class="qty-wrap">
    <button
      type="button"
      class="qty-btn"
      data-qty-minus
      aria-label="Decrease quantity"
    >
      −
    </button>

    <input
      class="qty-val"
      id="qty-{{ section.id }}"
      name="quantity"
      type="text"
      value="1"
      inputmode="numeric"
      readonly
    >

    <button
      type="button"
      class="qty-btn"
      data-qty-plus
      aria-label="Increase quantity"
    >
      +
    </button>
  </div>
</div>

      {% assign selected_variant_preorder = false %}
      {% if selected_variant.inventory_policy == 'continue' and selected_variant.inventory_quantity <= 0 %}
        {% assign selected_variant_preorder = true %}
      {% endif %}

      <div class="value-card">
        <div class="value-card__principle">
          <span class="value-card__principle-t">{{ section.settings.compare_principle | default: 'Step 1: Change the environment' }}</span>
        </div>
        <div class="value-card__grid">
          <div class="value-card__col value-card__col--loop">
            <p class="value-card__eyebrow value-card__eyebrow--loop">The workaround loop</p>
            <div class="value-card__items">
              <div class="value-card__item"><span class="value-card__x">✕</span><span>Soaked liners</span></div>
              <div class="value-card__item"><span class="value-card__x">✕</span><span>Glove-stick</span></div>
              <div class="value-card__item"><span class="value-card__x">✕</span><span>Constant hand resets</span></div>
              <div class="value-card__item"><span class="value-card__x">✕</span><span>Wet, irritated skin</span></div>
              <div class="value-card__item"><span class="value-card__x">✕</span><span>Cream after every shift</span></div>
            </div>
          </div>
          <div class="value-card__div" aria-hidden="true"></div>
          <div class="value-card__col value-card__col--base">
            <p class="value-card__eyebrow value-card__eyebrow--base">One base layer</p>
            <div class="value-card__items">
              <div class="value-card__item"><span class="value-card__arrow">→</span><span>Dryer hands all shift</span></div>
              <div class="value-card__item"><span class="value-card__arrow">→</span><span>No sticky glove changes</span></div>
              <div class="value-card__item"><span class="value-card__arrow">→</span><span>Oil and grime hit the liner, not your skin</span></div>
              <div class="value-card__item"><span class="value-card__arrow">→</span><span>Machine washable</span></div>
              <div class="value-card__item"><span class="value-card__arrow">→</span><span>Fits under any sealed glove</span></div>
            </div>
          </div>
        </div>
      </div>

      <div class="step2">
        <button class="step2__btn" aria-expanded="false" aria-controls="step2panel-{{ section.id }}" id="step2btn-{{ section.id }}">
          {{ section.settings.step2_label | default: 'Step 2: Notice the difference after 5 min' }}
          <svg class="step2__chev" viewBox="0 0 10 6" fill="none"><path d="M0 0l5 6 5-6z" fill="currentColor"/></svg>
        </button>
        <div class="step2__panel" id="step2panel-{{ section.id }}"><div class="step2__inner">
          <div class="vtl">
            {% for block in section.blocks %}{% if block.type == 'timeline_row' %}<div class="vtl__row" {{ block.shopify_attributes }}><span class="vtl__mark">{{ block.settings.marker }}</span><span class="vtl__out">{{ block.settings.outcome }}</span></div>{% endif %}{% endfor %}
          </div>
        </div></div>
      </div>

      <div class="price-row" data-price-row>
        <span class="price" data-price>{{ selected_variant.price | money_with_currency }}</span>
        {% if price_note != blank %}
          <span class="price-note">{{ price_note }}</span>
        {% endif %}
        {%- comment -%} Market-correct money format sample — read by JS so it never guesses currency/separators {%- endcomment -%}
        <span class="dryeNEW-visually-hidden" data-money-sample aria-hidden="true">{{ 123456789 | money_with_currency }}</span>
      </div>

      {% if section.settings.cpm_enabled %}
        {%- assign cpm_low = section.settings.cpm_months_low | default: 6 -%}
        {%- assign cpm_high = section.settings.cpm_months_high | default: 12 -%}
        {%- assign cpm_suffix = section.settings.cpm_month_suffix | default: 'mo' -%}
        {%- assign cpm_note_low = section.settings.cpm_note_low -%}
        {%- assign cpm_note_high = section.settings.cpm_note_high -%}
        <p class="cpm permo" data-cpm hidden>About <span data-cpm-price="{{ cpm_low }}"></span>/{{ cpm_suffix }} over {{ cpm_low }} months of heavy shop use · <span data-cpm-price="{{ cpm_high }}"></span>/{{ cpm_suffix }} over {{ cpm_high }}</p>
      {% endif %}

      <button
        type="submit"
        class="atc-btn-full"
        data-main-atc
        {% unless selected_variant.available or selected_variant_preorder %}disabled{% endunless %}
      >
        {% if selected_variant.available or selected_variant_preorder %}
          {{ atc_button_label }}
        {% else %}
          Sold out
        {% endif %}
      </button>
    {% endform %}

    <div class="trust-row">
      <div class="trust-item">
        <img
          src="{{ 'icon-shield-check.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_1 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-refund-arrows (2).svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_2 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-truck.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_3 }}</span>
      </div>
    </div>

    {% if section.settings.atc_undernote != blank %}
      <p class="atc-undernote">{{ section.settings.atc_undernote }}</p>
    {% endif %}

{% comment %} Worker Proof — compact green proof line + sliding/expandable comment ticker {% endcomment %}
{% if section.settings.proof_enabled %}
  {% liquid
    assign proof_has_items = false
    for i in (1..6)
      assign s_key = 'proof_item_' | append: i | append: '_short'
      if section.settings[s_key] != blank
        assign proof_has_items = true
        break
      endif
    endfor
  %}
  <section class="drye-proof" data-drye-proof-module aria-label="Worker proof">
    {% if section.settings.proof_returns_line != blank %}
      <div class="drye-proof__line">
        <svg class="drye-proof__check" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M3 8.4l3 3 7-7.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="drye-proof__returns">{{ section.settings.proof_returns_line }}</span>
      </div>
    {% endif %}
    {% if section.settings.proof_keep_line != blank %}
      <div class="drye-proof__keep">{{ section.settings.proof_keep_line }}</div>
    {% endif %}

    {% if proof_has_items %}
      {% if section.settings.proof_ticker_label != blank %}
        <div class="drye-proof__tlabel">{{ section.settings.proof_ticker_label }}</div>
      {% endif %}

      <div class="drye-proof__ticker-wrap" data-drye-proof-tickerwrap>
        <ul class="drye-proof__ticker" data-drye-proof-ticker>
          {% for pass in (1..2) %}
            {% for i in (1..6) %}
              {% liquid
                assign s_key = 'proof_item_' | append: i | append: '_short'
                assign f_key = 'proof_item_' | append: i | append: '_full'
                assign h_key = 'proof_item_' | append: i | append: '_handle'
                assign l_key = 'proof_item_' | append: i | append: '_label'
                assign u_key = 'proof_item_' | append: i | append: '_url'
                assign it_short = section.settings[s_key]
                assign it_full = section.settings[f_key] | default: section.settings[s_key]
                assign it_handle = section.settings[h_key]
                assign it_label = section.settings[l_key]
                assign it_url = section.settings[u_key]
              %}
              {% if it_short != blank %}
