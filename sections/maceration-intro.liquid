{{ 'section-maceration-intro.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section maceration-intro" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container">
    <div class="maceration-intro__inner">

      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro maceration-intro__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank or section.settings.heading_em != blank %}
        <h2 class="dryeNEW-h2 maceration-intro__heading">
          {% if section.settings.heading != blank %}
            {{ section.settings.heading }}
          {% endif %}

          {% if section.settings.heading_em != blank %}
            <span class="dryeNEW-editorial maceration-intro__heading-em">
              {{ section.settings.heading_em }}
            </span>
          {% endif %}
        </h2>
      {% endif %}

      <div class="maceration-intro__body">
        {% if section.settings.lead != blank %}
          <div class="dryeNEW-body maceration-intro__lead">
            {{ section.settings.lead }}
          </div>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="maceration-intro__timeline">
            {% for block in section.blocks %}
              <div class="maceration-intro__step" {{ block.shopify_attributes }}>
                {% if block.settings.label != blank %}
                  <span class="dryeNEW-micro maceration-intro__step-label">
                    {{ block.settings.label }}
                  </span>
                {% endif %}

                {% if block.settings.text != blank %}
                  <div class="dryeNEW-body maceration-intro__step-body">
                    {{ block.settings.text }}
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.close != blank %}
          <div class="dryeNEW-body maceration-intro__close">
            {{ section.settings.close }}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Maceration intro",
  "tag": "section",
  "class": "shopify-section--maceration-intro",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The name for it"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "There's a name for what's happening to your hands."
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Editorial heading line",
      "default": "It's called maceration."
    },
    {
      "type": "richtext",
      "id": "lead",
      "label": "Lead text",
      "default": "<p>Skin works like a sponge. Inside a sealed glove with nowhere for sweat to go, it absorbs water — and the outer barrier, the part that normally keeps oil, solvents and bacteria out, swells, softens, and starts to break down.</p>"
    },
    {
      "type": "richtext",
      "id": "close",
      "label": "Closing text",
      "default": "<p>That's not \"sweaty hands.\" <strong>That's chemical exposure with no barrier.</strong></p>"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Timeline step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Hour two"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Your skin stops protecting itself. The barrier is open.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maceration intro",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "label": "Hour two",
            "text": "<p>Your skin stops protecting itself. The barrier is open.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "Hour four",
            "text": "<p>Oil, solvents and chemicals soak <em>into</em> the skin — not off it.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "End of shift",
            "text": "<p>You wash your hands. The damage is already done. Tomorrow it starts again.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

