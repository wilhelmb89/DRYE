{{ 'section-drye-stretch.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section drye-stretch"
  id="drye-stretch-{{ section.id }}"
  data-drye-stretch
  data-drye-section
  data-section-id="{{ section.id }}"
  data-section-index="18"
  data-section-name="timeline"
>
  <div class="dryeNEW-container">

<div class="drye-stretch__layout">

<header class="drye-stretch__intro">
  {% if section.settings.eyebrow != blank %}
    <span class="dryeNEW-micro dryeNEW-reveal">
      {{ section.settings.eyebrow }}
    </span>
  {% endif %}

  {% if section.settings.heading != blank or section.settings.heading_italic != blank %}
    <h2 class="dryeNEW-h2 drye-stretch__heading dryeNEW-reveal dryeNEW-rd1">
      {% if section.settings.heading != blank %}
        {{ section.settings.heading }}
      {% endif %}

      {% if section.settings.heading_italic != blank %}
        <em class="dryeNEW-em">{{ section.settings.heading_italic }}</em>
      {% endif %}
    </h2>
  {% endif %}

  {% if section.settings.lead != blank %}
    <div class="dryeNEW-body drye-stretch__lead dryeNEW-reveal dryeNEW-rd2">
      {{ section.settings.lead }}
    </div>
  {% endif %}
</header>


  <div class="drye-stretch__timeline-col">
    <ol class="drye-stretch__timeline">
      {% assign timeline_blocks = section.blocks | where: 'type', 'timeline_stop' %}

{% for block in timeline_blocks %}
  <li
class="drye-stretch__stop {% if forloop.first %}drye-stretch__stop--guided{% endif %} {% if block.settings.inverted %}drye-stretch__stop--final{% endif %} dryeNEW-reveal"    {{ block.shopify_attributes }}
  >
    <button
      class="drye-stretch__trigger"
      type="button"
      aria-expanded="false"
      aria-controls="drye-stretch-panel-{{ section.id }}-{{ block.id }}"
    >
      <span class="drye-stretch__clock" aria-hidden="true">
        <svg viewBox="0 0 60 60" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="30" cy="30" r="26" stroke-width="1.5"/>
          <line x1="30" y1="7" x2="30" y2="12" stroke-width="1.5"/>
          <line x1="53" y1="30" x2="48" y2="30" stroke-width="1.5"/>
          <line x1="30" y1="53" x2="30" y2="48" stroke-width="1.5"/>
          <line x1="7" y1="30" x2="12" y2="30" stroke-width="1.5"/>
          <line x1="30" y1="30" x2="30" y2="11" stroke-width="1.5" transform="rotate(0, 30, 30)"/>
          <line x1="30" y1="30" x2="30" y2="16" stroke-width="2.5" transform="rotate({{ block.settings.clock_angle }}, 30, 30)"/>
          <circle cx="30" cy="30" r="2.5" fill="currentColor" stroke="none"/>
        </svg>
      </span>

      <span class="drye-stretch__heading-block">
        {% if block.settings.time != blank %}
          <span class="dryeNEW-stat-number drye-stretch__time">
            {{ block.settings.time }}
          </span>
        {% endif %}

        {% if block.settings.title != blank %}
          <span class="dryeNEW-body--sm drye-stretch__title">
            {{ block.settings.title }}
          </span>
        {% endif %}
      </span>

      <span class="drye-stretch__click-cue" aria-hidden="true">
        <span class="dryeNEW-body--lg drye-stretch__click-cue-label">
          {% if forloop.last %}
            Finish shift
          {% else %}
            Next stop
          {% endif %}
        </span>
      </span>

      <span class="drye-stretch__toggle" aria-hidden="true"></span>
    </button>

    <div class="drye-stretch__body" id="drye-stretch-panel-{{ section.id }}-{{ block.id }}">
      <div class="drye-stretch__body-inner">
        <div class="drye-stretch__body-content">
          <ul class="drye-stretch__beat-list">
            {% if block.settings.bullet_1 != blank %}
              <li class="dryeNEW-body">{{ block.settings.bullet_1 }}</li>
            {% endif %}

            {% if block.settings.bullet_2 != blank %}
              <li class="dryeNEW-body">{{ block.settings.bullet_2 }}</li>
            {% endif %}

            {% if block.settings.bullet_3 != blank %}
              <li class="dryeNEW-body">{{ block.settings.bullet_3 }}</li>
            {% endif %}
          </ul>

          <div class="drye-stretch__proof">
            {% if block.settings.proof_label != blank %}
              <span class="dryeNEW-micro drye-stretch__proof-label">
                {{ block.settings.proof_label }}
              </span>
            {% endif %}

            {% if block.settings.proof_value != blank %}
              <span class="dryeNEW-stat-number drye-stretch__proof-value">
                {{ block.settings.proof_value }}
              </span>
            {% endif %}

            {% if block.settings.proof_sub != blank %}
              <span class="dryeNEW-body--caption drye-stretch__proof-sub">
                {{ block.settings.proof_sub }}
              </span>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </li>
{% endfor %}
    </ol>
  </div>

</div>

    {% assign compound_blocks = section.blocks | where: 'type', 'compound_column' %}

    {% if compound_blocks.size > 0 %}
      <div class="drye-stretch__compound dryeNEW-reveal">
        {% for block in compound_blocks %}
          <div class="drye-stretch__compound-cell" {{ block.shopify_attributes }}>
            {% if block.settings.label != blank %}
              <span class="dryeNEW-micro drye-stretch__compound-label">
                {{ block.settings.label }}
              </span>
            {% endif %}

            {% if block.settings.value != blank %}
              <span class="dryeNEW-stat-number drye-stretch__compound-value">
                {{ block.settings.value }}
              </span>
            {% endif %}

            {% if block.settings.desc != blank %}
              <span class="dryeNEW-body--caption drye-stretch__compound-desc">
                {{ block.settings.desc }}
              </span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.cta_label != blank %}
      <div class="drye-stretch__cta-wrap dryeNEW-reveal">
        {% if section.settings.cta_url != blank %}
          <a href="{{ section.settings.cta_url }}" class="drye-stretch__cta">
            {{ section.settings.cta_label }}
          </a>
        {% else %}
          <button type="button" class="drye-stretch__cta">
            {{ section.settings.cta_label }}
          </button>
        {% endif %}

        {% if section.settings.cta_note != blank %}
          <div class="dryeNEW-body--caption drye-stretch__cta-note">
            {{ section.settings.cta_note }}
          </div>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('drye-stretch-{{ section.id }}');
    if (!section) return;

    const stops = Array.from(section.querySelectorAll('.drye-stretch__stop'));

    const setGuidedStop = () => {
      const openIndex = stops.findIndex((item) => item.classList.contains('is-open'));

      stops.forEach((item, index) => {
        item.classList.toggle('is-guided', index === openIndex + 1);
      });
    };

    stops.forEach((stop) => {
      const trigger = stop.querySelector('.drye-stretch__trigger');
      if (!trigger) return;

      trigger.addEventListener('click', () => {
        const isOpen = stop.classList.contains('is-open');

        stops.forEach((item) => {
          item.classList.remove('is-open');

          const itemTrigger = item.querySelector('.drye-stretch__trigger');
          if (itemTrigger) {
            itemTrigger.setAttribute('aria-expanded', 'false');
          }
        });

        if (!isOpen) {
          stop.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }

        setGuidedStop();
      });
    });

    setGuidedStop();
  })();
</script>

