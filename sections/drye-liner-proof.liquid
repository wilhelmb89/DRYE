{{ 'drye-liner-proof.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section drye-liner-proof drye-liner-proof--stat-{{ section.settings.stat_scheme | default: 'dark' }}" id="{{ section.settings.section_id | default: 'liner-proof' }}" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container drye-liner-proof__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="dryeNEW-micro drye-liner-proof__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="dryeNEW-h2 drye-liner-proof__heading">
        {{ section.settings.heading }}
        {%- if section.settings.heading_emphasis != blank -%}
          <span class="dryeNEW-editorial">{{ section.settings.heading_emphasis }}</span>
        {%- endif -%}
        {%- if section.settings.heading_suffix != blank -%}
          {{ section.settings.heading_suffix }}
        {%- endif -%}
      </h2>
    {%- endif -%}

    <div class="drye-liner-proof__media-wrap">
      <div class="drye-liner-proof__media">
        {%- if section.settings.media_badge != blank -%}
          <span class="drye-liner-proof__media-badge">{{ section.settings.media_badge }}</span>
        {%- endif -%}

        {%- if section.settings.video_url != blank -%}
          {%- assign proof_v = section.settings.video_url -%}
          {%- assign proof_v_lower = proof_v | downcase -%}
          {%- if proof_v_lower contains '.mp4' or proof_v_lower contains '.webm' -%}
            {%- comment -%} Direct video file (Cloudflare R2 / hosted MP4) {%- endcomment -%}
            <video
              class="drye-liner-proof__media-video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              {%- if section.settings.media_image != blank %} poster="{{ section.settings.media_image | image_url: width: 1600 }}"{% endif -%}
            >
              <source src="{{ proof_v }}" type="video/mp4">
            </video>
          {%- else -%}
            {%- comment -%} Cloudflare Stream (or other) iframe embed — append autoplay params {%- endcomment -%}
            {%- if proof_v contains '?' -%}{%- assign proof_sep = '&' -%}{%- else -%}{%- assign proof_sep = '?' -%}{%- endif -%}
            <div class="drye-liner-proof__media-embed">
              <iframe
                src="{{ proof_v }}{{ proof_sep }}autoplay=true&muted=true&loop=true&controls=false"
                loading="lazy"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                title="{{ section.settings.media_placeholder_title | escape }}"
              ></iframe>
            </div>
          {%- endif -%}
        {%- elsif section.settings.media_image != blank -%}
          {{
            section.settings.media_image
            | image_url: width: 1600
            | image_tag:
              class: 'drye-liner-proof__media-image',
              alt: section.settings.media_placeholder_title,
              loading: 'lazy',
              widths: '480, 720, 1000, 1400, 1600'
          }}
        {%- else -%}
          <div class="drye-liner-proof__placeholder">
            {%- if section.settings.media_placeholder_label != blank -%}
              <span class="drye-liner-proof__placeholder-label">{{ section.settings.media_placeholder_label }}</span>
            {%- endif -%}
            {%- if section.settings.media_placeholder_title != blank -%}
              <span class="drye-liner-proof__placeholder-title">{{ section.settings.media_placeholder_title }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="drye-liner-proof__stat">
      <div class="drye-liner-proof__stat-row">
        <span class="drye-liner-proof__stat-name">{{ section.settings.cotton_label }}</span>
        <span class="drye-liner-proof__stat-num">{{ section.settings.cotton_value }}</span>
      </div>
      <div class="drye-liner-proof__stat-row drye-liner-proof__stat-row--drye">
        <span class="drye-liner-proof__stat-name">{{ section.settings.drye_label }}</span>
        <span class="drye-liner-proof__stat-num">{{ section.settings.drye_value }}</span>
      </div>
    </div>

    {%- if section.settings.source_text != blank -%}
      <div class="drye-liner-proof__source">{{ section.settings.source_text }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <div class="drye-liner-proof__cta-wrap">
        <a class="dryeNEW-button drye-liner-proof__cta" href="{{ section.settings.cta_url | default: '#' }}">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "DRYE Liner Proof",
  "tag": "section",
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "default": "liner-proof"
    },
    {
      "type": "select",
      "id": "stat_scheme",
      "label": "Stat block color scheme",
      "options": [
        { "value": "dark", "label": "Dark (navy)" },
        { "value": "light", "label": "Light (white)" }
      ],
      "default": "dark"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent lab test"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Proven to move moisture"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasized number",
      "default": "82×"
    },
    {
      "type": "text",
      "id": "heading_suffix",
      "label": "Heading suffix",
      "default": "further."
    },
    {
      "type": "text",
      "id": "media_badge",
      "label": "Media badge text",
      "default": "WickView® test · 2025"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4 — e.g. Cloudflare R2/Stream)",
      "info": "If set, plays instead of the image. Autoplays muted and loops. Use a direct .mp4 URL."
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Media image (also used as video poster)"
    },
    {
      "type": "text",
      "id": "media_placeholder_label",
      "label": "Placeholder label (shown when no image)",
      "default": "Reserved for lab test still"
    },
    {
      "type": "text",
      "id": "media_placeholder_title",
      "label": "Placeholder title (shown when no image)",
      "default": "Water absorption test — Textile Fashion Center, Swedish School of Textiles"
    },
    {
      "type": "text",
      "id": "cotton_label",
      "label": "Cotton row label",
      "default": "Cotton liner"
    },
    {
      "type": "text",
      "id": "cotton_value",
      "label": "Cotton row value",
      "default": "99"
    },
    {
      "type": "text",
      "id": "drye_label",
      "label": "DRYE row label",
      "default": "DRYE Liner"
    },
    {
      "type": "text",
      "id": "drye_value",
      "label": "DRYE row value",
      "default": "8,111"
    },
    {
      "type": "richtext",
      "id": "source_text",
      "label": "Source citation",
      "default": "<p>Wick Flow Index — higher = faster moisture transfer away from skin.<br>Independent testing, Swedish School of Textiles, 2025.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "See the test"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ],
  "presets": [
    {
      "name": "DRYE Liner Proof"
    }
  ]
}
{% endschema %}
