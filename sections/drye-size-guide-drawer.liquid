{% liquid
  assign section_id = 'drye-size-guide-' | append: section.id
  assign default_heading = 'Size Guide'
  assign default_diag_label = 'How to measure'
  assign default_circ_label = 'Hand circumference'
  assign default_circ_desc = 'Measure around your palm, below the knuckles, without the thumb. This decides your size.'
  assign default_tip_html = '<strong>Between sizes?</strong> The liner is thin and stretchable. Hand circumference is the best guide for a comfortable fit — size up if unsure.'
  assign default_footer_label = "Still unsure? We'll help —"
  assign default_email = 'info@drye.se'
  assign default_cta_label = 'Shop DRYE Liners →'
  assign default_cta_link = '#'

  assign default_shortcut_nitrile = 'Most people order the same number as their nitrile.'
  assign default_shortcut_hv = 'HV gloves run loose. Order one size up from your HV size.'
  assign default_guarantee = 'Wrong size? If you measured against our guide and it still doesn’t fit, we ship the correct size at no cost.'
  assign default_glove_q = 'Which gloves do you wear?'
  assign default_glove_nitrile = 'Nitrile'
  assign default_glove_hv = 'HV / Class 0'
  assign default_head_nitrile = 'Your nitrile'
  assign default_head_hv = 'Your HV glove'
  assign default_head_size = 'DRYE Size'
  assign default_head_circ = 'Hand circumference'
  assign default_size_word = 'Size'

  assign head_size = section.settings.table_heading_size | default: default_head_size
  assign head_circ = section.settings.table_heading_circ | default: default_head_circ
  assign size_word = section.settings.size_word | default: default_size_word
%}

{{ 'section-drye-size-guide-drawer.css' | asset_url | stylesheet_tag }}


<!-- OVERLAY -->
<div
  class="overlay"
  id="{{ section_id }}-overlay"
  onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.close('{{ section_id }}')"
></div>

<!-- DRAWER -->
<div
  class="drawer"
  id="{{ section_id }}-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="{{ section.settings.drawer_aria_label | escape }}"
  data-glove="nitrile"
  data-unit="mm"
  data-glove-provisional="{% if section.settings.glove_provisional == false %}false{% else %}true{% endif %}"
  data-shortcut-nitrile="{{ section.settings.shortcut_nitrile | default: default_shortcut_nitrile | escape }}"
  data-shortcut-hv="{{ section.settings.shortcut_hv | default: default_shortcut_hv | escape }}"
  data-head-nitrile="{{ section.settings.glove_head_nitrile | default: default_head_nitrile | escape }}"
  data-head-hv="{{ section.settings.glove_head_hv | default: default_head_hv | escape }}"
  data-head-size="{{ head_size | escape }}"
  data-head-circ="{{ head_circ | escape }}"
  data-size-word="{{ size_word | escape }}"
>

  <!-- HEADER -->
  <div class="drawer-header">
    <span class="drawer-title">{{ section.settings.heading | default: default_heading }}</span>
    <button
      class="drawer-close"
      type="button"
      onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.close('{{ section_id }}')"
      aria-label="{{ section.settings.close_label | escape }}"
    >✕</button>
  </div>

  <!-- BODY -->
  <div class="drawer-body">

    <!-- SHORTCUT + GUARANTEE (top) -->
    <div class="sg-top">
      <p class="sg-shortcut" id="{{ section_id }}-shortcut">{{ section.settings.shortcut_nitrile | default: default_shortcut_nitrile }}</p>
      {% assign sg_guarantee = section.settings.guarantee_text | default: default_guarantee %}
      {% if sg_guarantee != blank %}
        <div class="sg-guarantee">{{ sg_guarantee }}</div>
      {% endif %}
    </div>

    <!-- DIAGRAM (circumference only) -->
    <div class="diagram-section">
      <span class="diag-label">{{ section.settings.diagram_label | default: default_diag_label }}</span>
      <div class="diag-wrap">

<!-- Hand image -->
<div class="hand-svg-wrap">
  {% if section.settings.hand_image != blank %}
    <img
      src="{{ section.settings.hand_image | image_url: width: 400 }}"
      alt="{{ section.settings.hand_image_alt | default: 'How to measure your hand' | escape }}"
      width="{{ section.settings.hand_image.width }}"
      height="{{ section.settings.hand_image.height }}"
      loading="lazy"
    >
  {% endif %}
</div>

        <!-- Callout — circumference decides the size -->
        <div class="diag-callouts">
          <div class="diag-callout">
            <div class="dc-name circ"><span class="dc-dot circ"></span>{{ section.settings.circ_label | default: default_circ_label }}</div>
            <p class="dc-desc">{{ section.settings.circ_desc | default: default_circ_desc }}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- TABLE -->
    <div class="table-section">

      <!-- Glove-type toggle (hidden until glove data is filled in) -->
      <div class="glove-toggle" id="{{ section_id }}-glove-toggle" hidden>
        <p class="glove-toggle__q">{{ section.settings.glove_q | default: default_glove_q }}</p>
        <div class="seg" role="group" aria-label="{{ section.settings.glove_q | default: default_glove_q | escape }}">
          <button
            class="seg-btn"
            type="button"
            data-glove="nitrile"
            aria-pressed="true"
            onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.setGlove('{{ section_id }}', 'nitrile', this)"
          >{{ section.settings.glove_nitrile_label | default: default_glove_nitrile }}</button>
          <button
            class="seg-btn"
            type="button"
            data-glove="hv"
            aria-pressed="false"
            onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.setGlove('{{ section_id }}', 'hv', this)"
          >{{ section.settings.glove_hv_label | default: default_glove_hv }}</button>
        </div>
      </div>

      <!-- Unit toggle -->
      <div class="unit-toggle">
        <button
          class="unit-btn active"
          type="button"
          onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.setUnit('{{ section_id }}', 'mm', this)"
        >{{ section.settings.unit_mm_label }}</button>
        <button
          class="unit-btn"
          type="button"
          onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.setUnit('{{ section_id }}', 'in', this)"
        >{{ section.settings.unit_in_label }}</button>
      </div>

      <table class="size-table" id="{{ section_id }}-size-table">
        <thead>
          <tr id="{{ section_id }}-thead-row"><!-- filled by JS --></tr>
        </thead>
        <tbody id="{{ section_id }}-table-body">
          <!-- filled by JS -->
        </tbody>
      </table>

      <noscript>
        <table class="size-table">
          <thead><tr><th>{{ head_size }}</th><th>{{ head_circ }}</th></tr></thead>
          <tbody>
            {% for block in section.blocks %}
              <tr>
                <td class="st-size">{{ size_word }} {{ block.settings.size }}</td>
                <td class="st-circ">{{ block.settings.circ_min_mm }}–{{ block.settings.circ_max_mm }} mm</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </noscript>
    </div>

    <!-- TIP -->
    <div class="size-tip">
      <p>{{ section.settings.tip_html | default: default_tip_html }}</p>
    </div>

  </div><!-- /drawer-body -->

  <!-- FOOTER -->
  <div class="drawer-footer">
    <p class="drawer-footer-label">
      {{ section.settings.footer_label | default: default_footer_label }}
      <a href="mailto:{{ section.settings.email | default: default_email }}" style="color:var(--emerald);text-decoration:none;">
        {{ section.settings.email | default: default_email }}
      </a>
    </p>
    <a
      href="{{ section.settings.cta_link | default: default_cta_link }}"
      class="btn-shop"
      onclick="window.DryeSizeGuideDrawer && window.DryeSizeGuideDrawer.close('{{ section_id }}')"
    >
      {{ section.settings.cta_label | default: default_cta_label }}
    </a>
  </div>

</div>

<script>
  window.DryeSizeGuideDrawer = window.DryeSizeGuideDrawer || {
    mmToIn(mm) {
      return (mm / 25.4).toFixed(1);
    },

    getSizes(sectionId) {
      const sizeMap = {
        {{ section_id | json }}: [
          {% for block in section.blocks %}
            {
              size: {{ block.settings.size | json }},
              circMM: [{{ block.settings.circ_min_mm | default: 0 }}, {{ block.settings.circ_max_mm | default: 0 }}],
              nitrile: {{ block.settings.nitrile_val | default: '' | json }},
              hv: {{ block.settings.hv_val | default: '' | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      };

      const raw = sizeMap[sectionId] || [];
      // Provisional mapping: until real glove sizes are entered per row, derive them from
      // the copy rule — nitrile = same number as the DRYE size, HV = one size up.
      const drawer = document.getElementById(sectionId + '-drawer');
      const prov = drawer && drawer.dataset.gloveProvisional === 'true';
      return raw.map(function(s) {
        let n = (s.nitrile || '').trim();
        let h = (s.hv || '').trim();
        if (prov) {
          if (!n) { n = s.size; }
          if (!h) { const num = parseInt(s.size, 10); h = isNaN(num) ? '' : String(num - 1); }
        }
        return { size: s.size, circMM: s.circMM, nitrile: n, hv: h };
      });
    },

    activeGloveKey(sizes, chosen) {
      const anyN = sizes.some(function(s) { return (s.nitrile || '').trim() !== ''; });
      const anyH = sizes.some(function(s) { return (s.hv || '').trim() !== ''; });
      if (anyN && anyH) return chosen || 'nitrile';
      if (anyN) return 'nitrile';
      if (anyH) return 'hv';
      return null;
    },

    renderTable(sectionId, unit) {
      const drawer = document.getElementById(sectionId + '-drawer');
      const theadRow = document.getElementById(sectionId + '-thead-row');
      const tbody = document.getElementById(sectionId + '-table-body');
      if (!drawer || !theadRow || !tbody) return;

      const ds = drawer.dataset;
      const sizes = this.getSizes(sectionId);
      const anyN = sizes.some(function(s) { return (s.nitrile || '').trim() !== ''; });
      const anyH = sizes.some(function(s) { return (s.hv || '').trim() !== ''; });
      const showToggle = anyN && anyH;
      const gkey = this.activeGloveKey(sizes, ds.glove);

      // Glove toggle visibility + pressed state
      const toggle = document.getElementById(sectionId + '-glove-toggle');
      if (toggle) {
        toggle.hidden = !showToggle;
        toggle.querySelectorAll('.seg-btn').forEach(function(b) {
          b.setAttribute('aria-pressed', b.getAttribute('data-glove') === gkey ? 'true' : 'false');
        });
      }

      // Shortcut line follows the active glove (defaults to nitrile copy)
      const shortcut = document.getElementById(sectionId + '-shortcut');
      if (shortcut) {
        const txt = gkey === 'hv' ? ds.shortcutHv : ds.shortcutNitrile;
        if (txt) shortcut.textContent = txt;
      }

      // Header — glove column first (only when a glove column is shown)
      let head = '';
      if (gkey) {
        head += '<th class="h-glove">' + (gkey === 'hv' ? ds.headHv : ds.headNitrile) + '</th>';
      }
      head += '<th>' + ds.headSize + '</th><th>' + ds.headCirc + '</th>';
      theadRow.innerHTML = head;

      // Body
      const sizeWord = ds.sizeWord || 'Size';
      tbody.innerHTML = sizes.map(function(s) {
        const c = unit === 'mm'
          ? s.circMM[0] + '–' + s.circMM[1] + ' mm'
          : window.DryeSizeGuideDrawer.mmToIn(s.circMM[0]) + '–' + window.DryeSizeGuideDrawer.mmToIn(s.circMM[1]) + '"';

        let cells = '';
        if (gkey) {
          const v = ((gkey === 'hv' ? s.hv : s.nitrile) || '').trim();
          cells += '<td class="st-glove' + (v ? '' : ' empty') + '">' + (v || '—') + '</td>';
        }
        cells += '<td class="st-size">' + sizeWord + ' ' + s.size + '</td>' +
                 '<td class="st-circ">' + c + '</td>';
        return '<tr>' + cells + '</tr>';
      }).join('');
    },

    setUnit(sectionId, unit, btn) {
      const drawer = document.getElementById(sectionId + '-drawer');
      if (!drawer) return;

      drawer.dataset.unit = unit;

      drawer.querySelectorAll('.unit-btn').forEach(function(button) {
        button.classList.remove('active');
      });

      if (btn) btn.classList.add('active');

      this.renderTable(sectionId, unit);
    },

    setGlove(sectionId, glove, btn) {
      const drawer = document.getElementById(sectionId + '-drawer');
      if (!drawer) return;

      drawer.dataset.glove = glove;
      this.renderTable(sectionId, drawer.dataset.unit || 'mm');
    },

    open(sectionId) {
      const drawer = document.getElementById(sectionId + '-drawer');
      const overlay = document.getElementById(sectionId + '-overlay');

      if (!drawer || !overlay) return;

      drawer.classList.add('open');
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    },

    close(sectionId) {
      const drawer = document.getElementById(sectionId + '-drawer');
      const overlay = document.getElementById(sectionId + '-overlay');

      if (!drawer || !overlay) return;

      drawer.classList.remove('open');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    },

    bindEscape() {
      if (this.escapeBound) return;
      this.escapeBound = true;

      document.addEventListener('keydown', function(e) {
        if (e.key !== 'Escape') return;

        document.querySelectorAll('.drawer.open').forEach(function(drawer) {
          drawer.classList.remove('open');
        });

        document.querySelectorAll('.overlay.open').forEach(function(overlay) {
          overlay.classList.remove('open');
        });

        document.body.style.overflow = '';
      });
    },

    bindExternalTriggers() {
      if (this.externalTriggersBound) return;
      this.externalTriggersBound = true;

      document.addEventListener('click', function(e) {
        const trigger = e.target.closest('.js-open-size-guide');
        if (!trigger) return;

        const firstDrawer = document.querySelector('.drawer[id$="-drawer"]');
        if (!firstDrawer) return;

        const sectionId = firstDrawer.id.replace('-drawer', '');

        if (window.DryeSizeGuideDrawer) {
          window.DryeSizeGuideDrawer.open(sectionId);
        }
      });
    },

    init(sectionId) {
      this.bindEscape();
      this.bindExternalTriggers();
      const drawer = document.getElementById(sectionId + '-drawer');
      if (drawer) {
        if (!drawer.dataset.unit) drawer.dataset.unit = 'mm';
        if (!drawer.dataset.glove) drawer.dataset.glove = 'nitrile';
        this.renderTable(sectionId, drawer.dataset.unit);
      } else {
        this.renderTable(sectionId, 'mm');
      }
    }
  };

  window.DryeSizeGuideDrawer.init({{ section_id | json }});
</script>

