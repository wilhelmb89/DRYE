{{ 'dryeNEW-professions.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section dryeNEW-professions"
  id="{{ section.settings.section_id | default: 'professions' }}"
  data-section-id="{{ section.id }}"
  style="
    --dryeNEW-professions-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --dryeNEW-professions-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --dryeNEW-professions-pt-desktop: {{ section.settings.padding_top_desktop }}px;
    --dryeNEW-professions-pb-desktop: {{ section.settings.padding_bottom_desktop }}px;
  "
>
  <div class="dryeNEW-container">
    <div class="dryeNEW-grid dryeNEW-professions__grid">

      {% if section.settings.heading_main != blank or section.settings.heading_em != blank %}
        <h2 class="dryeNEW-professions__heading">
          {{ section.settings.heading_main | newline_to_br }}
          {% if section.settings.heading_em != blank %}
            <em class="dryeNEW-professions__heading-em">{{ section.settings.heading_em | newline_to_br }}</em>
          {% endif %}
        </h2>
      {% endif %}

      <div class="dryeNEW-professions__tabs-wrap">
        <div class="dryeNEW-professions__tabs" role="tablist" aria-label="{{ section.settings.tabs_aria_label }}">
          {% for block in section.blocks %}
            {% if block.type == 'profession_panel' %}
              <button
                class="dryeNEW-professions__tab{% if forloop.first %} is-active{% endif %}"
                type="button"
                role="tab"
                id="dryeNEW-professions-tab-{{ section.id }}-{{ block.id }}"
                aria-controls="dryeNEW-professions-panel-{{ section.id }}-{{ block.id }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                data-tab-target="dryeNEW-professions-panel-{{ section.id }}-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.tab_label }}
              </button>
            {% endif %}
          {% endfor %}
        </div>

        <div class="dryeNEW-professions__panels">
          {% for block in section.blocks %}
            {% if block.type == 'profession_panel' %}
              <div
                class="dryeNEW-professions__panel{% if forloop.first %} is-active{% endif %}"
                id="dryeNEW-professions-panel-{{ section.id }}-{{ block.id }}"
                role="tabpanel"
                aria-labelledby="dryeNEW-professions-tab-{{ section.id }}-{{ block.id }}"
                {% unless forloop.first %}hidden{% endunless %}
              >
                <div class="dryeNEW-professions__panel-inner">
                  <div class="dryeNEW-professions__panel-left">
                    {% if block.settings.pain_label != blank %}
                      <div class="dryeNEW-professions__pain-label">
                        {{ block.settings.pain_label }}
                      </div>
                    {% endif %}

                    {% if block.settings.panel_title != blank %}
                      <h3 class="dryeNEW-professions__panel-title">
                        {{ block.settings.panel_title | newline_to_br }}
                      </h3>
                    {% endif %}

                    <ul class="dryeNEW-professions__pain-list">
                      {% if block.settings.pain_1 != blank %}<li>{{ block.settings.pain_1 }}</li>{% endif %}
                      {% if block.settings.pain_2 != blank %}<li>{{ block.settings.pain_2 }}</li>{% endif %}
                      {% if block.settings.pain_3 != blank %}<li>{{ block.settings.pain_3 }}</li>{% endif %}
                      {% if block.settings.pain_4 != blank %}<li>{{ block.settings.pain_4 }}</li>{% endif %}
                      {% if block.settings.pain_5 != blank %}<li>{{ block.settings.pain_5 }}</li>{% endif %}
                    </ul>
                  </div>

                  <div class="dryeNEW-professions__panel-right">
                    {% if block.settings.quote_label != blank %}
                      <div class="dryeNEW-professions__quote-label">
                        {{ block.settings.quote_label }}
                      </div>
                    {% endif %}

                    {% if block.settings.quote != blank %}
                      <blockquote class="dryeNEW-professions__quote">
                        {{ block.settings.quote }}
                      </blockquote>
                    {% endif %}

                    {% if block.settings.quote_source_strong != blank or block.settings.quote_source_tail != blank %}
                      <p class="dryeNEW-professions__quote-src">
                        {% if block.settings.quote_source_strong != blank %}
                          <strong>{{ block.settings.quote_source_strong }}</strong>
                        {% endif %}
                        {% if block.settings.quote_source_tail != blank %}
                          — {{ block.settings.quote_source_tail }}
                        {% endif %}
                      </p>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const tabs = Array.from(section.querySelectorAll('.dryeNEW-professions__tab'));
    const panels = Array.from(section.querySelectorAll('.dryeNEW-professions__panel'));

    const activateTab = (tab) => {
      const targetId = tab.getAttribute('data-tab-target');

      tabs.forEach((btn) => {
        const isActive = btn === tab;
        btn.classList.toggle('is-active', isActive);
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        const isActive = panel.id === targetId;
        panel.classList.toggle('is-active', isActive);
        panel.hidden = !isActive;
      });
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateTab(tab));

      tab.addEventListener('keydown', (event) => {
        const currentIndex = tabs.indexOf(tab);
        let nextIndex = currentIndex;

        if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabs.length;
        if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;

        if (nextIndex !== currentIndex) {
          event.preventDefault();
          tabs[nextIndex].focus();
          activateTab(tabs[nextIndex]);
        }
      });
    });
  })();
</script>

