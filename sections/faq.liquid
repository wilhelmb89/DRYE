{% comment %}
  DRYE – FAQ section (layout only, Base controls colors/fonts)
{% endcomment %}

{{ 'faq-section.css' | asset_url | stylesheet_tag }}

{%- assign ss = section.settings -%}

<section
  class="drye-faq-section drye-section
    {% if ss.color_scheme == 'dark' %}
      drye-section--dark
    {% else %}
      drye-section--light
    {% endif %}"
  style="
    --faq-pad-top: {{ ss.pad_top }}px;
    --faq-pad-bottom: {{ ss.pad_bottom }}px;
    --faq-pad-top-mobile: {{ ss.pad_top_mobile }}px;
    --faq-pad-bottom-mobile: {{ ss.pad_bottom_mobile }}px;
  "
>
  <div class="drye-faq-inner page-width">
    <div class="drye-faq-accordion">
      {%- for block in section.blocks -%}
        {%- assign input_id = 'faq-' | append: section.id | append: '-' | append: block.id -%}

        <div class="drye-faq-item" {{ block.shopify_attributes }}>
          <input
            class="drye-faq-item-input"
            type="checkbox"
            id="{{ input_id }}"
            {% if ss.open_first and forloop.first %}checked{% endif %}
          >

          <label class="drye-faq-item-label" for="{{ input_id }}">
            <h4 class="q">{{ block.settings.title }}</h4>

            <div class="drye-faq-plus" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <line
                  class="vertical-line"
                  x1="12"
                  y1="5"
                  x2="12"
                  y2="19"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
                <line
                  class="horizontal-line"
                  x1="5"
                  y1="12"
                  x2="19"
                  y2="12"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>
            </div>
          </label>

          <div class="drye-faq-content-wrapper">
            <div class="drye-faq-content">
              <div class="drye-faq-body">
                {{ block.settings.body }}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {
        "@type": "Question",
        "name": {{ block.settings.title | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.body | strip_html | json }}
        }
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "drye-faq-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "light",
      "options": [
        { "value": "light", "label": "Light (white background)" },
        { "value": "dark", "label": "Dark (black background)" }
      ]
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": true
    },

    {
      "type": "range",
      "id": "pad_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "default": 160,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 400,
      "step": 4,
      "default": 300,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "pad_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 112,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Question / Title",
          "default": "Sample question title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Answer / Body",
          "default": "<p>Answer text here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    { "name": "FAQ" }
  ]
}
{% endschema %}
