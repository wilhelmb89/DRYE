{{ 'section-story-gallery.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section story-gallery" id="StoryGallery-{{ section.id }}" data-section-id="{{ section.id }}" data-drye-section data-section-index="19" data-section-name="gallery_drye">
  <div class="dryeNEW-container">

    <div class="story-gallery__intro dryeNEW-reveal">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro story-gallery__eyebrow">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank or section.settings.heading_emphasis != blank %}
        <h2 class="dryeNEW-h2 story-gallery__heading">
          {% if section.settings.heading != blank %}
            <span class="story-gallery__heading-main">
              {{ section.settings.heading }}
            </span>
          {% endif %}

          {% if section.settings.heading_emphasis != blank %}
            <span class="dryeNEW-em story-gallery__heading-emphasis">
              {{ section.settings.heading_emphasis }}
            </span>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <div class="dryeNEW-body--caption story-gallery__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="dryeNEW-body story-gallery__sub">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 0 %}
      <div class="story-gallery__strip-wrap dryeNEW-reveal dryeNEW-rd1">
        <button
  class="story-gallery__arrow story-gallery__arrow--prev"
  type="button"
  data-story-prev
  aria-label="Previous"
>
  ←
</button>

<button
  class="story-gallery__arrow story-gallery__arrow--next"
  type="button"
  data-story-next
  aria-label="Next"
>
  →
</button>
        <div class="story-gallery__strip" data-story-strip>
          {% for block in section.blocks %}
            <figure class="story-gallery__card" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <div class="story-gallery__media">
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag:
                      class: 'story-gallery__img',
                      loading: 'lazy',
                      sizes: '(min-width: 960px) 33vw, 85vw',
                      alt: block.settings.image_alt
                  }}
                </div>
              {% endif %}

              {% if block.settings.label != blank or block.settings.caption != blank %}
                <figcaption class="story-gallery__caption-wrap">
                  {% if block.settings.label != blank %}
                    <span class="dryeNEW-micro story-gallery__item-label">
                      {{ block.settings.label }}
                    </span>
                  {% endif %}

                  {% if block.settings.caption != blank %}
                    <div class="dryeNEW-body--sm story-gallery__caption">
                      {{ block.settings.caption }}
                    </div>
                  {% endif %}
                </figcaption>
              {% endif %}
            </figure>
          {% endfor %}
        </div>

        <div class="dryeNEW-micro story-gallery__swipe-hint" data-story-swipe-hint aria-hidden="true">
          {{ section.settings.swipe_label }}
        </div>

        <div class="story-gallery__fade" aria-hidden="true"></div>
      </div>
    {% endif %}

    {% if section.settings.cta_label != blank or section.settings.cta_note != blank %}
      <div class="story-gallery__cta-wrap dryeNEW-reveal dryeNEW-rd2">
        {% if section.settings.cta_label != blank %}
          <a
            class="dryeNEW-button dryeNEW-body--caption story-gallery__cta"
            href="{{ section.settings.cta_url | default: '#' }}"
          >
            {{ section.settings.cta_label }}
          </a>
        {% endif %}

        {% if section.settings.cta_note != blank %}
          <div class="dryeNEW-body--caption story-gallery__cta-note">
            {{ section.settings.cta_note }}
          </div>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('StoryGallery-{{ section.id }}');
    if (!section) return;

    const strip = section.querySelector('[data-story-strip]');
    const hint = section.querySelector('[data-story-swipe-hint]');
    const prevBtn = section.querySelector('[data-story-prev]');
    const nextBtn = section.querySelector('[data-story-next]');

    if (!strip) return;

    const desktopMq = window.matchMedia('(min-width: 960px)');
    let hasInteracted = false;

    const getStep = () => {
      const card = strip.querySelector('.story-gallery__card');
      if (!card) return strip.clientWidth * 0.85;

      const styles = window.getComputedStyle(strip);
      const gap = parseFloat(styles.columnGap || styles.gap) || 0;

      return card.getBoundingClientRect().width + gap;
    };

    const scrollByStep = (dir) => {
      strip.scrollBy({
        left: getStep() * dir,
        behavior: 'smooth'
      });
    };

    if (prevBtn) {
      prevBtn.addEventListener('click', () => scrollByStep(-1));
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => scrollByStep(1));
    }

    const updateHint = () => {
      if (!hint) return;

      if (desktopMq.matches) {
        hint.classList.add('is-hidden');
        return;
      }

      const maxScroll = strip.scrollWidth - strip.clientWidth;

      if (maxScroll <= 8 || strip.scrollLeft > 16 || hasInteracted) {
        hint.classList.add('is-hidden');
      } else {
        hint.classList.remove('is-hidden');
      }
    };

    const hideHintOnInteraction = () => {
      hasInteracted = true;

      if (hint) {
        hint.classList.add('is-hidden');
      }
    };

    strip.addEventListener('scroll', updateHint, { passive: true });
    strip.addEventListener('touchstart', hideHintOnInteraction, { passive: true });
    strip.addEventListener('pointerdown', hideHintOnInteraction, { passive: true });

    window.addEventListener('resize', updateHint);

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      setTimeout(() => {
        if (strip.scrollWidth <= strip.clientWidth) return;

        strip.scrollBy({ left: 18, behavior: 'smooth' });

        setTimeout(() => {
          strip.scrollBy({ left: -18, behavior: 'smooth' });
        }, 400);
      }, 700);
    }

    updateHint();
  })();
</script>

{% schema %}
{
  "name": "Story gallery v2",
  "tag": "section",
  "class": "shopify-section--story-gallery",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "From first wear to months of shifts"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "One layer under the nitrile."
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "Heading emphasis",
      "default": "Day one to month six."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small line under heading",
      "default": "0.4mm thin. No chemicals. No coatings. Fits inside any work glove."
    },
{
  "type": "textarea",
  "id": "body",
  "label": "Body"
},
    {
      "type": "text",
      "id": "swipe_label",
      "label": "Swipe label",
      "default": "Swipe"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Order now →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    },
    {
      "type": "text",
      "id": "cta_note",
      "label": "CTA note",
      "default": "as"
    }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Green label",
          "default": "DAY 1"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Sweat moves out from the first pull-on. Skin side stays dry."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story gallery v2",
      "blocks": [
        {
          "type": "story",
          "settings": {
            "label": "DAY 1",
            "caption": "Sweat moves out from the first pull-on. Skin side stays dry."
          }
        },
        {
          "type": "story",
          "settings": {
            "label": "DAY 3",
            "caption": "By the third shift, the cycle starts to break. Less sting. Less swap-outs."
          }
        },
        {
          "type": "story",
          "settings": {
            "label": "WEEK 2",
            "caption": "Two weeks in. Less reaching for the cream tube. Hands feel different."
          }
        },
        {
          "type": "story",
          "settings": {
            "label": "MONTH 1",
            "caption": "One month, one liner. The same pair you started with."
          }
        },
        {
          "type": "story",
          "settings": {
            "label": "MONTH 6",
            "caption": "120 disposable liners, replaced by one. No coatings. Performance is structural — washing can't strip it."
          }
        }
      ]
    }
  ]
}
{% endschema %}