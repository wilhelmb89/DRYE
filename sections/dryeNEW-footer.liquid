{{ 'dryeNEW-footer.css' | asset_url | stylesheet_tag }}

<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a
          href="{{ section.settings.logo_link | default: routes.root_url }}"
          class="logo"
          aria-label="{{ shop.name }}"
        >
          {% if section.settings.logo != blank %}
            {{
              section.settings.logo
              | image_url: width: 400
              | image_tag:
                alt: shop.name,
                loading: 'lazy',
                widths: '200,300,400'
            }}
          {% else %}
            <span>{{ shop.name }}</span>
          {% endif %}
        </a>

        {% if section.settings.brand_text != blank %}
          <p>{{ section.settings.brand_text | newline_to_br }}</p>
        {% endif %}
      </div>

      <div class="footer-col">
        {% if section.settings.col_1_heading != blank %}
          <h4>{{ section.settings.col_1_heading }}</h4>
        {% endif %}

        <ul>
          {% if section.settings.col_1_link_1_label != blank %}
            <li><a href="{{ section.settings.col_1_link_1_url | default: '#' }}">{{ section.settings.col_1_link_1_label }}</a></li>
          {% endif %}
          {% if section.settings.col_1_link_2_label != blank %}
            <li><a href="{{ section.settings.col_1_link_2_url | default: '#' }}">{{ section.settings.col_1_link_2_label }}</a></li>
          {% endif %}
          {% if section.settings.col_1_link_3_label != blank %}
            <li><a href="{{ section.settings.col_1_link_3_url | default: '#' }}">{{ section.settings.col_1_link_3_label }}</a></li>
          {% endif %}
          {% if section.settings.col_1_link_4_label != blank %}
            <li><a href="{{ section.settings.col_1_link_4_url | default: '#' }}">{{ section.settings.col_1_link_4_label }}</a></li>
          {% endif %}
          {% if section.settings.col_1_link_5_label != blank %}
            <li><a href="{{ section.settings.col_1_link_5_url | default: '#' }}">{{ section.settings.col_1_link_5_label }}</a></li>
          {% endif %}
        </ul>
      </div>

      <div class="footer-col">
        {% if section.settings.col_2_heading != blank %}
          <h4>{{ section.settings.col_2_heading }}</h4>
        {% endif %}

        <ul>
          {% if section.settings.col_2_link_1_label != blank %}
            <li><a href="{{ section.settings.col_2_link_1_url | default: '#' }}">{{ section.settings.col_2_link_1_label }}</a></li>
          {% endif %}
          {% if section.settings.col_2_link_2_label != blank %}
            <li><a href="{{ section.settings.col_2_link_2_url | default: '#' }}">{{ section.settings.col_2_link_2_label }}</a></li>
          {% endif %}
          {% if section.settings.col_2_link_3_label != blank %}
            <li><a href="{{ section.settings.col_2_link_3_url | default: '#' }}">{{ section.settings.col_2_link_3_label }}</a></li>
          {% endif %}
          {% if section.settings.col_2_link_4_label != blank %}
            <li><a href="{{ section.settings.col_2_link_4_url | default: '#' }}">{{ section.settings.col_2_link_4_label }}</a></li>
          {% endif %}
          {% if section.settings.col_2_link_5_label != blank %}
            <li><a href="{{ section.settings.col_2_link_5_url | default: '#' }}">{{ section.settings.col_2_link_5_label }}</a></li>
          {% endif %}
        </ul>
      </div>

      <div class="footer-col">
        {% if section.settings.col_3_heading != blank %}
          <h4>{{ section.settings.col_3_heading }}</h4>
        {% endif %}

        <ul>
          {% if section.settings.col_3_link_1_label != blank %}
            <li><a href="{{ section.settings.col_3_link_1_url | default: '#' }}">{{ section.settings.col_3_link_1_label }}</a></li>
          {% endif %}
          {% if section.settings.col_3_link_2_label != blank %}
            <li><a href="{{ section.settings.col_3_link_2_url | default: '#' }}">{{ section.settings.col_3_link_2_label }}</a></li>
          {% endif %}
          {% if section.settings.col_3_link_3_label != blank %}
            <li><a href="{{ section.settings.col_3_link_3_url | default: '#' }}">{{ section.settings.col_3_link_3_label }}</a></li>
          {% endif %}
          {% if section.settings.col_3_link_4_label != blank %}
            <li><a href="{{ section.settings.col_3_link_4_url | default: '#' }}">{{ section.settings.col_3_link_4_label }}</a></li>
          {% endif %}
          {% if section.settings.col_3_link_5_label != blank %}
            <li><a href="{{ section.settings.col_3_link_5_url | default: '#' }}">{{ section.settings.col_3_link_5_label }}</a></li>
          {% endif %}
        </ul>
      </div>

      <div class="footer-newsletter">
        {% if section.settings.newsletter_heading != blank %}
          <h4>{{ section.settings.newsletter_heading }}</h4>
        {% endif %}

        {% if section.settings.newsletter_text != blank %}
          <p>{{ section.settings.newsletter_text }}</p>
        {% endif %}

        <div class="footer-email-form">
          <input
            type="email"
            placeholder="{{ section.settings.newsletter_placeholder }}"
            autocomplete="email"
          >
          <button type="submit">{{ section.settings.newsletter_button_label }}</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      {% if section.settings.bottom_text != blank %}
        <p>{{ section.settings.bottom_text }}</p>
      {% endif %}

      <div class="footer-bottom-links">
        {% if section.settings.bottom_link_1_label != blank %}
          <a href="{{ section.settings.bottom_link_1_url | default: '#' }}">{{ section.settings.bottom_link_1_label }}</a>
        {% endif %}
        {% if section.settings.bottom_link_2_label != blank %}
          <a href="{{ section.settings.bottom_link_2_url | default: '#' }}">{{ section.settings.bottom_link_2_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

