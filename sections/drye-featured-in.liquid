{%- comment -%}
  DRYE Featured In — standalone press-logo strip. Add under the hero in the
  theme editor. Uses DRYE's own press logos (Gadget Flow + wordmarks) by
  default; add "Logo" blocks to override with your own uploaded logos.
{%- endcomment -%}

{%- assign uid = section.id -%}
{%- assign logos = section.blocks | where: 'type', 'logo' -%}
{%- assign is_dark = section.settings.logo_theme -%}

<style>
  #drye-featured-{{ uid }} {
    padding: {{ section.settings.pad_top | default: 28 }}px 20px {{ section.settings.pad_bottom | default: 28 }}px;
    background: {{ section.settings.bg_color | default: '#F8FAFC' }};
    text-align: center;
  }
  #drye-featured-{{ uid }} .drye-featured__label {
    display: block;
    margin: 0 auto 14px;
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: {% if is_dark %}rgba(255,255,255,0.55){% else %}#9CA3AF{% endif %};
  }
  #drye-featured-{{ uid }} .drye-featured__row {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 20px 34px; max-width: 900px; margin: 0 auto;
  }
  #drye-featured-{{ uid }} .drye-featured__item {
    display: inline-flex; align-items: center; text-decoration: none;
    color: {% if is_dark %}#fff{% else %}#111{% endif %};
    opacity: {% if is_dark %}0.7{% else %}0.5{% endif %};
    filter: grayscale(1);
    transition: opacity 0.18s ease, transform 0.18s ease, filter 0.18s ease, color 0.18s ease;
  }
  #drye-featured-{{ uid }} a.drye-featured__item { cursor: pointer; }
  #drye-featured-{{ uid }} a.drye-featured__item:hover {
    opacity: 1; filter: grayscale(0); transform: translateY(-2px); color: var(--emerald, #0D9488);
  }
  #drye-featured-{{ uid }} .drye-featured__item img {
    height: {{ section.settings.logo_height | default: 28 }}px; width: auto; max-width: 150px;
    object-fit: contain; display: block;
  }
  #drye-featured-{{ uid }} .lg-bygg { font-size: 13px; line-height: 1; text-align: left; font-weight: 800; }
  #drye-featured-{{ uid }} .lg-bygg small { display: block; font-size: 13px; font-weight: 800; }
  #drye-featured-{{ uid }} .lg-gnosjo { font-size: 14px; line-height: 1; font-weight: 900; letter-spacing: 0.02em; }
  #drye-featured-{{ uid }} .lg-smarta { font-size: 17px; font-weight: 800; letter-spacing: -0.02em; }
  #drye-featured-{{ uid }} .lg-gadget { font-size: 14px; font-weight: 700; letter-spacing: -0.01em; }
  @media (max-width: 749px) {
    {% if section.settings.hide_label_mobile %}#drye-featured-{{ uid }} .drye-featured__label { display: none; }{% endif %}
    #drye-featured-{{ uid }} { padding: 14px 12px; }
    #drye-featured-{{ uid }} .drye-featured__row { gap: 0 8px; flex-wrap: nowrap; max-width: 100%; }
    #drye-featured-{{ uid }} .drye-featured__item { flex: 1 1 0; min-width: 0; justify-content: center; text-align: center; }
    #drye-featured-{{ uid }} .lg-bygg,
    #drye-featured-{{ uid }} .lg-bygg small { font-size: 8px; line-height: 1.2; }
    #drye-featured-{{ uid }} .lg-gnosjo { font-size: 8.5px; line-height: 1.2; }
    #drye-featured-{{ uid }} .lg-smarta { font-size: 12px; }
    #drye-featured-{{ uid }} .lg-gadget { font-size: 10px; }
    #drye-featured-{{ uid }} .drye-featured__item img { height: 20px; max-width: 100%; }
  }
</style>

<section id="drye-featured-{{ uid }}" class="drye-featured">
  {% if section.settings.label != blank %}
    <span class="drye-featured__label">{{ section.settings.label }}</span>
  {% endif %}
  <div class="drye-featured__row">
    {% if logos.size > 0 %}
      {% for block in logos %}
        {% if block.settings.image != blank %}
          {% if block.settings.url != blank %}
            <a class="drye-featured__item" href="{{ block.settings.url }}" target="_blank" rel="noopener" {{ block.shopify_attributes }}><img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}"></a>
          {% else %}
            <span class="drye-featured__item" {{ block.shopify_attributes }}><img src="{{ block.settings.image | image_url: width: 320 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}"></span>
          {% endif %}
        {% endif %}
      {% endfor %}
    {% else %}
      <a class="drye-featured__item" href="{{ section.settings.bygg_url | default: 'https://byggkatalogen.byggtjanst.se/nyheter/torra-hander-i-handskarna/37639' }}" target="_blank" rel="noopener"><span class="lg-bygg">SVENSK<small>BYGGTJÄNST</small></span></a>
      <a class="drye-featured__item" href="{{ section.settings.gnosjo_url | default: 'https://www.svarvning.nu/personlig-kamp-mot-hudproblem-resulterar-i-innovativa-handskar/' }}" target="_blank" rel="noopener"><span class="lg-gnosjo">GNOSJÖ<br>SVARVNING</span></a>
      <span class="drye-featured__item"><span class="lg-smarta">smartasaker</span></span>
      <a class="drye-featured__item" href="https://thegadgetflow.com/blog/drye-liner-review-glove-liner/" target="_blank" rel="noopener"><span class="lg-gadget">Gadget&nbsp;Flow</span></a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "DRYE Featured",
  "tag": "section",
  "class": "drye-featured-section",
  "settings": [
    { "type": "text", "id": "label", "label": "Label", "default": "Featured in" },
    { "type": "checkbox", "id": "hide_label_mobile", "label": "Hide label on mobile", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F8FAFC" },
    { "type": "checkbox", "id": "logo_theme", "label": "Light logos (for dark background)", "default": false },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 18, "max": 56, "step": 2, "unit": "px", "default": 28 },
    { "type": "range", "id": "pad_top", "label": "Padding top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 28 },
    { "type": "range", "id": "pad_bottom", "label": "Padding bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 28 },
    { "type": "header", "content": "Default wordmark links" },
    { "type": "url", "id": "bygg_url", "label": "Svensk Byggtjänst link" },
    { "type": "url", "id": "gnosjo_url", "label": "Gnosjö Svarvning link" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo image" },
        { "type": "text", "id": "name", "label": "Name (alt text)" },
        { "type": "url", "id": "url", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "DRYE Featured" }
  ]
}
{% endschema %}