{{ 'drye-section-03-mechanism.css' | asset_url | stylesheet_tag }}

<section class="sec mech-sec">
  <div class="sec-in">
    <div class="micro micro-w">
      {{ section.settings.eyebrow }}
    </div>

    <h2 class="mech-h">
      {{ section.settings.heading }}
    </h2>

    <p class="mech-sub">
      {{ section.settings.subheading }}
    </p>

    <div class="mech-cols">
      <div class="mech-col old">
        <div class="mc-lbl">{{ section.settings.old_label }}</div>
        <div class="mc-title">{{ section.settings.old_title }}</div>
        <ul class="mc-list ol">
          {% for block in section.blocks %}
            {% if block.type == 'old_point' %}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>

      <div class="mech-col new">
        <div class="mc-lbl">{{ section.settings.new_label }}</div>
        <div class="mc-title">{{ section.settings.new_title }}</div>
        <ul class="mc-list nw">
          {% for block in section.blocks %}
            {% if block.type == 'new_point' %}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>

    <div class="diag-wrap">
      <div class="diag-title">{{ section.settings.diagram_title }}</div>

      <div class="diag-stack">
        <div class="dl outer">{{ section.settings.diagram_outer }}</div>
        <div class="diag-arr">↑ ↑ ↑</div>
        <div class="dl rel">{{ section.settings.diagram_release }}</div>
        <div class="dl grad">{{ section.settings.diagram_gradient }}</div>
        <div class="diag-arr mech-arr-down">↑ ↑ ↑</div>
        <div class="dl skin">{{ section.settings.diagram_skin }}</div>
      </div>

      <div class="diag-note">{{ section.settings.diagram_note }}</div>
    </div>
  </div>
</section>

<div class="proof-bar">
  <div class="proof-in">
    {% for block in section.blocks %}
      {% if block.type == 'proof_stat' %}
        <div {{ block.shopify_attributes }}>
          <div class="p-num">
            {{ block.settings.value_main }}<span>{{ block.settings.value_suffix }}</span>
          </div>
          <div class="p-lbl">{{ block.settings.label }}</div>
          <div class="p-src">{{ block.settings.source }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

