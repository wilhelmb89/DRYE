{{ 'drye-research-study-breakdown.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section field-section" data-drye-section data-section-index="16" data-section-name="study_breakdown">
  <div class="dryeNEW-container">
    <span class="micro dryeNEW-reveal">
      {{ section.settings.micro_label }}
    </span>

    <h2 class="dryeNEW-reveal dryeNEW-rd1">
      {{ section.settings.heading }}
    </h2>

    <p class="field-section-intro dryeNEW-reveal dryeNEW-rd2">
      {{ section.settings.intro_text }}
    </p>

    {% if section.blocks.size > 0 %}
      <div class="field-grid">
        {% for block in section.blocks %}
          <div class="field-card dryeNEW-reveal {% case forloop.index %}{% when 1 %}dryeNEW-rd1{% when 2 %}dryeNEW-rd2{% when 3 %}dryeNEW-rd3{% endcase %}" {{ block.shopify_attributes }}>
            <div class="field-card-header">
              <div class="field-card-title">
                {{ block.settings.title_line_1 }}<br>{{ block.settings.title_line_2 }}
              </div>

              {% if block.settings.badge != blank %}
                <div class="field-card-badge">
                  {{ block.settings.badge }}
                </div>
              {% endif %}
            </div>

            <div class="field-results">
              {% for i in (1..4) %}
                {% liquid
                  assign label_key = 'result_label_' | append: i
                  assign value_key = 'result_value_' | append: i
                  assign width_key = 'result_width_' | append: i

                  assign result_label = block.settings[label_key]
                  assign result_value = block.settings[value_key]
                  assign result_width = block.settings[width_key] | plus: 0 | at_least: 0 | at_most: 100
                %}

                {% if result_label != blank %}
                  <div class="field-result-row">
                    <div class="field-result-label">{{ result_label }}</div>
                    <div class="field-result-bar-wrap">
                      <div
                        class="field-result-bar"
                        data-width="{{ result_width }}"
                        style="width:0%;"
                      ></div>
                    </div>
                    <div class="field-result-pct">{{ result_value }}</div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            {% if block.settings.note != blank %}
              <div class="field-card-note">
                {{ block.settings.note }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<script>
  (() => {
    const bars = document.querySelectorAll('.field-result-bar');
    if (!bars.length) return;

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const card = entry.target;
        card.querySelectorAll('.field-result-bar').forEach((bar) => {
          const width = bar.getAttribute('data-width') || '0';
          requestAnimationFrame(() => {
            bar.style.width = width + '%';
          });
        });

        obs.unobserve(card);
      });
    }, { threshold: 0.25 });

    document.querySelectorAll('.field-card').forEach((card) => {
      observer.observe(card);
    });
  })();
</script>

