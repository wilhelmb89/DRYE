      "type": "header",
      "content": "With DRYE (right card)"
    },
    {
      "type": "text",
      "id": "right_label",
      "label": "Eyebrow",
      "default": "With DRYE"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Card title",
      "default": "Sweat routes outward"
    },
    {
      "type": "text",
      "id": "right_text_top",
      "label": "Top skin layer text",
      "default": "Skin stays dry"
    },
    {
      "type": "text",
      "id": "right_text_mid",
      "label": "Mid skin layer text",
      "default": "Skin barrier intact"
    },
    {
      "type": "text",
      "id": "right_text_climax",
      "label": "Deep skin layer text (climax)",
      "default": "Chemicals stay out"
    },
    {
      "type": "textarea",
      "id": "right_desc",
      "label": "Description below diagram",
      "default": "The skin side is hydrophobic — sweat can't bond to it. The outer side pulls moisture toward it. Sweat routes from skin to outside, continuously."
    }
  ],
  "presets": [
    {
      "name": "Occlusion Bridge",
      "category": "DRYE"
    }
