{% liquid
  assign current_product = section.settings.selected_product
  if current_product == blank
    assign current_product = product
  endif
  assign selected_variant = current_product.selected_or_first_available_variant
  assign review_rating = current_product.metafields.custom.review_rating.value | default: section.settings.review_rating_fallback
  assign review_count = current_product.metafields.custom.review_count.value | default: section.settings.review_count_fallback
  assign review_anchor = '#judgeme_product_reviews'
  assign price_note = section.settings.price_note
  assign sticky_button_label = section.settings.sticky_button_label
  assign atc_button_label = section.settings.atc_button_label
  assign preorder_note = 'Ships May 21'
  assign in_stock_note = 'In stock, ready for fast delivery'
%}

{{ 'drye-pdp-hero.css' | asset_url | stylesheet_tag }}
{{ 'drye-review-slider.css' | asset_url | stylesheet_tag }}

<section
  class="hero"
  id="product-top"
  data-section-id="{{ section.id }}"
  data-product-section
>
  <div class="hero-media" data-gallery-root>
    {% comment %} Local gallery — sourced from section blocks, not product.media {% endcomment %}
    {% assign gallery_blocks = section.blocks | where: 'type', 'gallery_media' %}
    {% assign visible_media_count = gallery_blocks.size %}

    {% if visible_media_count > 1 %}
      <div class="hero-gallery-thumbs" aria-hidden="true">
        {% for block in gallery_blocks %}
          {% assign thumb_index = forloop.index0 %}
          {% assign has_video = false %}
          {% if block.settings.video != blank %}
            {% assign has_video = true %}
          {% endif %}

          <button
            type="button"
            class="hero-gallery-thumb{% if thumb_index == 0 %} is-active{% endif %}"
            data-gallery-thumb
            data-gallery-thumb-index="{{ thumb_index }}"
            aria-label="View media {{ forloop.index }}"
            tabindex="-1"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 240
                | image_tag:
                  alt: block.settings.alt | default: current_product.title,
                  widths: '120, 180, 240',
                  sizes: '(min-width: 1024px) 60px, 0px',
                  loading: 'lazy'
              }}
              {% if has_video %}
                <span class="hero-gallery-thumb__play" aria-hidden="true">▶</span>
              {% endif %}
            {% elsif has_video %}
              {% assign poster = block.settings.video.preview_image %}
              {% if poster != blank %}
                {{
                  poster
                  | image_url: width: 240
                  | image_tag:
                    alt: block.settings.alt | default: current_product.title,
                    widths: '120, 180, 240',
                    sizes: '(min-width: 1024px) 60px, 0px',
                    loading: 'lazy'
                }}
              {% endif %}
              <span class="hero-gallery-thumb__play" aria-hidden="true">▶</span>
            {% else %}
              <span class="hero-gallery-thumb__fallback">media</span>
            {% endif %}
          </button>
        {% endfor %}
      </div>
    {% endif %}

    <div class="hero-gallery-main" data-gallery-viewport>
      <div class="hero-gallery-track" data-gallery-track>
        {% if visible_media_count > 0 %}
          {% for block in gallery_blocks %}
            <div class="hero-gallery-slide" data-gallery-slide {{ block.shopify_attributes }}>
              {% if block.settings.video != blank %}
                {{
                  block.settings.video
                  | video_tag:
                    class: 'hero-media-video',
                    autoplay: true,
                    loop: true,
                    muted: true,
                    controls: false,
                    playsinline: true,
                    preload: 'auto'
                }}
              {% elsif block.settings.image != blank %}
                {{
                  block.settings.image
                  | image_url: width: 2200
                  | image_tag:
                    alt: block.settings.alt | default: current_product.title,
                    widths: '480, 720, 960, 1200, 1600, 2000, 2200',
                    sizes: '(min-width: 1024px) 600px, (min-width: 768px) 50vw, 100vw',
                    loading: 'eager',
                    class: 'hero-media-img'
                }}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'hero-media-img hero-media-placeholder' }}
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          <div class="hero-gallery-slide" data-gallery-slide>
            {{ 'product-1' | placeholder_svg_tag: 'hero-media-img hero-media-placeholder' }}
          </div>
        {% endif %}
      </div>

      {% if visible_media_count > 1 %}
        <div class="hero-gallery-nav">
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--prev"
            data-gallery-prev
            aria-label="Previous image"
            disabled
          >
            ‹
          </button>
          <button
            type="button"
            class="hero-gallery-arrow hero-gallery-arrow--next"
            data-gallery-next
            aria-label="Next image"
          >
            ›
          </button>
        </div>
      {% endif %}
    </div>
  </div>

{% comment %} Review swiper — mobile/tablet only, between gallery and info {% endcomment %}
{% for block in section.blocks %}
  {% if block.type == 'review_slider' %}
    <div class="pdp-review-slider-block pdp-review-slider-block--mobile" {{ block.shopify_attributes }}>
      {% render 'drye-review-slider-inline', block: block %}
    </div>
  {% endif %}
{% endfor %}

  <div class="hero-info">

    {% comment %} Stars moved to top — visible price-of-credibility before headline {% endcomment %}
    <div class="stars-row">
      <span class="stars" aria-hidden="true">★★★★★</span>
      <span class="stars-lbl">
        {{ review_rating }}/5 · <a href="{{ review_anchor }}">{{ review_count }} reviews</a>
      </span>
    </div>

<h1 class="h-title">
  {% if section.settings.heading_line_1 != blank %}{{ section.settings.heading_line_1 }}{% endif %}
  {% if section.settings.heading_line_1_em != blank %}<em>{{ section.settings.heading_line_1_em }}</em>{% endif %}
  <br>
  {% if section.settings.heading_line_2 != blank %}{{ section.settings.heading_line_2 }}{% endif %}
  {% if section.settings.heading_line_2_em != blank %}<em>{{ section.settings.heading_line_2_em }}</em>{% endif %}
</h1>

    <div class="h-sub">
      {{ section.settings.subtext }}
    </div>

    <div class="price-row" data-price-row>
      <span class="price" data-price>{{ selected_variant.price | money_with_currency }}</span>
      {% if price_note != blank %}
        <span class="price-note">{{ price_note }}</span>
      {% endif %}
    </div>

    {% assign size_option_position = blank %}
    {% for option in current_product.options_with_values %}
      {% assign option_name_downcase = option.name | downcase %}
      {% if option_name_downcase contains 'size' or option_name_downcase contains 'storlek' %}
        {% assign size_option_position = option.position %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% form 'product', current_product, class: 'product-form', novalidate: 'novalidate', action: routes.cart_add_url, data-product-form: '' %}
      {% if size_option_position != blank %}
        <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-id>
      {% endif %}

      {% comment %} Quantity defaults to 1 — managed in cart drawer {% endcomment %}
      <input type="hidden" name="quantity" value="1">

      <div class="buy-block">
        <div class="form-lbl">
          <span>{{ section.settings.option_label }}</span>
          <button type="button" class="size-guide-link js-open-size-guide">
            {{ section.settings.size_guide_label }}
          </button>
        </div>

        {% if size_option_position != blank %}
          {% assign size_option_index = size_option_position | minus: 1 %}
          {% assign size_option = current_product.options_with_values[size_option_index] %}

          <div class="sz-dd" data-size-dropdown>
            <button
              type="button"
              class="sz-dd-trigger{% if selected_variant.options[size_option_index] != blank %} has-val{% endif %}"
              data-size-trigger
              aria-expanded="false"
              aria-haspopup="listbox"
            >
              <span data-size-label>
                {% if selected_variant.options[size_option_index] != blank %}
                  {{ selected_variant.options[size_option_index] }}
                {% else %}
                  {{ section.settings.size_placeholder }}
                {% endif %}
              </span>
              <svg class="sz-dd-arrow" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M0 0l5 6 5-6z" fill="#9CA3AF"/>
              </svg>
            </button>

            <div class="sz-dd-list" data-size-list role="listbox" aria-label="{{ size_option.name }}">
              <button
                type="button"
                class="sz-dd-help dryeNEW-body--caption js-open-size-guide"
              >
                <span>Unsure of your size? Click here</span>
                <span class="sz-dd-help__arrow" aria-hidden="true">→</span>
              </button>

              {% for value in size_option.values %}
                {% liquid
                  assign matched_variant = blank
                  for variant in current_product.variants
                    if variant.options[size_option_index] == value
                      assign matched_variant = variant
                      break
                    endif
                  endfor

                  assign is_selected = false
                  if selected_variant.options[size_option_index] == value
                    assign is_selected = true
                  endif

                  assign is_preorder = false
                  if matched_variant != blank
                    if matched_variant.inventory_policy == 'continue' and matched_variant.inventory_quantity <= 0
                      assign is_preorder = true
                    endif
                  endif

                  assign is_available = true
                  if matched_variant != blank and matched_variant.available == false and is_preorder == false
                    assign is_available = false
                  endif

                  assign is_in_stock = false
                  if matched_variant != blank and matched_variant.available and is_preorder == false
                    assign is_in_stock = true
                  endif
                %}
                <button
                  type="button"
                  class="sz-dd-opt{% unless is_available %} sold-out{% endunless %}{% if is_selected %} selected{% endif %}{% if is_preorder %} preorder{% endif %}"
                  data-size-option
                  data-option-position="{{ size_option_position }}"
                  data-option-value="{{ value | escape }}"
                  data-available="{% if is_available %}true{% else %}false{% endif %}"
                  data-preorder="{% if is_preorder %}true{% else %}false{% endif %}"
                  role="option"
                  aria-selected="{% if is_selected %}true{% else %}false{% endif %}"
                  {% unless is_available %}disabled{% endunless %}
                >
                  {{ value }}{% if is_preorder %} — {{ preorder_note }}{% elsif is_in_stock %} — {{ in_stock_note }}{% elsif is_available == false %} — Sold out{% endif %}
                </button>
              {% endfor %}
            </div>
          </div>
        {% else %}
          <select class="variant-select-fallback" name="id">
            {% for variant in current_product.variants %}
              <option
                value="{{ variant.id }}"
                {% if variant.id == selected_variant.id %}selected{% endif %}
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title }} - {{ variant.price | money_with_currency }}
              </option>
            {% endfor %}
          </select>
        {% endif %}
      </div>

      {% assign selected_variant_preorder = false %}
      {% if selected_variant.inventory_policy == 'continue' and selected_variant.inventory_quantity <= 0 %}
        {% assign selected_variant_preorder = true %}
      {% endif %}

      <button
        type="submit"
        class="atc-btn-full"
        data-main-atc
        {% unless selected_variant.available or selected_variant_preorder %}disabled{% endunless %}
      >
        {% if selected_variant.available or selected_variant_preorder %}
          {{ atc_button_label }}
        {% else %}
          Sold out
        {% endif %}
      </button>
    {% endform %}

{% comment %} Review swiper — desktop only, inside product info column {% endcomment %}
{% for block in section.blocks %}
  {% if block.type == 'review_slider' %}
    <div class="pdp-review-slider-block pdp-review-slider-block--desktop">
      {% render 'drye-review-slider-inline', block: block %}
    </div>
  {% endif %}
{% endfor %}

    <div class="trust-row">
      <div class="trust-item">
        <img
          src="{{ 'icon-shield-check.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_1 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-refund-arrows (2).svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_2 }}</span>
      </div>

      <div class="trust-item">
        <img
          src="{{ 'icon-truck.svg' | asset_url }}"
          alt=""
          width="20"
          height="20"
          loading="lazy"
        >
        <span>{{ section.settings.trust_text_3 }}</span>
      </div>
    </div>

    {% comment %} Product description — always-open, loads from description block {% endcomment %}
    {% assign desc_media = section.blocks | where: 'type', 'desc_media' %}
    {% assign rendered_desc = '' %}
    {% assign desc_title = section.settings.description_toggle_closed %}
    {% assign found_description_block = false %}

    {% for block in section.blocks %}
      {% if block.type == 'description' %}
        {% assign found_description_block = true %}
        {% assign desc_title = block.settings.title | default: section.settings.description_toggle_closed %}

{% if block.settings.use_product_description and current_product.description != blank %}
  {% assign rendered_desc = current_product.description %}
        {% else %}
          {% assign rendered_desc = block.settings.custom_description %}
        {% endif %}

        {% for m in desc_media %}
          {% assign key = m.settings.key | strip %}
          {% if key != blank and rendered_desc contains key %}
            {% capture media_markup %}
<div class="desc-media">
  {% if m.settings.video != blank %}
    {{ m.settings.video | video_tag: class: 'desc-media__video', autoplay: true, loop: true, muted: true, controls: false, playsinline: true, preload: 'auto' }}
  {% elsif m.settings.image != blank %}
    {{ m.settings.image | image_url: width: 1600 | image_tag: class: 'desc-media__img', loading: 'lazy', decoding: 'async' }}
  {% endif %}
</div>
            {% endcapture %}
            {% assign rendered_desc = rendered_desc | replace: key, media_markup %}
          {% endif %}
        {% endfor %}
      {% endif %}
    {% endfor %}

    {% if found_description_block %}
      <div class="pdp-desc">
        <div class="pdp-desc-title">
          {{ desc_title }}
        </div>

        <div class="pdp-extra open">
          <div class="pdp-richtext">
            {{ rendered_desc }}
          </div>
        </div>
      </div>
    {% endif %}

    {% comment %} ═══════════════════════════════════════
       HORIZONTAL TABS: What to Expect / FAQs / Reviews
       ═══════════════════════════════════════ {% endcomment %}

    {% assign wte_blocks = section.blocks | where: 'type', 'htab_wte_stage' %}
    {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
    {% assign review_block = section.blocks | where: 'type', 'review_slider' | first %}

    {% if wte_blocks.size > 0 or faq_blocks.size > 0 %}
      <div class="htabs" data-htabs>

        <div class="htab-nav" role="tablist">
          {% if wte_blocks.size > 0 %}
            <button type="button" class="htab-btn active" data-htab-tab="wte" role="tab" aria-selected="true">
              {{ section.settings.htab_wte_label | default: 'What to Expect' }}
            </button>
          {% endif %}
          {% if faq_blocks.size > 0 %}
            <button type="button" class="htab-btn{% unless wte_blocks.size > 0 %} active{% endunless %}" data-htab-tab="faq" role="tab" aria-selected="{% if wte_blocks.size > 0 %}false{% else %}true{% endif %}">
              {{ section.settings.htab_faq_label | default: 'FAQs' }}
            </button>
          {% endif %}
<button type="button" class="htab-btn" data-htab-tab="rev" role="tab" aria-selected="false">
  {{ section.settings.htab_rev_label | default: 'Reviews' }}
</button>
        </div>

        {% if wte_blocks.size > 0 %}
          <div class="htab-panel active" data-htab-panel="wte" role="tabpanel">
            {% for block in wte_blocks %}
              <div class="htab-wte-card" {{ block.shopify_attributes }}>
                <div class="htab-stage">{{ block.settings.stage_label }}</div>
                <div class="htab-wte-head">
                  {{ block.settings.headline_start }} <em>{{ block.settings.headline_italic }}</em>
                </div>
                <ul class="htab-wte-list">
                  {% if block.settings.bullet_1 != blank %}<li>{{ block.settings.bullet_1 }}</li>{% endif %}
                  {% if block.settings.bullet_2 != blank %}<li>{{ block.settings.bullet_2 }}</li>{% endif %}
                  {% if block.settings.bullet_3 != blank %}<li>{{ block.settings.bullet_3 }}</li>{% endif %}
                  {% if block.settings.bullet_4 != blank %}<li><strong>{{ block.settings.bullet_4 }}</strong></li>{% endif %}
                </ul>
              </div>
            {% endfor %}
          </div>
        {% endif %}

        {% if faq_blocks.size > 0 %}
          <div class="htab-panel{% unless wte_blocks.size > 0 %} active{% endunless %}" data-htab-panel="faq" role="tabpanel">
            {% for block in faq_blocks %}
              <div class="htab-faq-item{% if block.settings.open_by_default %} open{% endif %}" {{ block.shopify_attributes }}>
                <button type="button" class="htab-faq-q">
                  <span>{{ block.settings.question }}</span>
                  <span class="htab-faq-ic" aria-hidden="true"></span>
                </button>
                <div class="htab-faq-a">
                  <div class="htab-faq-a-inner">{{ block.settings.answer | escape | newline_to_br }}</div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}

<div class="htab-panel" data-htab-panel="rev" role="tabpanel">
  {% if review_block %}
    {% for i in (1..9) %}
      {% liquid
        assign quote_key    = 'review_' | append: i | append: '_quote'
        assign name_key     = 'review_' | append: i | append: '_name'
        assign location_key = 'review_' | append: i | append: '_location'
        assign label_key    = 'review_' | append: i | append: '_label'
        assign stars_key    = 'review_' | append: i | append: '_stars'
        assign rev_quote    = review_block.settings[quote_key]
        assign rev_name     = review_block.settings[name_key]
        assign rev_location = review_block.settings[location_key]
        assign rev_label    = review_block.settings[label_key]
        assign rev_stars    = review_block.settings[stars_key] | default: 5 | plus: 0
      %}
      {% if rev_quote != blank %}
        <div class="htab-testi-card">
          <div class="htab-testi-stars">
            {% for s in (1..rev_stars) %}
              <svg viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5.5 0L6.7 3.8h4L7.5 6.2 8.7 10 5.5 7.6 2.3 10l1.2-3.8L.3 3.8h4L5.5 0z" fill="#5F8A8B"/></svg>
            {% endfor %}
          </div>
          <p class="htab-testi-quote">{{ rev_quote | escape }}</p>
          <div class="htab-testi-meta">
            <span class="htab-testi-name">{{ rev_name | escape }}</span>
            {% if rev_label != blank or rev_location != blank %}
              <span class="htab-testi-role">{{ rev_label | escape }}{% if rev_label != blank and rev_location != blank %} · {% endif %}{{ rev_location | escape }}</span>
            {% endif %}
          </div>
          <span class="htab-testi-verified">
            <svg viewBox="0 0 8 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3.94 9.65C2.83 9.35 1.85 8.7 1.14 7.79.43 6.89.03 5.78 0 4.63V1.21L3.94 0l3.94 1.21v3.42c-.03 1.15-.43 2.26-1.14 3.16-.71.91-1.69 1.56-2.8 1.86z" fill="#9CA3AF"/><path d="M3.3 5.27L2.16 4.22l-.57.53 1.14 1.05.57.53.57-.53 2.28-2.1-.57-.52-2.28 2.1z" fill="#fff"/></svg>
            Verified buyer
          </span>
        </div>
      {% endif %}
    {% endfor %}
    <div class="htab-testi-cta-wrap">
      <a href="#judgeme_product_reviews" class="htab-testi-cta">
        {{ section.settings.htab_rev_link_label | default: 'Read all reviews ↓' }}
      </a>
    </div>
  {% endif %}
</div>

      </div>
    {% endif %}

<script type="application/json" data-product-json>
{
  "id": {{ current_product.id | json }},
  "title": {{ current_product.title | json }},
  "selected_or_first_available_variant": {
    "id": {{ selected_variant.id | json }},
    "options": {{ selected_variant.options | json }}
  },
  "variants": [
    {% for variant in current_product.variants %}
      {
        "id": {{ variant.id | json }},
        "title": {{ variant.title | json }},
        "sku": {{ variant.sku | json }},
        "available": {{ variant.available | json }},
        "inventory_policy": {{ variant.inventory_policy | json }},
        "inventory_quantity": {{ variant.inventory_quantity | json }},
        "options": {{ variant.options | json }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
    </script>
  </div>
</section>

{% if review_rating != blank and review_count != blank %}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ current_product.title | json }},
      {% if current_product.featured_image %}
        "image": [{{ current_product.featured_image | image_url: width: 1200 | json }}],
      {% endif %}
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": {{ review_rating | json }},
        "reviewCount": {{ review_count | json }}
      }
    }
  </script>
{% endif %}

<script>
  (() => {
    const sectionEl = document.querySelector('[data-section-id="{{ section.id }}"][data-product-section]');
    if (!sectionEl || sectionEl.dataset.dryePdpBound === 'true') return;
    sectionEl.dataset.dryePdpBound = 'true';

    const productJsonEl = sectionEl.querySelector('[data-product-json]');
    if (!productJsonEl) return;

    const productData = JSON.parse(productJsonEl.textContent);
    const form = sectionEl.querySelector('[data-product-form]');
    const variantIdInput = form ? form.querySelector('[data-variant-id]') : null;
    const priceEl = sectionEl.querySelector('[data-price]');
    const stickyPriceEl = document.querySelector('[data-sticky-price]');
    const mainAtc = sectionEl.querySelector('[data-main-atc]');
    const stickySubmit = document.querySelector('[data-sticky-submit]');
    const sizeTrigger = sectionEl.querySelector('[data-size-trigger]');
    const sizeList = sectionEl.querySelector('[data-size-list]');
    const sizeLabel = sectionEl.querySelector('[data-size-label]');
    const sizeOptions = Array.from(sectionEl.querySelectorAll('[data-size-option]'));
    const htabButtons = Array.from(sectionEl.querySelectorAll('[data-htab-tab]'));
    const htabPanels = Array.from(sectionEl.querySelectorAll('[data-htab-panel]'));
    const faqButtons = Array.from(sectionEl.querySelectorAll('.htab-faq-q'));

    const shopifyRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

    let currentOptions = (productData.selected_or_first_available_variant && productData.selected_or_first_available_variant.options)
      ? [...productData.selected_or_first_available_variant.options]
      : (productData.variants[0] ? [...productData.variants[0].options] : []);

    function isVariantPreorder(variant) {
      if (!variant) return false;
      return variant.inventory_policy === 'continue' && Number(variant.inventory_quantity) <= 0;
    }

    function syncButtonStates(selectedVariant) {
      const canBuy = !!(selectedVariant && (selectedVariant.available || isVariantPreorder(selectedVariant)));

      if (mainAtc) {
        mainAtc.disabled = !canBuy;
        mainAtc.textContent = canBuy ? {{ atc_button_label | json }} : 'Sold out';
      }

      if (stickySubmit) {
        stickySubmit.disabled = !canBuy;
        stickySubmit.textContent = canBuy ? {{ sticky_button_label | json }} : 'Sold out';
      }
    }

    function syncSizeUI() {
      if (!sizeOptions.length || !sizeLabel || !sizeTrigger) return;

      sizeOptions.forEach((option) => {
        const position = Number(option.dataset.optionPosition) - 1;
        const isSelected = currentOptions[position] === option.dataset.optionValue;

        option.classList.toggle('selected', isSelected);
        option.setAttribute('aria-selected', isSelected ? 'true' : 'false');

        if (isSelected) {
          sizeLabel.textContent = option.dataset.optionValue;
          sizeTrigger.classList.add('has-val');
        }
      });
    }

    function closeSizeDropdown() {
      if (!sizeTrigger || !sizeList) return;
      sizeTrigger.classList.remove('open');
      sizeList.classList.remove('open');
      sizeTrigger.setAttribute('aria-expanded', 'false');
    }

    sectionEl.querySelectorAll('.js-open-size-guide').forEach((button) => {
      button.addEventListener('click', () => {
        closeSizeDropdown();
      });
    });

    function getVariantFromOptions() {
      return productData.variants.find((variant) => {
        return variant.options.every((option, index) => option === currentOptions[index]);
      }) || null;
    }

    function pushViewItem(selectedVariant) {
      if (!selectedVariant) return;

      const eventKey = `view_item:${productData.id}:${selectedVariant.id}`;
      window.DRYETrackedEvents = window.DRYETrackedEvents || {};

      if (window.DRYETrackedEvents[eventKey]) return;
      window.DRYETrackedEvents[eventKey] = true;

      fetch(shopifyRoot + 'variants/' + selectedVariant.id + '.js', {
        credentials: 'same-origin',
        headers: { Accept: 'application/json' }
      })
        .then(function (res) { return res.ok ? res.json() : null; })
        .then(function (variant) {
          if (!variant) return;

          const presentmentValue = Number(variant.price) / 100;

          return fetch(shopifyRoot + 'cart.js', {
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
          })
            .then(function (res) { return res.ok ? res.json() : null; })
            .then(function (cart) {
              const currency = (cart && cart.currency) || 'SEK';

              window.dataLayer = window.dataLayer || [];
              window.dataLayer.push({
                event: 'view_item',
                event_source: 'drye_pdp_hero',
                ecommerce: {
                  currency: currency,
                  value: presentmentValue,
                  items: [{
                    item_id: String(selectedVariant.sku || selectedVariant.id),
                    item_name: productData.title,
                    item_brand: 'DRYE',
                    item_variant: selectedVariant.title,
                    price: presentmentValue,
                    quantity: 1
                  }]
                }
              });
            });
        })
        .catch(function (err) {
          console.warn('[DRYE PDP] view_item tracking skipped', err);
        });
    }

    function updateVariant(pushEvent = false) {
      const selectedVariant = getVariantFromOptions();

      syncSizeUI();
      syncButtonStates(selectedVariant);

      if (selectedVariant) {
        if (variantIdInput) variantIdInput.value = selectedVariant.id;

        if (pushEvent && !(window.Shopify && window.Shopify.designMode)) {
          pushViewItem(selectedVariant);
        }
      }
    }

    if (sizeTrigger && sizeList) {
      sizeTrigger.addEventListener('click', (event) => {
        event.stopPropagation();
        const isOpen = sizeTrigger.classList.toggle('open');
        sizeList.classList.toggle('open', isOpen);
        sizeTrigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      sizeOptions.forEach((option) => {
        option.addEventListener('click', (event) => {
          event.stopPropagation();
          if (option.disabled) return;

          const position = Number(option.dataset.optionPosition) - 1;
          currentOptions[position] = option.dataset.optionValue;

          closeSizeDropdown();
          updateVariant(true);
        });
      });

      document.addEventListener('click', (event) => {
        if (!event.target.closest('[data-size-dropdown]')) {
          closeSizeDropdown();
        }
      });
    }

    if (stickySubmit && form) {
      stickySubmit.addEventListener('click', () => {
        form.requestSubmit();
      });
    }

    /* Horizontal tabs */
    htabButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.htabTab;
        htabButtons.forEach((b) => {
          b.classList.toggle('active', b === btn);
          b.setAttribute('aria-selected', b === btn ? 'true' : 'false');
        });
        htabPanels.forEach((p) => {
          p.classList.toggle('active', p.dataset.htabPanel === id);
        });
      });
    });

    /* FAQ accordions inside htabs */
    faqButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const item = button.closest('.htab-faq-item');
        item.classList.toggle('open');
      });
    });

    const isThemeEditor = window.Shopify && window.Shopify.designMode;
    updateVariant();
    const initialVariant = getVariantFromOptions();
    if (!isThemeEditor && initialVariant) {
      pushViewItem(initialVariant);
    }
  })();
</script>

