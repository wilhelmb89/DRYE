{{ 'section-drye-eight-things.css' | asset_url | stylesheet_tag }}

<section class="dryeNEW-section eight-things" data-section-id="{{ section.id }}">
  <div class="dryeNEW-container">
    <div class="eight-things__intro">
      {% if section.settings.eyebrow != blank %}
        <span class="dryeNEW-micro eight-things__eyebrow dryeNEW-reveal dryeNEW-rd1">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="dryeNEW-h2 eight-things__heading dryeNEW-reveal dryeNEW-rd2">
          {{ section.settings.heading }}
          {% if section.settings.heading_emphasis != blank %}
            <em class="dryeNEW-em eight-things__heading-emphasis">
              {{ section.settings.heading_emphasis }}
            </em>
          {% endif %}
        </h2>
      {% endif %}

      {% if section.settings.body != blank %}
        <div class="dryeNEW-body eight-things__sub dryeNEW-reveal dryeNEW-rd3">
          {{ section.settings.body }}
        </div>
      {% endif %}
    </div>

    <div class="eight-things__strip-wrap">
      <div
        class="eight-things__swipe-hint"
        data-eight-swipe-hint
        aria-hidden="true"
      >
        Swipe
      </div>

      <div class="eight-things__grid" data-eight-strip>
        {% for block in section.blocks %}
          <article
            class="eight-things__card dryeNEW-reveal {% cycle 'dryeNEW-rd1', 'dryeNEW-rd2', 'dryeNEW-rd3', 'dryeNEW-rd2' %}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.label != blank %}
              <span class="dryeNEW-micro eight-things__label">
                {{ block.settings.label }}
              </span>
            {% endif %}

            {% if block.settings.headline != blank %}
              <h3 class="dryeNEW-h3 eight-things__name">
                {{ block.settings.headline }}
              </h3>
            {% endif %}

            {% if block.settings.body != blank %}
              <div class="dryeNEW-body eight-things__why">
                {{ block.settings.body }}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>

      <div
        class="eight-things__fade"
        data-eight-fade
        aria-hidden="true"
      ></div>
    </div>

    {% if section.settings.foot_quote != blank or section.settings.cta_label != blank %}
      <div class="eight-things__foot dryeNEW-reveal dryeNEW-rd3">
        {% if section.settings.foot_quote != blank %}
          <div class="eight-things__foot-q">
            {{ section.settings.foot_quote }}
          </div>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
          <a href="{{ section.settings.cta_link }}" class="eight-things__foot-cta">
            {{ section.settings.cta_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</section>

<script>
  (() => {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;

    const strip = section.querySelector('[data-eight-strip]');
    const hint = section.querySelector('[data-eight-swipe-hint]');
    const fade = section.querySelector('[data-eight-fade]');
    const desktopMq = window.matchMedia('(min-width: 768px)');

    if (!strip) return;

    let hasInteracted = false;

    const hasScrollableContent = () => {
      return strip.scrollWidth - strip.clientWidth > 8;
    };

    const updateHint = () => {
      if (!hint) return;

      if (desktopMq.matches || !hasScrollableContent()) {
        hint.classList.add('is-hidden');
        return;
      }

      if (strip.scrollLeft > 16 || hasInteracted) {
        hint.classList.add('is-hidden');
      } else {
        hint.classList.remove('is-hidden');
      }
    };

    const updateFade = () => {
      if (!fade) return;

      if (desktopMq.matches || !hasScrollableContent()) {
        fade.classList.add('is-hidden');
        return;
      }

      const maxScroll = strip.scrollWidth - strip.clientWidth;
      const atEnd = strip.scrollLeft >= maxScroll - 8;

      fade.classList.toggle('is-hidden', atEnd);
    };

    const hideHintOnInteraction = () => {
      if (desktopMq.matches || hasInteracted) return;

      hasInteracted = true;
      if (hint) hint.classList.add('is-hidden');
    };

    const updateAll = () => {
      updateHint();
      updateFade();
    };

    strip.addEventListener('scroll', updateAll, { passive: true });
    strip.addEventListener('touchstart', hideHintOnInteraction, { passive: true });
    strip.addEventListener('pointerdown', hideHintOnInteraction, { passive: true });
    window.addEventListener('resize', updateAll);

    updateAll();
  })();
</script>

