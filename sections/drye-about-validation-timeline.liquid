{{ 'section-drye-about-validation-timeline.css' | asset_url | stylesheet_tag }}

<section
  class="dryeNEW-section drye-about-validation"
  id="drye-about-validation-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="dryeNEW-container">
    <div class="drye-about-validation__header dryeNEW-reveal">
      <div class="drye-about-validation__header-left">
        {% if section.settings.eyebrow != blank %}
          <span class="dryeNEW-micro drye-about-validation__eyebrow">
            {{ section.settings.eyebrow }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="dryeNEW-h2 drye-about-validation__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
      </div>

      {% if section.settings.subtext != blank %}
        <div class="dryeNEW-body drye-about-validation__sub">
          <p>{{ section.settings.subtext }}</p>
        </div>
      {% endif %}
    </div>

    <div class="drye-about-validation__timeline dryeNEW-reveal dryeNEW-rd1">
      {% for block in section.blocks %}
        {% if block.type == 'timeline_item' %}
          <div class="drye-about-validation__item drye-about-validation__item--{{ block.settings.status }}" {{ block.shopify_attributes }}>
            <div class="drye-about-validation__dot"></div>

            {% if block.settings.year != blank %}
              <div class="dryeNEW-h4 drye-about-validation__year">{{ block.settings.year }}</div>
            {% endif %}

            {% if block.settings.title != blank %}
              <div class="dryeNEW-body--sm drye-about-validation__title">{{ block.settings.title }}</div>
            {% endif %}

            {% if block.settings.institution != blank %}
              <div class="dryeNEW-body--caption drye-about-validation__institution">{{ block.settings.institution }}</div>
            {% endif %}

            {% if block.settings.description != blank %}
              <div class="dryeNEW-body--caption drye-about-validation__desc">
                <p>{{ block.settings.description }}</p>
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <div class="drye-about-validation__partners dryeNEW-reveal">
      {% if section.settings.partners_label != blank %}
        <span class="dryeNEW-micro drye-about-validation__partners-label">
          {{ section.settings.partners_label }}
        </span>
      {% endif %}

      {% for block in section.blocks %}
        {% if block.type == 'partner' %}
          <span class="dryeNEW-body--caption drye-about-validation__partner-pill" {{ block.shopify_attributes }}>
            {{ block.settings.name }}
          </span>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DRYE About - Timeline",
  "tag": "section",
  "class": "section-drye-about-validation-timeline",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Seven years. Four institutions."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We didn't ship until it was verified externally."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Every milestone in the timeline below required external validation — not internal sign-off. The product was not commercially available until the mechanism had been confirmed independently."
    },
    {
      "type": "text",
      "id": "partners_label",
      "label": "Partners label",
      "default": "Partners"
    }
  ],
  "blocks": [
    {
      "type": "timeline_item",
      "name": "Timeline item",
      "settings": [
        {
          "type": "select",
          "id": "status",
          "label": "Status",
          "default": "done",
          "options": [
            { "value": "done", "label": "Done" },
            { "value": "active", "label": "Active" }
          ]
        },
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "2019–2020"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Concept prototyping"
        },
        {
          "type": "text",
          "id": "institution",
          "label": "Institution",
          "default": "RISE — Research Institutes of Sweden"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Initial material concept validated. Capillary routing confirmed as structurally viable at lab scale."
        }
      ]
    },
    {
      "type": "partner",
      "name": "Partner",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Partner name",
          "default": "Uppsala University"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DRYE About Validation Timeline",
      "blocks": [
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2019–2020",
            "title": "Concept prototyping",
            "institution": "RISE — Research Institutes of Sweden",
            "description": "Initial material concept validated. Capillary routing confirmed as structurally viable at lab scale."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2021",
            "title": "Moisture transport mechanism confirmed",
            "institution": "Uppsala University — Material science, fibre gradient architecture",
            "description": "The routing mechanism validated at materials level. Fibre geometry confirmed as primary driver — not chemical treatment."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2022",
            "title": "Textile architecture verified",
            "institution": "Swedish School of Textiles, Borås",
            "description": "Three field studies published. Structural design finalised — 0.4mm dual-layer gradient confirmed manufacturable at scale."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2023",
            "title": "Clinical context established",
            "institution": "Skåne University Hospital — Dermatology / MASD context",
            "description": "MASD (Moisture-Associated Skin Damage) context validated. Clinical framing of the problem confirmed."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2024",
            "title": "Field validation — automotive & professional users",
            "institution": "Automotive field study, Borås — October 2023 · Pro user cohort",
            "description": "7/9 reduced sweat retention. 3/3 with pre-existing dermatitis reported measurable skin improvement. First D2C sales."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "done",
            "year": "2025",
            "title": "Military field test — active combat conditions",
            "institution": "National Guard of Ukraine, 2nd Corps",
            "description": "10/10 would use in combat. 9/10 reported improved weapon precision. Signed by Corps Chaplain."
          }
        },
        {
          "type": "timeline_item",
          "settings": {
            "status": "active",
            "year": "2026",
            "title": "D2C launch — USA, Canada, UK",
            "institution": "Direct to consumer · OEM readiness",
            "description": "98% of sales from North America and UK. Patent pending. First commercial scale."
          }
        },
        {
          "type": "partner",
          "settings": { "name": "Uppsala University" }
        },
        {
          "type": "partner",
          "settings": { "name": "RISE" }
        },
        {
          "type": "partner",
          "settings": { "name": "Swedish School of Textiles" }
        },
        {
          "type": "partner",
          "settings": { "name": "Skåne University Hospital" }
        },
        {
          "type": "partner",
          "settings": { "name": "Vinnova" }
        },
        {
          "type": "partner",
          "settings": { "name": "Uppsala Innovation Center" }
        }
      ]
    }
  ]
}
{% endschema %}