{% comment %}
  DRYE Mini Review — compact PDP Hero review slider
  Keeps new low/compact layout.
  Adds old features:
  - Prev/next arrows
  - B2B badge instead of stars per review
  - Flag per review
  - Optional attribution
  - No bottom trust/footer links
{% endcomment %}

{% liquid
  assign max_reviews = 9
  assign slide_count = 0

  for i in (1..max_reviews)
    assign quote_key = 'review_' | append: i | append: '_quote'
    assign name_key = 'review_' | append: i | append: '_name'
    assign location_key = 'review_' | append: i | append: '_location'

    assign rev_quote = block.settings[quote_key]
    assign rev_name = block.settings[name_key]
    assign rev_location = block.settings[location_key]

    if rev_quote != blank or rev_name != blank or rev_location != blank
      assign slide_count = slide_count | plus: 1
    endif
  endfor
%}

{% if slide_count > 0 %}
  <section
    class="drye-mini-review"
    data-drye-review-slider
    aria-label="Customer reviews"
  >

    {% if slide_count > 1 %}
      <button
        type="button"
        class="drye-mini-review__arrow drye-mini-review__arrow--prev"
        data-drye-review-prev
        aria-label="Previous review"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <button
        type="button"
        class="drye-mini-review__arrow drye-mini-review__arrow--next"
        data-drye-review-next
        aria-label="Next review"
      >
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 6L15 12L9 18" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {% endif %}

    <div class="drye-mini-review__viewport">
      {% assign rendered_index = 0 %}

      {% for i in (1..max_reviews) %}
        {% liquid
          assign quote_key       = 'review_' | append: i | append: '_quote'
          assign name_key        = 'review_' | append: i | append: '_name'
          assign location_key    = 'review_' | append: i | append: '_location'
          assign label_key       = 'review_' | append: i | append: '_label'
          assign stars_key       = 'review_' | append: i | append: '_stars'
          assign b2b_key         = 'review_' | append: i | append: '_show_as_b2b'
          assign badge_key       = 'review_' | append: i | append: '_badge_text'
          assign attribution_key = 'review_' | append: i | append: '_attribution'
          assign flag_key        = 'review_' | append: i | append: '_flag_url'

          assign rev_quote       = block.settings[quote_key]
          assign rev_name        = block.settings[name_key]
          assign rev_location    = block.settings[location_key]
          assign rev_label       = block.settings[label_key]
          assign rev_stars       = block.settings[stars_key] | default: 5 | plus: 0
          assign rev_is_b2b      = block.settings[b2b_key]
          assign rev_badge       = block.settings[badge_key]
          assign rev_attribution = block.settings[attribution_key]
          assign rev_flag        = block.settings[flag_key]

          assign has_review = false
          if rev_quote != blank or rev_name != blank or rev_location != blank
            assign has_review = true
          endif
        %}

        {% if has_review %}
          <article
            class="drye-mini-review__card{% if rendered_index == 0 %} is-active{% endif %}"
            data-drye-review-slide
            data-review-index="{{ rendered_index }}"
          >

            {% if rev_is_b2b %}
              <div class="drye-mini-review__badge">
                {{ rev_badge | default: 'FIELD STUDY' | escape }}
              </div>
            {% else %}
              <div class="drye-mini-review__stars" aria-label="{{ rev_stars }} out of 5 stars">
                {% for s in (1..rev_stars) %}
                  <svg viewBox="0 0 11 11" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M5.5 0L6.7 3.8h4L7.5 6.2 8.7 10 5.5 7.6 2.3 10l1.2-3.8L.3 3.8h4L5.5 0z" fill="#5F8A8B"/>
                  </svg>
                {% endfor %}
              </div>
            {% endif %}

            {% if rev_quote != blank %}
              <p class="drye-mini-review__quote">
                {{ rev_quote | escape }}
              </p>
            {% endif %}

            {% if rev_attribution != blank %}
              <div class="drye-mini-review__attribution">
                {{ rev_attribution | escape }}
              </div>
            {% endif %}

            <div class="drye-mini-review__meta">
              <div class="drye-mini-review__left">
{% if rev_name != blank %}
  <span class="drye-mini-review__name-row">
    <span class="drye-mini-review__name">
      {{ rev_name | escape }}
    </span>

    {% if rev_flag != blank %}
      <img
        class="drye-mini-review__flag"
        src="{{ rev_flag | escape }}"
        alt=""
        loading="lazy"
        width="14"
        height="9"
      >
    {% endif %}
  </span>
{% endif %}

{% if rev_label != blank or rev_location != blank %}
  <div class="drye-mini-review__role">
    {{ rev_label | escape }}{% if rev_label != blank and rev_location != blank %} · {% endif %}{{ rev_location | escape }}
  </div>
{% endif %}
              </div>

              <span class="drye-mini-review__verified" aria-label="Verified buyer">
                <svg viewBox="0 0 8 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <path d="M3.94 9.65C2.83 9.35 1.85 8.7 1.14 7.79.43 6.89.03 5.78 0 4.63V1.21L3.94 0l3.94 1.21v3.42c-.03 1.15-.43 2.26-1.14 3.16-.71.91-1.69 1.56-2.8 1.86z" fill="#9CA3AF"/>
                  <path d="M3.3 5.27L2.16 4.22l-.57.53 1.14 1.05.57.53.57-.53 2.28-2.1-.57-.52-2.28 2.1z" fill="#fff"/>
                </svg>
                Verified
              </span>
            </div>

          </article>

          {% assign rendered_index = rendered_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>

    {% if slide_count > 1 %}
      <div class="drye-mini-review__footer">
        <div class="drye-mini-review__dots" data-drye-review-dots>
          {% for i in (1..slide_count) %}
            <button
              type="button"
              class="drye-mini-review__dot{% if forloop.first %} is-active{% endif %}"
              data-drye-review-dot
              data-review-dot-index="{{ forloop.index0 }}"
              aria-label="Review {{ forloop.index }}"
              {% if forloop.first %}aria-current="true"{% endif %}
            ></button>
          {% endfor %}
        </div>

        <span class="drye-mini-review__swipe-hint" data-drye-swipe-hint aria-hidden="true">
          swipe ›
        </span>
      </div>
    {% endif %}

  </section>

  <script>
    (() => {
      const sliders = document.querySelectorAll('[data-drye-review-slider]:not([data-drye-review-bound])');

      sliders.forEach((slider) => {
        slider.dataset.dryeReviewBound = 'true';

        const slides = Array.from(slider.querySelectorAll('[data-drye-review-slide]'));
        const dots = Array.from(slider.querySelectorAll('[data-drye-review-dot]'));
        const prev = slider.querySelector('[data-drye-review-prev]');
        const next = slider.querySelector('[data-drye-review-next]');
        const swipeHint = slider.querySelector('[data-drye-swipe-hint]');

        if (!slides.length) return;

        let active = 0;
        let timer = null;
        let hinted = false;

        function hideHint() {
          if (hinted || !swipeHint) return;

          hinted = true;
          swipeHint.classList.add('is-hidden');
        }

        function setActive(index) {
          active = (index + slides.length) % slides.length;

          slides.forEach((slide, i) => {
            slide.classList.toggle('is-active', i === active);
          });

          dots.forEach((dot, i) => {
            const on = i === active;

            dot.classList.toggle('is-active', on);

            if (on) {
              dot.setAttribute('aria-current', 'true');
            } else {
              dot.removeAttribute('aria-current');
            }
          });
        }

        function startAuto() {
          if (slides.length <= 1) return;

          stopAuto();
          timer = setInterval(() => setActive(active + 1), 5000);
        }

        function stopAuto() {
          if (timer) {
            clearInterval(timer);
            timer = null;
          }
        }

        if (prev) {
          prev.addEventListener('click', () => {
            setActive(active - 1);
            startAuto();
            hideHint();
          });
        }

        if (next) {
          next.addEventListener('click', () => {
            setActive(active + 1);
            startAuto();
            hideHint();
          });
        }

        dots.forEach((dot, i) => {
          dot.addEventListener('click', () => {
            setActive(i);
            startAuto();
            hideHint();
          });
        });

        slider.addEventListener('mouseenter', stopAuto);
        slider.addEventListener('mouseleave', startAuto);

        let touchX = 0;

        slider.addEventListener('touchstart', (event) => {
          touchX = event.changedTouches[0].screenX;
          stopAuto();
        }, { passive: true });

        slider.addEventListener('touchend', (event) => {
          const diff = touchX - event.changedTouches[0].screenX;

          if (Math.abs(diff) > 40) {
            setActive(active + (diff > 0 ? 1 : -1));
            hideHint();
          }

          startAuto();
        }, { passive: true });

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            stopAuto();
          } else {
            startAuto();
          }
        });

        setActive(0);
        startAuto();
      });
    })();
  </script>
{% endif %}