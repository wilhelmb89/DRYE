    "drye_section_06_faq_9BK9Uy": {
      "type": "drye-section-06-faq",
      "blocks": {
        "faq_item_yw9EKh": {
          "type": "faq_item",
          "settings": {
            "question": "What is a glove liner?",
            "answer": "A glove liner is a thin textile worn between skin and a protective glove to manage moisture. Most liners absorb sweat — and eventually saturate, holding wetness against the skin. DRYE routes moisture directionally through the fabric instead, with no saturation point."
          }
        },
        "faq_item_GqgjLE": {
          "type": "faq_item",
          "settings": {
            "question": "Does it work under nitrile gloves specifically?",
            "answer": "Yes. DRYE was developed and tested primarily for use under nitrile — the most common glove in healthcare, automotive, and lab environments. At 0.4mm, it fits inside any standard nitrile glove without affecting the fit or tactile feel. Dexterity is unchanged."
          }
        },
        "faq_item_Xeg4W3": {
          "type": "faq_item",
          "settings": {
            "question": "Do glove liners work for hockey?",
            "answer": "Yes — if they route moisture instead of absorbing it. A hockey period is 20 minutes. Any absorbent liner saturates within that time and holds warm, damp material against skin for the rest of play. DRYE has no saturation point and continues working through full game conditions."
          }
        },
        "faq_item_LXfMBR": {
          "type": "faq_item",
          "settings": {
            "question": "Do glove liners help with eczema?",
            "answer": "Yes, when the mechanism is right. Sealed gloves trap sweat against skin, which prevents the barrier from recovering between exposures. A liner that keeps the skin surface dry removes that trigger. DRYE users with hand eczema report skin stabilising within days to weeks of consistent use."
          }
        }
      },
      "block_order": [
        "faq_item_yw9EKh",
        "faq_item_GqgjLE",
        "faq_item_Xeg4W3",
        "faq_item_LXfMBR"
