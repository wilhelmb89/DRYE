        "content_4NcLzf": {
          "type": "content",
          "settings": {
            "shipping_html": "<style>\n  .policy-table-scroll {\n    width: 100%;\n    overflow-x: auto;\n    -webkit-overflow-scrolling: touch;\n    margin-top: 16px;\n  }\n\n  .policy-table-scroll .delivery-table {\n    min-width: 680px;\n  }\n\n  .policy-scroll-hint {\n    display: none;\n    font-size: 12px;\n    color: #6f7d8f;\n    margin-top: 8px;\n  }\n\n  @media screen and (max-width: 749px) {\n    .policy-table-scroll .delivery-table {\n      min-width: 720px;\n    }\n\n    .policy-scroll-hint {\n      display: block;\n    }\n\n    .delivery-table th,\n    .delivery-table td {\n      vertical-align: top;\n    }\n  }\n</style>\n\n<div class=\"policy-section\" id=\"what-to-expect\">\n  <span class=\"ps-label\">Overview</span>\n  <h2 class=\"ps-h\">What to expect</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      We ship worldwide from Sweden. Orders dispatch within\n      <strong>12–24 hours</strong> Monday to Friday, excluding Swedish public\n      holidays. Orders placed on weekends or holidays ship the next business day.\n    </p>\n  </div>\n\n  <div class=\"policy-stat-row\" style=\"margin-top:24px;\">\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">12–24<em>h</em>\n</div>\n      <div class=\"policy-stat-lbl\">Dispatch time, Mon–Fri</div>\n    </div>\n\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">2<em>+</em>\n</div>\n      <div class=\"policy-stat-lbl\">Carriers — PostNord, UPS</div>\n    </div>\n\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">SE</div>\n      <div class=\"policy-stat-lbl\">Ships from Stockholm, Sweden</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"delivery-times\">\n  <span class=\"ps-label\">Timeline</span>\n  <h2 class=\"ps-h\">Estimated delivery times</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      All delivery estimates below are\n      <strong>business days after dispatch</strong>. Times may vary due to\n      customs processing, carrier delays, or local conditions.\n    </p>\n  </div>\n\n  <div class=\"policy-table-scroll\">\n    <table class=\"delivery-table\">\n      <thead>\n        <tr>\n          <th>Region</th>\n          <th>PostNord</th>\n          <th>UPS Express Saver</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>USA</td>\n          <td>4–6 days</td>\n          <td>1–3 days</td>\n        </tr>\n\n        <tr>\n          <td>Canada</td>\n          <td>4–6 days</td>\n          <td>1–3 days</td>\n        </tr>\n\n        <tr>\n          <td>EU</td>\n          <td>1–4 days</td>\n          <td>Next day where available</td>\n        </tr>\n\n        <tr>\n          <td>UK</td>\n          <td>2–7 days</td>\n          <td>1–3 days</td>\n        </tr>\n\n        <tr>\n          <td>Norway</td>\n          <td>1–4 days</td>\n          <td>Next day where available</td>\n        </tr>\n\n        <tr>\n          <td>Australia &amp; New Zealand</td>\n          <td>4–10 days</td>\n          <td>3–5 days where available</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <p class=\"policy-scroll-hint\">Scroll sideways to compare carriers.</p>\n</div>\n\n<div class=\"policy-section\" id=\"shipping-costs\">\n  <span class=\"ps-label\">Cost</span>\n  <h2 class=\"ps-h\">Shipping costs</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      Shipping prices are shown at checkout. Import charges depend on the\n      carrier, destination, and delivery option selected at checkout.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>PostNord</strong> — import charges are prepaid by DRYE for\n      shipments to the USA and Canada when the checkout option is marked\n      <strong>Import fees included</strong>.\n    </p>\n  </div>\n\n  <div class=\"policy-table-scroll\">\n    <table class=\"delivery-table\">\n      <thead>\n        <tr>\n          <th>Region</th>\n          <th>Import terms</th>\n          <th>Import fees included?</th>\n          <th>Extra after checkout</th>\n          <th>Handled by DRYE?</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>USA</td>\n          <td>PostNord PDDP</td>\n          <td><strong>Yes</strong></td>\n          <td>\n            <strong>USD 0 expected at delivery.</strong>\n            Applicable U.S. postal customs duty and import-processing fees are\n            paid by DRYE.\n          </td>\n          <td><strong>Yes</strong></td>\n        </tr>\n\n        <tr>\n          <td>Canada</td>\n          <td>PostNord DDP</td>\n          <td><strong>Yes</strong></td>\n          <td>\n            <strong>CAD 0 expected at delivery.</strong>\n            Applicable Canadian import taxes, customs duty, and postal handling\n            fees are paid by DRYE.\n          </td>\n          <td><strong>Yes</strong></td>\n        </tr>\n\n        <tr>\n          <td>EU</td>\n          <td>Intra-EU delivery</td>\n          <td><strong>Not applicable</strong></td>\n          <td>\n            No customs import bill. Applicable VAT is shown at checkout.\n          </td>\n          <td><strong>Yes</strong></td>\n        </tr>\n\n        <tr>\n          <td>UK</td>\n          <td>Recipient-paid unless stated otherwise at checkout</td>\n          <td><strong>No</strong></td>\n          <td>\n            VAT, customs duty, and postal handling fees may apply.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>Norway</td>\n          <td>Recipient-paid unless stated otherwise at checkout</td>\n          <td><strong>No</strong></td>\n          <td>\n            Local import tax, customs duty, and postal handling fees may apply.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>Australia &amp; New Zealand</td>\n          <td>Recipient-paid unless stated otherwise at checkout</td>\n          <td><strong>No</strong></td>\n          <td>\n            Local taxes, customs duty, and postal handling fees may apply.\n          </td>\n          <td>No</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <p class=\"policy-scroll-hint\">Scroll sideways to see all columns.</p>\n\n  <div class=\"callout\">\n    <p>\n      <strong>UPS Express Saver</strong> — fastest option. UPS shipments to the\n      USA and Canada are sent under <strong>DAP</strong> terms, which means the\n      recipient is responsible for import charges.\n    </p>\n  </div>\n\n  <div class=\"policy-table-scroll\">\n    <table class=\"delivery-table\">\n      <thead>\n        <tr>\n          <th>Region</th>\n          <th>Import terms</th>\n          <th>Import fees included?</th>\n          <th>Estimated extra cost</th>\n          <th>Handled by DRYE?</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>USA</td>\n          <td>UPS DAP</td>\n          <td><strong>No</strong></td>\n          <td>\n            Applicable U.S. customs duty plus any UPS brokerage, disbursement,\n            clearance, or processing fees. Any sales tax collected by DRYE is\n            shown separately at checkout.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>Canada</td>\n          <td>UPS DAP</td>\n          <td><strong>No</strong></td>\n          <td>\n            Canadian sales tax is generally 5–15% depending on the province or\n            territory, plus any UPS brokerage, disbursement, clearance, or\n            processing fees. Customs duty may be 0% where CETA treatment applies.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>EU</td>\n          <td>Intra-EU delivery</td>\n          <td><strong>Not applicable</strong></td>\n          <td>\n            No customs import bill. Applicable VAT is shown at checkout.\n          </td>\n          <td><strong>Yes</strong></td>\n        </tr>\n\n        <tr>\n          <td>UK</td>\n          <td>UPS DAP</td>\n          <td><strong>No</strong></td>\n          <td>\n            VAT, customs duty, and UPS brokerage or processing fees may apply.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>Norway</td>\n          <td>UPS DAP</td>\n          <td><strong>No</strong></td>\n          <td>\n            Local import tax, customs duty, and UPS brokerage or processing\n            fees may apply.\n          </td>\n          <td>No</td>\n        </tr>\n\n        <tr>\n          <td>Australia &amp; New Zealand</td>\n          <td>UPS DAP</td>\n          <td><strong>No</strong></td>\n          <td>\n            Local taxes, customs duty, and UPS brokerage or processing fees\n            may apply.\n          </td>\n          <td>No</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <p class=\"policy-scroll-hint\">Scroll sideways to see all columns.</p>\n</div>\n\n<div class=\"policy-section\" id=\"customs\">\n  <span class=\"ps-label\">Import fees</span>\n  <h2 class=\"ps-h\">Customs &amp; duties</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      The tables above show whether import charges are prepaid by DRYE or paid\n      separately by the recipient. Import charges may include customs duty,\n      sales or import tax, and carrier clearance or processing fees.\n    </p>\n  </div>\n\n  <div class=\"policy-table-scroll\">\n    <table class=\"delivery-table\">\n      <thead>\n        <tr>\n          <th>Label</th>\n          <th>Meaning</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>\n            <strong>Included / PDDP / DDP</strong>\n          </td>\n          <td>\n            DRYE pays the applicable import charges. No separate import payment\n            is expected from the recipient at delivery.\n          </td>\n        </tr>\n\n        <tr>\n          <td>\n            <strong>Not included / DAP</strong>\n          </td>\n          <td>\n            The recipient is responsible for applicable customs duty, tax, and\n            carrier fees before or after delivery.\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>USA:</strong> PostNord uses Postal Delivered Duties Paid\n      (PDDP). DRYE pays the applicable U.S. postal customs duty and related\n      postal import charges. PostNord currently lists a 15% customs-duty rate\n      for goods shipments to the USA. The recipient should therefore pay\n      <strong>USD 0 at delivery</strong> when PostNord PDDP is selected.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>UPS to the USA:</strong> UPS shipments are sent under DAP terms.\n      The recipient may therefore be charged customs duty and UPS brokerage,\n      disbursement, clearance, or processing fees.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>U.S. state and local sales tax:</strong> Sales-tax rates can vary\n      by state, county, city, delivery address, and product. Any sales tax that\n      DRYE is required to collect is calculated and shown at checkout. It is\n      separate from customs duty and carrier import fees.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>Canada:</strong> Qualifying products of European Union origin\n      may receive 0% customs duty under CETA. CETA does not remove Canadian\n      GST, HST, PST, QST, or carrier processing fees.\n    </p>\n  </div>\n\n  <div class=\"ps-body\">\n    <p>\n      <strong>Indicative Canadian sales tax by province or territory</strong>\n    </p>\n\n    <p>\n      The table below shows the typical combined tax on standard taxable goods\n      and an example based on CAD 100 of taxable value.\n    </p>\n  </div>\n\n  <div class=\"policy-table-scroll\">\n    <table class=\"delivery-table\">\n      <thead>\n        <tr>\n          <th>Province or territory</th>\n          <th>Indicative combined tax</th>\n          <th>Approximate tax per CAD 100</th>\n        </tr>\n      </thead>\n\n      <tbody>\n        <tr>\n          <td>\n            Alberta, Northwest Territories, Nunavut, and Yukon\n          </td>\n          <td>5%</td>\n          <td>CAD 5.00</td>\n        </tr>\n\n        <tr>\n          <td>Saskatchewan</td>\n          <td>11%</td>\n          <td>CAD 11.00</td>\n        </tr>\n\n        <tr>\n          <td>British Columbia and Manitoba</td>\n          <td>12%</td>\n          <td>CAD 12.00</td>\n        </tr>\n\n        <tr>\n          <td>Ontario</td>\n          <td>13%</td>\n          <td>CAD 13.00</td>\n        </tr>\n\n        <tr>\n          <td>Nova Scotia</td>\n          <td>14%</td>\n          <td>CAD 14.00</td>\n        </tr>\n\n        <tr>\n          <td>Quebec</td>\n          <td>14.975%</td>\n          <td>Approximately CAD 14.98</td>\n        </tr>\n\n        <tr>\n          <td>\n            New Brunswick, Newfoundland and Labrador, and Prince Edward Island\n          </td>\n          <td>15%</td>\n          <td>CAD 15.00</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n\n  <p class=\"policy-scroll-hint\">Scroll sideways to see all columns.</p>\n\n  <div class=\"callout\">\n    <p>\n      <strong>PostNord to Canada:</strong> DRYE uses DDP and pays the applicable\n      Canadian import taxes, customs duty, and postal handling fees. The\n      recipient should therefore pay <strong>CAD 0 at delivery</strong>.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>UPS to Canada:</strong> UPS shipments are sent under DAP terms.\n      The recipient pays the applicable Canadian sales tax and any UPS\n      brokerage, disbursement, clearance, or processing fees. Customs duty may\n      be 0% where CETA treatment is accepted.\n    </p>\n  </div>\n\n  <div class=\"callout\">\n    <p>\n      <strong>Canada Post handling:</strong> Canada Post currently charges\n      CAD 9.95 for a taxable or dutiable postal item. Under DRYE's PostNord DDP\n      option, this charge is handled by DRYE rather than collected from the\n      recipient.\n    </p>\n  </div>\n\n  <div class=\"callout callout-warn\">\n    <p>\n      Customs authorities and carriers make the final assessment of customs\n      value, classification, origin, duty, tax, and processing fees. Rates and\n      carrier charges may change.\n    </p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"tracking\">\n  <span class=\"ps-label\">Tracking</span>\n  <h2 class=\"ps-h\">Tracking your order</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      Tracking availability depends on the service you choose at checkout.\n    </p>\n  </div>\n\n  <ul class=\"policy-list\">\n    <li>\n      <strong>UPS Express Saver</strong> — tracking included\n    </li>\n    <li>\n      <strong>PostNord Tracked Letterbox</strong> — tracking included\n    </li>\n    <li>\n      <strong>PostNord Untracked Letter</strong> — no tracking number provided\n    </li>\n  </ul>\n\n  <div class=\"callout callout-warn\">\n    <p>\n      If you choose an untracked option, delivery visibility is limited after\n      dispatch.\n    </p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"delivery-issues\">\n  <span class=\"ps-label\">Problems</span>\n  <h2 class=\"ps-h\">Delivery issues</h2>\n\n  <div class=\"ps-body\">\n    <p>\n      If your package arrives damaged or incomplete, contact us within\n      <strong>7 days of delivery</strong> at\n      <a href=\"mailto:info@drye.se\">info@drye.se</a>.\n    </p>\n\n    <p>\n      We cannot control carrier delays — including weather, customs processing,\n      or strikes — but we will assist promptly if something goes wrong.\n    </p>\n\n    <p>\n      If your selected shipping method was marked\n      <strong>Import fees included</strong>, <strong>PDDP</strong>, or\n      <strong>DDP</strong>, but the carrier requests an import payment, send us\n      the complete customs or carrier receipt and your tracking number.\n    </p>\n\n    <p>\n      If payment is required to prevent the package from being returned, keep\n      the receipt. DRYE will review whether the charge should have been covered\n      by the selected shipping method.\n    </p>\n\n    <p>\n      Import charges on shipments marked <strong>DAP</strong> are the\n      recipient's responsibility.\n    </p>\n\n    <p>\n      Questions? Email\n      <a href=\"mailto:info@drye.se\">info@drye.se</a> — we respond within\n      24 hours.\n    </p>\n  </div>\n\n  <p class=\"policy-updated\">\n    Last updated: 18 July 2026.\n  </p>\n</div>",
            "returns_html": "<div class=\"policy-section\" id=\"guarantee\">\n  <span class=\"ps-label\">Our commitment</span>\n  <h2 class=\"ps-h\">30-day money-back guarantee</h2>\n  <div class=\"ps-body\">\n    <p>If it doesn't work for you, return within 30 days. Contact us and we'll handle the rest.</p>\n  </div>\n  <div class=\"policy-stat-row\" style=\"margin-top:24px;\">\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">30<em>d</em>\n</div>\n      <div class=\"policy-stat-lbl\">Return window from delivery</div>\n    </div>\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">5–10<em>d</em>\n</div>\n      <div class=\"policy-stat-lbl\">Refund processing after approval</div>\n    </div>\n    <div class=\"policy-stat\">\n      <div class=\"policy-stat-num\">0</div>\n      <div class=\"policy-stat-lbl\">Forms to fill. One email to start.</div>\n    </div>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"eligibility\">\n  <span class=\"ps-label\">Requirements</span>\n  <h2 class=\"ps-h\">Eligibility</h2>\n  <div class=\"ps-body\">\n    <p>To qualify for a return:</p>\n  </div>\n  <ul class=\"policy-list\">\n    <li>Product must be in original condition — undamaged</li>\n    <li>Return must be requested within 30 days of receiving your order</li>\n    <li>Light use is accepted — we understand the need to try them in real conditions</li>\n  </ul>\n</div>\n\n<div class=\"policy-section\" id=\"how-to-return\">\n  <span class=\"ps-label\">Process</span>\n  <h2 class=\"ps-h\">How to start a return</h2>\n  <div class=\"step-list\">\n    <div class=\"step\">\n      <div class=\"step-num\">01</div>\n      <div class=\"step-body\">\n        <div class=\"step-title\">Email <a href=\"mailto:info@drye.se\" style=\"color:var(--emerald);text-decoration:none;\">info@drye.se</a>\n</div>\n        <div class=\"step-desc\">Include your order number and a short reason. Short and simple is fine.</div>\n      </div>\n    </div>\n    <div class=\"step\">\n      <div class=\"step-num\">02</div>\n      <div class=\"step-body\">\n        <div class=\"step-title\">We send return instructions</div>\n        <div class=\"step-desc\">We confirm eligibility and provide return shipping details. You cover return shipping unless the product was damaged or incorrect.</div>\n      </div>\n    </div>\n    <div class=\"step\">\n      <div class=\"step-num\">03</div>\n      <div class=\"step-body\">\n        <div class=\"step-title\">Refund issued within 5–10 business days</div>\n        <div class=\"step-desc\">Processed to your original payment method after approval. You'll receive a confirmation email.</div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"refunds\">\n  <span class=\"ps-label\">Money back</span>\n  <h2 class=\"ps-h\">Refunds</h2>\n  <ul class=\"policy-list\">\n    <li>Refund to your original payment method</li>\n    <li>Processed within <strong>5–10 business days</strong> after approval</li>\n    <li>Confirmation email sent once issued</li>\n  </ul>\n</div>\n\n<div class=\"policy-section\" id=\"what-can-be-returned\">\n  <span class=\"ps-label\">Conditions</span>\n  <h2 class=\"ps-h\">What can be returned</h2>\n  <div class=\"ps-body\">\n    <p>You can return liners even if they've been lightly used. Excessive wear or damage may disqualify a full refund — assessed case by case.</p>\n  </div>\n  <div class=\"callout\">\n    <p>Questions? Email <a href=\"mailto:info@drye.se\">info@drye.se</a> — business hours 08:00–17:00 CET.</p>\n  </div>\n  <p class=\"policy-updated\">This policy applies to all purchases made directly from <a href=\"https://www.drye.se\">www.drye.se</a>.</p>\n</div>",
            "privacy_html": "<div class=\"policy-section\" id=\"privacy-intro\">\n  <span class=\"ps-label\">Overview</span>\n  <h2 class=\"ps-h\">Privacy policy</h2>\n  <div class=\"ps-body\">\n    <p>This policy explains how we collect, use, and protect your personal information. We follow GDPR and other applicable laws. This applies to all visitors and customers on drye.se.</p>\n    <p>DRYE AB, reg. no. 559313-1476, is responsible for your personal data. Questions? Email <a href=\"mailto:info@drye.se\">info@drye.se</a>.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"what-we-collect\">\n  <span class=\"ps-label\">Data collection</span>\n  <h2 class=\"ps-h\">What we collect and why</h2>\n  <div class=\"ps-body\">\n    <p>We only collect data necessary to provide our products and services.</p>\n  </div>\n  <ul class=\"policy-list\">\n    <li>Name, email, phone number</li>\n    <li>Delivery and billing address</li>\n    <li>Order and transaction details</li>\n    <li>Communication history with us</li>\n  </ul>\n  <div class=\"ps-body\" style=\"margin-top:20px;\">\n    <p>We use this to fulfill orders, provide customer support, handle returns, and improve site functionality. We only send marketing if you've opted in.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"your-rights\">\n  <span class=\"ps-label\">Your rights</span>\n  <h2 class=\"ps-h\">You control your data</h2>\n  <div class=\"ps-body\">\n    <p>At any time, you can:</p>\n  </div>\n  <ul class=\"policy-list\">\n    <li>Request a copy of your data</li>\n    <li>Ask us to correct or delete your data</li>\n    <li>Object to how we use your data</li>\n    <li>Withdraw consent at any time</li>\n  </ul>\n  <div class=\"callout\" style=\"margin-top:16px;\">\n    <p>Email <a href=\"mailto:info@drye.se\">info@drye.se</a> to exercise your rights.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"sms\">\n  <span class=\"ps-label\">SMS</span>\n  <h2 class=\"ps-h\">SMS communication</h2>\n  <div class=\"ps-body\">\n    <p>If you opt into SMS messages, we may send order updates, shipping notifications, abandoned cart reminders, and review requests. Standard message and data rates apply.</p>\n  </div>\n  <div class=\"callout\" style=\"border-left-color:#ef4444;background:#fcf7f7;\">\n    <p>Opt out anytime by replying <strong>STOP</strong> or emailing <a href=\"mailto:info@drye.se\">info@drye.se</a>.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"data-sharing\">\n  <span class=\"ps-label\">Third parties</span>\n  <h2 class=\"ps-h\">Sharing of data</h2>\n  <div class=\"ps-body\">\n    <p>We do not sell your data. We only share it with trusted third parties necessary for delivering our service — logistics, payment processing, and warehousing. These partners follow our instructions and cannot use your data for their own purposes.</p>\n  </div>\n  <div class=\"callout\">\n    <p>Questions? Email <a href=\"mailto:info@drye.se\">info@drye.se</a>.</p>\n  </div>\n</div>",
            "terms_html": "<div class=\"policy-section\" id=\"terms-intro\">\n  <span class=\"ps-label\">Overview</span>\n  <h2 class=\"ps-h\">Terms of use</h2>\n  <div class=\"ps-body\">\n    <p>By visiting and using drye.se, you agree to these terms. Please read carefully and contact us if you have questions.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"copyright\">\n  <span class=\"ps-label\">Intellectual property</span>\n  <h2 class=\"ps-h\">Copyright &amp; trademarks</h2>\n  <div class=\"ps-body\">\n    <p>All content on this website — including text, images, logos, and software — is protected by copyright and belongs to DRYE or our licensors. You may not copy, distribute, modify, or use any content without our written consent.</p>\n    <p>All trademarks, logos, and service marks displayed on this website are owned by DRYE or our licensors. You may not use any of these without our written permission.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"disclaimer\">\n  <span class=\"ps-label\">Liability</span>\n  <h2 class=\"ps-h\">Disclaimer</h2>\n  <div class=\"ps-body\">\n    <p>We aim to provide accurate and up-to-date information, but we cannot guarantee completeness or accuracy. We are not responsible for any errors or omissions.</p>\n    <p>This site may contain links to third-party websites. We are not responsible for the content or operation of these sites and do not control their ownership.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"user-responsibility\">\n  <span class=\"ps-label\">Your responsibility</span>\n  <h2 class=\"ps-h\">User responsibility</h2>\n  <div class=\"ps-body\">\n    <p>By using this website, you agree to comply with applicable laws and not use the site for illegal or unauthorized purposes. You are responsible for keeping your account and password secure and notifying us of any unauthorized activity.</p>\n  </div>\n</div>\n\n<div class=\"policy-section\" id=\"changes\">\n  <span class=\"ps-label\">Updates</span>\n  <h2 class=\"ps-h\">Changes to terms</h2>\n  <div class=\"ps-body\">\n    <p>We reserve the right to modify these terms at any time without notice. It is your responsibility to review the terms regularly for updates.</p>\n  </div>\n  <div class=\"callout\">\n    <p>Questions? Email <a href=\"mailto:info@drye.se\">info@drye.se</a>.</p>\n  </div>\n</div>"
          }
        }
      },
