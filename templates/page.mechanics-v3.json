          "type": "faq_item",
          "settings": {
            "question": "Does it work under nitrile gloves specifically?",
            "answer": "Yes. DRYE is 0.4mm thin and fits under nitrile, latex, vinyl, rubber and many sealed work gloves without changing the feel much."
          }
        },
