          }
        },
        "faq_item_7LAyF9": {
          "type": "faq_item",
          "settings": {
            "question": "Can I wash it? How?",
            "answer": "Yes. Machine wash up to 90°C / 194°F. Air dry or tumble dry. No coatings or membranes to wash out."
          }
        },
        "faq_item_eWk7cW": {
          "type": "faq_item",
          "settings": {
            "question": "How long does it last? Does it degrade?",
            "answer": "With regular use and machine washing, DRYE lasts 6–12 months. The routing structure is built into the physical composition of the textile — it doesn't rely on a chemical treatment that can wash out. The mechanism doesn't degrade with washing."
          }
        }
