        "card_HLKCtU": {
          "type": "card",
          "settings": {
            "profession": "Automotive repair",
            "question": "How much time does it save?",
            "quote": "<i> “Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer.” </i>",
