    "drye_section_06_faq_NanA39": {
      "type": "drye-section-06-faq",
      "blocks": {
        "faq_item_t8zgQ4": {
          "type": "faq_item",
          "settings": {
            "question": "Does it work under nitrile gloves specifically?",
            "answer": "Yes. DRYE is 0.4mm thin and fits under nitrile, latex, vinyl, rubber and many sealed work gloves without changing the feel much."
          }
        },
        "faq_item_3xXVG9": {
          "type": "faq_item",
          "settings": {
            "question": "What if it doesn't work for me?",
            "answer": "Full refund within 30 days. No questions. The claim is that the physics works — if it doesn't change your shift, you pay nothing."
          }
        },
        "faq_item_7LAyF9": {
          "type": "faq_item",
          "settings": {
            "question": "Can I wash it? How?",
            "answer": "Yes. Machine wash up to 90°C / 194°F. Air dry or tumble dry. No coatings or membranes to wash out."
          }
        },
        "faq_item_eWk7cW": {
          "type": "faq_item",
          "settings": {
            "question": "How long does it last? Does it degrade?",
            "answer": "With regular use and machine washing, DRYE lasts 6–12 months. The routing structure is built into the physical composition of the textile — it doesn't rely on a chemical treatment that can wash out. The mechanism doesn't degrade with washing."
          }
        },
        "faq_item_cJEeEB": {
          "type": "faq_item",
          "settings": {
            "question": "Who it's not for",
            "answer": "DRYE works when gloves stay on. If you remove them every few minutes — hairdressers feeling individual hair strands, food handlers in open kitchens — the routing mechanism doesn't have time to function and the liner becomes an extra layer with no benefit.It's also not for sterile surgical environments. Non-sterile use only."
          }
        }
      },
      "block_order": [
