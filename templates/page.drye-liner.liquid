{% comment %}
  Standalone DRYE Liner landing page.
  Rendered without theme chrome via {% layout none %}; the page is a fully
  self-contained document (own <head>, fonts, nav, footer). Content is wrapped
  in {% raw %} so Liquid never parses the inline CSS/JS.
  Reachable at /pages/<page-handle> for any page assigned this template.
{% endcomment %}
{% layout none %}{% raw %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DRYE Liner — Add one dry layer under your gloves</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400&family=Playfair+Display:ital,wght@1,400;1,500&display=swap" rel="stylesheet">

<style>
/* ═══════════════════════════════════════════════════════════
   DRYE — TOKENS (matches base.css)
   ═══════════════════════════════════════════════════════════ */
:root {
  --deep:      #1E3A4C;
  --emerald:   #0D9488;
  --sage:      #5F8A8B;
  --accent:    #3D5A5E;
  --gold:      #F5B301;

  --body:      #374151;
  --muted:     #4B5563;
  --caption:   #9CA3AF;

  --border:    #E5E7EB;
  --bg:        #FFFFFF;
  --bg-soft:   #F8FAFC;
  --bg-ink:    #0F2230;
  --border-base: 1px solid #E5E7EB;

  --white-100: rgba(255,255,255,1);
  --white-085: rgba(255,255,255,.88);
  --white-075: rgba(255,255,255,.75);
  --white-050: rgba(255,255,255,.5);
  --white-035: rgba(255,255,255,.35);
  --white-015: rgba(255,255,255,.15);
  --white-008: rgba(255,255,255,.08);

  --font-display:   'Clash Grotesk', 'DM Sans', sans-serif;
  --font-body:      'DM Sans', sans-serif;
  --font-editorial: 'Playfair Display', Georgia, serif;

  --fw-medium: 500;
  --fw-semibold: 600;

  --fs-hero-h1:    clamp(30px, 8vw, 40px);
  --fs-section-h2: clamp(20px, 5.5vw, 26px);
  --fs-h3:         17px;
  --fs-body:       13px;
  --fs-body-md:    14px;
  --fs-caption:    12px;
  --fs-micro:      10px;
  --fs-micro-2:    9px;

  --space-4: 4px;   --space-6: 6px;   --space-8: 8px;
  --space-10: 10px; --space-12: 12px; --space-14: 14px;
  --space-16: 16px; --space-18: 18px; --space-20: 20px;
  --space-24: 24px; --space-28: 28px; --space-32: 32px;
  --space-40: 40px;

  --page-pad: 20px;
  --section-pad-y: 40px;
  --nav-h: 52px;
  --sticky-h: 60px;

  --dur-base: .2s;
  --dur-reveal: .5s;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  font-size: var(--fs-body);
  background: var(--bg);
  color: var(--body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
  padding-bottom: var(--sticky-h);
}
img { display: block; max-width: 100%; height: auto; }
a { color: inherit; text-decoration: none; }
button { font: inherit; background: none; border: none; cursor: pointer; color: inherit; }
svg { display: block; }

/* ═══════════════════════════════════════════════════════════
   NAV + BENEFIT STRIP
   ═══════════════════════════════════════════════════════════ */
.nav {
  position: sticky; top: 0; z-index: 100; height: var(--nav-h);
  background: var(--bg); border-bottom: var(--border-base);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 var(--page-pad);
}
.nav-logo { font-family: var(--font-display); font-size: 16px; font-weight: var(--fw-semibold); letter-spacing: 0.14em; color: var(--deep); }
.nav-menu { width: 22px; height: 22px; color: var(--deep); display: flex; flex-direction: column; justify-content: center; gap: 4px; }
.nav-menu span { display: block; width: 100%; height: 1.5px; background: currentColor; }
.nav-bag { width: 22px; height: 22px; color: var(--deep); }

.benefit-strip {
  display: flex; overflow-x: auto; border-bottom: var(--border-base);
  scrollbar-width: none; background: var(--bg);
  padding-left: var(--page-pad);
  scroll-snap-type: x mandatory;
  -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 16px, #000 calc(100% - 48px), transparent 100%);
  mask-image: linear-gradient(90deg, transparent 0, #000 16px, #000 calc(100% - 48px), transparent 100%);
}
.benefit-strip::-webkit-scrollbar { display: none; }
.benefit-item {
  flex: 0 0 auto; white-space: nowrap;
  scroll-snap-align: start;
  font-size: var(--fs-micro-2); font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 10px 14px; color: var(--sage);
  border-right: var(--border-base);
}
.benefit-item:last-child { padding-right: var(--page-pad); border-right: none; }

/* ═══════════════════════════════════════════════════════════
   SECTION SYSTEM
   ═══════════════════════════════════════════════════════════ */
.section { padding: var(--section-pad-y) var(--page-pad); border-top: var(--border-base); }
.section:first-of-type { border-top: none; }
.section--soft { background: var(--bg-soft); }
.section--dark { background: var(--bg-ink); color: var(--white-085); border-top-color: transparent; }

.section-eyebrow {
  display: block; font-family: var(--font-body);
  font-size: var(--fs-micro-2); font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: var(--emerald); margin-bottom: var(--space-8);
}
.section--dark .section-eyebrow { color: var(--sage); }

.section-h2 {
  font-family: var(--font-display);
  font-size: var(--fs-section-h2); font-weight: var(--fw-semibold);
  letter-spacing: -0.03em; line-height: 1.06;
  color: var(--deep); margin-bottom: var(--space-10);
}
.section--dark .section-h2 { color: var(--white-100); }

.section-body {
  font-size: var(--fs-body); line-height: 1.6;
  color: var(--muted); margin-bottom: var(--space-16);
}
.section--dark .section-body { color: #C8D4DA; }
.section-body strong { color: var(--deep); font-weight: var(--fw-semibold); }
.section--dark .section-body strong { color: var(--white-100); }

.em { font-family: var(--font-editorial); font-style: italic; font-weight: 400; }

/* ═══════════════════════════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════════════════════════ */
.btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-8);
  font-family: var(--font-body); font-size: var(--fs-caption);
  font-weight: var(--fw-semibold); letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 14px 20px; border-radius: 0;
  border: 1.5px solid transparent;
  transition: background var(--dur-base) ease, color var(--dur-base) ease;
}
.btn--primary { background: var(--emerald); color: #fff; border-color: var(--emerald); width: 100%; }
.btn--primary:hover { background: #0a7d73; border-color: #0a7d73; }
.btn--outline { background: transparent; color: var(--deep); border-color: var(--deep); width: 100%; }
.btn--outline:hover { background: var(--deep); color: #fff; }

.text-link {
  display: inline-block; font-family: var(--font-body);
  font-size: var(--fs-micro); font-weight: var(--fw-semibold);
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--emerald); border-bottom: 1px solid var(--emerald);
  padding-bottom: 2px;
}

/* ═══════════════════════════════════════════════════════════
   HERO
   ═══════════════════════════════════════════════════════════ */
.hero { border-top: none; padding: 0; }
.hero-media { position: relative; aspect-ratio: 4 / 5; background: #0d1f2d; overflow: hidden; }
.hero-media-placeholder {
  position: absolute; inset: 0;
  background: linear-gradient(160deg, #1c3040 0%, #0a1620 100%);
  display: flex; align-items: flex-end; padding: var(--space-20);
}
.hero-media-placeholder span { font-size: var(--fs-micro-2); letter-spacing: 0.12em; text-transform: uppercase; color: var(--sage); }

.hero-info { padding: 18px var(--page-pad) 28px; }
.hero-eyebrow { font-size: var(--fs-micro-2); font-weight: var(--fw-semibold); letter-spacing: 0.18em; text-transform: uppercase; color: var(--sage); margin-bottom: 12px; }
.hero-title {
  font-family: var(--font-display); font-size: var(--fs-hero-h1);
  font-weight: var(--fw-semibold); letter-spacing: -0.03em;
  line-height: 1.02; color: var(--deep); margin-bottom: var(--space-12);
}
.hero-sub { font-size: var(--fs-body-md); color: var(--muted); line-height: 1.6; margin-bottom: var(--space-18); }
.hero-sub strong { color: var(--body); font-weight: var(--fw-semibold); }

.hero-bullets { list-style: none; margin-bottom: var(--space-20); border-top: var(--border-base); }
.hero-bullets li {
  font-size: var(--fs-body); color: var(--muted);
  padding: 9px 0; border-bottom: var(--border-base);
  display: flex; align-items: center; gap: var(--space-10);
}
.hero-bullets li svg { flex-shrink: 0; color: var(--emerald); }

.hero-guarantee {
  text-align: center; font-size: var(--fs-micro-2);
  color: var(--caption); letter-spacing: 0.1em;
  margin-top: var(--space-10); text-transform: uppercase; font-weight: 700;
}

/* ═══════════════════════════════════════════════════════════
   SWIPE GALLERIES
   ═══════════════════════════════════════════════════════════ */
.swipe-wrap {
  overflow-x: auto; overflow-y: hidden;
  scrollbar-width: none; -webkit-overflow-scrolling: touch;
  scroll-snap-type: x mandatory;
  -webkit-mask-image: linear-gradient(90deg, #000 0, #000 calc(100% - 14px), transparent 100%);
  mask-image: linear-gradient(90deg, #000 0, #000 calc(100% - 14px), transparent 100%);
}
.swipe-wrap::-webkit-scrollbar { display: none; }
.swipe-track {
  display: flex; gap: 8px;
  padding-left: var(--space-12);
  padding-right: var(--page-pad);
  width: max-content;
}
.problem-card { flex: 0 0 62vw; scroll-snap-align: start; }
.problem-card-media {
  aspect-ratio: 2 / 3; background: var(--bg-ink);
  overflow: hidden; margin-bottom: var(--space-8); position: relative;
}
.problem-card-media .placeholder {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #1a2b38 0%, #0d1f2d 100%);
  display: flex; align-items: flex-end; padding: var(--space-12);
}
.problem-card-media .placeholder span {
  font-size: var(--fs-micro-2); color: var(--sage);
  letter-spacing: 0.08em; text-transform: uppercase;
}
.problem-card-label {
  font-family: var(--font-display); font-size: var(--fs-body-md);
  font-weight: var(--fw-semibold); color: var(--deep);
  line-height: 1.2; letter-spacing: -0.01em;
}
.problem-card-sub { font-size: 11.5px; color: var(--muted); margin-top: 2px; line-height: 1.35; }

.dots { display: flex; gap: 5px; margin-top: var(--space-14); justify-content: center; }
.dot { width: 5px; height: 5px; background: var(--border); transition: all var(--dur-base) ease; }
.dot.is-active { background: var(--emerald); width: 16px; }

/* ═══════════════════════════════════════════════════════════
   PRODUCT CLARITY
   ═══════════════════════════════════════════════════════════ */
.product-image {
  aspect-ratio: 2 / 3; background: var(--bg-soft);
  overflow: hidden; margin: var(--space-16) 0; position: relative;
}
.product-image .placeholder {
  position: absolute; inset: 0;
  background: linear-gradient(145deg, #f8fafc 0%, #e5e7eb 100%);
  display: flex; align-items: center; justify-content: center;
}
.product-image .placeholder span {
  font-size: var(--fs-micro-2); color: var(--caption);
  letter-spacing: 0.08em; text-transform: uppercase;
  text-align: center; padding: 0 20px;
}

.spec-list { list-style: none; border-top: var(--border-base); }
.spec-list li {
  display: grid; grid-template-columns: 20px 1fr;
  gap: var(--space-10); padding: var(--space-10) 0;
  border-bottom: var(--border-base);
  font-size: var(--fs-body); color: var(--muted); line-height: 1.5;
}
.spec-list li strong { color: var(--deep); font-weight: var(--fw-semibold); }
.spec-list li svg { color: var(--emerald); margin-top: 2px; }

/* ═══════════════════════════════════════════════════════════
   FAIL CARDS — 3 STACKED READABLE
   ═══════════════════════════════════════════════════════════ */
.fail-stack { display: grid; gap: 10px; margin-top: var(--space-16); }
.fail-card {
  background: var(--bg); border: var(--border-base); padding: var(--space-16);
  display: grid; grid-template-columns: 28px 1fr; gap: var(--space-12);
  align-items: flex-start;
}
.fail-card-num {
  font-family: var(--font-display); font-size: 20px; font-weight: var(--fw-semibold);
  color: var(--emerald); letter-spacing: -0.03em; line-height: 1; padding-top: 1px;
}
.fail-card-title {
  font-family: var(--font-display); font-size: var(--fs-body-md);
  font-weight: var(--fw-semibold); letter-spacing: -0.01em;
  color: var(--deep); margin-bottom: var(--space-4); line-height: 1.2;
}
.fail-card-desc { font-size: var(--fs-body); line-height: 1.5; color: var(--muted); }

.fail-note {
  margin-top: var(--space-20);
  padding-top: var(--space-14);
  border-top: var(--border-base);
  font-size: 11px;
  line-height: 1.5;
  color: var(--caption);
  font-style: italic;
}

/* ── Handske-bild bredvid fail-cards ── */
.fail-hand {
  margin: var(--space-20) 0 var(--space-20) auto;
  aspect-ratio: 4 / 5;
  overflow: hidden;
  background: var(--bg-soft);
  position: relative;
  max-width: 50%;
}
.fail-hand img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  display: block;
}

/* ═══════════════════════════════════════════════════════════
   VS-BLOCK — Cotton vs DRYE side by side (mörk sektion)
   ═══════════════════════════════════════════════════════════ */
.vs-block { margin-top: var(--space-20); margin-bottom: var(--space-24); }
.vs-label {
  text-align: center;
  font-size: var(--fs-micro-2);
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: var(--space-14);
  position: relative;
}
.vs-label::before,
.vs-label::after {
  content: '';
  position: absolute;
  top: 50%;
  width: calc(50% - 48px);
  height: 1px;
  background: var(--white-015);
}
.vs-label::before { left: 0; }
.vs-label::after { right: 0; }

.vs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.vs-card {
  border: 1px solid var(--white-015);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.vs-card--drye { border-color: rgba(13, 148, 136, 0.5); }
.vs-media {
  aspect-ratio: 1 / 1;
  background: #0a1620;
  position: relative;
  overflow: hidden;
}
.vs-media .placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-10);
  text-align: center;
}
.vs-media .placeholder span {
  font-size: 9px;
  color: var(--sage);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  line-height: 1.4;
}
.vs-media--wet {
  background: #FAFAFA;
}
.vs-media--dry {
  background: #FAFAFA;
}

/* ═══════════════════════════════════════════════════════════
   COTTON-FLOW — exakt original-SVG från Section 4 sealed glove
   Vit ram, padding runt så diagrammet får luft. Matchar DRYE-kortets
   struktur för visuell parallell.
   ═══════════════════════════════════════════════════════════ */
.cotton-flow {
  position: absolute;
  inset: 12%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cotton-flow svg {
  width: 100%;
  height: auto;
  max-height: 100%;
  display: block;
}

.vs-body {
  padding: var(--space-12);
  background: rgba(255,255,255,0.02);
}
.vs-name {
  font-family: var(--font-display);
  font-size: var(--fs-caption);
  font-weight: var(--fw-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--white-050);
  margin-bottom: var(--space-6);
}
.vs-card--drye .vs-name { color: var(--emerald); }
.vs-desc {
  font-family: var(--font-body);
  font-size: 12px;
  line-height: 1.4;
  color: var(--white-075);
}
.vs-card--drye .vs-desc { color: var(--white-085); font-weight: var(--fw-medium); }

/* Asymmetric layering diagram (nedanför VS) */
.mech-diagram {
  border-top: 1px solid var(--white-008);
  padding-top: var(--space-24);
  margin-top: var(--space-8);
}
.mech-diagram-label {
  font-size: var(--fs-micro-2);
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: var(--space-12);
  text-align: center;
}
.mech-step { padding: var(--space-14) 0; }
.mech-step-label {
  font-size: var(--fs-micro-2);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--sage);
  margin-bottom: var(--space-4);
}
.mech-step-title {
  font-family: var(--font-display);
  font-size: var(--fs-h3);
  font-weight: var(--fw-semibold);
  color: var(--white-100);
  letter-spacing: -0.02em;
  margin-bottom: var(--space-4);
}
.mech-step-body {
  font-size: var(--fs-body);
  color: #C8D4DA;
  line-height: 1.5;
}
.mech-arrow {
  text-align: center;
  color: var(--emerald);
  font-size: 20px;
  padding: var(--space-6) 0;
  opacity: 0.7;
}

/* ═══════════════════════════════════════════════════════════
   HOW IT WORKS — 4 COMPRESSED BEATS
   ═══════════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════════
   PROOF SECTION — media first, then big stat block
   ═══════════════════════════════════════════════════════════ */

/* Full-bleed proof image */
.proof-media-wrap {
  margin: 0 calc(-1 * var(--page-pad)) var(--space-20);
}
.proof-media {
  position: relative;
  aspect-ratio: 4 / 5;
  background: var(--bg-ink);
  overflow: hidden;
}
.proof-media .placeholder {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to top, rgba(15,34,48,0.85) 0%, rgba(15,34,48,0.15) 55%, transparent 100%),
    linear-gradient(145deg, #1a2b38 0%, #0a1620 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: var(--space-16);
}
.proof-media .placeholder-label {
  font-size: 9px;
  color: var(--sage);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 6px;
}
.proof-media .placeholder-title {
  font-family: var(--font-display);
  font-size: 15px;
  color: var(--white-085);
  line-height: 1.3;
  max-width: 240px;
}

.proof-media-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(15,34,48,0.7);
  backdrop-filter: blur(4px);
  border: 1px solid var(--white-015);
  padding: 6px 10px;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--emerald);
  z-index: 2;
}

/* Big stat block (dark) */
.proof-stat {
  background: var(--bg-ink);
  color: #fff;
  padding: var(--space-24) var(--space-20);
  margin: 0 calc(-1 * var(--page-pad));
  display: grid;
  gap: var(--space-16);
}
.proof-stat-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: var(--space-12);
  align-items: baseline;
}
.proof-stat-name {
  font-size: 11px;
  font-weight: var(--fw-semibold);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--sage);
}
.proof-stat-num {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: var(--fw-semibold);
  color: var(--white-050);
  letter-spacing: -0.03em;
  line-height: 1;
}
.proof-stat-row--drye {
  padding: var(--space-16) 0;
  border-top: 1px solid rgba(13, 148, 136, 0.3);
  border-bottom: 1px solid rgba(13, 148, 136, 0.3);
}
.proof-stat-row--drye .proof-stat-name { color: var(--emerald); }
.proof-stat-row--drye .proof-stat-num {
  font-size: 48px;
  color: var(--emerald);
}

.proof-source {
  font-size: 11px;
  color: var(--sage);
  line-height: 1.5;
  letter-spacing: 0.02em;
}

.proof-cta-wrap { margin-top: var(--space-20); }

/* ═══════════════════════════════════════════════════════════
   WHAT CHANGES ON SHIFT — belief-shift bridge
   3 stora tiles, ingen dekoration som konkurrerar med copy.
   Nummer i editorial serif, titel i display, punkter med hairline.
   ═══════════════════════════════════════════════════════════ */
.shift-stack {
  display: grid;
  gap: var(--space-16);
  margin-top: var(--space-24);
}
.shift-card {
  background: var(--bg);
  border: var(--border-base);
  padding: var(--space-20) var(--space-16);
  display: grid;
  grid-template-columns: 42px 1fr;
  column-gap: var(--space-14);
  row-gap: var(--space-12);
  align-items: start;
}
.shift-card__num {
  font-family: var(--font-editorial);
  font-style: italic;
  font-weight: 500;
  font-size: 30px;
  line-height: 1;
  color: var(--emerald);
  letter-spacing: -0.02em;
}
.shift-card__title {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: var(--fw-semibold);
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--deep);
  align-self: center;
}
.shift-card__list {
  grid-column: 1 / -1;
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: var(--border-base);
}
.shift-card__list li {
  padding: var(--space-12) 0;
  border-bottom: var(--border-base);
  font-size: var(--fs-body);
  line-height: 1.5;
  color: var(--muted);
}
.shift-card__list li:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

/* ═══════════════════════════════════════════════════════════
   SATURATION — mobil kompakt (samma som beat2), desktop stacked
   Mobile: flat 3-child grid — name/note stack i vänster kolumn,
           bar i mitten, value till höger. Ren och kompakt.
   Desktop (≥768px): grid template areas → name+value på topp,
           note under, bar full-width.
   ═══════════════════════════════════════════════════════════ */
.sat { color: var(--white-085); }
.sat-intro { margin-bottom: var(--space-20); }
.sat-chart { display: grid; gap: 10px; }
.sat-chart-head { display: none; }

/* ── MOBIL: 3-child grid (name / bar / value) ── */
.sat-row {
  display: grid;
  grid-template-columns: 84px 1fr 52px;
  column-gap: 8px;
  align-items: center;
}
.sat-name {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: var(--fw-semibold);
  color: #AEBFC8;
  line-height: 1.2;
  letter-spacing: -0.01em;
}
.sat-note {
  display: block;
  font-family: var(--font-body);
  font-style: normal;
  font-size: 10px;
  font-weight: 400;
  color: rgba(255,255,255,0.4);
  margin-top: 1px;
  line-height: 1.3;
}
.sat-chip { display: none; }
.sat-bar {
  display: block;
  height: 8px;
  background: var(--white-015);
  position: relative;
  overflow: hidden;
}
.sat-bar i {
  display: block;
  height: 100%;
  width: var(--bar, 0%);
  background: #8FA6B0;
}
.sat-value {
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: var(--fw-semibold);
  color: rgba(255,255,255,0.75);
  text-align: right;
  letter-spacing: -0.02em;
  white-space: nowrap;
  font-variant-numeric: tabular-nums;
}

/* DRYE row — mobil */
.sat-row--drye {
  padding: 8px 0 0;
  border-top: 1px solid rgba(13, 148, 136, 0.35);
  margin-top: 4px;
}
.sat-row--drye .sat-name { color: var(--emerald); font-weight: var(--fw-semibold); }
.sat-row--drye .sat-note { color: var(--sage); }
.sat-row--drye .sat-bar { background: rgba(13, 148, 136, 0.18); }
.sat-row--drye .sat-bar i { background: var(--emerald); min-width: 3px; }
.sat-row--drye .sat-value { color: var(--emerald); }

.sat-source {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--white-008);
  font-size: 10px;
  color: var(--sage);
  line-height: 1.5;
}

/* ── DESKTOP: mech-saturation stacked layout ── */
@media (min-width: 768px) {
  .sat-intro {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 48px;
  }
  .sat-chart {
    max-width: 920px;
    margin: 0 auto;
    display: grid;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    gap: 0;
  }
  .sat-chart-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 20px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .sat-col-label {
    display: inline-block;
    margin: 0;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
  }
  .sat-col-label--right { text-align: right; }

  .sat-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "name value"
      "bar  bar";
    column-gap: 24px;
    row-gap: 16px;
    padding: 28px 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    align-items: baseline;
  }
  .sat-row:last-child { border-bottom: 0; }

  .sat-name {
    grid-area: name;
    font-size: 18px;
    color: var(--white-100);
    line-height: 1.15;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }
  .sat-note {
    width: 100%;
    font-family: var(--font-editorial);
    font-style: italic;
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    margin-top: 6px;
    line-height: 1.4;
  }
  .sat-value {
    grid-area: value;
    font-size: 22px;
    color: var(--white-100);
    text-align: right;
  }
  .sat-bar {
    grid-area: bar;
    height: 4px;
  }

  .sat-chip {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--emerald);
    padding: 3px 8px;
    border: 1px solid var(--emerald);
    white-space: nowrap;
    line-height: 1;
  }

  .sat-row--drye {
    padding: 28px 20px;
    margin-inline: -20px;
    background: linear-gradient(90deg, rgba(255,255,255,0.05) 0%, transparent 70%);
    border-top: 1px solid rgba(95, 138, 139, 0.3);
    border-bottom: 1px solid rgba(95, 138, 139, 0.3);
    margin-top: 0;
  }
  .sat-row--drye .sat-bar { height: 5px; }
  .sat-row--drye .sat-note { color: rgba(255,255,255,0.6); }

  .sat-source {
    max-width: 920px;
    margin: 32px auto 0;
    padding-top: 0;
    border-top: 0;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    text-align: left;
  }
}

/* ═══════════════════════════════════════════════════════════
   SLUT SATURATION
   ═══════════════════════════════════════════════════════════ */

/* ═══════════════════════════════════════════════════════════
   HOW IT WORKS — 3 BEATS (previously 4)
   ═══════════════════════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════════════
   DRYE DIAGRAM — routing visualization (Beat 02)
   Adapted from Occlusion Bridge — glove → DRYE layers → skin
   ═══════════════════════════════════════════════════════════ */
.drye-diag {
  --d-height: 320px;
  --d-glove-h: 26px;
  --d-lyocell-h: 22px;
  --d-pp-h: 22px;
  --d-drye-h: calc(var(--d-lyocell-h) + var(--d-pp-h));

  --d-skin-top-h: 28px;
  --d-skin-mid-h: 58px;
  --d-skin-deep-h: 48px;
  --d-skin-total: calc(var(--d-skin-top-h) + var(--d-skin-mid-h) + var(--d-skin-deep-h));

  --d-rise-end: calc(var(--d-height) - var(--d-glove-h) - 4px);
  --d-rise-mid: calc(var(--d-height) - var(--d-glove-h) - var(--d-drye-h) - 5px);
  --d-rise-start: 30px;

  position: relative;
  width: 100%;
  height: var(--d-height);
  overflow: hidden;
  background: var(--bg);
  border: var(--border-base);
}

.drye-diag__video-slot {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 10;
  background: rgba(15,34,48,0.85);
  color: var(--white-085);
  padding: 4px 8px;
  font-size: 8px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.drye-diag-micro {
  display: inline-block;
  font-family: var(--font-body);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  line-height: 1;
}

/* Sealed glove bar at top */
.drye-diag__glove {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: var(--d-glove-h);
  background: var(--deep);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 8;
}
.drye-diag__glove .drye-diag-micro { color: rgba(255,255,255,0.8); }

/* DRYE layers */
.drye-diag__drye {
  position: absolute;
  top: var(--d-glove-h);
  left: 0; right: 0;
  z-index: 5;
}
.drye-diag__lyocell,
.drye-diag__pp {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-inline: var(--space-12);
}
.drye-diag__lyocell {
  height: var(--d-lyocell-h);
  background: linear-gradient(180deg, #DDE9E9 0%, #E8F0F0 100%);
  border-bottom: 1px dashed rgba(95, 138, 139, 0.4);
}
.drye-diag__pp {
  height: var(--d-pp-h);
  background: linear-gradient(180deg, #EAEFEF 0%, #F0F4F4 100%);
}
.drye-diag__layer-text { position: relative; z-index: 2; }
.drye-diag__lyocell .drye-diag__layer-text { color: var(--sage); }
.drye-diag__pp .drye-diag__layer-text { color: var(--deep); }

/* Layer textures */
.drye-diag__lyocell::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(45deg, rgba(95, 138, 139, 0.18) 25%, transparent 25%),
    linear-gradient(-45deg, rgba(95, 138, 139, 0.18) 25%, transparent 25%);
  background-size: 6px 6px;
  pointer-events: none;
}
.drye-diag__pp::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, rgba(30, 58, 76, 0.2) 0.6px, transparent 0.6px);
  background-size: 5px 5px;
  pointer-events: none;
}

/* Emerald up-arrows */
.drye-diag__arrows {
  position: absolute;
  inset: 0;
  z-index: 3;
  pointer-events: none;
  color: var(--emerald);
}
.drye-diag__arrow {
  position: absolute;
  top: 76px;
  width: 16px;
}
.drye-diag__arrow svg { width: 16px; height: 130px; display: block; }
.drye-diag__arrow--1 { left: calc(20% - 8px); }
.drye-diag__arrow--2 { left: calc(45% - 8px); }
.drye-diag__arrow--3 { left: calc(70% - 8px); }

/* Rising droplets */
.drye-diag__droplets {
  position: absolute;
  inset: 0;
  z-index: 6;
  pointer-events: none;
}
.drye-diag__droplet {
  position: absolute;
  width: 6px;
  height: 8px;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  background: rgba(100, 180, 255, 0.7);
  animation-name: drye-diag-rise;
  animation-duration: 4.5s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}
.drye-diag__droplet--1 { left: calc(20% - 3px); animation-delay: 0s; }
.drye-diag__droplet--2 { left: calc(45% - 3px); animation-delay: 1s; }
.drye-diag__droplet--3 { left: calc(70% - 3px); animation-delay: 2s; }
.drye-diag__droplet--4 { left: calc(32% - 3px); animation-delay: 0.5s; }
.drye-diag__droplet--5 { left: calc(57% - 3px); animation-delay: 1.5s; }
.drye-diag__droplet--6 { left: calc(82% - 3px); animation-delay: 2.5s; }

@keyframes drye-diag-rise {
  0% {
    bottom: var(--d-rise-start);
    opacity: 0;
    transform: scale(1);
  }
  8% { opacity: 0.9; }
  75% {
    bottom: var(--d-rise-mid);
    opacity: 0.9;
    transform: scale(1);
    background: rgba(100, 180, 255, 0.7);
  }
  88% {
    bottom: calc(var(--d-rise-mid) + 15px);
    opacity: 0.55;
    transform: scale(1.5, 0.7);
    background: rgba(80, 140, 220, 0.4);
  }
  96% {
    bottom: var(--d-rise-end);
    opacity: 0.2;
    transform: scale(2.6, 0.4);
  }
  100% {
    bottom: var(--d-rise-end);
    opacity: 0;
    transform: scale(3.5, 0.3);
  }
}

@media (prefers-reduced-motion: reduce) {
  .drye-diag__droplet {
    animation: none;
    opacity: 0.7;
    bottom: var(--d-rise-mid);
  }
}

/* Skin block underneath */
.drye-diag__skin {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 1;
}
.drye-diag__skin-layer {
  position: relative;
  display: flex;
  align-items: center;
  padding-inline: var(--space-12);
}
.drye-diag__skin-layer--top {
  height: var(--d-skin-top-h);
  background: linear-gradient(180deg, #F4D7DB 0%, #F1E2E0 100%);
}
.drye-diag__skin-layer--mid {
  height: var(--d-skin-mid-h);
  background: linear-gradient(180deg, #F8E0E3 0%, #F2C8CC 100%);
}
.drye-diag__skin-layer--mid::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(ellipse 8px 4px at 8px 8px, rgba(217, 160, 166, 0.4) 0%, transparent 70%),
    radial-gradient(ellipse 8px 4px at 24px 16px, rgba(217, 160, 166, 0.4) 0%, transparent 70%),
    radial-gradient(ellipse 8px 4px at 40px 8px, rgba(217, 160, 166, 0.4) 0%, transparent 70%),
    radial-gradient(ellipse 8px 4px at 16px 24px, rgba(217, 160, 166, 0.4) 0%, transparent 70%);
  background-size: 32px 32px;
  pointer-events: none;
}
.drye-diag__skin-layer--deep {
  height: var(--d-skin-deep-h);
  background: #F5EBD8;
}
.drye-diag__skin-text {
  position: relative;
  z-index: 2;
  color: var(--emerald);
}

.beats { display: grid; gap: var(--space-20); margin-top: var(--space-20); }

.beat {
  background: var(--bg);
  border: var(--border-base);
  padding: var(--space-18) var(--space-16);
}
.beat-num {
  display: inline-block;
  font-family: var(--font-body);
  font-size: var(--fs-micro-2);
  font-weight: 700;
  letter-spacing: 0.18em;
  color: var(--emerald);
  margin-bottom: var(--space-8);
}
.beat-num::before { content: '— '; opacity: 0.6; }
.beat-title {
  font-family: var(--font-display);
  font-size: var(--fs-h3);
  font-weight: var(--fw-semibold);
  color: var(--deep);
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin-bottom: var(--space-14);
}
.beat-title--large {
  font-size: var(--fs-section-h2);
  letter-spacing: -0.03em;
  line-height: 1.06;
}
.beat-visual {
  margin: 0 calc(-1 * var(--space-16)) var(--space-14);
  padding: var(--space-16) var(--space-16);
  background: var(--bg-soft);
  border-top: var(--border-base);
  border-bottom: var(--border-base);
}
.beat-copy {
  font-size: var(--fs-body);
  line-height: 1.55;
  color: var(--muted);
}
.beat-copy strong { color: var(--deep); font-weight: var(--fw-semibold); }

/* ── DARK beat variant — for material fail (02) and proof payoff (04) ── */
.beat--dark {
  background: var(--bg-ink);
  border-color: var(--bg-ink);
  color: var(--white-085);
  position: relative;
}
.beat--dark .beat-num { color: var(--emerald); }
.beat--dark .beat-title { color: var(--white-100); }
.beat--dark .beat-title .em { color: var(--white-100); }
.beat--dark .beat-copy { color: #C8D4DA; }
.beat--dark .beat-copy strong { color: var(--white-100); }

/* Dark beat visuals sit flush without inner soft band */
.beat--dark .beat-visual {
  background: transparent;
  border-top-color: var(--white-008);
  border-bottom-color: var(--white-008);
  padding-top: var(--space-18);
  padding-bottom: var(--space-18);
}

/* ── BEAT 1: Open air vs sealed system ── */
.beat1-pair {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.beat1-box {
  background: var(--bg);
  border: var(--border-base);
  padding: var(--space-10);
}
.beat1-box-label {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--caption);
  margin-bottom: var(--space-8);
  text-align: center;
}
.beat1-box svg { width: 100%; height: auto; display: block; }
.beat1-box-status {
  margin-top: var(--space-8);
  font-size: 11px;
  text-align: center;
  color: var(--muted);
  line-height: 1.35;
}
.beat1-box--fail .beat1-box-status { color: var(--muted); }
.beat1-box--fail .beat1-box-status strong { color: var(--deep); }

/* ── BEAT 2: Material regain bars ── */
.beat2-chart { display: grid; gap: var(--space-10); }
.beat2-row {
  display: grid;
  grid-template-columns: 68px 1fr 44px;
  gap: 8px;
  align-items: center;
}
.beat2-name {
  font-size: 11px;
  font-weight: var(--fw-medium);
  color: var(--deep);
  line-height: 1.2;
}
.beat2-name em {
  display: block;
  font-family: var(--font-body);
  font-style: normal;
  font-size: 10px;
  font-weight: 400;
  color: var(--caption);
  margin-top: 1px;
}
.beat2-bar {
  display: block;
  height: 8px;
  background: var(--border);
  position: relative;
}
.beat2-bar i {
  display: block;
  height: 100%;
  background: #A8B5BC;
}
.beat2-value {
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: var(--fw-semibold);
  color: var(--deep);
  text-align: right;
  letter-spacing: -0.02em;
}
.beat2-row--drye {
  padding: var(--space-8) 0 0;
  border-top: 1px solid rgba(13, 148, 136, 0.25);
  margin-top: 4px;
}
.beat2-row--drye .beat2-name { color: var(--emerald); font-weight: var(--fw-semibold); }
.beat2-row--drye .beat2-name em { color: var(--sage); }
.beat2-row--drye .beat2-bar i { background: var(--emerald); }
.beat2-row--drye .beat2-value { color: var(--emerald); }

.beat2-source {
  margin-top: var(--space-14);
  font-size: 10px;
  color: var(--caption);
  line-height: 1.4;
  letter-spacing: 0.02em;
}

/* Dark context (PDP invention pattern) */
.beat--dark .beat2-name { color: #AEBFC8; }
.beat--dark .beat2-name em { color: rgba(255,255,255,0.4); }
.beat--dark .beat2-bar { background: var(--white-015); }
.beat--dark .beat2-bar i { background: #8FA6B0; }
.beat--dark .beat2-value { color: var(--white-100); }
.beat--dark .beat2-row--drye {
  padding: var(--space-10) 0;
  border-top: 1px solid rgba(13, 148, 136, 0.35);
  border-bottom: 1px solid rgba(13, 148, 136, 0.35);
  margin-top: 4px;
  background: linear-gradient(90deg, rgba(13, 148, 136, 0.12) 0%, transparent 70%);
  margin-inline: calc(-1 * var(--space-16));
  padding-inline: var(--space-16);
}

.beat--dark .beat2-row--drye .beat2-bar {
  background: rgba(13, 148, 136, 0.18);
}
.beat--dark .beat2-row--drye .beat2-name { color: var(--white-085); font-weight: var(--fw-semibold); }
.beat--dark .beat2-row--drye .beat2-name em { color: var(--sage); }
.beat--dark .beat2-row--drye .beat2-bar i {
  background: linear-gradient(90deg, var(--emerald) 0%, var(--sage) 60%, transparent 100%);
  min-width: 20px;
}
.beat--dark .beat2-row--drye .beat2-value { color: var(--emerald); }
.beat--dark .beat2-source { color: var(--sage); }

/* ── BEAT 3: Routing diagram / video slot ── */
.beat3-visual {
  aspect-ratio: 3 / 2;
  background: var(--bg);
  border: var(--border-base);
  position: relative;
  overflow: hidden;
}
.beat3-visual .diagram {
  position: absolute;
  inset: 0;
  padding: var(--space-16);
}
.beat3-visual .diagram svg {
  width: 100%;
  height: 100%;
}
.beat3-video-slot {
  position: absolute;
  top: 8px;
  right: 8px;
  background: rgba(15,34,48,0.8);
  color: var(--white-085);
  padding: 4px 8px;
  font-size: 8px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

/* ── BEAT 4: 8,111 vs 99 ── */
.beat4-cmp { display: grid; gap: var(--space-14); }
.beat4-row {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: baseline;
  gap: var(--space-10);
}
.beat4-name-block {
  min-width: 0;
}
.beat4-name {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--caption);
  margin-bottom: var(--space-6);
}
.beat4-bar {
  display: block;
  height: 6px;
  background: var(--border);
}
.beat4-bar i {
  display: block;
  height: 100%;
  background: #A8B5BC;
}
.beat4-value {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: var(--fw-semibold);
  color: var(--muted);
  letter-spacing: -0.02em;
  line-height: 1;
}
.beat4-value sup {
  font-size: 9px;
  font-weight: var(--fw-medium);
  color: var(--caption);
  margin-left: 2px;
}
.beat4-row--drye .beat4-name { color: var(--emerald); }
.beat4-row--drye .beat4-bar { background: rgba(13, 148, 136, 0.15); }
.beat4-row--drye .beat4-bar i { background: var(--emerald); }
.beat4-row--drye .beat4-value {
  font-size: 32px;
  color: var(--emerald);
}
.beat4-row--drye .beat4-value sup { color: var(--sage); }

.beat4-source {
  margin-top: var(--space-14);
  padding-top: var(--space-14);
  border-top: var(--border-base);
  font-size: 10px;
  color: var(--caption);
  line-height: 1.4;
}
.beat4-source strong { color: var(--muted); font-weight: var(--fw-semibold); }

/* Dark context */
.beat--dark .beat4-name { color: #AEBFC8; }
.beat--dark .beat4-bar { background: var(--white-015); }
.beat--dark .beat4-bar i { background: #8FA6B0; }
.beat--dark .beat4-value { color: rgba(255,255,255,0.6); }
.beat--dark .beat4-value sup { color: rgba(255,255,255,0.4); }
.beat--dark .beat4-row--drye {
  padding: var(--space-12) 0;
  border-top: 1px solid rgba(13, 148, 136, 0.3);
  border-bottom: 1px solid rgba(13, 148, 136, 0.3);
}
.beat--dark .beat4-row--drye .beat4-name { color: var(--emerald); }
.beat--dark .beat4-row--drye .beat4-bar { background: rgba(13, 148, 136, 0.15); }
.beat--dark .beat4-row--drye .beat4-bar i { background: var(--emerald); }
.beat--dark .beat4-row--drye .beat4-value {
  font-size: 36px;
  color: var(--emerald);
}
.beat--dark .beat4-row--drye .beat4-value sup { color: var(--sage); }
.beat--dark .beat4-source {
  border-top-color: var(--white-008);
  color: var(--sage);
}
.beat--dark .beat4-source strong { color: var(--white-085); }

.how-cta { margin-top: var(--space-20); }

/* ═══════════════════════════════════════════════════════════
   OBJECTION REVIEWS
   ═══════════════════════════════════════════════════════════ */
/* ═══════════════════════════════════════════════════════════
   WORKER PROOF TICKER — adapted from PDP drye-worker-proof.css
   Compact card: returns line + sliding/expandable comment ticker.
   ═══════════════════════════════════════════════════════════ */
.lp-proof {
  margin: var(--space-12) var(--page-pad) var(--space-32);
  padding: var(--space-14) var(--space-16);
  background: var(--bg);
  border: 1px solid #E5E5E5;
  border-radius: 12px;
  box-sizing: border-box;
}
.lp-proof__line {
  display: flex; align-items: center; gap: 6px;
  color: var(--emerald);
}
.lp-proof__check { flex: 0 0 15px; width: 15px; height: 15px; display: block; }
.lp-proof__returns {
  font-family: var(--font-display); font-size: 13.5px; font-weight: var(--fw-semibold);
  letter-spacing: -0.01em; color: var(--emerald);
}
.lp-proof__keep {
  margin-top: 3px; font-size: 12.5px; font-weight: var(--fw-medium);
  line-height: 1.3; color: var(--deep);
}
.lp-proof__tlabel {
  margin: 11px 0 5px; font-size: 9px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--caption);
}
.lp-proof__ticker-wrap {
  position: relative; width: 100%; max-width: 100%; overflow: hidden;
  -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 14px, #000 calc(100% - 14px), transparent 100%);
  mask-image: linear-gradient(90deg, transparent 0, #000 14px, #000 calc(100% - 14px), transparent 100%);
}
.lp-proof__ticker {
  display: flex; align-items: center; gap: 0; margin: 0; padding: 0; list-style: none;
  width: max-content; will-change: transform;
  animation: lpProofTicker 38s linear infinite;
}
.lp-proof__ticker.is-paused { animation-play-state: paused; }
@keyframes lpProofTicker {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
@media (prefers-reduced-motion: reduce) {
  .lp-proof__ticker { animation: none; }
}
.lp-proof__item-wrap { position: relative; flex: 0 0 auto; padding-right: 22px; }
.lp-proof__item-wrap::after {
  content: "·"; position: absolute; right: 9px; top: 50%;
  transform: translateY(-50%); color: var(--caption);
}
.lp-proof__item {
  display: inline-flex; align-items: center; gap: 5px;
  margin: 0; padding: 7px 0; border: 0; background: none; cursor: pointer;
  white-space: nowrap; font-size: 12.5px; line-height: 1.2; color: var(--deep);
  font-family: var(--font-body);
}
.lp-proof__ihandle { font-weight: var(--fw-semibold); color: var(--emerald); }
.lp-proof__iquote { color: var(--deep); }
.lp-proof__iplus {
  display: inline-grid; place-items: center; width: 15px; height: 15px;
  margin-left: 3px; border-radius: 999px; background: var(--emerald);
  color: #fff; font-size: 11px; line-height: 1; font-weight: var(--fw-semibold);
}
.lp-proof__item.is-open .lp-proof__iplus { background: var(--deep); }
.lp-proof__hint {
  display: flex; align-items: center; gap: 6px; margin-top: 7px;
  font-size: 11px; line-height: 1.3; color: var(--muted);
}
.lp-proof__hint-plus {
  display: inline-grid; place-items: center; flex: 0 0 15px; width: 15px; height: 15px;
  border-radius: 999px; background: var(--emerald); color: #fff;
  font-size: 11px; font-weight: var(--fw-semibold); line-height: 1;
  animation: lpProofPulse 1.8s ease-in-out infinite;
}
@keyframes lpProofPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.18); } }
@media (prefers-reduced-motion: reduce) { .lp-proof__hint-plus { animation: none; } }

.lp-proof__expand {
  position: relative; margin-top: 9px; padding: 9px 24px 2px 0;
  border-top: 1px solid #E5E5E5;
}
.lp-proof__expand[hidden] { display: none; }
.lp-proof__expand-close {
  position: absolute; top: 7px; right: 0; width: 22px; height: 22px;
  padding: 0; border: 0; background: none; color: var(--caption);
  font-size: 18px; line-height: 1; cursor: pointer;
}
.lp-proof__expand-quote { margin: 0; font-size: 13px; font-weight: var(--fw-medium); line-height: 1.45; color: var(--deep); }
.lp-proof__expand-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 6px; }
.lp-proof__expand-source { font-size: 11px; color: var(--muted); }
.lp-proof__expand-link {
  font-size: 11px; font-weight: var(--fw-semibold); color: var(--emerald);
  text-decoration: none; border-bottom: 1px solid currentColor;
}
.lp-proof__expand-link[hidden] { display: none; }

.lp-proof__orders {
  margin-top: 12px; padding-top: 4px;
  font-size: 11.5px; line-height: 1.5; color: var(--muted);
}
.lp-proof__orders strong { color: var(--deep); font-weight: var(--fw-semibold); }
.lp-proof__states { margin-top: 4px; color: var(--caption); }

.review-slider { margin-top: var(--space-14); }

.rating-badge {
  display: flex; align-items: center; gap: 6px;
  margin-bottom: var(--space-16);
}
.rating-badge-stars { color: var(--gold); font-size: 14px; letter-spacing: 1px; }
.rating-badge-score {
  font-family: var(--font-display); font-weight: var(--fw-semibold);
  font-size: 14px; color: var(--deep);
}
.rating-badge-count {
  font-size: 13px; color: var(--emerald); font-weight: var(--fw-medium);
  text-decoration: underline; text-decoration-color: rgba(13,148,136,0.4);
}
.review-card { background: var(--bg); border: var(--border-base); padding: var(--space-20) var(--space-16); }
.review-question {
  font-size: var(--fs-micro-2); font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: var(--sage); margin-bottom: var(--space-10);
}
.review-quote {
  font-family: var(--font-body); font-style: normal;
  font-size: var(--fs-body); line-height: 1.45;
  color: var(--body); margin-bottom: var(--space-14);
}
.review-attribution { display: flex; align-items: center; gap: var(--space-8); margin-bottom: var(--space-4); }
.review-verified { display: inline-flex; align-items: center; justify-content: center; width: 14px; height: 14px; background: var(--emerald); color: #fff; }
.review-name { font-family: var(--font-display); font-size: 13px; font-weight: var(--fw-semibold); color: var(--deep); }
.review-role { font-size: 11.5px; color: var(--muted); margin-left: 22px; }
.review-stars { color: var(--gold); font-size: 12px; letter-spacing: 1.5px; margin-top: var(--space-6); margin-left: 22px; }

.review-nav { display: flex; align-items: center; justify-content: space-between; margin-top: var(--space-14); }
.review-nav-btns { display: flex; gap: 8px; }
.review-nav-btn {
  width: 36px; height: 36px; border: var(--border-base);
  background: var(--bg); color: var(--deep); font-size: 16px;
  display: flex; align-items: center; justify-content: center;
}
.review-readall {
  font-family: var(--font-body); font-size: var(--fs-micro);
  font-weight: var(--fw-semibold); letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--deep);
  border-bottom: 1px solid var(--deep); padding-bottom: 1px;
}

/* ═══════════════════════════════════════════════════════════
   RISK REVERSAL
   ═══════════════════════════════════════════════════════════ */
.risk-wrap {
  display: grid; grid-template-columns: 68px 1fr;
  gap: var(--space-16); align-items: center;
  margin-bottom: var(--space-18);
}
.risk-badge {
  width: 68px; height: 68px; border: 1.5px solid var(--deep);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.risk-num { font-family: var(--font-display); font-size: 22px; font-weight: var(--fw-semibold); line-height: 1; color: var(--deep); letter-spacing: -0.02em; }
.risk-word { font-size: 8.5px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--deep); margin-top: 2px; }
.risk-copy h3 { font-family: var(--font-display); font-size: 18px; font-weight: var(--fw-semibold); letter-spacing: -0.02em; color: var(--deep); margin-bottom: 4px; line-height: 1.15; }
.risk-copy p { font-size: 12px; color: var(--muted); line-height: 1.5; }

/* ═══════════════════════════════════════════════════════════
   MORE REVIEWS + FAQ
   ═══════════════════════════════════════════════════════════ */
.more-review-card {
  flex: 0 0 72vw; scroll-snap-align: start;
  border: var(--border-base); padding: var(--space-16); background: var(--bg);
}
.more-review-stars { color: var(--gold); font-size: 12px; letter-spacing: 1.5px; margin-bottom: var(--space-8); }
.more-review-quote { font-size: var(--fs-body); line-height: 1.45; color: var(--body); margin-bottom: var(--space-10); }
.more-review-meta { font-size: 11px; color: var(--muted); display: flex; align-items: center; gap: 6px; }

.faq-list { margin-top: var(--space-14); }
.faq-item { border-bottom: var(--border-base); }
.faq-question {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--space-14) 0; width: 100%; text-align: left;
  font-family: var(--font-body); font-size: var(--fs-body-md);
  font-weight: var(--fw-semibold); color: var(--deep);
}
.faq-icon { position: relative; width: 14px; height: 14px; flex-shrink: 0; }
.faq-icon::before, .faq-icon::after {
  content: ''; position: absolute; top: 50%; left: 50%;
  background: var(--emerald); transition: transform var(--dur-base) ease;
}
.faq-icon::before { width: 12px; height: 1.5px; transform: translate(-50%, -50%); }
.faq-icon::after { width: 1.5px; height: 12px; transform: translate(-50%, -50%); }
.faq-item.is-open .faq-icon::after { transform: translate(-50%, -50%) rotate(90deg); opacity: 0; }
.faq-answer {
  font-size: var(--fs-body); line-height: 1.6; color: var(--muted);
  max-height: 0; overflow: hidden;
  transition: max-height var(--dur-base) ease, padding-bottom var(--dur-base) ease;
}
.faq-item.is-open .faq-answer { max-height: 320px; padding-bottom: var(--space-14); }

.research-box {
  margin-top: var(--space-24); padding: var(--space-16);
  background: var(--bg-soft); border: var(--border-base);
  display: grid; grid-template-columns: 40px 1fr;
  gap: var(--space-12); align-items: flex-start;
}
.research-icon {
  width: 40px; height: 40px; border: 1px solid var(--border);
  background: var(--bg); display: flex; align-items: center; justify-content: center;
  color: var(--emerald);
}
.research-text h4 { font-family: var(--font-display); font-size: var(--fs-body-md); font-weight: var(--fw-semibold); color: var(--deep); margin-bottom: 2px; }
.research-text p { font-size: 11.5px; color: var(--muted); margin-bottom: var(--space-10); line-height: 1.45; }

/* ═══════════════════════════════════════════════════════════
   STICKY CTA + FOOTER
   ═══════════════════════════════════════════════════════════ */
.sticky-cta {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
  background: var(--bg); border-top: var(--border-base);
  padding: 8px var(--page-pad); height: var(--sticky-h);
  display: flex; align-items: center;
  transform: translateY(100%); transition: transform var(--dur-base) ease;
}
.sticky-cta.is-visible { transform: translateY(0); }
.sticky-cta .btn { padding: 12px 20px; font-size: 11.5px; }

.footer-cta { background: var(--bg-ink); padding: var(--space-32) var(--page-pad); text-align: center; }
.footer-cta .btn { background: var(--emerald); color: #fff; border-color: var(--emerald); }
.footer-cta p { margin-top: var(--space-10); font-size: var(--fs-micro-2); color: var(--sage); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
.footer { background: var(--bg-ink); padding: var(--space-20) var(--page-pad) var(--space-32); text-align: center; border-top: 1px solid var(--white-008); }
.footer p { font-size: 11px; color: var(--white-035); letter-spacing: 0.08em; }

.reveal { opacity: 0; transform: translateY(12px); transition: opacity var(--dur-reveal) ease, transform var(--dur-reveal) ease; }
.reveal.is-visible { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
  * { animation: none !important; transition: none !important; }
}
/* ═══════════════════════════════════════════════════════════════════════
   DESKTOP (≥768px)
   -----------------------------------------------------------------------
   Arkitektur: varje .section är full-bleed bakgrund.
   Innehåll centreras via .dt-wrap — en inre div som är max 1100px bred
   och har 40px sidopadding. Noll negativa margins, noll !important.
   Mobil-CSS ovan är helt orörd.
   ═══════════════════════════════════════════════════════════════════════ */
@media (min-width: 768px) {

  /* ── Typografi: skala upp till desktop-storlekar ── */
  :root {
    --fs-hero-h1:    clamp(40px, 5.5vw, 60px);
    --fs-section-h2: clamp(28px, 3.2vw, 40px);
    --fs-h3:         20px;
    --fs-body:       15px;
    --fs-body-md:    16px;
    --fs-caption:    13px;
  }

  /* ── dt-wrap: den enda containern som styr bredd och centrering ── */
  .dt-wrap {
    width: 100%;
    max-width: 1180px;
    margin-inline: auto;
    padding-inline: 40px;
  }

  /* ── NAV ── */
  .nav {
    padding-inline: 40px;
  }

  /* ── BENEFIT STRIP: statisk rad, ingen scroll ── */
  .benefit-strip {
    padding-inline: 40px;
    overflow-x: visible;
    scroll-snap-type: none;
    mask-image: none;
    -webkit-mask-image: none;
    justify-content: flex-start;
  }
  .benefit-item:last-child {
    padding-right: 0;
    border-right: none;
  }

  /* ── SECTION: enbart vertikal padding. Horisontell hanteras av dt-wrap ── */
  .section {
    padding-top: 88px;
    padding-bottom: 88px;
    padding-inline: 0;
  }

  /* ── HERO: bild vänster, text höger ── */
  .hero {
    padding-inline: 40px;
    padding-block: 72px;
  }
  .hero .dt-wrap {
    display: flex;
    align-items: center;
    gap: 64px;
  }
  .hero-media {
    flex: 0 0 360px;
    aspect-ratio: 4 / 5;
  }
  .hero-info {
    flex: 1 1 auto;
    padding: 0;
    max-width: 500px;
  }
  .hero-sub { max-width: 440px; }
  .btn--primary, .btn--outline { width: auto; min-width: 240px; }
  .hero-info .btn--primary { width: auto; }

  /* ── SECTION 2 — TUESDAY AFTERNOON ──
     Kort behåller mobil-storlek. Pilar visas. Dots döljs. ── */
  .section-2-inner {
    position: relative;
  }
  .swipe-nav {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
  }
  .swipe-nav-btn {
    width: 40px;
    height: 40px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--deep);
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
    flex-shrink: 0;
  }
  .swipe-nav-btn:hover {
    background: var(--deep);
    color: #fff;
  }
  /* På desktop: dölj dots, visa pilar */
  .section-2-dots { display: none; }
  .swipe-nav { display: flex; }

  /* Scroll-wrap får full bredd av .dt-wrap */
  .section-2-inner .swipe-wrap {
    margin-inline: 0;
  }
  .section-2-inner .swipe-track {
    padding-left: 0;
    padding-right: 0;
  }
  /* Kort: behåll mobil-storlek (62vw är för stort på desktop — cap:a till 220px) */
  .problem-card {
    flex: 0 0 220px;
  }

  /* ── SECTION 3 — PRODUCT CLARITY: text vänster, bild höger ──
     Mobil: naturlig DOM-ordning: intro → bild → specs
     Desktop: 2-kolumn grid; intro+specs staplade vänster, bild höger ── */
  .section-3-inner {
    display: grid;
    grid-template-columns: 1fr 300px;
    grid-template-areas:
      "intro image"
      "specs image";
    column-gap: 56px;
    align-items: start;
  }
  .section-3-intro { grid-area: intro; }
  .section-3-specs { grid-area: specs; }
  .section-3-image {
    grid-area: image;
  }
  .section-3-image .product-image {
    margin: 0;
    aspect-ratio: 2 / 3;
  }

  /* ── SECTION 4 (fail cards) — 3 kolumner på desktop, centrerad intro ── */
  .section-fail-inner {
    text-align: center;
  }
  .section-fail-inner .section-eyebrow,
  .section-fail-inner .section-h2,
  .section-fail-inner .section-body {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-fail-inner .fail-stack {
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 40px;
    text-align: left;
    max-width: 1000px;
    margin-inline: auto;
  }

  /* ── SECTION 4.5 (mechanism) — centrerad intro, VS + diagram ── */
  .section-mech-inner {
    max-width: 900px;
    margin-inline: auto;
    text-align: center;
  }
  .section-mech-inner .section-eyebrow,
  .section-mech-inner .section-h2,
  .section-mech-inner .section-body {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }
  .section-mech-inner .vs-block {
    max-width: 720px;
    margin-inline: auto;
    margin-top: 40px;
    text-align: left;
  }
  .section-mech-inner .vs-grid {
    gap: 16px;
  }
  .section-mech-inner .vs-body {
    padding: 20px;
  }
  .section-mech-inner .mech-diagram {
    max-width: 640px;
    margin: 24px auto 0;
    padding-top: 32px;
    text-align: left;
  }
  .section-mech-inner .mech-diagram-label {
    text-align: center;
  }
  .section-mech-inner .mech-step {
    padding: 20px 0;
  }

  /* ── SECTION 5 — WHY NORMAL LINERS STAY WET (mörk) ──
     Sat-blocket har egen mobile-first + desktop-CSS ovan.
     Inga overrides behövs här. ── */

  /* ── PROOF (Independent lab test) — desktop ── */
  .proof-inner {
    text-align: center;
    max-width: 760px;
    margin: 0 auto;
  }
  .proof-inner .section-eyebrow,
  .proof-inner .section-h2 {
    text-align: center;
  }
  .proof-media-wrap {
    max-width: 720px;
    margin: 40px auto 0;
  }
  .proof-media {
    aspect-ratio: 16 / 9;
  }
  .proof-stat {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 48px;
  }
  .proof-stat-row {
    padding: 8px 0;
  }
  .proof-stat-num {
    font-size: 28px;
  }
  .proof-stat-row--drye .proof-stat-num {
    font-size: 64px;
