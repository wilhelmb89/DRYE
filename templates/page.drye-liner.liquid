/* Worker Proof ticker: pause on touch, tap-to-expand */
(function () {
  var wrap = document.getElementById('lp-proof-wrap');
  var ticker = document.getElementById('lp-proof-ticker');
  var expand = document.querySelector('[data-lp-proof-expand]');
  var module = document.getElementById('lp-proof-module');
  var hovering = false, locked = false, openItem = null, resumeTimer = null;

  function setPaused() {
    if (ticker) ticker.classList.toggle('is-paused', hovering || locked);
  }
  if (wrap) {
    wrap.addEventListener('touchstart', function () {
      hovering = true; setPaused();
      if (resumeTimer) clearTimeout(resumeTimer);
    }, { passive: true });
    wrap.addEventListener('touchend', function () {
      if (resumeTimer) clearTimeout(resumeTimer);
      resumeTimer = setTimeout(function () { if (!locked) { hovering = false; setPaused(); } }, 2500);
    }, { passive: true });
    wrap.addEventListener('mouseenter', function () { hovering = true; setPaused(); });
    wrap.addEventListener('mouseleave', function () { hovering = false; setPaused(); });
  }

  function setPlus(btn, isOpen) {
    var p = btn.querySelector('.lp-proof__iplus');
    if (p) p.textContent = isOpen ? '−' : '+';
    btn.classList.toggle('is-open', isOpen);
  }
  function openExpand(btn) {
    if (!expand) return;
    if (openItem && openItem !== btn) setPlus(openItem, false);
    var full = btn.getAttribute('data-full') || '';
    var handle = btn.getAttribute('data-handle') || '';
    var label = btn.getAttribute('data-label') || '';
    var q = expand.querySelector('[data-lp-proof-quote]');
    var src = expand.querySelector('[data-lp-proof-source]');
    if (q) q.textContent = '"' + full + '"';
    if (src) src.textContent = [handle, label].filter(Boolean).join(' · ');
    expand.hidden = false;
    setPlus(btn, true);
    openItem = btn;
    locked = true; setPaused();
  }
  function closeExpand() {
    if (expand) expand.hidden = true;
    if (openItem) { setPlus(openItem, false); openItem = null; }
    locked = false; hovering = false; setPaused();
  }
  if (module) {
    module.addEventListener('click', function (e) {
      var t = e.target;
      if (t.closest && t.closest('[data-lp-proof-close]')) { closeExpand(); return; }
      var btn = t.closest ? t.closest('[data-lp-proof-item]') : null;
      if (!btn) return;
      if (btn === openItem) closeExpand(); else openExpand(btn);
    });
  }
})();

function toggleFaq(id) {
  const item = document.getElementById(id);
  const isOpen = item.classList.contains('is-open');
  document.querySelectorAll('.faq-item').forEach(el => el.classList.remove('is-open'));
  if (!isOpen) item.classList.add('is-open');
}

const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); }
  });
}, { threshold: 0.12 });
document.querySelectorAll('.section, .beat').forEach(s => { s.classList.add('reveal'); revealObs.observe(s); });
</script>

</body>
