/* ── Swipe gallery: scroll tracking, dots, desktop arrow nav ── */
function initSwipeGallery({ trackId, dotsId, navId, prevId, nextId, cardSel }) {
  const track = document.getElementById(trackId);
  if (!track) return;
  const wrap = track.closest('.swipe-wrap');
  if (!wrap) return;

  const dots = dotsId ? document.querySelectorAll('#' + dotsId + ' .dot') : [];
  const nav = navId ? document.getElementById(navId) : null;

  function getCardStep() {
    const cards = track.querySelectorAll(cardSel);
    if (!cards.length) return 0;
    return cards[0].offsetWidth + 8;
  }

  wrap.addEventListener('scroll', () => {
    const step = getCardStep();
    if (!step) return;
    const cards = track.querySelectorAll(cardSel);
    const idx = Math.min(Math.round(wrap.scrollLeft / step), cards.length - 1);
    dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
  }, { passive: true });

  function applyBreakpoint() {
    const isDesktop = window.innerWidth >= 768;
    if (nav) nav.style.display = isDesktop ? 'flex' : 'none';
  }
  applyBreakpoint();
  window.addEventListener('resize', applyBreakpoint);

  document.getElementById(prevId)?.addEventListener('click', () => {
    wrap.scrollBy({ left: -getCardStep(), behavior: 'smooth' });
  });
  document.getElementById(nextId)?.addEventListener('click', () => {
    wrap.scrollBy({ left: getCardStep(), behavior: 'smooth' });
  });
}

initSwipeGallery({
  trackId: 'problem-track',
  dotsId: 'problem-dots',
  navId: 'problem-nav',
  prevId: 'problem-prev',
  nextId: 'problem-next',
  cardSel: '.problem-card'
});

initSwipeGallery({
  trackId: 'more-review-track',
  dotsId: 'more-review-dots',
  navId: 'more-review-nav',
  prevId: 'more-review-prev',
  nextId: 'more-review-next',
  cardSel: '.more-review-card'
});

/* One-time "swipe teach" nudge: gently scrolls a swipeable row a few px
   right then back, once on load, so first-time visitors physically feel
   that the row moves — without adding a persistent icon or text hint.
   Skips entirely for prefers-reduced-motion and for rows with nothing
   to scroll (content narrower than the viewport). */
function nudgeSwipe(track, delay) {
  if (!track) return;
  const wrap = track.parentElement;
  if (!wrap) return;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) return;
  if (wrap.scrollWidth <= wrap.clientWidth + 4) return;
  setTimeout(() => {
    const prevSnap = wrap.style.scrollSnapType;
    wrap.style.scrollSnapType = 'none'; // mandatory snap would otherwise cancel the scrollTo instantly
    wrap.scrollTo({ left: 46, behavior: 'smooth' });
    setTimeout(() => {
      wrap.scrollTo({ left: 0, behavior: 'smooth' });
      setTimeout(() => { wrap.style.scrollSnapType = prevSnap; }, 500);
    }, 480);
  }, delay);
}
nudgeSwipe(document.getElementById('problem-track'), 700);
