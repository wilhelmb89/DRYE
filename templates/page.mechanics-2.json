            "stat_prefix": "",
            "stat": "47",
            "stat_suffix": "%",
            "stat_qualitative": false,
            "body": "Within 30 minutes inside sealed gloves, <strong>skin starts softening from trapped sweat.</strong>",
            "source": "Ryatt KS, Mobayen M, Stevenson JM et al., 1988"
          }
        },
        "card_kn47HN": {
          "type": "card",
          "settings": {
            "label": "WHAT GETS THROUGH",
            "stat_prefix": "",
