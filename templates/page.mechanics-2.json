          }
        },
        "bridge_NDhLBU": {
          "type": "bridge",
          "settings": {
            "label": "The mechanism",
            "paradigm": "One layer. One direction.",
            "mechanism": "<span class=\"drye-brand\">DRYE's Glove Liner</span> moves moisture away continuously instead of trapping sweat against the skin.",
