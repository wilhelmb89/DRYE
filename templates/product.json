    "drye_section_06_faq_LBYNDJ": {
      "type": "drye-section-06-faq",
      "blocks": {
        "faq_item_XVt9MA": {
          "type": "faq_item",
          "settings": {
            "question": "Do I wear this under or instead of gloves?",
            "answer": "They’re liners. You wear them under nitrile, latex, vinyl, or work gloves. The knit compresses naturally so your gloves still seal, flex, and grip as usual."
          }
        },
        "faq_item_4N4Fnm": {
          "type": "faq_item",
          "settings": {
            "question": "How long does a pair last and how do I wash them?",
            "answer": "- Machine wash up to 60°C / 140°F. Air dry or tumble dry — both work.\n- Handles industrial laundry. No special care required.\n- Heavy daily use: 6 months. Light use: up to a year.\n- Performance is structural — no coatings, no membranes, no chemical treatments to wash out."
          }
        },
        "faq_item_MEnNcp": {
          "type": "faq_item",
          "settings": {
            "question": "Do they work with nitrile, latex, and vinyl gloves?",
            "answer": "Yes — this is the primary use case. 0.4mm thin, designed to layer inside sealed gloves without affecting fit. Works with nitrile, latex, vinyl, rubber, hockey gloves, ski gloves, and work gloves."
          }
        },
        "faq_item_4GzGcj": {
          "type": "faq_item",
          "settings": {
            "question": "What's actually different from a cotton liner?",
            "answer": "Cotton absorbs moisture and holds it. Once saturated, it becomes a wet layer between skin and glove — which accelerates breakdown. DRYE routes moisture through the fiber via a structural gradient. No absorption, no saturation point, nothing that can wash out."
          }
        },
        "faq_item_PBMBwz": {
          "type": "faq_item",
          "settings": {
            "question": "Will they make my gloves tighter or affect grip?",
            "answer": "At 0.4mm, the liner adds less bulk than a standard glove lining. In the automotive field study, 9/9 workers reported zero dexterity compromise. Grip is typically maintained or improved — dry skin has better tactile contact with glove material."
          }
        },
        "faq_item_3WgNjG": {
          "type": "faq_item",
          "settings": {
            "question": "Will this heal my eczema or just protect it?",
            "answer": "DRYE isn’t a medical treatment. What it does is reduce common triggers like sweat, friction, and heat inside gloves. Many people find that when their skin is kept drier and calmer, it feels less irritated and has a better chance to recover between flare-ups."
          }
        },
        "faq_item_gNqRVE": {
          "type": "faq_item",
          "settings": {
            "question": "Can I use them overnight with cream?",
            "answer": "Yes. Many users combine overnight cream with DRYE as a liner under cotton gloves. The structural transport still functions. The cream is not displaced — DRYE routes moisture only, not cream or oil."
          }
        }
      },
