        "description_czn8Gm": {
          "type": "description",
          "settings": {
            "title": "",
            "use_product_description": true,
            "custom_description": "<style>\n  .hero .drye-pdp-desc {\n    max-width: 520px;\n    padding: 0;\n    background: var(--bg);\n    box-sizing: border-box;\n  }\n\n  .hero .drye-pdp-desc p {\n    margin: 0;\n    color: var(--deep);\n  }\n\n  .hero .drye-pdp-desc p + p {\n    margin-top: var(--space-10);\n  }\n\n  .hero .drye-pdp-desc__block {\n    margin-top: var(--space-18);\n  }\n\n  .hero .drye-pdp-desc__block:first-child {\n    margin-top: 0;\n  }\n\n  .hero .drye-pdp-desc__heading {\n    margin-bottom: var(--space-2);\n  }\n\n  .hero .drye-pdp-desc__heading p {\n    font-weight: var(--fw-semibold);\n  }\n\n  .hero .drye-pdp-desc strong {\n    color: var(--deep);\n    font-weight: var(--fw-semibold);\n  }\n\n  .hero .drye-pdp-desc__footnote {\n    margin-top: var(--space-16);\n  }\n\n  .hero .drye-pdp-desc__footnote p {\n    color: var(--caption);\n  }\n</style>\n\n<div class=\"drye-pdp-desc\">\n\n  <div class=\"drye-pdp-desc__block\">\n    <div class=\"drye-pdp-desc__heading\">\n      <p class=\"dryeNEW-body\">What changes</p>\n    </div>\n\n    <p class=\"dryeNEW-body\">\n      Your glove still does the protecting. DRYE changes what touches your skin.\n    </p>\n\n    <p class=\"dryeNEW-body\">\n      A thin dry layer sits between your hand and the glove — so sweaty nitrile, latex, rubber or sealed work gloves are not sitting directly against your skin.\n    </p>\n  </div>\n\n  <div class=\"drye-pdp-desc__block\">\n    <div class=\"drye-pdp-desc__heading\">\n      <p class=\"dryeNEW-body\">Why it’s different</p>\n    </div>\n\n    <p class=\"dryeNEW-body\">\n      Every liner that absorbs has a saturation point. Once it fills up, it becomes the wet layer. DRYE routes moisture outward instead. It does not have a saturation point like other liners — because the skin side is built not to hold sweat.\n    </p>\n\n    <p class=\"dryeNEW-body\">\n      \n    </p>\n  </div>\n\n  <div class=\"drye-pdp-desc__block\">\n    <div class=\"drye-pdp-desc__heading\">\n      <p class=\"dryeNEW-body\">How it’s built</p>\n    </div>\n\n    <p class=\"dryeNEW-body\">\n      Asymmetric Layering — one layer. One direction: away from skin. No coatings. No chemicals. No membranes. Just a washable textile structure built for months of sealed-glove use.\n    </p>\n  </div>\n\n  <div class=\"drye-pdp-desc__footnote\">\n    <p class=\"dryeNEW-body--caption\">\n      Seven years of textile development. Patent pending · SE 261539-3.\n    </p>\n  </div>\n\n</div>"
          }
        },
        "faq_RmnBHQ": {
          "type": "faq",
          "settings": {
            "question": "I've worn gloves for ten years. Why would I start using a liner now?",
            "answer": "Because changing gloves doesn’t fix the sweat inside them.  Cotton soaks. Creams come too late. DRYE adds a thin dry layer that moves sweat away from your skin while you work.\n\nYour hands stay drier. Gloves slide better. Your shift feels easier.  \nTry it once — you’ll know.",
            "open_by_default": false
          }
        },
        "faq_wCzg8J": {
          "type": "faq",
          "settings": {
            "question": "Do I wear this under or instead of gloves?",
            "answer": "Under. Put DRYE on first, then your work glove. That's how the moisture routing works.",
            "open_by_default": false
          }
        },
        "faq_cVYHKP": {
          "type": "faq",
          "settings": {
            "question": "I've never worn anything under my gloves. Will it feel weird?",
            "answer": "New, not weird. It's 0.4mm — thinner than most people expect — and after a wear or two it just becomes part of putting your gloves on. The first time you take your gloves off to dry hands instead of wet ones, you stop thinking about the adjustment.",
            "open_by_default": false
          }
        },
        "faq_YPHreL": {
          "type": "faq",
          "settings": {
            "question": "Do they work with nitrile/latex/vinyl gloves?",
            "answer": "Yes. DRYE is 0.4mm thin and fits under nitrile, latex, vinyl, rubber, and many sealed work gloves without changing the feel much.",
            "open_by_default": false
          }
        },
        "faq_FeFy9M": {
          "type": "faq",
          "settings": {
            "question": "What about oil, grease, and chemicals — will they ruin the liner?",
            "answer": "No. Unlike cotton, DRYE doesn’t soak up oil. Wipe off surface grease after the shift and machine wash when needed.",
            "open_by_default": false
          }
        },
        "faq_4gTn8g": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Can I wear DRYE for EV/battery work?",
            "answer": "Yes. It's made for Class 00 and Class 0 gloves (up to 1,000V) — standard for EV service and battery assembly. That's shock work, not arc-flash. Not for Class 1+ or grid/high-voltage work. DRYE isn't arc-rated. Unsure? Ask your safety officer.",
            "open_by_default": false
          }
        },
        "faq_yEB4kW": {
          "type": "faq",
          "settings": {
            "question": "How long does a pair last, and how do I wash it?",
            "answer": "- Machine washable up to 90°C / 194°F\n- Air dry or tumble dry\n- Heavy daily use: 6 months\n- No coatings or membranes to wear out",
            "open_by_default": false
          }
        },
        "faq_fKYhkJ": {
          "type": "faq",
          "settings": {
            "question": "Will my hands get hotter?",
            "answer": "A little. Any extra layer can add warmth. But DRYE moves sweat away from your skin, so the warmth feels drier — not like trapped-sweat clamminess. Most users find it more comfortable than glove-on-skin.",
            "open_by_default": false
          }
        },
        "faq_8BwAyY": {
          "type": "faq",
          "settings": {
            "question": "What makes DRYE different from cotton liners?",
            "answer": "Cotton absorbs sweat and stays wet under pressure. DRYE doesn't absorb on the skin side — moisture moves outward. Skin stays dry through the shift.",
            "open_by_default": false
          }
        },
        "faq_aqPJyd": {
          "type": "faq",
          "settings": {
            "question": "Will this help heal my skin issues or just protect it?",
            "answer": "DRYE isn’t a medical treatment. It helps reduce the wet-glove conditions that can make hands feel cracked, irritated, or overworked. If you have a medical skin condition, check with a professional.",
            "open_by_default": false
          }
        },
        "faq_cR9VYK": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Can I use them overnight with cream?",
            "answer": "Yes — some users do. But DRYE is primarily built for long hours inside sealed work gloves, where sweat and humidity get trapped against the skin.",
            "open_by_default": false
          }
        },
        "faq_dHAEH3": {
          "type": "faq",
          "disabled": true,
          "settings": {
            "question": "Who it's not for",
            "answer": "DRYE is built for long hours inside sealed gloves — nitrile, latex, rubber and Class 00/0 dielectric HV gloves. If gloves come off every few minutes, there's less moisture buildup to solve. Not for arc flash rated environments (NFPA 70E). Non-sterile use only.",
            "open_by_default": false
          }
        },
        "faq_hzYRrW": {
          "type": "faq",
          "settings": {
            "question": "Shipping, Customs & Delivery",
            "answer": "Ships from Sweden.\n- PostNord · 4–7 business days · Duties covered. No brokerage fee.\n- UPS · 1–3 business days · Customs and brokerage fee charged at delivery.",
            "open_by_default": false
          }
        }
      },
