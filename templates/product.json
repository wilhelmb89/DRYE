          }
        },
        "faq_8BwAyY": {
          "type": "faq",
          "settings": {
            "question": "Will my hands get hotter?",
            "answer": "A little. Any extra layer can add warmth. But DRYE moves sweat away from your skin, so it feels drier — not like trapped-sweat clamminess.",
            "open_by_default": false
          }
        },
        "faq_aqPJyd": {
          "type": "faq",
          "settings": {
            "question": "Is this just cotton?",
            "answer": "No. Cotton absorbs sweat and stays wet. DRYE doesn’t absorb on the skin side — moisture moves outward so the skin-side stays drier.",
            "open_by_default": false
          }
        },
        "faq_cR9VYK": {
          "type": "faq",
          "settings": {
            "question": "Will this heal my skin issues?",
            "answer": "DRYE doesn’t treat skin conditions. It helps remove the physical trigger many glove-wearers deal with every day: sweat trapped against the skin.\n\nWhen your hands sit wet inside sealed gloves, the skin can feel waterlogged, soft, itchy, cracked or irritated. DRYE adds a thin dry layer under your glove so sweat moves away from the skin-side while you work.\n\nMany customers tell us their hands feel better within the first day or first few weeks.",
            "open_by_default": false
          }
        }
