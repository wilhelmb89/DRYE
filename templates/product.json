        "faq_FeFy9M": {
          "type": "faq",
          "settings": {
            "question": "What if oil gets on them?",
            "answer": "Unlike cotton, DRYE doesn’t soak up oil. Wipe off surface grease after the shift and machine wash when needed.",
            "open_by_default": false
          }
        },
        "faq_YPHreL": {
          "type": "faq",
          "settings": {
            "question": "Will they fit under nitrile gloves?",
            "answer": "Yes. DRYE is 0.4mm thin and fits under nitrile, latex, vinyl, rubber and many sealed work gloves without changing the feel much.",
            "open_by_default": false
          }
        },
        "faq_wCzg8J": {
          "type": "faq",
          "settings": {
            "question": "Do I wear them under my gloves?",
            "answer": "Yes. DRYE goes on first, then your work glove. That’s how the moisture-routing layer works.",
            "open_by_default": false
          }
        },
        "faq_RmnBHQ": {
          "type": "faq",
          "settings": {
            "question": "Why put anything under nitrile?",
            "answer": "Because changing gloves doesn’t fix the wet layer inside them. Cotton soaks. Creams come too late. DRYE adds a thin dry layer that moves sweat away from your skin while you work.",
            "open_by_default": false
          }
        },
        "faq_cVYHKP": {
          "type": "faq",
          "settings": {
            "question": "Will they feel weird?",
            "answer": "New, not weird. They’re 0.4mm thin, so most users adjust after a wear or two. The first time you pull your gloves off to drier hands, the extra step makes sense.",
            "open_by_default": false
          }
        },
        "faq_yEB4kW": {
          "type": "faq",
          "settings": {
            "question": "How long do they last?",
            "answer": "With heavy daily use, one pair typically lasts around 6 months.",
            "open_by_default": false
