    "drye_section_06_faq_Wdy8J6": {
      "type": "drye-section-06-faq",
      "blocks": {
        "faq_item_nRMPqR": {
          "type": "faq_item",
          "settings": {
            "question": "How thin is 0.4mm — really?",
            "answer": "Four sheets of standard printer paper. A standard nitrile glove is already 0.1–0.15mm thick — you can't feel that either. DRYE adds the equivalent of a thin second skin. In independent testing, zero participants reported reduced dexterity."
          }
        },
        "faq_item_eyHgh6": {
          "type": "faq_item",
          "settings": {
            "question": "Does it work under nitrile gloves specifically?",
            "answer": "Yes. DRYE was developed and tested primarily for use under nitrile — the most common glove in healthcare, automotive, and lab environments. At 0.4mm, it fits inside any standard nitrile glove without affecting the fit or tactile feel. Dexterity is unchanged."
          }
        },
        "faq_item_Na3DN9": {
          "type": "faq_item",
          "settings": {
            "question": "What if it doesn't work for me?",
            "answer": "Full refund within 30 days. No questions. The claim is that the physics works — if it doesn't change your shift, you pay nothing."
          }
        },
        "faq_item_KXKtPk": {
          "type": "faq_item",
          "settings": {
            "question": "Can I wash it? How?",
            "answer": "Machine washable. Cold or warm cycle, no fabric softener. Do not tumble dry — air dry flat. Fabric softener coats fibres and can partially block the capillary transport channels. One pair per person, washed after each shift."
          }
        },
        "faq_item_b4jXHh": {
          "type": "faq_item",
          "settings": {
            "question": "How long does it last? Does it degrade?",
            "answer": "With regular use and machine washing, DRYE lasts 4–12 months. The routing structure is built into the physical composition of the textile — it doesn't rely on a chemical treatment that can wash out. The mechanism doesn't degrade with washing."
          }
        },
        "faq_item_YTxdxr": {
          "type": "faq_item",
          "settings": {
            "question": "Who it's not for",
            "answer": "DRYE works when gloves stay on. If you remove them every few minutes — hairdressers feeling individual hair strands, food handlers in open kitchens — the routing mechanism doesn't have time to function and the liner becomes an extra layer with no benefit.It's also not for sterile surgical environments. Non-sterile use only."
          }
        }
      },
