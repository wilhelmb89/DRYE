    "drye_objection_cards_PPDxpW": {
      "type": "drye-objection-cards",
      "blocks": {
        "card_UJmUxk": {
          "type": "card",
          "settings": {
            "profession": "Automotive repair",
            "question": "Is this just cotton?",
            "quote": "<i>“These are incredible, nearly no more sweat in nitrile gloves, plus being so thin I barely notice them.”</i>",
            "name": "@fordbodytech811",
            "meta": "Automotive repair"
          }
        },
        "card_JxnVWd": {
          "type": "card",
          "settings": {
            "profession": "Car detailing",
            "question": "Will it kill my grip?",
            "quote": "<i>\"The slim thickness gives great dexterity. They do a great job keeping sweat off my hands.\"</i><br>\n<br>",
            "name": "Shoujun S.",
            "meta": "Car detailing, Rosemead, CA"
          }
        },
        "card_FdWTgA": {
          "type": "card",
          "settings": {
            "profession": "Automotive repair",
            "question": "What happens if oil gets on them?",
            "quote": "<i>\"When I get oil on the liners, I just wipe them off with electrical contact cleaner and a dry paper towel. Wipes right off.\"</i>",
            "name": "Brian Jee",
            "meta": "Automotive repair,  San Francisco, CA."
          }
        },
        "card_YJAGAh": {
          "type": "card",
          "settings": {
            "profession": "Automotive repair",
            "question": "How much time does it save?",
            "quote": "<i> “Without the lining gloves I had to remove my EV gloves, wash and dry my hands, then go to the computer. With the lining gloves, I could remove the EV gloves and go straight to the computer.” </i>",
            "name": "Field study / BMW",
            "meta": "EV service technician, Gothenburg, Sweden"
          }
        },
        "card_epw8At": {
          "type": "card",
          "settings": {
            "profession": "Automotive repair",
            "question": "What if I take gloves off all day?",
            "quote": "<i> “I take gloves on and off 9 times an hour. After two weeks with the lining gloves, my hands felt less itchy, less dry, and less rough.” </i>",
            "name": "Independent field study",
            "meta": "Vehicle inspection technician, Gothenburg, Sweden"
          }
        },
        "card_jadUxY": {
          "type": "card",
          "settings": {
            "profession": "Automotive painter",
            "question": "What about hot shops and summer heat?",
            "quote": "<i>\"Terrible sweat issues during summer wearing nitrile gloves. Wearing these, I'm no longer dripping sweat on my paint jobs and my hands feel better.\"</i>",
            "name": "Chad W.",
            "meta": "Automotive painter, Phoenix, AZ"
          }
        },
        "card_4AnchU": {
          "type": "card",
          "settings": {
            "profession": "AUTOMOTIVE · SCANIA BATTERY FACTORY",
            "question": "Does it work under EV safety gloves?",
