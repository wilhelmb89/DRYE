    "drye_letters_pij4dc": {
      "type": "drye-letters",
      "blocks": {
        "letter_Q7BRni": {
          "type": "letter",
          "settings": {
            "featured": true,
            "tag": "Hockey Parent → Founder",
            "quote": "<p>Just wanted to send you a quick note to say thank you. My son has been struggling with severe dry hands because of his hockey gloves for the past few years. <strong>No cream or prescription has helped.</strong> He's worn your gloves for <strong>3 ice times, and his hands are completely cleared up.</strong> Absolute game changer.</p>",
            "name": "Adam",
            "meta": "Hockey parent, USA"
          }
        },
        "letter_R6tzrE": {
          "type": "letter",
          "settings": {
            "featured": false,
            "tag": "Hockey Parent",
            "quote": "<p>My daughter has severe eczema and plays ice hockey 6 times a week. She destroyed the first pair — <strong>hence the order.</strong> She appreciates that the gloves fit tight and don't introduce slip — which was a problem with cotton gloves.</p>",
            "name": "Eric",
            "meta": "Hockey parent, Canada"
          }
        },
        "letter_z6kaMP": {
          "type": "letter",
          "settings": {
            "featured": false,
            "tag": "Healthcare Worker — Latex Gloves Daily",
            "quote": "<p>I wear latex gloves all day for work. Every hour I'd change my gloves and notice the sweat on my DRYE — <strong>but my hands remain dried.</strong> I have seven pairs to rotate.</p>",
            "name": "Phuong Ngo",
            "meta": "Lutz, Florida — 8 months continuous use"
          }
        },
        "letter_Hm4cWE": {
          "type": "letter",
          "settings": {
            "featured": false,
            "tag": "Automotive & Construction",
            "quote": "<p>I've been using them in automotive repair, home construction, and moving heavy materials. <strong>No more eczema or rashes on my hands.</strong> Nitrile gloves don't tear anymore because they go on and off easily without sweaty skin.</p>",
            "name": "Brian Jee",
            "meta": "USA"
          }
        },
        "letter_qF4AGt": {
          "type": "letter",
          "settings": {
            "featured": false,
            "tag": "Parent — Work Gloves",
            "quote": "<p>My son's hands were bright pink and raw with all of the skin peeling off from wearing work gloves. <strong>Within two weeks, they are completely healed and back to normal.</strong> I cannot believe the difference.</p>",
            "name": "Deborah Fields",
            "meta": "Cincinnati, Ohio"
          }
        },
        "letter_hXx8An": {
          "type": "letter",
          "settings": {
            "featured": false,
            "tag": "Lifelong Eczema — UK",
            "quote": "<p>I've had eczema on my palms since birth and have used steroid creams for years. <strong>I can finally do things like help my wife in the garden without my skin breaking.</strong></p>",
            "name": "Jon-Paul E.",
            "meta": "Newcastle upon Tyne, UK"
          }
        }
      },
