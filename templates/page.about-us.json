    "drye_about_skapa_APyfGX": {
      "type": "drye-about-skapa",
      "name": "DRYE About SKAPA",
      "settings": {
        "award_label": "SKAPA Prize — 2020",
        "heading": "Sweden's most recognised innovation award. In memory of Alfred Nobel.",
        "body": "<p>DRYE received the SKAPA Prize for its textile technology — developed to prevent moisture damage to the skin in protective equipment. The award is given in memory of Alfred Nobel, <strong>for innovations with genuine societal and commercial significance.</strong></p>",
        "link_label": "See the research",
        "link_url": "shopify://pages/research",
        "quote_text": "\"In a smart and practical way, DRYE has developed a concrete solution to a common everyday problem affecting many individuals. Through the textile's gradient, hands stay clean and dry without risk of drying out or eczema.\"",
        "quote_attr": "SKAPA Foundation — Innovation in Memory of Alfred Nobel"
      }
    },
